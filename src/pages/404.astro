---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Still brewing" description="This page is still brewing. Head back to the main site directory.">
  <section class="page-section narrow-stack">
    <div class="panel prose">
      <p class="eyebrow">404</p>
      <h1>Still brewing</h1>
      <p>The page you were looking for hasn’t surfaced yet, but the rest of the site is ready to explore.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="/blog">Go to Blog</a>
        <a class="button button-secondary" href="/projects">Go to Projects</a>
      </div>
    </div>
  </section>
</BaseLayout>
