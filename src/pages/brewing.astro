---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { formatDate } from '@/utils/format';

const current = await getEntry('now', 'current');
if (!current) throw new Error('Missing now/current entry');

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const projects = (await getCollection('projects')).sort((a, b) => b.data.priority - a.data.priority);

const labCards = [
  {
    title: 'Institutional Intel Platform',
    tag: 'Flagship',
    status: 'building',
    statusLabel: 'Building now',
    description: 'Resolve institutional managers by CRD and CIK, pull Form ADV and 13F data, and turn it into a clean research narrative.',
    href: '/apps/manager-search',
    features: ['CRD/CIK resolution', 'Form ADV parsing', '13F holdings', 'AI-driven summaries']
  },
  {
    title: 'Form ADV Search',
    tag: 'Live tool',
    status: 'live',
    statusLabel: 'Live',
    description: 'A fast regulatory search surface for navigating investment adviser filings without wading through the default workflow.',
    href: 'https://aistudio.google.com/apps/22413b76-84f4-492f-9424-602e8a68d040',
    external: true,
    features: ['Regulatory filings', 'Instant search', 'AI Studio powered']
  },
  {
    title: 'RFP Automator',
    tag: 'Research',
    status: 'brewing',
    statusLabel: 'Brewing',
    description: 'A multi-stage AI pipeline that transforms RFP questionnaires into structured, compliant responses using institutional knowledge bases.',
    href: '/brewing#rfp',
    features: ['Multi-stage AI pipeline', 'Knowledge base integration', 'Compliance mapping', 'Response drafting']
  },
  {
    title: '13F Data Finder',
    tag: 'Research',
    status: 'brewing',
    statusLabel: 'Brewing',
    description: 'A calmer entry point into holdings research, manager behavior, and repeatable diligence questions.',
    href: '/projects/13f-data-finder',
    features: ['Holdings research', 'Manager behavior', 'Diligence queries']
  },
  {
    title: 'Process Intelligence',
    tag: 'Framework',
    status: 'concept',
    statusLabel: 'Concept',
    description: 'Data-driven workflow intelligence inspired by strategic operations at institutional scale. Turning process signals into repeatable advantages.',
    href: '/brewing#process',
    features: ['Workflow mapping', 'Signal detection', 'Process optimization']
  }
];

const siteLinks = [
  { title: 'Blog', href: '/blog', count: `${blogPosts.length} posts`, description: 'Essays, notes, reviews, and product thinking.' },
  { title: 'Projects', href: '/projects', count: `${projects.length} builds`, description: 'Research products, data tools, and experiments.' },
  { title: 'Adventures', href: '/adventures', count: 'Cricket archive', description: 'Cricket records, travel, and field notes.' },
  { title: 'Writing', href: '/writing', count: 'Library', description: 'Books, movies, games, and deeper thinking.' },
  { title: 'Apps', href: '/apps', count: 'Tools', description: 'Focused product surfaces for research.' },
  { title: 'Notes', href: '/notes', count: 'Archive', description: 'Shorter observations and fragments.' },
];
---

<BaseLayout title="Brewing" description="Active builds, live tools, and in-progress experiments from C M Nafi.">
  <div class="brewing-page">

    <!-- ═══════════ HERO ═══════════ -->
    <section class="page-section brewing-hero-section">
      <div class="brewing-hero panel">
        <div class="brewing-hero__steam" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <p class="eyebrow">Labs &middot; Updated {formatDate(current.data.updatedAt)}</p>
        <h1 class="brewing-hero__title">Currently Brewing</h1>
        <p class="brewing-hero__sub">Active builds, live tools, and the in-progress experiments powering due diligence and RFP automation for institutional finance.</p>
      </div>
    </section>

    <!-- ═══════════ LAB CARDS ═══════════ -->
    <section class="page-section brewing-lab-section">
      <SectionHeading
        eyebrow="Active builds"
        title="The lab"
        description="Products and pipelines in various stages of development. Some are live, some are actively building, and some are still finding their shape."
      />
      <div class="lab-grid">
        {labCards.map((card) => (
          <a
            class={`lab-card lab-card--${card.status}`}
            href={card.href}
            target={card.external ? '_blank' : undefined}
            rel={card.external ? 'noreferrer' : undefined}
            id={card.title.toLowerCase().replace(/\s+/g, '-')}
          >
            <div class="lab-card__header">
              <span class="lab-card__tag">{card.tag}</span>
              <span class={`lab-card__status lab-card__status--${card.status}`}>
                <span class="status-dot"></span>
                {card.statusLabel}
              </span>
            </div>
            <h2 class="lab-card__title">{card.title}</h2>
            <p class="lab-card__desc">{card.description}</p>
            <div class="lab-card__features">
              {card.features.map((f) => (
                <span class="lab-feature">{f}</span>
              ))}
            </div>
            <div class="lab-card__skeleton" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════ CURRENT STATE ═══════════ -->
    <section class="page-section brewing-now-section">
      <SectionHeading
        eyebrow="Current focus"
        title="What I'm working on right now"
        description="A living snapshot of active work, exploration, and direction."
      />
      <div class="now-panels">
        <article class="now-panel panel">
          <h3>Building</h3>
          <ul>{current.data.building.map((item: string) => <li>{item}</li>)}</ul>
        </article>
        <article class="now-panel panel">
          <h3>Exploring</h3>
          <ul>{current.data.exploring.map((item: string) => <li>{item}</li>)}</ul>
        </article>
        <article class="now-panel panel">
          <h3>Reading</h3>
          <ul>{current.data.reading.map((item: string) => <li>{item}</li>)}</ul>
        </article>
        <article class="now-panel panel">
          <h3>Meeting around</h3>
          <ul>{current.data.meeting.map((item: string) => <li>{item}</li>)}</ul>
        </article>
      </div>
    </section>

    <!-- ═══════════ SITE DIRECTORY ═══════════ -->
    <section class="page-section brewing-dir-section">
      <SectionHeading
        eyebrow="Everything else"
        title="The rest of the site"
        description="Writing, projects, adventures, tools, and archives — each with its own dedicated space."
      />
      <div class="dir-grid">
        {siteLinks.map((link) => (
          <a class="dir-card panel" href={link.href}>
            <div class="dir-card__top">
              <h3>{link.title}</h3>
              <small>{link.count}</small>
            </div>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .brewing-page {
    width: min(calc(100% - 2rem), var(--max-width));
    margin-inline: auto;
  }

  /* ═══════════ HERO ═══════════ */
  .brewing-hero {
    padding: 3rem 2.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .brewing-hero__steam {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    pointer-events: none;
  }

  .brewing-hero__steam span {
    width: 2px;
    height: 40px;
    background: linear-gradient(180deg, transparent, var(--accent), transparent);
    border-radius: 999px;
    opacity: 0.3;
    animation: steam-rise 2.5s ease-in-out infinite;
  }

  .brewing-hero__steam span:nth-child(2) {
    height: 55px;
    animation-delay: 0.4s;
    opacity: 0.2;
  }

  .brewing-hero__steam span:nth-child(3) {
    height: 35px;
    animation-delay: 0.8s;
    opacity: 0.25;
  }

  @keyframes steam-rise {
    0%, 100% { transform: translateY(0) scaleY(1); opacity: 0; }
    30% { opacity: 0.3; }
    50% { transform: translateY(-20px) scaleY(1.2); opacity: 0.2; }
    100% { transform: translateY(-40px) scaleY(0.8); opacity: 0; }
  }

  .brewing-hero__title {
    font-family: "Fraunces", "Times New Roman", serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    letter-spacing: -0.04em;
    margin: 0.5rem 0 1rem;
  }

  .brewing-hero__sub {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 55ch;
    margin: 0 auto;
  }

  /* ═══════════ LAB CARDS ═══════════ */
  .lab-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .lab-card {
    position: relative;
    padding: 1.8rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));
    backdrop-filter: blur(20px);
    overflow: hidden;
    transition: transform 300ms ease, border-color 300ms ease, box-shadow 300ms ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
  }

  .lab-card:hover {
    transform: translateY(-3px);
    border-color: rgba(211, 154, 89, 0.3);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .lab-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .lab-card__tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--cool);
    background: rgba(126, 134, 157, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .lab-card__status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
  }

  .lab-card__status--live { color: #28c840; }
  .lab-card__status--live .status-dot {
    background: #28c840;
    box-shadow: 0 0 8px rgba(40, 200, 64, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .lab-card__status--building { color: var(--accent); }
  .lab-card__status--building .status-dot {
    background: var(--accent);
    box-shadow: 0 0 8px rgba(211, 154, 89, 0.4);
    animation: pulse-dot 2s ease-in-out infinite 0.3s;
  }

  .lab-card__status--brewing { color: var(--cool); }
  .lab-card__status--brewing .status-dot {
    background: var(--cool);
    animation: pulse-dot 3s ease-in-out infinite;
  }

  .lab-card__status--concept { color: var(--muted); }
  .lab-card__status--concept .status-dot {
    background: var(--muted);
    opacity: 0.5;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .lab-card__title {
    font-family: "Fraunces", serif;
    font-size: 1.3rem;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .lab-card__desc {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }

  .lab-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .lab-feature {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* Glassmorphism skeleton loader effect */
  .lab-card__skeleton {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    display: flex;
    gap: 2px;
    padding: 0 1.8rem;
    pointer-events: none;
  }

  .lab-card--building .lab-card__skeleton span,
  .lab-card--brewing .lab-card__skeleton span {
    flex: 1;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.15;
    animation: skeleton-shimmer 2.5s ease-in-out infinite;
  }

  .lab-card--brewing .lab-card__skeleton span {
    background: linear-gradient(90deg, transparent, var(--cool), transparent);
    animation-duration: 3.5s;
  }

  .lab-card__skeleton span:nth-child(2) { animation-delay: 0.3s; }
  .lab-card__skeleton span:nth-child(3) { animation-delay: 0.6s; }

  @keyframes skeleton-shimmer {
    0%, 100% { opacity: 0; transform: scaleX(0.3); }
    50% { opacity: 0.2; transform: scaleX(1); }
  }

  .lab-card--live { border-color: rgba(40, 200, 64, 0.15); }
  .lab-card--live:hover { border-color: rgba(40, 200, 64, 0.35); }
  .lab-card--building { border-color: rgba(211, 154, 89, 0.15); }

  /* ═══════════ NOW PANELS ═══════════ */
  .now-panels {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .now-panel {
    padding: 1.5rem;
  }

  .now-panel h3 {
    font-family: "Fraunces", serif;
    font-size: 1rem;
    margin: 0 0 0.75rem;
    color: var(--accent);
  }

  .now-panel ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .now-panel li {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
    padding-left: 1rem;
    position: relative;
  }

  .now-panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.4;
  }

  /* ═══════════ DIRECTORY ═══════════ */
  .dir-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .dir-card {
    padding: 1.4rem;
    transition: transform 250ms ease, border-color 250ms ease;
  }

  .dir-card:hover {
    transform: translateY(-2px);
    border-color: rgba(211, 154, 89, 0.25);
  }

  .dir-card__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .dir-card h3 {
    font-family: "Fraunces", serif;
    font-size: 1rem;
    margin: 0;
  }

  .dir-card small {
    font-size: 0.68rem;
    color: var(--cool);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .dir-card p {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.55;
    margin: 0;
  }

  /* ═══════════ RESPONSIVE ═══════════ */
  @media (max-width: 768px) {
    .brewing-hero { padding: 2rem 1.5rem; }
    .lab-grid { grid-template-columns: 1fr; }
    .now-panels { grid-template-columns: 1fr; }
    .dir-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .dir-grid { grid-template-columns: 1fr; }
  }
</style>
