---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Flag from '@/components/telemetry/Flag.astro';
import LapTimer from '@/components/telemetry/LapTimer.astro';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const notes = await getCollection('field-notes');
  return notes
    .filter(note => note.slug !== 'capital-lens-16' && note.slug !== 'capital-lens-17')
    .map(note => ({
      params: { slug: note.slug },
      props: { note },
    }));
}

const { note } = Astro.props;
const { Content } = await note.render();

// Adjacent published notes for prev/next navigation
const publishedNotes = (await getCollection('field-notes'))
  .filter(n =>
    !n.data.draft &&
    n.data.category !== 'Brewing' &&
    n.slug !== 'capital-lens-16' &&
    n.slug !== 'capital-lens-17'
  )
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const noteIndex = publishedNotes.findIndex(n => n.slug === note.slug);
const newerNote = noteIndex > 0 ? publishedNotes[noteIndex - 1] : null;
const olderNote = noteIndex >= 0 && noteIndex < publishedNotes.length - 1 ? publishedNotes[noteIndex + 1] : null;

// SEO surface — prefer the dedicated seo* frontmatter, fall back to editorial fields
const pageTitle = note.data.seoTitle || note.data.title;
const pageDescription = note.data.seoDescription || note.data.description || note.data.excerpt;
const canonicalPath = `/field-notes/${note.slug}`;
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const ogImage = note.data.coverImage || '/og-default.svg';
const publishedIso = note.data.publishedAt.toISOString();
const modifiedIso = (note.data.updatedAt || note.data.publishedAt).toISOString();
const displayDate = note.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: note.data.title,
  description: pageDescription,
  datePublished: publishedIso,
  dateModified: modifiedIso,
  image: new URL(ogImage, siteConfig.siteUrl).toString(),
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  author: { '@type': 'Person', name: siteConfig.author, url: siteConfig.siteUrl },
  publisher: { '@type': 'Person', name: siteConfig.author, url: siteConfig.siteUrl },
  articleSection: note.data.category,
  ...(note.data.tags.length > 0 && { keywords: note.data.tags.join(', ') })
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Field Notes', item: new URL('/field-notes', siteConfig.siteUrl).toString() },
    { '@type': 'ListItem', position: 3, name: note.data.title, item: canonicalUrl }
  ]
};
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalPath}
  image={ogImage}
  type="article"
  hideHeader={true}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishedIso} />
    <meta property="article:modified_time" content={modifiedIso} />
    <meta property="article:section" content={note.data.category} />
    <meta property="article:author" content={siteConfig.author} />
    {note.data.tags.map(tag => <meta property="article:tag" content={tag} />)}
    {note.data.tags.length > 0 && <meta name="keywords" content={note.data.tags.join(', ')} />}
    <meta name="author" content={siteConfig.author} />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <div class={`note-detail ${note.data.category === 'Cricket' ? 'theme-cricket' : ''}`}>
    <!-- Reading progress rail -->
    <div class="article-progress-rail" aria-hidden="true">
      <div class="article-progress-bar" id="article-progress-bar"></div>
    </div>

    <nav class="paddock-override-nav" aria-label="Breadcrumb">
      <a href="/field-notes" class="return-wall">← FIELD NOTES</a>
      <div class="nav-title">INCOMING TELEMETRY</div>
    </nav>

    <article class="paddock-article">
      <header class="article-header">
        <div class="note-meta">
          <Flag color="red" />
          <span>{note.data.category.toUpperCase()}</span>
          {note.data.subCategory && (
            <>
              <span>//</span>
              <span>{note.data.subCategory.toUpperCase()}</span>
            </>
          )}
          <span>//</span>
          <time datetime={publishedIso}>{displayDate}</time>
          <span class="timer-wrap"><LapTimer time={note.data.readingTime.replace(' min read', ':00.000')} /></span>
        </div>

        <h1>{note.data.title}</h1>
        {note.data.description && <p class="summary">{note.data.description}</p>}
      </header>

      <div class="prose">
        <Content />
      </div>

      {note.data.tags.length > 0 && (
        <div class="article-tags" aria-label="Article tags">
          {note.data.tags.map(tag => (
            <span class="tag-chip monospace-chip">{tag.toUpperCase()}</span>
          ))}
        </div>
      )}

      <footer class="article-footer">
        <div class="adjacent-notes">
          {olderNote && (
            <a class="adjacent-link" href={`/field-notes/${olderNote.slug}`} rel="prev">
              <span class="adj-label">← PREVIOUS LAP</span>
              <span class="adj-title">{olderNote.data.title}</span>
            </a>
          )}
          {newerNote && (
            <a class="adjacent-link adj-next" href={`/field-notes/${newerNote.slug}`} rel="next">
              <span class="adj-label">NEXT LAP →</span>
              <span class="adj-title">{newerNote.data.title}</span>
            </a>
          )}
        </div>
        <a href="/field-notes" class="all-notes-link">VIEW ALL FIELD NOTES</a>
      </footer>
    </article>
  </div>
</BaseLayout>

<script>
  function initArticleProgress() {
    const bar = document.getElementById('article-progress-bar');
    const article = document.querySelector('.paddock-article');
    if (!bar || !article) return;

    function onScroll() {
      const rect = article!.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const progress = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 1;
      bar!.style.width = `${progress * 100}%`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initArticleProgress);
</script>

<style>
  .paddock-override-nav { display: flex; justify-content: space-between; padding: 2rem; font-family: var(--font-mono); }
  .return-wall { color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
  .return-wall:hover { color: var(--pitlane-white); }
  .nav-title { color: var(--pitlane-white); font-size: 11px; letter-spacing: 0.15em; }

  .note-detail { min-height: 100vh; background: var(--paddock-black); }
  .paddock-article { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 6rem; }

  /* Reading progress rail */
  .article-progress-rail {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.03);
    z-index: 991;
    pointer-events: none;
  }
  .article-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, transparent, var(--accent));
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .article-header { border-bottom: 1px solid var(--carbon); padding-bottom: 2rem; margin-bottom: 3rem; }
  .note-meta {
    display: flex; align-items: center; gap: 1rem;
    font-family: var(--font-mono); font-size: 11px; color: var(--muted);
    margin-bottom: 2rem; letter-spacing: 0.1em; flex-wrap: wrap;
  }
  .timer-wrap { margin-left: auto; }

  .article-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    margin: 0 0 1.5rem;
    color: var(--pitlane-white);
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
  .summary { font-family: var(--font-body); font-size: 1.25rem; color: var(--muted); margin: 0; line-height: 1.6; }

  /* Header entrance — settle up, no bounce */
  @media (prefers-reduced-motion: no-preference) {
    .article-header {
      animation: header-settle var(--dur-slow) var(--ease-instrument) both;
    }
    @keyframes header-settle {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; }
    }
  }

  .prose { font-family: var(--font-body); font-size: 1.15rem; line-height: 1.8; color: var(--text); }
  .prose :global(h2) { font-family: var(--font-mono); font-size: 1.3rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4rem; margin-bottom: 1.5rem; color: var(--warning-amber); padding-bottom: 0px; }
  .prose :global(h3) { font-family: var(--font-display); font-size: 1.8rem; margin-top: 3rem; margin-bottom: 1rem; color: var(--pitlane-white); }
  .prose :global(p) { margin-bottom: 1.8rem; color: rgba(244, 244, 241, 0.85); }
  .prose :global(a) { color: var(--telemetry-green); text-decoration: underline; text-decoration-color: rgba(0, 230, 118, 0.4); text-underline-offset: 4px; transition: 0.2s; }
  .prose :global(a:hover) { text-decoration-color: var(--telemetry-green); }
  .prose :global(blockquote) { border-left: 3px solid var(--warning-amber); padding-left: 1.5rem; margin-left: 0; font-style: italic; color: var(--muted); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1.8rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.8rem; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-card); margin: 2rem 0; border: 1px solid var(--carbon); }
  .prose :global(figcaption) { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; color: var(--ink-tertiary); margin-top: -1.2rem; margin-bottom: 2rem; }
  .prose :global(hr) { border: none; border-top: 1px dashed var(--surface-line); margin: 3rem 0; }
  .prose :global(strong) { color: var(--pitlane-white); }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.88em; background: var(--surface-raised); border: 1px solid var(--surface-line); border-radius: var(--radius-chip); padding: 0.1em 0.4em; }
  .prose :global(pre) { background: var(--surface-raised); border: 1px solid var(--surface-line); border-radius: var(--radius-card); padding: 1.4rem; overflow-x: auto; margin-bottom: 1.8rem; font-size: 0.9rem; line-height: 1.6; }
  .prose :global(pre code) { background: none; border: none; padding: 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin-bottom: 1.8rem; font-size: 0.95rem; }
  .prose :global(th) { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; text-align: left; color: var(--ink-secondary); border-bottom: 1px solid var(--surface-line); padding: 0.6rem 0.8rem; }
  .prose :global(td) { border-bottom: 1px solid rgba(255, 255, 255, 0.04); padding: 0.6rem 0.8rem; font-variant-numeric: tabular-nums; }

  /* Tags */
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dashed var(--surface-line);
  }
  .tag-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-secondary);
    border: 1px solid var(--surface-line);
    border-radius: var(--radius-chip);
    padding: 0.3rem 0.6rem;
  }

  /* Prev / next navigation */
  .article-footer {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .adjacent-notes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .adjacent-link {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.4rem;
    background: linear-gradient(180deg, var(--surface-raised), var(--surface-base));
    border: 1px solid var(--surface-line);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color var(--dur-base) var(--ease-instrument), transform var(--dur-base) var(--ease-instrument);
  }
  .adjacent-link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .adj-next { text-align: right; align-items: flex-end; grid-column: 2; }
  .adj-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-tertiary);
  }
  .adj-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--pitlane-white);
    line-height: 1.3;
  }
  .all-notes-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--telemetry-green);
    text-decoration: none;
  }
  .all-notes-link:hover { color: var(--pitlane-white); }

  @media (max-width: 640px) {
    .adjacent-notes { grid-template-columns: 1fr; }
    .adj-next { grid-column: auto; }
  }

  /* CRICKET VIBE OVERRIDES */
  .theme-cricket {
    background-color: #0d2912 !important; /* Pitch grass green */
  }
  .theme-cricket .article-header { border-bottom: 1px solid rgba(255, 255, 255, 0.4); }
  .theme-cricket .paddock-override-nav { border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
  .theme-cricket .prose :global(h2) {
    color: #fff;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.5); /* Pitch crease line metaphor */
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }
  .theme-cricket .prose :global(blockquote) {
    border-left: 3px solid #fff;
    color: rgba(255, 255, 255, 0.9);
  }
  .theme-cricket .prose :global(a) { color: #fff; text-decoration-color: rgba(255,255,255,0.4); }
  .theme-cricket .prose :global(a:hover) { text-decoration-color: #fff; }
</style>
