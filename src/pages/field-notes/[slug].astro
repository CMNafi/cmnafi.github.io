---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Flag from '@/components/telemetry/Flag.astro';
import LapTimer from '@/components/telemetry/LapTimer.astro';

export async function getStaticPaths() {
  const notes = await getCollection('field-notes');
  return notes
    .filter(note => note.slug !== 'capital-lens-16' && note.slug !== 'capital-lens-17')
    .map(note => ({
      params: { slug: note.slug },
      props: { note },
    }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---
<BaseLayout title={note.data.title} hideHeader={true}>
  <div class={`note-detail ${note.data.category === 'Cricket' ? 'theme-cricket' : ''}`}>
    <nav class="paddock-override-nav">
      <a href="/field-notes" class="return-wall">← SECURE COMMS</a>
      <div class="nav-title">INCOMING TELEMETRY</div>
    </nav>

    <article class="paddock-article">
      <header class="article-header">
        <div class="note-meta">
          <Flag color="red" />
          <span>{note.data.category.toUpperCase()}</span>
          <span>//</span>
          <span>{note.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric'})}</span>
          <span class="timer-wrap"><LapTimer time={note.data.readingTime.replace(' min read', ':00.000')} /></span>
        </div>
        
        <h1>{note.data.title}</h1>
        {note.data.description && <p class="summary">{note.data.description}</p>}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .paddock-override-nav { display: flex; justify-content: space-between; padding: 2rem; font-family: var(--font-mono); }
  .return-wall { color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
  .nav-title { color: var(--pitlane-white); font-size: 11px; letter-spacing: 0.15em; }
  
  .note-detail { min-height: 100vh; background: var(--paddock-black); }
  .paddock-article { max-width: 760px; margin: 0 auto; padding: 2rem 2rem 6rem; }
  
  .article-header { border-bottom: 1px solid var(--carbon); padding-bottom: 2rem; margin-bottom: 3rem; }
  .note-meta { 
    display: flex; align-items: center; gap: 1rem; 
    font-family: var(--font-mono); font-size: 11px; color: var(--muted); 
    margin-bottom: 2rem; letter-spacing: 0.1em; flex-wrap: wrap;
  }
  .timer-wrap { margin-left: auto; }
  
  .article-header h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); margin: 0 0 1.5rem; color: var(--pitlane-white); line-height: 1.1; }
  .summary { font-family: var(--font-body); font-size: 1.25rem; color: var(--muted); margin: 0; line-height: 1.6; }
  
  .prose { font-family: var(--font-body); font-size: 1.15rem; line-height: 1.8; color: var(--text); }
  .prose :global(h2) { font-family: var(--font-mono); font-size: 1.3rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4rem; margin-bottom: 1.5rem; color: var(--warning-amber); padding-bottom: 0px; }
  .prose :global(h3) { font-family: var(--font-display); font-size: 1.8rem; margin-top: 3rem; margin-bottom: 1rem; color: var(--pitlane-white); }
  .prose :global(p) { margin-bottom: 1.8rem; color: rgba(244, 244, 241, 0.85); }
  .prose :global(a) { color: var(--telemetry-green); text-decoration: underline; text-decoration-color: rgba(0, 230, 118, 0.4); text-underline-offset: 4px; transition: 0.2s; }
  .prose :global(a:hover) { text-decoration-color: var(--telemetry-green); }
  .prose :global(blockquote) { border-left: 3px solid var(--warning-amber); padding-left: 1.5rem; margin-left: 0; font-style: italic; color: var(--muted); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1.8rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.8rem; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: var(--radius-card); margin: 2rem 0; border: 1px solid var(--carbon); }

  /* CRICKET VIBE OVERRIDES */
  .theme-cricket {
    background-color: #0d2912 !important; /* Pitch grass green */
  }
  .theme-cricket .article-header { border-bottom: 1px solid rgba(255, 255, 255, 0.4); }
  .theme-cricket .paddock-override-nav { border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
  .theme-cricket .prose :global(h2) {
    color: #fff;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.5); /* Pitch crease line metaphor */
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }
  .theme-cricket .prose :global(blockquote) {
    border-left: 3px solid #fff;
    color: rgba(255, 255, 255, 0.9);
  }
  .theme-cricket .prose :global(a) { color: #fff; text-decoration-color: rgba(255,255,255,0.4); }
  .theme-cricket .prose :global(a:hover) { text-decoration-color: #fff; }
</style>
