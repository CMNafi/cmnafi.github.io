---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Flag from '@/components/telemetry/Flag.astro';
import SectorBadge from '@/components/telemetry/SectorBadge.astro';

const rawNotes = await getCollection('field-notes');
const allNotes = rawNotes.filter(n => n.data.category !== 'Brewing');

const categoryCounts = allNotes.reduce((acc, note) => {
  acc[note.data.category] = (acc[note.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const sortedCategories = Object.keys(categoryCounts).sort((a, b) => categoryCounts[b] - categoryCounts[a]);

const subCategories = [...new Set(allNotes.filter(n => n.data.category === 'Finance').map(n => n.data.subCategory).filter(Boolean))];

const notesByCategory = sortedCategories.reduce((acc, cat) => {
  acc[cat] = allNotes
    .filter(n => n.data.category === cat)
    .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
  return acc;
}, {} as Record<string, any[]>);

const flatSortedNotes = allNotes.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const slugify = (str: string) => str.toLowerCase().replace(/\s+/g, '-');

const financeNotes = allNotes.filter(n => n.data.category === 'Finance');
const vcCount      = financeNotes.filter(n => n.data.subCategory === 'Venture Capital').length;
const peCount      = financeNotes.filter(n => n.data.subCategory === 'Private Equity').length;
const eqCount      = financeNotes.filter(n => n.data.subCategory === 'Public Equities').length;
const macroCount   = financeNotes.filter(n => n.data.subCategory === 'Macro').length;
const financeTotal = financeNotes.length;
const booksCount   = allNotes.filter(n => n.data.category === 'Books').length;
const cricketCount = allNotes.filter(n => n.data.category === 'Cricket').length;
---

<BaseLayout title="Field Notes" hideHeader={true}>
  
  <nav class="paddock-override-nav">
    <a href="/" class="return-wall">← PIT WALL</a>
    <div class="nav-title">RADIO LOGS</div>
  </nav>

  <main class="notes-viewport">
    <div class="notes-container">
      <header class="notes-header">
        <h1>Field Notes</h1>
        <p>Telemetry readouts from the race. Thoughts on finance, technology, and engineering.</p>
        
        <!-- Category Filter Chips -->
        <div class="filter-chips">
          <a href="/field-notes" class="chip top-chip" data-cat="all">ALL</a>
          {sortedCategories.map(cat => (
            <a href={`/field-notes?category=${slugify(cat)}`} class="chip top-chip" data-cat={slugify(cat)}>{cat.toUpperCase()}</a>
          ))}
        </div>

        <!-- Sub-Category Filter Chips (Dynamic injection for Finance) -->
        <div class="filter-chips sub-chips hidden" id="finance-sub-chips">
           <a href="#" class="chip subchip active" data-subcat="all">ALL FINANCE</a>
           {subCategories.map(sub => (
              <a href="#" class="chip subchip" data-subcat={slugify(sub)}>{sub.toUpperCase()}</a>
           ))}
        </div>
      </header>

      <!-- ════════════════════════════════════════════
           TOPIC TOPOLOGY MAP
           Static mind-map — categories branch from the
           root, sub-topics branch from categories.
           Connector lines are SVG; nodes are HTML.
      ════════════════════════════════════════════ -->
      <section class="topic-map-section" aria-label="Topic topology">
        <div class="map-eyebrow">TOPIC TOPOLOGY</div>

        <div class="topic-map-scroll">
          <div class="mindmap-wrap">

            <!-- ─── SVG connector paths (behind nodes) ─── -->
            <svg class="connectors" viewBox="0 0 670 510"
                 xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

              <!-- root → category trunks -->
              <path class="conn c-finance"  d="M 180,291 C 210,291 210,113 230,113"/>
              <path class="conn c-books"    d="M 180,291 C 210,291 210,323 230,323"/>
              <path class="conn c-cricket"  d="M 180,291 C 210,291 210,460 230,460"/>

              <!-- finance → leaves -->
              <path class="conn c-finance"  d="M 360,113 C 392,113 392,39  430,39"/>
              <path class="conn c-finance"  d="M 360,113 C 392,113 392,89  430,89"/>
              <path class="conn c-finance"  d="M 360,113 C 392,113 392,139 430,139"/>
              <path class="conn c-finance"  d="M 360,113 C 392,113 392,189 430,189"/>

              <!-- books → leaves -->
              <path class="conn c-books"    d="M 360,323 C 392,323 392,274 430,274"/>
              <path class="conn c-books"    d="M 360,323 L 430,323"/>
              <path class="conn c-books"    d="M 360,323 C 392,323 392,374 430,374"/>

              <!-- cricket → leaf -->
              <path class="conn c-cricket"  d="M 360,460 L 430,460"/>
            </svg>

            <!-- ─── ROOT ─── -->
            <div class="mn-node mn-root" style="left:20px;top:265px">
              FIELD<br>NOTES
            </div>

            <!-- ─── CATEGORY NODES ─── -->
            <a class="mn-node mn-cat mn-finance"
               href="#section-finance" style="left:230px;top:91px">
              <span class="mn-cat-label">FINANCE</span>
              <span class="mn-cat-count">{financeTotal}</span>
            </a>

            <a class="mn-node mn-cat mn-books"
               href="#section-books" style="left:230px;top:301px">
              <span class="mn-cat-label">BOOKS</span>
              <span class="mn-cat-count">{booksCount}</span>
            </a>

            <a class="mn-node mn-cat mn-cricket"
               href="#section-cricket" style="left:230px;top:438px">
              <span class="mn-cat-label">CRICKET</span>
              <span class="mn-cat-count">{cricketCount}</span>
            </a>

            <!-- ─── FINANCE LEAVES ─── -->
            <a class="mn-node mn-leaf mn-lf"
               href="/field-notes?category=finance"
               data-mapsubcat="venture-capital"
               style="left:430px;top:20px">
              <span class="mn-leaf-name">Venture Capital</span>
              <span class="mn-leaf-n">{vcCount}</span>
            </a>
            <a class="mn-node mn-leaf mn-lf"
               href="/field-notes?category=finance"
               data-mapsubcat="private-equity"
               style="left:430px;top:70px">
              <span class="mn-leaf-name">Private Equity</span>
              <span class="mn-leaf-n">{peCount}</span>
            </a>
            <a class="mn-node mn-leaf mn-lf"
               href="/field-notes?category=finance"
               data-mapsubcat="public-equities"
               style="left:430px;top:120px">
              <span class="mn-leaf-name">Public Equities</span>
              <span class="mn-leaf-n">{eqCount}</span>
            </a>
            <a class="mn-node mn-leaf mn-lf"
               href="/field-notes?category=finance"
               data-mapsubcat="macro"
               style="left:430px;top:170px">
              <span class="mn-leaf-name">Macro</span>
              <span class="mn-leaf-n">{macroCount}</span>
            </a>

            <!-- ─── BOOKS LEAVES (thematic clusters) ─── -->
            <a class="mn-node mn-leaf mn-lb"
               href="/field-notes/category/books"
               style="left:430px;top:255px">
              <span class="mn-leaf-name">Founders &amp; Builders</span>
            </a>
            <a class="mn-node mn-leaf mn-lb"
               href="/field-notes/category/books"
               style="left:430px;top:305px">
              <span class="mn-leaf-name">Philosophy &amp; Meaning</span>
            </a>
            <a class="mn-node mn-leaf mn-lb"
               href="/field-notes/category/books"
               style="left:430px;top:355px">
              <span class="mn-leaf-name">Markets &amp; Money</span>
            </a>

            <!-- ─── CRICKET LEAF ─── -->
            <a class="mn-node mn-leaf mn-lc"
               href="/field-notes/category/cricket"
               style="left:430px;top:441px">
              <span class="mn-leaf-name">Match Reports</span>
              <span class="mn-leaf-n">{cricketCount}</span>
            </a>

          </div><!-- /mindmap-wrap -->
        </div><!-- /scroll -->

        <p class="map-hint">SCROLL RIGHT ON MOBILE</p>
      </section>
      <!-- ════════════════════════════════════════════ -->

      <div class="main-feed-container" id="notes-feed">
        
        <div id="all-view" class="view-layer">
          {sortedCategories.map(cat => {
            const catNotes = notesByCategory[cat];
            const top4 = catNotes.slice(0, 4);
            return (
              <section class="category-section" id={`section-${slugify(cat)}`}>
                <h2 class="section-header">{cat.toUpperCase()}</h2>
                
                <div class="timeline-wrapper">
                  {top4.map((note, index) => (
                    <article class="note-row">
                      <div class="note-time">
                        <span>{note.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric'})}</span>
                        <div class="timeline-node"><Flag color={index === 0 ? "green" : "checkered"} /></div>
                      </div>
                      <a href={`/field-notes/${note.slug}`} class="note-content">
                        <div class="note-meta">
                          <SectorBadge variant="sector2" label={note.data.subCategory || note.data.category} />
                          <span class="read-time">{note.data.readingTime} READ</span>
                        </div>
                        <h3>{note.data.title}</h3>
                        <p>{note.data.description || note.data.excerpt}</p>
                      </a>
                    </article>
                  ))}
                </div>

                <div class="cat-link-wrap">
                  <a href={`/field-notes/category/${slugify(cat)}`} class="view-all-link">VIEW ALL {catNotes.length} POSTS IN {cat.toUpperCase()} →</a>
                </div>
              </section>
            );
          })}
        </div>

        <div id="filtered-view" class="view-layer hidden">
          <div class="timeline-wrapper" id="filtered-timeline">
            {flatSortedNotes.map((note, index) => (
              <article class="note-row filtered-note" data-cat={slugify(note.data.category)} data-subcat={note.data.subCategory ? slugify(note.data.subCategory) : 'none'}>
                <div class="note-time">
                  <span>{note.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric'})}</span>
                  <div class="timeline-node">
                    <div class="timeline-flag-inject"></div>
                  </div>
                </div>
                <a href={`/field-notes/${note.slug}`} class="note-content">
                  <div class="note-meta">
                    <SectorBadge variant="sector2" label={note.data.subCategory || note.data.category} />
                    <span class="read-time">{note.data.readingTime} READ</span>
                  </div>
                  <h3>{note.data.title}</h3>
                  <p>{note.data.description || note.data.excerpt}</p>
                </a>
              </article>
            ))}
          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function applyFilter(overrideCat = null, subCat = 'all') {
    const params = new URLSearchParams(window.location.search);
    const cat = overrideCat || params.get('category');
    
    // Top-level Chips state
    document.querySelectorAll('.filter-chips > .top-chip').forEach(el => {
      el.classList.remove('active');
      if (cat) {
        if (el.getAttribute('data-cat') === cat) el.classList.add('active');
      } else {
        if (el.getAttribute('data-cat') === 'all') el.classList.add('active');
      }
    });

    const subChipsTray = document.getElementById('finance-sub-chips');
    if (cat === 'finance') {
      subChipsTray?.classList.remove('hidden');
      document.querySelectorAll('.subchip').forEach(el => {
        el.classList.remove('active');
        if (el.getAttribute('data-subcat') === subCat) {
          el.classList.add('active');
        }
      });
    } else {
      subChipsTray?.classList.add('hidden');
    }

    const allView = document.getElementById('all-view');
    const filteredView = document.getElementById('filtered-view');
    const filteredNotes = document.querySelectorAll('.filtered-note');

    if (!cat || cat === 'all') {
      allView?.classList.remove('hidden');
      filteredView?.classList.add('hidden');
    } else {
      allView?.classList.add('hidden');
      filteredView?.classList.remove('hidden');
      
      let greenFlagAssigned = false;
      filteredNotes.forEach(el => {
        const hElement = el as HTMLElement;
        const matchesCat = hElement.getAttribute('data-cat') === cat;
        const matchesSub = subCat === 'all' || hElement.getAttribute('data-subcat') === subCat;

        if (matchesCat && matchesSub) {
          hElement.style.display = 'grid';
          const flagInject = hElement.querySelector('.timeline-flag-inject');
          if (flagInject) {
            if (!greenFlagAssigned) {
              flagInject.innerHTML = '<div class="flag green" style="width: 20px; height: 14px; background-color: var(--telemetry-green); display: inline-block; border-radius: 1px; box-shadow: 0 1px 2px rgba(0,0,0,0.5);"></div>';
              greenFlagAssigned = true;
            } else {
              flagInject.innerHTML = '<div class="flag checkered" style="width: 20px; height: 14px; background-color: var(--pitlane-white); display: inline-block; border-radius: 1px;"><div class="checker-pattern" style="width: 100%; height: 100%; background-image: linear-gradient(45deg, var(--paddock-black) 25%, transparent 25%, transparent 75%, var(--paddock-black) 75%), linear-gradient(45deg, var(--paddock-black) 25%, transparent 25%, transparent 75%, var(--paddock-black) 75%); background-size: 8px 8px; background-position: 0 0, 4px 4px;"></div></div>';
            }
          }
        } else {
          hElement.style.display = 'none';
        }
      });
    }
  }

  applyFilter();
  
  document.querySelectorAll('.top-chip').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const href = el.getAttribute('href');
      if(href) {
        window.history.pushState({}, '', href);
        applyFilter();
        window.scrollTo(0, 0);
      }
    });
  });

  document.querySelectorAll('.subchip').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const sub = el.getAttribute('data-subcat');
      // Push state optionally or just re-render UI state
      applyFilter('finance', sub);
    });
  });

  window.addEventListener('popstate', () => applyFilter());

  // Mindmap Finance leaves → navigate + activate subcategory filter
  document.querySelectorAll('.mn-lf[data-mapsubcat]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const sub = el.getAttribute('data-mapsubcat');
      window.history.pushState({}, '', '/field-notes?category=finance');
      applyFilter('finance', sub || 'all');
      document.getElementById('notes-feed')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>

<style>
  .hidden { display: none !important; }

  .paddock-override-nav {
    display: flex; justify-content: space-between; padding: 2rem; font-family: var(--font-mono);
  }
  .return-wall { color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
  .return-wall:hover { color: var(--pitlane-white); }
  .nav-title { color: var(--pitlane-white); font-size: 11px; letter-spacing: 0.15em; }

  .notes-viewport {
    min-height: 100vh;
    background: var(--paddock-black);
    padding: 2rem;
  }
  .notes-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .notes-header {
    margin-bottom: 4rem;
  }
  .notes-header h1 {
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--pitlane-white);
    margin: 0 0 1rem 0;
  }
  .notes-header p {
    font-family: var(--font-body);
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 600px;
  }

  /* CHIPS */
  .filter-chips {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 0.5rem;
    padding-bottom: 0.8rem;
    margin-top: 2rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    border-bottom: 1px solid var(--graphite);
  }
  .sub-chips {
    border-bottom: none;
    margin-top: 0.5rem;
  }
  .sub-chips .chip {
    font-size: 10px;
    padding: 0.3rem 0.6rem;
    border-style: dashed;
  }
  
  .filter-chips::-webkit-scrollbar { display: none; }
  .chip {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 11px;
    border: 1px solid var(--graphite);
    border-radius: var(--radius-chip);
    padding: 0.4rem 0.8rem;
    color: var(--muted);
    text-decoration: none;
    white-space: nowrap;
    transition: 0.2s;
  }
  .chip.active, .chip:hover {
    background: var(--warning-amber);
    color: var(--paddock-black);
    border-color: var(--warning-amber);
    font-weight: 700;
  }

  /* SECTION */
  .category-section {
    margin-bottom: 5rem;
  }
  .section-header {
    font-family: var(--font-display);
    font-size: 20px;
    font-variant: small-caps;
    color: var(--pitlane-white);
    margin: 0 0 2rem 0;
    text-align: left;
    position: relative;
    padding-bottom: 0.5rem;
  }
  .section-header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 24px;
    height: 2px;
    background: var(--warning-amber);
  }

  .view-all-link {
    display: inline-block;
    margin-top: 2rem;
    margin-left: 180px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--telemetry-green);
    text-decoration: none;
    transition: 0.2s;
  }
  .view-all-link:hover {
    color: var(--pitlane-white);
  }

  /* ROWS */
  .timeline-wrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .note-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 3rem;
    position: relative;
  }

  .note-time {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--muted);
    padding-top: 0.5rem;
  }

  .timeline-node {
    margin-top: -2px;
  }

  .timeline-wrapper .note-row:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 172px; /* aligns with flag */
    top: 24px;   
    bottom: -3rem; 
    width: 1px;
    background: var(--graphite);
  }

  .note-content {
    display: block;
    background: var(--carbon);
    padding: 2rem;
    border: 1px solid var(--graphite);
    border-radius: var(--radius-card);
    transition: transform 0.2s, border-color 0.2s;
  }
  .note-content:hover {
    transform: translateX(10px);
    border-color: var(--warning-amber);
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .read-time {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .note-content h3 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--pitlane-white);
    margin: 0 0 1rem 0;
  }
  .note-content p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: rgba(244, 244, 241, 0.7);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .note-row { grid-template-columns: 1fr; gap: 1rem; }
    .note-row:not(:last-child)::after { display: none; }
    .note-time { justify-content: flex-start; gap: 1rem; flex-direction: row-reverse; }
    .view-all-link { margin-left: 0; }
  }

  /* ═══════════════════════════════════════════════
     TOPIC TOPOLOGY MAP
  ═══════════════════════════════════════════════ */
  .topic-map-section {
    margin-bottom: 5rem;
    border-top: 1px solid var(--surface-line);
    padding-top: 2.5rem;
  }

  .map-eyebrow {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.25em;
    color: var(--ink-tertiary);
    margin-bottom: 1.5rem;
  }

  .topic-map-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .topic-map-scroll::-webkit-scrollbar { display: none; }

  /* Fixed-size canvas; SVG + nodes share the same pixel grid */
  .mindmap-wrap {
    position: relative;
    width: 670px;
    height: 510px;
    min-width: 670px;
  }

  /* SVG fills the canvas behind nodes */
  .connectors {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Connector path defaults */
  .conn {
    fill: none;
    stroke-width: 1.5px;
    stroke-linecap: round;
  }
  .c-finance { stroke: rgba(232, 184, 106, 0.35); }
  .c-books   { stroke: rgba(168, 156, 139, 0.35); }
  .c-cricket { stroke: rgba(125, 211, 160, 0.35); }

  /* ── Base node ── */
  .mn-node {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-card);
    text-decoration: none;
    font-family: var(--font-mono);
    transition: transform var(--dur-fast) var(--ease-instrument),
                border-color var(--dur-fast) var(--ease-instrument),
                background var(--dur-fast) var(--ease-instrument);
  }

  /* ── ROOT ── */
  .mn-root {
    width: 160px;
    height: 52px;
    background: var(--accent);
    border: 1.5px solid var(--accent);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--surface-base);
    text-align: center;
    line-height: 1.45;
    flex-direction: column;
    cursor: default;
    /* pulse glow */
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: rootPulse 3s ease-in-out infinite;
  }
  @keyframes rootPulse {
    0%, 100% { box-shadow: 0 0 0 0 var(--accent-glow); }
    50%       { box-shadow: 0 0 12px 4px var(--accent-glow); }
  }

  /* ── CATEGORY nodes ── */
  .mn-cat {
    width: 130px;
    height: 44px;
    background: var(--surface-raised);
    border-width: 1.5px;
    border-style: solid;
    flex-direction: column;
    gap: 3px;
  }
  .mn-finance { border-color: var(--status-warn); }
  .mn-books   { border-color: var(--ink-secondary); }
  .mn-cricket { border-color: var(--accent); }

  .mn-cat-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--ink-primary);
  }
  .mn-cat-count {
    font-size: 9px;
    letter-spacing: 0.1em;
  }
  .mn-finance .mn-cat-count { color: var(--status-warn); }
  .mn-books   .mn-cat-count { color: var(--ink-secondary); }
  .mn-cricket .mn-cat-count { color: var(--accent); }

  .mn-finance:hover { background: rgba(232,184,106,0.08); transform: translateY(-2px); }
