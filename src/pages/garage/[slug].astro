---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TelemetryGrid from '@/components/telemetry/TelemetryGrid.astro';
import SectorBadge from '@/components/telemetry/SectorBadge.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---
<BaseLayout title={project.data.title}>
  <div class="garage-detail">
    <nav class="paddock-override-nav">
      <a href="/garage" class="return-wall">← GARAGE LOGIC</a>
      <div class="nav-title">{project.data.status.toUpperCase()} DEPLOYMENT</div>
    </nav>
    <article class="paddock-article">
      <header class="article-header">
        <SectorBadge variant={project.data.status === 'live' ? 'p1' : 'p3'} label={project.data.status} />
        <h1>{project.data.title}</h1>
        <p class="summary">{project.data.summary}</p>
        <div class="telemetry-bar">
          <TelemetryGrid 
              updated={(project.data.updatedAt || project.data.startedAt)?.toLocaleDateString() || '--'}
              status={project.data.status as any}
              stack={project.data.stack?.join(', ') || 'N/A'}
              link={project.data.liveUrl || project.data.repoUrl}
              linkLabel={project.data.liveUrl ? "OPEN PROD →" : "GITHUB →"}
            />
        </div>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .paddock-override-nav { display: flex; justify-content: space-between; padding: 2rem; font-family: var(--font-mono); }
  .return-wall { color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
  .nav-title { color: var(--pitlane-white); font-size: 11px; letter-spacing: 0.15em; }
  .garage-detail { min-height: 100vh; background: var(--paddock-black); }
  .paddock-article { max-width: 850px; margin: 0 auto; padding: 2rem 2rem 6rem; }
  .article-header { border-bottom: 1px solid var(--carbon); padding-bottom: 3rem; margin-bottom: 3rem; }
  .article-header h1 { font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); margin: 1.5rem 0 1rem; color: var(--pitlane-white); line-height: 1.1; }
  .summary { font-family: var(--font-body); font-size: 1.25rem; color: var(--muted); margin-bottom: 3rem; line-height: 1.6; max-width: 650px; }
  .prose { font-family: var(--font-body); font-size: 1.15rem; line-height: 1.8; color: var(--text); }
  .prose :global(h2) { font-family: var(--font-mono); font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4rem; margin-bottom: 1.5rem; color: var(--warning-amber); border-bottom: 1px solid var(--graphite); padding-bottom: 0.5rem; }
  .prose :global(h3) { font-family: var(--font-display); font-size: 1.8rem; margin-top: 3rem; margin-bottom: 1rem; color: var(--pitlane-white); }
  .prose :global(p) { margin-bottom: 1.5rem; }
  .prose :global(ul) { margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.5rem; }
</style>
