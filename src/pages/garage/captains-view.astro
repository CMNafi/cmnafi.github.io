---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Captains View" hideHeader={true}>
  <div class="captains-detail-viewport">
    
    <!-- Header Navigation -->
    <nav class="paddock-override-nav">
      <a href="/garage" class="return-wall">← GARAGE COMMAND</a>
      <div class="nav-title">CAPTAINS VIEW // FIELDING STRATEGIST</div>
      <div class="telemetry-pill">
        <span class="pulse-dot"></span>
        <span class="pill-label">RADAR SCAN ACTIVE</span>
      </div>
    </nav>

    <!-- Wizard Step Progress Bar -->
    <div class="wizard-progress-bar">
      <div id="step-indicator-1" class="wizard-step active-step">
        <span class="step-num">01</span>
        <span class="step-label">SQUAD SETUP & INTEL</span>
      </div>
      <div class="wizard-connector"></div>
      <div id="step-indicator-2" class="wizard-step">
        <span class="step-num">02</span>
        <span class="step-label">TACTICAL STRATEGY BOARD</span>
      </div>
    </div>

    <!-- STEP 1 VIEW: THE SETUP WIZARD (Centered Form View) -->
    <div id="step-1-view" class="wizard-view-container centered-wizard-layout">
      <div class="glass-wizard-card">
        
        <!-- Header -->
        <header class="wizard-header-block">
          <h1 class="wizard-main-title">CRICKET CAPTAIN'S TACTICAL BOARD</h1>
          <p class="wizard-subtitle">Configure your squad, match settings, and initial strategy to launch the board.</p>
        </header>

        <!-- Configuration Grid: 2 sections (Left: Match Settings & Strategy; Right: 12-Player Roster) -->
        <div class="wizard-setup-grid">
          
          <!-- Left Column: Settings and Strategy -->
          <div class="wizard-settings-panel">
            
            <!-- Match Format Selection -->
            <div class="wizard-section-card">
              <h3 class="section-card-title">🏏 MATCH CONFIGURATION</h3>
              <div class="format-toggle-group">
                <button type="button" class="format-btn active" data-format="T20">T20 (20 Overs)</button>
                <button type="button" class="format-btn" data-format="16-Over">16-Over Game</button>
                <button type="button" class="format-btn" data-format="35-Over">35-Over Game</button>
              </div>
            </div>

            <!-- Strategy Selection -->
            <div class="wizard-section-card">
              <h3 class="section-card-title">⚡ OPENING FIELD STRATEGY</h3>
              <div class="strategy-cards-grid">
                
                <div class="strategy-card active" data-strategy="aggressive">
                  <div class="strat-card-header">
                    <span class="strat-icon">⚡</span>
                    <span class="strat-title">Aggressive Attack</span>
                  </div>
                  <p class="strat-desc">Tight slip cordon, close catchers (Silly Point, Gully) to induce errors.</p>
                </div>

                <div class="strategy-card" data-strategy="balanced">
                  <div class="strat-card-header">
                    <span class="strat-icon">🕸️</span>
                    <span class="strat-title">Balanced Ring</span>
                  </div>
                  <p class="strat-desc">Symmetric placement across the 30-yard circle to cut off singles.</p>
                </div>

                <div class="strategy-card" data-strategy="defensive">
                  <div class="strat-card-header">
                    <span class="strat-icon">🛡️</span>
                    <span class="strat-title">Defensive Powerplay</span>
                  </div>
                  <p class="strat-desc">Boundary protection with 2 deep fielders on the leg side & deep cover.</p>
                </div>

              </div>
            </div>

            <!-- Team & Opponent Info -->
            <div class="wizard-section-card">
              <h3 class="section-card-title">💾 TEAM DETAILS</h3>
              <div class="team-inputs-row">
                <div class="input-wrap">
                  <label for="team-name-input-s1">My Team Name</label>
                  <input type="text" id="team-name-input-s1" class="wizard-text-input" placeholder="e.g. India" value="My Team" />
                </div>
                <div class="input-wrap">
                  <label for="game-name-input-s1">Game / Opponent</label>
                  <input type="text" id="game-name-input-s1" class="wizard-text-input" placeholder="e.g. vs Australia" value="Match 1" />
                </div>
              </div>
            </div>

          </div>

          <!-- Right Column: 12-Player Squad Setup Grid -->
          <div class="wizard-roster-panel">
            <div class="roster-panel-header">
              <h3 class="section-card-title">👥 SQUAD ROSTER & ROLES</h3>
              <div class="roster-quick-actions">
                <button type="button" id="wizard-clear-names" class="btn-text-only">❌ Clear All Names</button>
                <button type="button" id="wizard-bulk-import-toggle" class="btn-text-only">📋 Bulk Import</button>
              </div>
            </div>

            <!-- Bulk Import Textarea (Toggleable) -->
            <div id="wizard-bulk-box" class="wizard-bulk-box hidden">
              <p class="bulk-info">Paste 12 names, one per line:</p>
              <textarea id="wizard-bulk-textarea" rows="4" placeholder="MS Dhoni&#10;Jasprit Bumrah&#10;Virat Kohli&#10;Rohit Sharma&#10;KL Rahul&#10;Hardik Pandya&#10;Ravindra Jadeja&#10;Suryakumar Yadav&#10;Mohammed Shami&#10;Kuldeep Yadav&#10;Axar Patel&#10;Yuzvendra Chahal"></textarea>
              <button type="button" id="wizard-apply-bulk" class="hud-action-btn btn-primary" style="margin-top: 0.5rem; width: 100%; justify-content: center;">Apply Bulk Names</button>
            </div>

            <!-- 12 Cards Grid -->
            <div class="wizard-roster-grid" id="wizard-roster-grid-container">
              <!-- Dynamically rendered player cards -->
            </div>
          </div>

        </div>

        <!-- Wizard Action Button -->
        <footer class="wizard-footer-action">
          <button type="button" id="generate-board-btn" class="generate-board-cta">
            GENERATE TACTICAL BOARD <span class="glowing-pulse-arrow">⚡</span>
          </button>
        </footer>

      </div>
    </div>

    <!-- STEP 2 VIEW: TACTICAL FIELD SANDBOX -->
    <div id="step-2-view" class="wizard-view-container hidden-view">
      <main class="tactical-board-grid step-2-grid">
        
        <!-- Left Column: Command & Tactical Controls -->
        <section class="command-dashboard">
          
          <!-- Back Step Button -->
          <button id="back-to-roster-btn" class="hud-action-btn back-roster-btn">
            ← ADJUST ROSTER & CONFIG
          </button>

          <!-- Match Control Settings Panel -->
          <div class="dashboard-card">
            <h2 class="card-title">TACTICAL METRICS</h2>
            <div class="metrics-grid">
              
              <div class="metric-group">
                <label for="match-format">MATCH FORMAT</label>
                <select id="match-format" class="minimal-select">
                  <option value="T20">T20 (20 Overs)</option>
                  <option value="16-Over" selected>16-Over Game</option>
                  <option value="35-Over">35-Over Game</option>
                </select>
              </div>

              <div class="metric-group">
                <label for="powerplay-toggle">POWERPLAY STATE</label>
                <div class="toggle-container">
                  <button id="powerplay-toggle" class="telemetry-toggle-btn active-state">
                    <span class="toggle-indicator"></span>
                    <span class="toggle-text">POWERPLAY ACTIVE</span>
                  </button>
                </div>
              </div>

              <div class="metric-group">
                <label for="handedness-toggle">BATTER STRIKE</label>
                <div class="toggle-container">
                  <button id="handedness-toggle" class="telemetry-toggle-btn">
                    <span class="handedness-badge">RHB</span>
                    <span class="toggle-text">RIGHT-HANDED</span>
                  </button>
                </div>
              </div>

              <div class="metric-group">
                <label for="bowler-select">CURRENT BOWLER</label>
                <select id="bowler-select" class="minimal-select">
                  <!-- Dynamically populated from active bowlers in roster -->
                </select>
              </div>

            </div>
          </div>

          <!-- Strategy Storage Card -->
          <div class="dashboard-card save-load-card">
            <h2 class="card-title">💾 STRATEGY STORAGE</h2>
            <div class="metrics-grid" style="grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-bottom: 0.6rem;">
              <div class="metric-group">
                <label for="team-name-input">MY TEAM NAME</label>
                <input type="text" id="team-name-input" class="player-name-input" style="height: 32px; background: var(--surface-base); border: 1px solid var(--surface-line); color: var(--ink-primary); font-family: var(--font-mono); font-size: 10px; padding: 0.2rem 0.5rem; border-radius: 4px;" placeholder="e.g. India" value="My Team" />
              </div>
              <div class="metric-group">
                <label for="game-name-input">GAME / OPPONENT</label>
                <input type="text" id="game-name-input" class="player-name-input" style="height: 32px; background: var(--surface-base); border: 1px solid var(--surface-line); color: var(--ink-primary); font-family: var(--font-mono); font-size: 10px; padding: 0.2rem 0.5rem; border-radius: 4px;" placeholder="e.g. vs Australia" value="Match 1" />
              </div>
            </div>
            
            <div class="save-load-controls" style="display: flex; flex-direction: column; gap: 0.5rem;">
              <div style="display: flex; gap: 0.5rem;">
                <button id="save-strategy-btn" class="hud-action-btn btn-primary" style="flex: 1; justify-content: center; height: 32px; font-size: 10px;">
                  💾 SAVE CURRENT STRATEGY
                </button>
              </div>
              
              <div style="display: flex; gap: 0.5rem; align-items: center;">
                <select id="saved-strategies-select" class="minimal-select" style="flex: 2; height: 32px; background: var(--surface-base); border: 1px solid var(--surface-line); color: var(--ink-primary); font-family: var(--font-mono); font-size: 10px;">
                  <option value="">-- No Saved Strategies --</option>
                </select>
                <button id="load-strategy-btn" class="hud-action-btn" style="flex: 1; justify-content: center; height: 32px; font-size: 10px; border-color: rgba(46, 204, 113, 0.4); color: #2ecc71;">
                  📂 LOAD
                </button>
                <button id="delete-strategy-btn" class="hud-action-btn" style="flex: 0.5; justify-content: center; height: 32px; font-size: 10px; border-color: rgba(231, 76, 60, 0.4); color: #e74c3c;">
                  🗑️
                </button>
              </div>
            </div>
          </div>

          <!-- Strategy Playbook Guide Card -->
          <div class="dashboard-card strategy-playbook-card">
            <div class="strategy-header-row" style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem;">
              <span id="playbook-stage-tag" class="strategy-tag" style="background: var(--accent); color: #0c0f0d; font-family: var(--font-mono); font-size: 9px; font-weight: 800; padding: 0.15rem 0.4rem; border-radius: 3px; letter-spacing: 0.05em;">STAGE 1</span>
              <h3 id="playbook-strategy-title" class="strategy-main-title" style="font-size: 11px; font-weight: bold; color: #ffffff; margin: 0;">THE CLASSIC SLIP ATTACK</h3>
            </div>
            <div id="playbook-strategy-phase" style="font-family: var(--font-mono); font-size: 9px; color: var(--accent); margin-bottom: 0.5rem; letter-spacing: 0.05em;">PHASE: POWERPLAY (OVERS 1-6)</div>
            <p id="playbook-strategy-explanation" style="font-size: 9.5px; color: var(--ink-secondary); line-height: 1.4; margin: 0;">
              In the initial powerplay phase, restrictions limit the defense to a maximum of 2 fielders outside the 30-yard circle. Capturing early wickets is key. In this ultra-aggressive layout, the captain deploys 3 slips, a gully, and a silly point, leaving the outfield completely unprotected. It applies maximum psychological pressure and locks down catching angles near the bat.
            </p>
          </div>

          <!-- Over Economy / Flip Analyzer Card -->
          <div class="dashboard-card over-economy-card">
            <div class="card-title-flex">
              <h2 class="card-title">OVER FLIP ECONOMY</h2>
              <button id="toggle-flip-btn" class="mini-feature-btn">SHOW</button>
            </div>
            <p style="font-size: 9px; color: var(--ink-tertiary); margin: 0 0 0.55rem; line-height: 1.4;">
              Distance each fielder covers when bowling end swaps. Minimize heavy runners.
            </p>
            <div class="economy-stats-strip">
              <div class="economy-chip">
                <span class="econ-chip-label">TOTAL MOVE</span>
                <span class="econ-chip-value" id="flip-total-run">—</span>
              </div>
              <div class="economy-chip">
                <span class="econ-chip-label">HEAVY SPRINTS</span>
                <span class="econ-chip-value" id="flip-sprint-count">—</span>
              </div>
            </div>
            <div class="flip-breakdown" id="flip-breakdown-list">
              <!-- Distance rows injected by JS -->
            </div>
            <!-- Bowler Protection Guard -->
            <div style="margin-top: 0.65rem; border-top: 1px solid rgba(125,211,160,0.1); padding-top: 0.55rem;">
              <div style="font-family: var(--font-mono); font-size: 9px; color: var(--ink-secondary); letter-spacing: 0.06em; margin-bottom: 0.4rem;">BOWLER GUARD POSITIONS</div>
              <div class="bowler-guard-strip" id="bowler-guard-strip">
                <span class="guard-pos-pill" data-pos="fine_leg">FL</span>
                <span class="guard-pos-pill" data-pos="third_man">TM</span>
                <span class="guard-pos-pill" data-pos="short_fine_leg">SFL</span>
                <span class="guard-pos-pill" data-pos="deep_fine_leg">DFL</span>
                <span class="guard-pos-pill" data-pos="deep_third_man">DTM</span>
              </div>
            </div>
          </div>

          <!-- Compact Squad Roster Panel (Step 2) -->
          <div class="dashboard-card compact-roster-card">
            <div class="roster-header">
              <h2 class="card-title">TACTICAL ROSTER LIST</h2>
              <div class="squad-counter"><span id="squad-active-count-s2">11</span> / 12 PLACED</div>
            </div>
            <p class="compact-tip">
              💡 Tap a player below to select, then click a slot on the turf to drop them.
            </p>
            <div class="roster-list-wrapper compact-list-wrapper">
              <div id="roster-items-list-s2" class="roster-flex-list">
                <!-- Dynamically populated compact rows -->
              </div>
            </div>
          </div>

          <!-- HUD Diagnostic Logger Card -->
          <div class="dashboard-card terminal-card compact-terminal-card">
            <div class="terminal-header">
              <h2 class="card-title monospace-title">FIELD DIAGNOSTICS</h2>
              <button id="clear-logs-btn-s2" class="terminal-clear-btn">CLEAR</button>
            </div>
            <div id="terminal-console-s2" class="terminal-log-output">
              <!-- Dynamically populated logs -->
            </div>
          </div>

        </section>

        <!-- Right Column: Interactive Green Field Sandbox -->
        <section class="fielding-sandbox">
          
          <!-- Diagnostic Warning Banner Overlay -->
          <div id="rules-violation-alert" class="rules-alert-banner hidden-banner">
            <div class="alert-content">
              <span class="warning-icon">⚠️</span>
              <span id="violation-message">INVALID FIELD SET: Powerplay constraints exceeded!</span>
            </div>
          </div>

          <!-- Selection Status Banner Overlay -->
          <div id="selection-status-banner" class="selection-banner-overlay hidden-banner">
            <div class="selection-banner-content">
              <span class="selection-icon">🎯</span>
              <span id="selection-banner-message">PLACING: Player Name. Tap any position on the turf to drop.</span>
              <button id="cancel-selection-btn" class="cancel-selection-pill">CANCEL</button>
            </div>
          </div>

          <div class="field-outer-wrapper">
            
            <div class="field-aspect-container">
              <div id="field-bounds" class="cricket-turf-field">
                
                <!-- SVG Background: Crisp high-contrast cricket markings -->
                <svg viewBox="0 0 100 100" class="svg-field-markings" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <!-- Soft shadow for the boundary rope -->
                    <filter id="rope-shadow" x="-10%" y="-10%" width="120%" height="120%">
                      <feDropShadow dx="0" dy="0.6" stdDeviation="0.4" flood-color="#000" flood-opacity="0.6" />
                    </filter>
                    <radialGradient id="turf-shading" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#3a7d44" />
                      <stop offset="70%" stop-color="#2b6035" />
                      <stop offset="100%" stop-color="#1a3d22" />
                    </radialGradient>
                    <!-- Arrowheads for over-flip economy arrows -->
                    <marker id="arrow-green" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L0,6 L6,3 z" fill="#7dd3a0" />
                    </marker>
                    <marker id="arrow-amber" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L0,6 L6,3 z" fill="#e8b86a" />
                    </marker>
                    <marker id="arrow-red" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L0,6 L6,3 z" fill="#e55555" />
                    </marker>
                  </defs>

                  <!-- Concentric Mowed Grass Turf Rings -->
                  <circle cx="50" cy="50" r="48" fill="url(#turf-shading)" />
                  <circle cx="50" cy="50" r="42" fill="none" stroke="#255127" stroke-width="2.5" opacity="0.4" />
                  <circle cx="50" cy="50" r="34" fill="none" stroke="#255127" stroke-width="2.5" opacity="0.4" />
                  <circle cx="50" cy="50" r="26" fill="none" stroke="#255127" stroke-width="2.5" opacity="0.4" />
                  <circle cx="50" cy="50" r="18" fill="none" stroke="#255127" stroke-width="2.5" opacity="0.4" />
                  <circle cx="50" cy="50" r="10" fill="none" stroke="#255127" stroke-width="2.5" opacity="0.4" />
                  
                  <!-- White Boundary Rope -->
                  <circle cx="50" cy="50" r="46" fill="none" stroke="#ffffff" stroke-width="0.8" filter="url(#rope-shadow)" opacity="0.9" />
                  
                  <!-- White 30-Yard Circle (Dashed) -->
                  <circle id="thirty-yard-circle-svg" cx="50" cy="50" r="28" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="0.5" stroke-dasharray="1.5 1" />
                  
                  <!-- Center Clay/Straw Pitch -->
                  <rect x="46.8" y="38" width="6.4" height="24" rx="0.3" fill="#dfc399" stroke="#b29b7a" stroke-width="0.25" />
                  
                  <!-- Crease Markings (White Lines) -->
                  <!-- Top Crease (Stumps and Popping) -->
                  <line x1="47.5" y1="41" x2="52.5" y2="41" stroke="#ffffff" stroke-width="0.2" />
                  <line x1="45" y1="43" x2="55" y2="43" stroke="#ffffff" stroke-width="0.2" />
                  <!-- Return Creases -->
                  <line x1="47.5" y1="41" x2="47.5" y2="39.5" stroke="#ffffff" stroke-width="0.2" />
                  <line x1="52.5" y1="41" x2="52.5" y2="39.5" stroke="#ffffff" stroke-width="0.2" />
                  
                  <!-- Bottom Crease (Stumps and Popping) -->
                  <line x1="47.5" y1="59" x2="52.5" y2="59" stroke="#ffffff" stroke-width="0.2" />
                  <line x1="45" y1="57" x2="55" y2="57" stroke="#ffffff" stroke-width="0.2" />
                  <!-- Return Creases -->
                  <line x1="47.5" y1="59" x2="47.5" y2="60.5" stroke="#ffffff" stroke-width="0.2" />
                  <line x1="52.5" y1="59" x2="52.5" y2="60.5" stroke="#ffffff" stroke-width="0.2" />
                  
                  <!-- Stumps Wickets (3 tiny brown stumps each end) -->
                  <circle cx="49.2" cy="41" r="0.25" fill="#583c18" />
                  <circle cx="50.0" cy="41" r="0.25" fill="#583c18" />
                  <circle cx="50.8" cy="41" r="0.25" fill="#583c18" />

                  <circle cx="49.2" cy="59" r="0.25" fill="#583c18" />
                  <circle cx="50.0" cy="59" r="0.25" fill="#583c18" />
                  <circle cx="50.8" cy="59" r="0.25" fill="#583c18" />

                  <!-- Pitch Center Mark -->
                  <circle cx="50" cy="50" r="0.3" fill="rgba(255,255,255,0.4)" />

                  <!-- === DYNAMIC ANALYSIS OVERLAY LAYERS === -->
                  <!-- Boundary Coverage Arc Segments (activated by Boundary Map toggle) -->
                  <g id="boundary-arcs-layer" display="none"></g>
                  <!-- Bowler Guard Highlight Rings (activated by Boundary Map toggle) -->
                  <g id="bowler-guard-layer" display="none"></g>
                  <!-- Over Flip Economy Arrows (activated by Flip Economy toggle) -->
                  <g id="over-flip-arrows-layer" display="none"></g>
                </svg>

                <!-- Preset position slots layer -->
                <div id="slots-container" class="slots-layer-container">
                  <!-- Preset position slots are injected here dynamically -->
                </div>

                <!-- HTML Player Tokens Interactive Layer -->
                <div id="tokens-container" class="tokens-layer-container">
                  <!-- Draggable player tokens are injected here dynamically -->
                </div>

                <!-- Premium Glassmorphic Fielder Tooltip -->
                <div id="fielder-tooltip" class="fielder-tooltip hidden"></div>

                <!-- Floating Assignment Menu -->
                <div id="slot-assign-menu" class="floating-assign-menu hidden-menu"></div>

              </div>
            </div>

            <!-- Bench Dugout for Substitutes -->
            <div class="bench-dugout-card">
              <div class="bench-header">
                <span class="pulse-dot-amber"></span>
                <span class="bench-title">BENCH / 12th MAN POOL</span>
              </div>
              <div id="bench-tokens-container" class="bench-tokens-flex">
                <!-- Benched player tokens are rendered here as interactive circles -->
              </div>
            </div>

            <!-- Quick Actions HUD Bar -->
            <div class="field-controls-hud">
              <button id="reset-field-btn" class="hud-action-btn">
                <span>↻</span> RESET TACTICS
              </button>
              <button id="toggle-flip-hud-btn" class="hud-action-btn" title="Toggle Over Flip Economy arrows on field">
                <span>⇄</span> FLIP ECONOMY
              </button>
              <button id="toggle-boundary-btn" class="hud-action-btn" title="Toggle Boundary Coverage map and Bowler Guard">
                <span>◉</span> BOUNDARY MAP
              </button>
              <div class="hud-legend">
                <span class="legend-item"><span class="legend-dot color-wk"></span> WICKET KEEPER</span>
                <span class="legend-item"><span class="legend-dot color-bowler"></span> ACTIVE BOWLER</span>
                <span class="legend-item"><span class="legend-dot color-fielder"></span> FIELDER</span>
              </div>
              <div class="circle-telemetry">
                OUTSIDE CIRCLE: <span id="outside-circle-count" class="mono-value">0</span> / <span id="outside-circle-limit" class="mono-value">2</span>
              </div>
            </div>

          </div>

        </section>

      </main>

      <!-- Dynamic Transition Master Range Toggle Slider (Playbook Timeline) -->
      <footer class="playbook-master-timeline">
        <div class="timeline-slider-card">
          <h3 class="timeline-card-title">🕹️ TIMELINE PRESET INTERACTION SLIDER</h3>
          <div class="timeline-step-labels">
            <div class="timeline-label active" data-step="1">
              <span class="step-dot"></span>
              <span class="step-title">1. SLIP ATTACK (PP)</span>
            </div>
            <div class="timeline-label" data-step="2">
              <span class="step-dot"></span>
              <span class="step-title">2. BALANCED RING</span>
            </div>
            <div class="timeline-label" data-step="3">
              <span class="step-dot"></span>
              <span class="step-title">3. LHB MIRROR</span>
            </div>
            <div class="timeline-label" data-step="4">
              <span class="step-dot"></span>
              <span class="step-title">4. DEATH SHIELD</span>
            </div>
          </div>
          <div class="timeline-range-container">
            <input type="range" id="playbook-range-slider" min="1" max="4" step="1" value="1" class="timeline-slider-element" />
          </div>
        </div>
      </footer>

    </div>

  </div>
</BaseLayout>

<style is:global>
  /* --- Global Scaffolding Override --- */
  .captains-detail-viewport {
    min-height: 100vh;
    background: var(--surface-base);
    display: flex;
    flex-direction: column;
    color: var(--ink-primary);
  }

  .paddock-override-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--surface-line);
    font-family: var(--font-mono);
    z-index: 100;
  }
  .return-wall {
    color: var(--ink-secondary);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-decoration: none;
    transition: color 0.2s;
  }
  .return-wall:hover {
    color: var(--accent);
  }
  .nav-title {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--ink-primary);
    font-weight: 600;
  }
  .telemetry-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(125, 211, 160, 0.08);
    border: 1px solid var(--accent-dim);
    padding: 0.35rem 0.6rem;
    border-radius: 99px;
    font-size: 10px;
    letter-spacing: 0.05em;
  }
  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: breathing-pulse 2s infinite ease-in-out;
  }
  .pill-label {
    color: var(--accent);
    font-weight: 700;
  }

  @keyframes breathing-pulse {
    0% { transform: scale(0.9); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 8px var(--accent); }
    100% { transform: scale(0.9); opacity: 0.5; }
  }

  /* --- Wizard Navigation Styles --- */
  .wizard-progress-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(20, 24, 21, 0.6);
    border-bottom: 1px solid var(--surface-line);
    padding: 0.75rem 2rem;
    gap: 1.5rem;
    font-family: var(--font-mono);
  }
  .wizard-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink-tertiary);
    font-size: 11px;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    cursor: pointer;
  }
  .wizard-step.active-step {
    color: var(--accent);
    text-shadow: 0 0 8px var(--accent-glow);
    font-weight: 700;
  }
  .step-num {
    background: var(--surface-line);
    color: var(--ink-secondary);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    font-size: 9px;
    font-weight: bold;
    transition: all 0.3s;
  }
  .active-step .step-num {
    background: var(--accent);
    color: var(--surface-base);
    box-shadow: 0 0 10px var(--accent-glow);
  }
  .wizard-connector {
    width: 60px;
    height: 1px;
    background: var(--surface-line);
  }
  
  .wizard-view-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    animation: fade-in 0.4s var(--ease-instrument);
  }
  .hidden-view {
    display: none !important;
  }
  
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- Premium Setup Wizard Centered Card UI --- */
  .centered-wizard-layout {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2.5rem 1.5rem;
    background: radial-gradient(circle at center, #1b261e 0%, #0f1311 100%);
    min-height: calc(100vh - 106px);
    overflow-y: auto;
  }
  .glass-wizard-card {
    width: 100%;
    max-width: 1120px;
    background: rgba(20, 26, 22, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), 0 0 40px rgba(125, 211, 160, 0.05);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .wizard-header-block {
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding-bottom: 1.25rem;
  }
  .wizard-main-title {
    font-family: var(--font-mono);
    font-size: 20px;
    letter-spacing: 0.15em;
    font-weight: 800;
    background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.4rem;
  }
  .wizard-subtitle {
    font-size: 11px;
    color: var(--ink-tertiary);
    letter-spacing: 0.02em;
    margin: 0;
  }
  .wizard-setup-grid {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 2rem;
  }
  @media (max-width: 960px) {
    .wizard-setup-grid {
      grid-template-columns: 1fr;
    }
  }
  .wizard-settings-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .wizard-section-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    padding: 1.25rem;
  }
  .section-card-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-secondary);
    margin-top: 0;
    margin-bottom: 0.8rem;
    font-weight: bold;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.04);
    padding-bottom: 0.4rem;
  }
  .format-toggle-group {
    display: flex;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 0.25rem;
    gap: 0.25rem;
  }
  .format-btn {
    flex: 1;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: var(--ink-tertiary);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: bold;
    padding: 0.5rem 0;
    cursor: pointer;
    transition: all 0.2s;
  }
  .format-btn:hover {
    color: #fff;
  }
  .format-btn.active {
    background: var(--accent);
    color: var(--surface-base);
    box-shadow: 0 0 10px var(--accent-glow);
  }
  .strategy-cards-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .strategy-card {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
    padding: 0.75rem 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .strategy-card:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(125, 211, 160, 0.3);
  }
  .strategy-card.active {
    border-color: var(--accent);
    background: rgba(125, 211, 160, 0.05);
    box-shadow: 0 0 12px rgba(125, 211, 160, 0.1);
  }
  .strat-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .strat-icon {
    font-size: 13px;
  }
  .strat-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: bold;
    color: #fff;
  }
  .strat-desc {
    font-size: 9px;
    color: var(--ink-tertiary);
    margin: 0;
    line-height: 1.3;
  }
  .wizard-text-input {
    width: 100%;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    color: #fff;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 11px;
    outline: none;
    transition: border-color 0.2s;
  }
  .wizard-text-input:focus {
    border-color: var(--accent);
  }
  .team-inputs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .input-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .input-wrap label {
    font-family: var(--font-mono);
    font-size: 8px;
    color: var(--ink-tertiary);
    font-weight: bold;
  }
  .wizard-roster-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .roster-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .roster-quick-actions {
    display: flex;
    gap: 0.8rem;
  }
  .btn-text-only {
    background: none;
    border: none;
    color: var(--ink-tertiary);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
  }
  .btn-text-only:hover {
    color: var(--accent);
  }
  .wizard-bulk-box {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
    padding: 0.8rem;
  }
  .wizard-bulk-box.hidden {
    display: none;
  }
  .bulk-info {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-tertiary);
    margin-top: 0;
    margin-bottom: 0.4rem;
  }
  .wizard-bulk-box textarea {
    width: 100%;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 0.4rem;
    resize: none;
    outline: none;
  }
  .wizard-roster-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    max-height: 520px;
    overflow-y: auto;
    padding-right: 0.5rem;
  }
  @media (max-width: 768px) {
    .wizard-roster-grid {
      grid-template-columns: 1fr;
    }
  }
  .player-config-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    transition: all 0.2s ease;
  }
  .player-config-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(125, 211, 160, 0.3);
  }
  .player-config-card.is-benched {
    opacity: 0.6;
    border-color: rgba(255, 255, 255, 0.02);
  }
  .card-index-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--accent);
    opacity: 0.6;
    font-weight: 700;
  }
  .card-player-name {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: #fff;
    padding: 0.3rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    outline: none;
    transition: all 0.2s;
  }
  .card-player-name:focus {
    border-color: var(--accent);
    background: rgba(0, 0, 0, 0.4);
  }
  .card-role-selector {
    display: flex;
    gap: 0.3rem;
  }
  .role-btn {
    flex: 1;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: var(--ink-secondary);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    padding: 0.3rem 0;
    cursor: pointer;
    transition: all 0.2s;
  }
  .role-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }
  .role-btn.active[data-role="fielder"] {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
    color: #fff;
  }
  .role-btn.active[data-role="wk"] {
    background: rgba(241, 196, 15, 0.20);
    border-color: #f1c40f;
    color: #f1c40f;
  }
  .role-btn.active[data-role="bowler"] {
    background: rgba(231, 76, 60, 0.20);
    border-color: #e74c3c;
    color: #e74c3c;
  }
  .role-btn.active[data-role="bench"] {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--ink-tertiary);
    color: var(--ink-tertiary);
  }
  .wizard-footer-action {
    display: flex;
    justify-content: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1.5rem;
  }
  .generate-board-cta {
    background: var(--accent);
    color: var(--surface-base);
    border: none;
    border-radius: 6px;
    padding: 1rem 3.5rem;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 0.08em;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(125, 211, 160, 0.4);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .generate-board-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(125, 211, 160, 0.7);
  }
  .glowing-pulse-arrow {
    animation: arrow-blink 1.2s infinite;
  }
  @keyframes arrow-blink {
    0% { opacity: 0.4; }
    50% { opacity: 1; }
    100% { opacity: 0.4; }
  }

  /* --- Main Columns Grid Layout (Step 2) --- */
  .tactical-board-grid {
    flex: 1;
    display: grid;
    border-top: none;
    overflow: hidden;
  }
  
  .step-2-grid {
    grid-template-columns: 460px 1fr;
    max-height: calc(100vh - 106px);
  }

  /* --- Left Column: Roster & Command Dashboard --- */
  .command-dashboard {
    background: var(--surface-base);
    border-right: 1px solid var(--surface-line);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    overflow-y: auto;
    height: 100%;
  }

  .dashboard-card {
    background: var(--surface-raised);
    border: 1px solid var(--surface-line);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .card-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--ink-secondary);
    margin: 0 0 1rem 0;
    border-bottom: 1px solid var(--surface-line);
    padding-bottom: 0.5rem;
    font-weight: 700;
  }

  /* Setup Settings Dials */
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .metric-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .metric-group label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--ink-tertiary);
    font-weight: bold;
  }
  .minimal-select {
    background: var(--surface-base);
    border: 1px solid var(--surface-line);
    border-radius: 4px;
    color: var(--ink-primary);
    padding: 0.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    outline: none;
    transition: border-color 0.2s;
  }
  .minimal-select:focus {
    border-color: var(--accent);
  }

  .telemetry-toggle-btn {
    background: var(--surface-base);
    border: 1px solid var(--surface-line);
    border-radius: 4px;
    color: var(--ink-secondary);
    padding: 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    transition: all 0.2s;
    height: 100%;
    min-height: 31px;
  }
  .telemetry-toggle-btn:hover {
    border-color: var(--ink-secondary);
  }
  
  /* Active states for Powerplay & Batter Handedness */
  .telemetry-toggle-btn.active-state {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(125, 211, 160, 0.05);
  }
  .toggle-indicator {
    width: 6px;
    height: 6px;
    background: var(--ink-tertiary);
    border-radius: 50%;
    transition: all 0.2s;
  }
  .active-state .toggle-indicator {
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }
  
  .handedness-badge {
    background: var(--surface-line);
    color: var(--ink-secondary);
    padding: 0.15rem 0.3rem;
    border-radius: 2px;
    font-size: 9px;
    font-weight: bold;
    transition: all 0.2s;
  }
  .active-state .handedness-badge {
    background: var(--accent);
    color: var(--surface-base);
  }

  .squad-counter {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--accent);
    font-weight: bold;
  }

  /* Compact roster view and rows */
  .roster-list-wrapper {
    flex: 1;
    overflow-y: auto;
    border: 1px solid var(--surface-line);
    border-radius: 4px;
    background: var(--surface-base);
  }
  .roster-flex-list {
    display: flex;
    flex-direction: column;
    padding: 0.25rem;
  }
  
  .roster-flex-item {
    display: flex;
    padding: 0.5rem 0.6rem;
    border: 1px solid transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: background 0.2s, border-color 0.2s;
    cursor: pointer;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
  .roster-flex-item:hover {
    background: rgba(255, 255, 255, 0.02);
  }
  .roster-flex-item.item-selected {
    background: rgba(125, 211, 160, 0.12) !important;
    border-color: var(--accent) !important;
    box-shadow: 0 0 10px rgba(125, 211, 160, 0.15);
  }
  .roster-flex-item.item-benched {
    background: rgba(18, 15, 13, 0.4);
    opacity: 0.7;
  }

  .roster-index {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-tertiary);
    font-weight: bold;
    min-width: 14px;
  }

  .position-telemetry-badge {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.02em;
    color: var(--accent);
    background: rgba(125, 211, 160, 0.06);
    border: 1px solid var(--accent-dim);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    font-weight: 700;
    transition: all 0.2s;
  }
  .item-benched .position-telemetry-badge {
    color: var(--ink-tertiary);
    background: transparent;
    border-color: var(--surface-line);
  }

  /* HUD Diagnostic Console */
  .terminal-card {
    height: 140px;
  }
  .terminal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .terminal-clear-btn {
    background: none;
    border: none;
    color: var(--ink-tertiary);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.05em;
    cursor: pointer;
    font-weight: bold;
  }
  .terminal-clear-btn:hover {
    color: var(--ink-secondary);
  }
  .terminal-log-output {
    background: var(--surface-base);
    border: 1px solid var(--surface-line);
    border-radius: 4px;
    flex: 1;
    padding: 0.6rem;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
    overflow-y: auto;
  }
  .log-line {
    margin-bottom: 0.25rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.02);
    padding-bottom: 0.15rem;
  }
  .text-green { color: var(--accent); }
  .text-amber { color: var(--status-warn); }
  .text-red { color: #f28b82; }

  .compact-roster-card {
    flex: 1;
    min-height: 200px;
  }
  .compact-tip {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--ink-tertiary);
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }
  .compact-list-wrapper {
    max-height: calc(100vh - 540px) !important;
  }
  .compact-terminal-card {
    height: 120px;
  }

  /* --- Right Column: The Grass Field Viewport --- */
  .fielding-sandbox {
    background: #0f1c11; /* Deep forest grass */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 1.5rem;
    height: 100%;
  }

  /* Rules violation alert banner */
  .rules-alert-banner {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: #b33939; /* Alert red */
    color: #ffffff;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    z-index: 50;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4), 0 0 15px rgba(179, 57, 57, 0.4);
    border-left: 4px solid #ff5252;
    transition: transform 0.3s var(--ease-instrument), opacity 0.3s;
    pointer-events: none;
  }
  .rules-alert-banner.hidden-banner {
    transform: translate(-50%, -40px);
    opacity: 0;
  }
  .alert-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Selection banner overlay */
  .selection-banner-overlay {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(18, 15, 13, 0.95);
    border: 1px solid var(--accent);
    color: var(--ink-primary);
    padding: 0.6rem 1.5rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    z-index: 60;
    box-shadow: 0 4px 25px rgba(0, 0, 0, 0.6), 0 0 15px rgba(125, 211, 160, 0.25);
    border-left: 4px solid var(--accent);
    transition: transform 0.3s var(--ease-instrument), opacity 0.3s;
    pointer-events: auto;
  }
  .selection-banner-overlay.hidden-banner {
    transform: translate(-50%, -40px);
    opacity: 0;
    pointer-events: none;
  }
  .selection-banner-content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .selection-icon {
    font-size: 13px;
    animation: breathing-pulse 2s infinite ease-in-out;
  }
  .cancel-selection-pill {
    background: rgba(231, 76, 60, 0.15);
    border: 1px solid #c0392b;
    color: #e74c3c;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: bold;
    transition: all 0.15s;
  }
  .cancel-selection-pill:hover {
    background: #e74c3c;
    color: #ffffff;
    box-shadow: 0 0 8px rgba(231, 76, 60, 0.4);
  }

  .field-outer-wrapper {
    width: 100%;
    max-width: 620px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field-aspect-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  /* The turf field */
  .cricket-turf-field {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 
      0 10px 40px rgba(0,0,0,0.5), 
      inset 0 0 30px rgba(0,0,0,0.3);
    overflow: visible;
  }

  .svg-field-markings {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    border-radius: 50%;
  }

  /* --- Interactive Player Tokens --- */
  .tokens-layer-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .player-token {
    position: absolute;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: #120f0d;
    cursor: grab;
    pointer-events: auto;
    user-select: none;
    touch-action: none;
    transform: translate(-50%, -50%);
    box-shadow: 0 4px 10px rgba(0,0,0,0.4);
    transition: left 0.5s ease-out, top 0.5s ease-out, border-color 0.2s, box-shadow 0.2s;
  }
  .player-token:hover {
    box-shadow: 0 6px 15px rgba(0,0,0,0.6);
  }
  .player-token:active {
    cursor: grabbing;
  }

  /* Draggable state overrides transitions */
  .player-token.dragging {
    transition: none !important;
    cursor: grabbing;
    z-index: 1000 !important;
    opacity: 0.9;
    box-shadow: 0 10px 25px rgba(0,0,0,0.7), 0 0 12px rgba(255,255,255,0.2) !important;
  }

  /* Snapped visual highlight */
  .player-token.snapped-crease {
    border-color: #ffd700 !important;
  }

  /* Selected visual highlight */
  .player-token.token-selected {
    border-color: var(--accent) !important;
    box-shadow: 0 0 15px var(--accent), 0 0 5px var(--accent) !important;
    z-index: 1000 !important;
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Role specific styles */
  .role-wk {
    background: #f1c40f; /* Gold */
    border: 2.5px solid #d4ac0d;
    color: #1a1714;
    z-index: 200;
  }
  .role-wk:hover {
    box-shadow: 0 0 8px rgba(241, 196, 15, 0.5);
  }
  
  .role-bowler {
    background: #e74c3c; /* Crimson */
    border: 2.5px solid #c0392b;
    color: #ffffff;
    z-index: 200;
  }
  .role-bowler:hover {
    box-shadow: 0 0 8px rgba(231, 76, 60, 0.5);
  }

  .role-fielder {
    background: #f4ede4; /* Warm white */
    border: 2.5px solid #a89c8b;
    color: #1a1714;
    z-index: 100;
  }
  .role-fielder:hover {
    box-shadow: 0 0 8px rgba(244, 238, 228, 0.5);
    border-color: var(--accent);
  }
  
  /* Pulser animation for illegal positions */
  .player-token.pp-illegal-position {
    animation: token-error-flicker 1.5s infinite alternate ease-in-out;
    border-color: #e74c3c !important;
  }
  @keyframes token-error-flicker {
    0% { box-shadow: 0 0 5px #e74c3c; }
    100% { box-shadow: 0 0 15px #ff6b6b, inset 0 0 5px #ff6b6b; }
  }

  /* --- Premium Glassmorphic Tooltip --- */
  .fielder-tooltip {
    position: absolute;
    transform: translate(-50%, -100%) translateY(-12px);
    background: rgba(18, 15, 13, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 15px rgba(125, 211, 160, 0.1);
    color: var(--ink-primary);
    font-family: var(--font-mono);
    pointer-events: none;
    z-index: 2100;
    transition: opacity 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 140px;
  }
  .fielder-tooltip.hidden {
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, -100%) translateY(0);
  }
  .tooltip-name {
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
  }
  .tooltip-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tooltip-role {
    font-size: 8px;
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-weight: bold;
    text-transform: uppercase;
  }
  .role-badge-fielder {
    background: rgba(255, 255, 255, 0.1);
    color: #ccc;
  }
  .role-badge-wk {
    background: rgba(241, 196, 15, 0.2);
    color: #f1c40f;
  }
  .role-badge-bowler {
    background: rgba(231, 76, 60, 0.2);
    color: #e74c3c;
  }
  .tooltip-position {
    font-size: 9px;
    color: var(--ink-secondary);
  }

  /* --- HUD Control Bar --- */
  .field-controls-hud {
    background: var(--surface-raised);
    border: 1px solid var(--surface-line);
    border-radius: 8px;
    padding: 0.8rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-secondary);
  }
  
  .hud-action-btn {
    background: var(--surface-base);
    border: 1px solid var(--surface-line);
    color: var(--ink-primary);
    border-radius: 4px;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.2s;
  }
  .hud-action-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .hud-legend {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 9px;
    letter-spacing: 0.05em;
  }
  .legend-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .color-wk { background: #f1c40f; }
  .color-bowler { background: #e74c3c; }
  .color-fielder { background: #f4ede4; border: 1px solid #a89c8b; }

  .circle-telemetry {
    font-weight: 700;
  }
  .mono-value {
    color: var(--ink-primary);
    font-size: 11px;
  }
  #outside-circle-count.count-warn {
    color: #f28b82;
    animation: text-pulse 1s infinite alternate;
  }
  @keyframes text-pulse {
    0% { opacity: 0.7; }
    100% { opacity: 1; text-shadow: 0 0 4px #ff6b6b; }
  }

  /* --- Responsive Styles Stack --- */
  @media (max-width: 1080px) {
    .step-2-grid {
      grid-template-columns: 1fr !important;
      max-height: none;
      overflow-y: auto;
    }
    .command-dashboard {
      border-right: none;
      border-bottom: 1px solid var(--surface-line);
      height: auto;
    }
    .fielding-sandbox {
      padding: 3rem 1.5rem;
      height: auto;
    }
  }

  @media (max-width: 600px) {
    .paddock-override-nav {
      padding: 1rem;
    }
    .wizard-progress-bar {
      flex-direction: column;
      gap: 0.5rem;
    }
    .wizard-connector {
      display: none;
    }
    .metrics-grid {
      grid-template-columns: 1fr;
    }
    .field-controls-hud {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
    .hud-legend {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  /* Preset position slots layers */
  .slots-layer-container {
    position: absolute;
    inset: 0;
    pointer-events: auto;
  }

  /* Upgraded unoccupied slots: Glowing ruby-red dots with breathing pulse */
  .position-slot {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ff2d55;
    border: 1px solid rgba(255, 255, 255, 0.4);
    transform: translate(-50%, -50%);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10;
    box-shadow: 0 0 8px rgba(255, 45, 85, 0.8);
    /* Flex centering for label text inside slot */
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono), monospace;
    font-weight: 700;
    text-align: center;
    /* Hide the abbreviation text by default */
    font-size: 0px;
    color: transparent;
    overflow: visible;
  }

  /* Empty slot pulse ring */
  .position-slot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgba(255, 45, 85, 0.4);
    transform: translate(-50%, -50%);
    animation: slot-ring-pulse 2s infinite ease-in-out;
    pointer-events: none;
  }
  @keyframes slot-ring-pulse {
    0% { width: 100%; height: 100%; opacity: 1; }
    100% { width: 300%; height: 300%; opacity: 0; }
  }

  /* Empty slot hover behavior */
  .position-slot:not(.slot-occupied):hover {
    width: 32px;
    height: 32px;
    font-size: 9px;
    color: #ff2d55;
    border: 1.5px solid #ff2d55;
    background: rgba(255, 45, 85, 0.25);
    box-shadow: 0 0 18px rgba(255, 45, 85, 0.7), inset 0 0 6px rgba(255, 45, 85, 0.4);
    z-index: 500;
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Tactical Mode: When a player is selected */
  .cricket-turf-field.has-selection .position-slot:not(.slot-occupied) {
    width: 28px;
    height: 28px;
    font-size: 9px;
    color: #ff2d55;
    border: 1.5px dashed #ff2d55;
    background: rgba(255, 45, 85, 0.12);
    box-shadow: 0 0 10px rgba(255, 45, 85, 0.4);
    z-index: 200;
    animation: slot-pulse-red 1.8s infinite ease-in-out;
  }

  /* Hovering expanded slot in tactical mode */
  .cricket-turf-field.has-selection .position-slot:not(.slot-occupied):hover {
    width: 32px;
    height: 32px;
    border-style: solid;
    background: rgba(255, 45, 85, 0.25);
    box-shadow: 0 0 18px rgba(255, 45, 85, 0.8), inset 0 0 6px rgba(255, 45, 85, 0.4);
    z-index: 500;
    animation: none;
    transform: translate(-50%, -50%) scale(1.15);
  }

  /* Swap target highlighting */
  .cricket-turf-field.has-selection .player-token:not(.token-selected) {
    border: 2.5px solid var(--status-warn) !important;
    box-shadow: 0 0 15px rgba(243, 156, 18, 0.7), 0 2px 5px rgba(0,0,0,0.5) !important;
  }
  .cricket-turf-field.has-selection .player-token:not(.token-selected):hover {
    transform: translate(-50%, -50%) scale(1.15) !important;
    box-shadow: 0 0 22px rgba(243, 156, 18, 0.9), 0 4px 10px rgba(0,0,0,0.6) !important;
  }

  @keyframes slot-pulse-red {
    0% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.8; }
    50% { transform: translate(-50%, -50%) scale(1.05); opacity: 1; box-shadow: 0 0 14px rgba(255, 45, 85, 0.6); }
    100% { transform: translate(-50%, -50%) scale(0.95); opacity: 0.8; }
  }

  /* Occupied slot state */
  .position-slot.slot-occupied {
    opacity: 0 !important;
    pointer-events: none;
  }

  /* Active assignment glowing state */
  .position-slot.slot-active-assign {
    width: 34px !important;
    height: 34px !important;
    font-size: 10px !important;
    font-weight: 800 !important;
    color: #ffffff !important;
    background: #ff2d55 !important;
    border: 2px solid #ffffff !important;
    box-shadow: 0 0 20px #ff2d55, 0 0 40px rgba(255, 45, 85, 0.6), inset 0 0 8px rgba(255, 255, 255, 0.8) !important;
    z-index: 600 !important;
    transform: translate(-50%, -50%) scale(1.1) !important;
    animation: active-slot-glow 1.5s infinite alternate ease-in-out !important;
  }

  @keyframes active-slot-glow {
    0% {
      box-shadow: 0 0 15px #ff2d55, 0 0 30px rgba(255, 45, 85, 0.5), inset 0 0 4px rgba(255, 255, 255, 0.6);
      transform: translate(-50%, -50%) scale(1.05);
    }
    100% {
      box-shadow: 0 0 25px #ff2d55, 0 0 50px rgba(255, 45, 85, 0.8), inset 0 0 10px rgba(255, 255, 255, 1);
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  /* --- Bench Dugout UI --- */
  .bench-dugout-card {
    background: var(--surface-raised);
    border: 1px solid var(--surface-line);
    border-radius: 8px;
    padding: 0.8rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bench-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--ink-secondary);
    letter-spacing: 0.05em;
  }
  .pulse-dot-amber {
    width: 6px;
    height: 6px;
    background: var(--status-warn);
    border-radius: 50%;
    animation: breathing-pulse-amber 2s infinite ease-in-out;
  }
  @keyframes breathing-pulse-amber {
    0% { transform: scale(0.9); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 8px var(--status-warn); }
    100% { transform: scale(0.9); opacity: 0.5; }
  }
  .bench-tokens-flex {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
    min-height: 44px;
    padding: 0.4rem;
    background: var(--surface-base);
    border: 1px dashed var(--surface-line);
    border-radius: 4px;
  }
  
  .bench-player-token {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    background: rgba(25, 28, 26, 0.6);
    border: 2px solid var(--surface-line);
    color: var(--ink-secondary);
    cursor: pointer;
    transition: all 0.2s ease-out;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    position: relative;
    user-select: none;
  }
  .bench-player-token:hover {
    border-color: var(--ink-secondary);
    color: var(--ink-primary);
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
  }
  .bench-player-token.token-selected {
    border-color: var(--accent) !important;
    color: var(--ink-primary) !important;
    background: rgba(125, 211, 160, 0.12) !important;
    box-shadow: 0 0 12px var(--accent), 0 0 4px var(--accent) !important;
    transform: scale(1.1);
  }
  .bench-player-token::after {
    content: attr(data-player-name);
    position: absolute;
    bottom: -22px;
    left: 50%;
    transform: translateX(-50%) scale(0.85);
    background: rgba(18, 15, 13, 0.95);
    border: 1px solid var(--surface-line);
    color: var(--ink-primary);
    font-family: var(--font-mono);
    font-size: 8px;
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.15s ease-out;
    pointer-events: none;
    z-index: 1010;
  }
  .bench-player-token:hover::after {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scale(1);
  }

  /* Floating assignment popup */
  .floating-assign-menu {
    position: absolute;
    background: rgba(18, 15, 13, 0.96);
    border: 1px solid var(--accent-dim);
    border-radius: 6px;
    padding: 0.5rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7), 0 0 15px rgba(125, 211, 160, 0.15);
    z-index: 2000;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 140px;
    font-family: var(--font-mono);
    font-size: 10px;
    max-height: 200px;
    overflow-y: auto;
  }
  .floating-assign-menu.hidden-menu {
    display: none;
  }
  .assign-menu-title {
    font-size: 9px;
    color: var(--ink-tertiary);
    border-bottom: 1px solid var(--surface-line);
    padding: 0.25rem 0.5rem;
    margin-bottom: 0.25rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .assign-menu-item {
    padding: 0.35rem 0.5rem;
    border-radius: 3px;
    color: var(--ink-secondary);
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    width: 100%;
  }
  .assign-menu-item:hover {
    background: var(--accent);
    color: var(--surface-base);
  }

  /* --- Timeline Footer Range Slider --- */
  .playbook-master-timeline {
    max-width: 1300px;
    margin: 2rem auto 1rem;
    width: 100%;
    padding: 0 1rem;
  }
  @media (max-width: 1024px) {
    .playbook-master-timeline {
      padding: 0 0.5rem;
    }
  }

  .timeline-slider-card {
    background: var(--surface-raised);
    border: 1px solid var(--surface-line);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .timeline-card-title {
    font-family: var(--font-mono), monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--ink-tertiary);
    letter-spacing: 0.15em;
    margin: 0;
    text-transform: uppercase;
  }

  .timeline-step-labels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    text-align: center;
    position: relative;
  }
  .timeline-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink-tertiary);
    cursor: pointer;
    transition: all 0.3s;
  }
  .timeline-label.active {
    color: var(--accent);
  }
  
  .step-dot {
    width: 8px;
    height: 8px;
    background: var(--surface-line);
    border-radius: 50%;
    border: 2px solid var(--surface-raised);
    transition: all 0.3s;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.1);
  }
  .timeline-label.active .step-dot {
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    transform: scale(1.3);
  }
  .step-title {
    font-family: var(--font-mono), monospace;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 0.05em;
  }

  .timeline-range-container {
    position: relative;
    width: 100%;
    margin-top: -0.85rem;
    padding: 0 12%; /* Perfect spacing align with dots */
    z-index: 10;
  }
  @media (max-width: 600px) {
    .timeline-range-container {
      padding: 0 8%;
    }
  }

  /* Range input customization */
  .timeline-slider-element {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: var(--surface-line);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  .timeline-slider-element::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent);
    border: 4px solid var(--surface-raised);
    box-shadow: 0 0 10px rgba(125, 211, 160, 0.8);
    transition: transform 0.1s;
  }
  .timeline-slider-element::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }
  .timeline-slider-element::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 4px solid var(--surface-raised);
    box-shadow: 0 0 10px rgba(125, 211, 160, 0.8);
  }

  /* ═══════════════════════════════════════════════════════════════
     VISUAL OVERHAUL — better contrast, lighter feel, readability
  ═══════════════════════════════════════════════════════════════ */

