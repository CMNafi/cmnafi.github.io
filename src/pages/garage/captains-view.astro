      if (!teamName || !gameName) {
        addLog(`[SAVE ERROR] Both Team Name and Game/Opponent fields must be filled.`, 'red');
        return;
      }
      
      const now = new Date();
      const timestamp = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')} ${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
      
      const newStrategy = {
        id: `strat-${Date.now()}`,
        teamName,
        gameName,
        timestamp,
        format: state.matchContext.format,
        isPowerplay: state.matchContext.isPowerplay,
        batterHandedness: state.matchContext.batterHandedness,
        currentBowlerId: state.matchContext.currentBowlerId,
        squad: JSON.parse(JSON.stringify(state.squad))
      };
      
      let strats = [];
      try {
        const raw = localStorage.getItem('captains_view_saved_strategies');
        if (raw) {
          strats = JSON.parse(raw);
        }
      } catch (err) {}
      
      strats.push(newStrategy);
      
      try {
        localStorage.setItem('captains_view_saved_strategies', JSON.stringify(strats));
        addLog(`[STORAGE] Saved strategy "${teamName} vs ${gameName}" successfully.`, 'green');
        loadSavedStrategiesList();
        elSavedStrategiesSelect.value = newStrategy.id;
      } catch (err) {
        addLog(`[SAVE ERROR] Failed to save strategy: ${err.message}`, 'red');
      }
