    const elWizardClearNames = document.getElementById('wizard-clear-names');
    const elWizardBulkImportToggle = document.getElementById('wizard-bulk-import-toggle');
    const elWizardBulkBox = document.getElementById('wizard-bulk-box');
    const elWizardBulkTextarea = document.getElementById('wizard-bulk-textarea');
    const elWizardApplyBulk = document.getElementById('wizard-apply-bulk');

    // Unified System Log Helper
    function addLog(text, type = 'green') {
      const time = new Date().toLocaleTimeString().split(' ')[0];
      const logLine = document.createElement('div');
      logLine.className = `log-line text-${type}`;
      logLine.innerText = `[${time}] ${text}`;
      
      if (elTerminalConsoleS2) {
        elTerminalConsoleS2.appendChild(logLine);
        elTerminalConsoleS2.scrollTop = elTerminalConsoleS2.scrollHeight;
      }
    }

    // Zero-padded initials helper
    function getInitials(name, index = 0) {
      if (!name) return String(index + 1).padStart(2, '0');
      const parts = name.trim().split(/\s+/);
      if (parts.length === 0 || !parts[0]) return String(index + 1).padStart(2, '0');
      if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
      return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    }

    // Euclidean coordinates distance
    function calcDistance(x, y) {
      return Math.sqrt(Math.pow(x - 50, 2) + Math.pow(y - 50, 2));
    }

    // Coordinates mirror calculation for LHB
    function getSlotCoords(slot) {
      if (!slot) return { x: 50, y: 50 };
      let x = slot.x;
      let y = slot.y;
      if (state.matchContext.batterHandedness === 'LHB') {
        x = 100 - x;
      }
      return { x, y };
    }

    // Find closest slots
    function findClosestSlot(pctX, pctY) {
      let checkX = pctX;
      if (state.matchContext.batterHandedness === 'LHB') {
        checkX = 100 - pctX;
      }
      let closestSlot = null;
      let minDistance = Infinity;

      fieldingPositions.forEach(s => {
        const dist = Math.sqrt(Math.pow(checkX - s.x, 2) + Math.pow(pctY - s.y, 2));
        if (dist < minDistance) {
          minDistance = dist;
          closestSlot = s;
        }
      });
      return closestSlot;
    }

    // Get count of fielders outside the circle
    function getOutsideCount() {
      return state.squad.filter(p => {
        if (p.status !== 'active' || !p.positionId) return false;
        const slot = fieldingPositions.find(s => s.id === p.positionId);
        if (!slot) return false;
        return calcDistance(slot.x, slot.y) > RADIUS_30YD;
      }).length;
    }

    function getMaxAllowedOutside() {
      if (state.matchContext.isPowerplay) return 2;
      return 5;
    }

    function updatePlayerRoleFromPosition(player) {
      if (player.positionId === 'wk') {
        player.role = 'WK';
      } else if (player.positionId === 'bowler') {
        player.role = 'Bowler';
        state.matchContext.currentBowlerId = player.id;
      } else {
        player.role = 'Fielder';
      }
    }

    function getFieldPositionName(player) {
      if (player.status === 'benched') return '12th Man';
      const slot = fieldingPositions.find(s => s.id === player.positionId);
      return slot ? slot.name : 'Unassigned';
    }

    function showSelectionBanner(name, role) {
      if (elSelectionBannerMessage && elSelectionStatusBanner && elFieldBounds) {
        elSelectionBannerMessage.innerText = `PLACING: ${name} (${role}). Tap any position on the turf to drop.`;
        elSelectionStatusBanner.classList.remove('hidden-banner');
        elFieldBounds.classList.add('has-selection');
      }
    }

    function hideSelectionBanner() {
      if (elSelectionStatusBanner && elFieldBounds) {
        elSelectionStatusBanner.classList.add('hidden-banner');
        elFieldBounds.classList.remove('has-selection');
      }
    }

    function togglePlayerSelection(playerId) {
      if (state.selectedPlayerId === playerId) {
        state.selectedPlayerId = null;
        hideSelectionBanner();
        addLog(`Deselected player.`);
      } else {
        const player = state.squad.find(p => p.id === playerId);
        state.selectedPlayerId = playerId;
        showSelectionBanner(player.name, player.role);
        addLog(`Selected ${player.name || ('Player ' + (state.squad.indexOf(player) + 1))}. Click any slot (glowing red dot) or player on the field to place/swap them.`, 'green');
      }
      renderApp();
    }

    // premium glassmorphic tooltips helpers
    function showTooltip(player, tokenEl) {
      if (!elTooltip || !elFieldBounds) return;
      const slot = fieldingPositions.find(s => s.id === player.positionId);
      const positionName = slot ? slot.name : 'Unknown';
      
      let roleBadgeClass = 'role-badge-fielder';
      if (player.role === 'WK') roleBadgeClass = 'role-badge-wk';
      else if (player.id === state.matchContext.currentBowlerId) roleBadgeClass = 'role-badge-bowler';
      
      elTooltip.innerHTML = `
        <div class="tooltip-name">${player.name || 'Player'}</div>
        <div class="tooltip-meta">
          <span class="tooltip-role ${roleBadgeClass}">${player.role}</span>
          <span class="tooltip-position">${positionName}</span>
        </div>
      `;
      
      const tokenRect = tokenEl.getBoundingClientRect();
      const fieldRect = elFieldBounds.getBoundingClientRect();
      
      // Calculate relative percentage positions inside the field bounds
      const relativeLeft = ((tokenRect.left + tokenRect.width / 2 - fieldRect.left) / fieldRect.width) * 100;
      const relativeTop = ((tokenRect.top - fieldRect.top) / fieldRect.height) * 100;
      
      elTooltip.style.left = `${relativeLeft}%`;
      elTooltip.style.top = `${relativeTop}%`;
      
      elTooltip.classList.remove('hidden');
    }

    function hideTooltip() {
      if (elTooltip) {
        elTooltip.classList.add('hidden');
      }
    }

    // Step 1 Roster Setup Cards dynamic renderer
    function renderRosterSetupWizard() {
      if (!elWizardRosterContainer) return;
      elWizardRosterContainer.innerHTML = '';

      state.squad.forEach((player, index) => {
        const card = document.createElement('div');
        const isBenched = player.status === 'benched';
        card.className = `player-config-card ${isBenched ? 'is-benched' : ''}`;
        card.dataset.playerId = player.id;

        // Index Label
        const idxLabel = document.createElement('div');
        idxLabel.className = 'card-index-label';
        idxLabel.innerText = `PLAYER ${String(index + 1).padStart(2, '0')}`;
        card.appendChild(idxLabel);

        // Name input textbox
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'card-player-name';
        input.value = player.name;
        input.placeholder = `Player ${index + 1}`;
        input.addEventListener('change', (e) => {
          const oldName = player.name;
          player.name = e.target.value.trim();
          addLog(`Rename roster slot ${index+1}: ${oldName || '[Empty]'} is now ${player.name}`);
        });
        card.appendChild(input);

        // Interactive role button toggles selector
        const selector = document.createElement('div');
        selector.className = 'card-role-selector';

        const roles = [
          { id: 'fielder', label: 'FLD', tooltip: 'Fielder' },
          { id: 'wk', label: 'WK', tooltip: 'Wicket Keeper' },
          { id: 'bowler', label: 'BWL', tooltip: 'Bowler' },
          { id: 'bench', label: 'BNC', tooltip: 'Bench / 12th Man' }
        ];

        roles.forEach(r => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'role-btn';
          btn.innerText = r.label;
          btn.title = r.tooltip;

          let isActive = false;
          if (r.id === 'bench' && player.status === 'benched') {
            isActive = true;
          } else if (player.status === 'active') {
            if (r.id === 'wk' && player.role === 'WK') isActive = true;
            else if (r.id === 'bowler' && player.role === 'Bowler') isActive = true;
            else if (r.id === 'fielder' && player.role === 'Fielder') isActive = true;
          }

          if (isActive) {
            btn.classList.add('active');
            if (r.id === 'wk') btn.classList.add('role-wk');
            if (r.id === 'bowler') btn.classList.add('role-bowler');
            if (r.id === 'bench') btn.classList.add('role-bench');
          }

          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleRoleToggle(player, r.id);
          });

          selector.appendChild(btn);
        });

        card.appendChild(selector);
        elWizardRosterContainer.appendChild(card);
      });
    }

    // Role Toggling guidelines self-healing routine
    function handleRoleToggle(player, roleId) {
      const idx = state.squad.indexOf(player);

      if (roleId === 'bench') {
        if (player.status !== 'benched') {
          // Revert previous benched player to Fielder status
          const prevBenched = state.squad.find(p => p.status === 'benched');
          if (prevBenched) {
            prevBenched.status = 'active';
            prevBenched.role = 'Fielder';
            addLog(`[ROSTER] Subbed in "${prevBenched.name || 'Player'}" from dugout bench.`, 'green');
          }
          player.status = 'benched';
          player.positionId = null;
          player.role = 'Fielder';
          addLog(`[ROSTER] Subbed out "${player.name || ('Player ' + (idx + 1))}" to dugout bench.`, 'amber');
        }
      } else {
        if (player.status === 'benched') {
          player.status = 'active';
          // Find an active player (preferably Fielder) to bench instead to maintain exactly 11 active
          let toBench = state.squad.find(p => p.status === 'active' && p.role === 'Fielder' && p.id !== player.id);
          if (!toBench) {
            toBench = state.squad.find(p => p.status === 'active' && p.id !== player.id);
          }
          if (toBench) {
            toBench.status = 'benched';
            toBench.positionId = null;
            toBench.role = 'Fielder';
            addLog(`[ROSTER] Auto-benched "${toBench.name || 'Player'}" to maintain 11-man on-field limit.`, 'amber');
          }
        }

        if (roleId === 'wk') {
          // Enforce exactly one WK
          state.squad.forEach(p => {
            if (p.role === 'WK' && p.id !== player.id) {
              p.role = 'Fielder';
            }
          });
          player.role = 'WK';
          addLog(`[ROSTER] Designated "${player.name || ('Player ' + (idx + 1))}" as Wicket Keeper.`, 'green');
        } else if (roleId === 'bowler') {
          player.role = 'Bowler';
          addLog(`[ROSTER] Designated "${player.name || ('Player ' + (idx + 1))}" as Bowler.`, 'green');
        } else {
          player.role = 'Fielder';
          addLog(`[ROSTER] Designated "${player.name || ('Player ' + (idx + 1))}" as Fielder.`, 'green');
        }
      }

      ensureAllActivePlayersHaveSlots();
      renderApp();
    }

    // Step 2 compact tactical list rows renderer
    function renderRosterStep2() {
      if (!elRosterItemsListS2) return;
      elRosterItemsListS2.innerHTML = '';
      
      state.squad.forEach((player, index) => {
        const isSelected = state.selectedPlayerId === player.id;
        const item = document.createElement('div');
        item.className = `roster-flex-item ${player.status === 'benched' ? 'item-benched' : ''} ${isSelected ? 'item-selected' : ''}`;
        
        item.addEventListener('click', () => {
          togglePlayerSelection(player.id);
        });

        // Left elements (Index + Name + Role Badge)
        const leftBox = document.createElement('div');
        leftBox.style.display = 'flex';
        leftBox.style.alignItems = 'center';
        leftBox.style.gap = '0.5rem';
        
        const idxBadge = document.createElement('span');
        idxBadge.className = 'roster-index';
        idxBadge.innerText = String(index + 1).padStart(2, '0');
        leftBox.appendChild(idxBadge);
        
        const nameSpan = document.createElement('span');
        nameSpan.style.fontFamily = 'var(--font-mono)';
        nameSpan.style.fontSize = '10px';
        nameSpan.style.fontWeight = 'bold';
        nameSpan.innerText = player.name || `Player ${index + 1}`;
        leftBox.appendChild(nameSpan);
        
        // Role pill label
        const rolePill = document.createElement('span');
        rolePill.style.fontSize = '8px';
        rolePill.style.padding = '0.1rem 0.3rem';
        rolePill.style.borderRadius = '2px';
        rolePill.style.fontFamily = 'var(--font-mono)';
        rolePill.style.fontWeight = 'bold';
        
        if (player.status === 'benched') {
          rolePill.innerText = 'BENCH';
          rolePill.style.background = '#2a2420';
          rolePill.style.color = 'var(--ink-tertiary)';
        } else if (player.role === 'WK') {
          rolePill.innerText = 'WK';
          rolePill.style.background = '#f1c40f';
          rolePill.style.color = '#1a1714';
        } else if (player.id === state.matchContext.currentBowlerId) {
          rolePill.innerText = 'BOWLER';
          rolePill.style.background = '#e74c3c';
          rolePill.style.color = '#ffffff';
        } else {
          rolePill.innerText = 'FIELDER';
          rolePill.style.background = 'var(--surface-line)';
          rolePill.style.color = 'var(--ink-secondary)';
        }
        leftBox.appendChild(rolePill);
        item.appendChild(leftBox);

        // Position description label badge
        const posBadge = document.createElement('span');
        posBadge.className = 'position-telemetry-badge';
        posBadge.innerText = getFieldPositionName(player).toUpperCase();
        item.appendChild(posBadge);
        
        elRosterItemsListS2.appendChild(item);
      });
    }

    // Coordinate position assign with overlap protection swapping
    function assignPlayerToSlot(player, slotId) {
      const targetSlot = fieldingPositions.find(s => s.id === slotId);
      if (!targetSlot) return false;

      const isOutside = calcDistance(targetSlot.x, targetSlot.y) > RADIUS_30YD;
      const otherOutsideCount = state.squad.filter(p => 
        p.id !== player.id && 
        p.status === 'active' && 
        p.positionId && 
        (() => {
          const s = fieldingPositions.find(pos => pos.id === p.positionId);
          return s ? calcDistance(s.x, s.y) > RADIUS_30YD : false;
        })()
      ).length;

      const newOutsideCount = otherOutsideCount + (isOutside ? 1 : 0);
      const maxLimit = getMaxAllowedOutside();

      if (isOutside && newOutsideCount > maxLimit) {
        const ruleMsg = state.matchContext.isPowerplay 
          ? `Only 2 fielders allowed outside during Powerplay!` 
          : `Only 5 fielders allowed outside during Non-Powerplay!`;
        
        addLog(`[VIOLATION] Cannot place player at ${targetSlot.name}. ${ruleMsg}`, 'red');
        showRulesBanner(`Fielding Rule Violation: ${ruleMsg}`);
        renderApp();
        return false;
      }

      const wasBenched = (player.status === 'benched');

      if (wasBenched) {
        const activeOccupant = state.squad.find(p => p.status === 'active' && p.positionId === slotId);
        if (activeOccupant) {
          activeOccupant.status = 'benched';
          activeOccupant.positionId = null;
          activeOccupant.role = 'Fielder';
          addLog(`[SUB] ${player.name} subbed in at ${targetSlot.name}. ${activeOccupant.name} is now benched.`, 'amber');
        } else {
          const activeCount = state.squad.filter(p => p.status === 'active').length;
          if (activeCount >= 11) {
            let playerToBench = state.squad.find(p => p.status === 'active' && p.role === 'Fielder');
            if (!playerToBench) {
              playerToBench = state.squad.find(p => p.status === 'active' && p.id !== player.id);
            }
            if (playerToBench) {
              playerToBench.status = 'benched';
              playerToBench.positionId = null;
              playerToBench.role = 'Fielder';
              addLog(`[SUB] ${player.name} placed at empty slot ${targetSlot.name}. Active player ${playerToBench.name} is now benched to maintain 11-man roster.`, 'amber');
            }
          } else {
            addLog(`[PLACE] ${player.name} placed at empty slot ${targetSlot.name}.`);
          }
        }
        player.status = 'active';
      }

      const occupant = state.squad.find(p => p.status === 'active' && p.positionId === slotId && p.id !== player.id);
      const oldSlotId = player.positionId;

      if (occupant) {
        occupant.positionId = oldSlotId;
        updatePlayerRoleFromPosition(occupant);
        addLog(`[SWAP] ${player.name} took ${targetSlot.name}. Swapped ${occupant.name} to old slot.`);
      }

      player.positionId = slotId;
      updatePlayerRoleFromPosition(player);
      
      addLog(`Position updated: ${player.name} assigned to ${targetSlot.name}.`);
      hideRulesBanner();
      populateBowlerSelect();
      state.selectedSlotId = null;
      renderApp();
      return true;
    }

    function getFirstEmptySlotId() {
      for (const slot of fieldingPositions) {
        const occupant = state.squad.find(p => p.status === 'active' && p.positionId === slot.id);
        if (!occupant) return slot.id;
      }
      return fieldingPositions[0].id;
    }

    function populateBowlerSelect() {
      const bowlers = state.squad.filter(p => p.status === 'active' && p.role === 'Bowler');
      if (!elBowlerSelect) return;
      elBowlerSelect.innerHTML = '';
      
      if (bowlers.length === 0) {
        const opt = document.createElement('option');
        opt.value = '';
        opt.innerText = 'No active Bowlers';
        elBowlerSelect.appendChild(opt);
        return;
      }

      bowlers.forEach(b => {
        const opt = document.createElement('option');
        opt.value = b.id;
        opt.innerText = b.name;
        if (state.matchContext.currentBowlerId === b.id || bowlers.length === 1) {
          opt.selected = true;
          state.matchContext.currentBowlerId = b.id;
        }
        elBowlerSelect.appendChild(opt);
      });
    }

    // Render upgraded unoccupied positions slots as glowing Red dots
    function renderSlots() {
      if (!elSlotsContainer) return;
      elSlotsContainer.innerHTML = '';
      
      fieldingPositions.forEach(slot => {
        const coords = getSlotCoords(slot);
        
        const slotEl = document.createElement('div');
        slotEl.className = 'position-slot';
        slotEl.style.left = `${coords.x}%`;
        slotEl.style.top = `${coords.y}%`;
        slotEl.dataset.id = slot.id;
        slotEl.title = slot.name;
        slotEl.innerText = slot.abbr;

        const occupant = state.squad.find(p => p.status === 'active' && p.positionId === slot.id);
        if (occupant) {
          slotEl.classList.add('slot-occupied');
        }

        if (state.selectedSlotId === slot.id) {
          slotEl.classList.add('slot-active-assign');
        }

        slotEl.addEventListener('click', (e) => {
          e.stopPropagation();
          if (state.selectedPlayerId) {
            const selectedPlayer = state.squad.find(p => p.id === state.selectedPlayerId);
            if (selectedPlayer) {
              const success = assignPlayerToSlot(selectedPlayer, slot.id);
              if (success) {
                state.selectedPlayerId = null;
                hideSelectionBanner();
              }
            }
          } else if (!occupant) {
            state.selectedSlotId = slot.id;
            showAssignmentMenu(slot, coords.x, coords.y);
            renderApp();
          }
        });

        elSlotsContainer.appendChild(slotEl);
      });
    }

    function showAssignmentMenu(slot, pctX, pctY) {
      if (!elSlotAssignMenu) return;
      elSlotAssignMenu.innerHTML = '';
      elSlotAssignMenu.classList.remove('hidden-menu');

      // Stop propagation on assignment menu clicks so clicking inside the menu doesn't close it
      elSlotAssignMenu.onclick = (e) => {
        e.stopPropagation();
      };

      const title = document.createElement('div');
      title.className = 'assign-menu-title';
      title.innerText = `ASSIGN ${slot.abbr}`;
      elSlotAssignMenu.appendChild(title);

      const candidates = state.squad.filter(p => p.positionId !== slot.id);

      if (candidates.length === 0) {
        const emptyMsg = document.createElement('div');
        emptyMsg.style.padding = '0.35rem 0.6rem';
        emptyMsg.style.color = 'var(--ink-tertiary)';
        emptyMsg.innerText = 'No players available';
        elSlotAssignMenu.appendChild(emptyMsg);
      } else {
        candidates.forEach(p => {
          const btn = document.createElement('button');
          btn.className = 'assign-menu-item';
          
          const displayName = p.name || `Player ${state.squad.indexOf(p) + 1}`;
          const currentPos = getFieldPositionName(p);
          btn.innerText = `${displayName} (${currentPos})`;
          btn.addEventListener('click', () => {
            assignPlayerToSlot(p, slot.id);
            elSlotAssignMenu.classList.add('hidden-menu');
          });
          elSlotAssignMenu.appendChild(btn);
        });
      }

      elSlotAssignMenu.style.left = `${pctX}%`;
      elSlotAssignMenu.style.top = `${pctY + 4}%`;
    }

    const elViewport = document.querySelector('.captains-detail-viewport');
      if (elViewport) {
        elViewport.addEventListener('click', () => {
          let changed = false;
          if (elSlotAssignMenu && !elSlotAssignMenu.classList.contains('hidden-menu')) {
            elSlotAssignMenu.classList.add('hidden-menu');
            changed = true;
          }
          if (state.selectedSlotId !== null) {
            state.selectedSlotId = null;
            changed = true;
          }
          if (changed) {
            renderApp();
          }
        });
      }

    function handleTokenClick(player) {
      if (state.selectedPlayerId) {
        const selectedPlayer = state.squad.find(p => p.id === state.selectedPlayerId);
        if (selectedPlayer) {
          if (selectedPlayer.id === player.id) {
            state.selectedPlayerId = null;
            hideSelectionBanner();
            addLog(`Deselected player.`);
          } else {
            const targetSlotId = player.positionId;
            const success = assignPlayerToSlot(selectedPlayer, targetSlotId);
            if (success) {
              state.selectedPlayerId = null;
              hideSelectionBanner();
            }
          }
        }
      } else {
        state.selectedPlayerId = player.id;
        showSelectionBanner(player.name, player.role);
        addLog(`Selected ${player.name} on the field. Click another slot or player to move/swap them.`, 'green');
      }
      renderApp();
    }

    // Render active players as elegant dots showing initials with hover glass tooltips
    function renderTokens() {
      if (!elTokensContainer) return;
      elTokensContainer.innerHTML = '';

      state.squad.forEach((player, idx) => {
        if (player.status !== 'active' || !player.positionId) return;

        const slot = fieldingPositions.find(s => s.id === player.positionId);
        if (!slot) return;

        const coords = getSlotCoords(slot);

        const token = document.createElement('div');
        token.className = 'player-token';
        token.dataset.id = player.id;
        token.dataset.playerName = player.name || `Player ${idx + 1}`;
        
        token.dataset.playerPos = slot.name;
        token.style.left = `${coords.x}%`;
        token.style.top = `${coords.y}%`;

        if (state.selectedPlayerId === player.id) {
          token.classList.add('token-selected');
        }

        const isCurrentBowler = (player.id === state.matchContext.currentBowlerId);
        if (player.role === 'WK') {
          token.classList.add('role-wk');
        } else if (isCurrentBowler) {
          token.classList.add('role-bowler');
        } else {
          token.classList.add('role-fielder');
        }

        token.innerHTML = '';
        
        const initialsSpan = document.createElement('span');
        initialsSpan.className = 'player-initials';
        if (player.role === 'WK') {
          initialsSpan.innerText = 'WK';
        } else if (isCurrentBowler) {
          initialsSpan.innerText = 'BW';
        } else {
          initialsSpan.innerText = getInitials(player.name, idx);
        }
        token.appendChild(initialsSpan);

        if (player.role === 'WK' || isCurrentBowler) {
          token.classList.add('snapped-crease');
        }

        const dist = calcDistance(slot.x, slot.y);
        const isOutside = dist > RADIUS_30YD;
        const outsideCount = getOutsideCount();
        const maxLimit = getMaxAllowedOutside();

        if (isOutside && outsideCount > maxLimit) {
          token.classList.add('pp-illegal-position');
        }

        // premium glassmorphic tooltips interactions
        token.addEventListener('mouseenter', () => {
          if (!token.classList.contains('dragging')) {
            showTooltip(player, token);
          }
        });
        token.addEventListener('mouseleave', () => {
          hideTooltip();
        });
        token.addEventListener('pointerdown', () => {
          hideTooltip();
        });

        setupDragEngine(token, player);
        elTokensContainer.appendChild(token);
      });
    }

    function renderBench() {
      const elBenchTokensContainer = document.getElementById('bench-tokens-container');
      if (!elBenchTokensContainer) return;
      elBenchTokensContainer.innerHTML = '';
      
      const benchedPlayers = state.squad.filter(p => p.status === 'benched');
      
      if (benchedPlayers.length === 0) {
        const emptyMsg = document.createElement('div');
        emptyMsg.style.padding = '0.5rem 1rem';
        emptyMsg.style.color = 'var(--ink-tertiary)';
        emptyMsg.style.fontFamily = 'var(--font-mono)';
        emptyMsg.style.fontSize = '9px';
        emptyMsg.innerText = 'NO PLAYERS ON BENCH (ALL 12 ACTIVE ON FIELD?)';
        elBenchTokensContainer.appendChild(emptyMsg);
        return;
      }
      
      benchedPlayers.forEach(player => {
        const idx = state.squad.indexOf(player);
        const token = document.createElement('div');
        token.className = 'bench-player-token';
        token.dataset.id = player.id;
        token.dataset.playerName = player.name || `Player ${idx + 1}`;
        token.innerText = getInitials(player.name, idx);
        
        if (state.selectedPlayerId === player.id) {
          token.classList.add('token-selected');
        }
        
        token.addEventListener('click', (e) => {
          e.stopPropagation();
          togglePlayerSelection(player.id);
        });
        
        elBenchTokensContainer.appendChild(token);
      });
    }

    // PointerEvents Drag Engine
    function setupDragEngine(token, player) {
      token.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        token.setPointerCapture(e.pointerId);
        token.classList.add('dragging');
        addLog(`Positioning player ${player.name} on field...`, 'green');

        const rect = elFieldBounds.getBoundingClientRect();
        const startClientX = e.clientX;
        const startClientY = e.clientY;

        const slot = fieldingPositions.find(s => s.id === player.positionId);
        if (!slot) return;
        const coords = getSlotCoords(slot);
        const startX = coords.x;
        const startY = coords.y;

        let lastX = startX;
        let lastY = startY;
        let hasMoved = false;

        function onPointerMove(moveEvent) {
          if (moveEvent.pointerId !== e.pointerId) return;
          const deltaX = moveEvent.clientX - startClientX;
          const deltaY = moveEvent.clientY - startClientY;

          if (Math.abs(deltaX) > 4 || Math.abs(deltaY) > 4) {
            hasMoved = true;
          }

          const pctDx = (deltaX / rect.width) * 100;
          const pctDy = (deltaY / rect.height) * 100;

          let newX = startX + pctDx;
          let newY = startY + pctDy;

          if (newX < 1) newX = 1;
          if (newX > 99) newX = 99;
          if (newY < 1) newY = 1;
          if (newY > 99) newY = 99;

          token.style.left = `${newX}%`;
          token.style.top = `${newY}%`;

          lastX = newX;
          lastY = newY;
        }

        function onPointerUp(upEvent) {
          if (upEvent.pointerId !== e.pointerId) return;
          token.releasePointerCapture(e.pointerId);
          document.removeEventListener('pointermove', onPointerMove);
          document.removeEventListener('pointerup', onPointerUp);
          token.classList.remove('dragging');

          if (!hasMoved) {
            handleTokenClick(player);
            return;
          }

          const closestSlot = findClosestSlot(lastX, lastY);

          if (closestSlot) {
            const success = assignPlayerToSlot(player, closestSlot.id);
            if (!success) {
              token.style.transition = 'left 0.4s ease-out, top 0.4s ease-out';
              token.style.left = `${startX}%`;
              token.style.top = `${startY}%`;
              setTimeout(() => {
                token.style.transition = 'left 0.5s ease-out, top 0.5s ease-out';
                renderApp();
              }, 400);
            }
          } else {
            renderApp();
          }
        }

        document.addEventListener('pointermove', onPointerMove);
        document.addEventListener('pointerup', onPointerUp);
      });
    }

    if (elCancelSelectionBtn) {
      elCancelSelectionBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        state.selectedPlayerId = null;
        hideSelectionBanner();
