    elFieldBounds.addEventListener('click', (e) => {
      if (!state.selectedPlayerId) {
        return;
      }

      if (e.target.closest('.player-token') || e.target.closest('.position-slot') || e.target.closest('#cancel-selection-btn')) {
        return;
      }

      const rect = elFieldBounds.getBoundingClientRect();
      const clickX = ((e.clientX - rect.left) / rect.width) * 100;
      const clickY = ((e.clientY - rect.top) / rect.height) * 100;

      const closestSlot = findClosestSlot(clickX, clickY);
      if (closestSlot) {
        const selectedPlayer = state.squad.find(p => p.id === state.selectedPlayerId);
        if (selectedPlayer) {
          const success = assignPlayerToSlot(selectedPlayer, closestSlot.id);
          if (success) {
            state.selectedPlayerId = null;
            hideSelectionBanner();
          }
        }
      }
      renderApp();
    });

