    // Step 1 Bulk Import parse and load
    function handleBulkImportStep1() {
      if (!elWizardBulkTextarea) return;
      const text = elWizardBulkTextarea.value.trim();
      if (!text) {
        addLog(`[IMPORT ERROR] No names entered for bulk import.`, 'red');
        return;
      }

      const rawNames = text.split(/[\n,]+/).map(name => name.trim()).filter(name => name.length > 0);
      
      if (rawNames.length === 0) {
        addLog(`[IMPORT ERROR] No valid names parsed.`, 'red');
        return;
      }

      addLog(`Bulk import triggered: Parsed ${rawNames.length} names.`, 'green');
      
      const limit = Math.min(rawNames.length, 12);
      for (let i = 0; i < limit; i++) {
        state.squad[i].name = rawNames[i];
      }

      elWizardBulkTextarea.value = '';
      if (elWizardBulkBox) elWizardBulkBox.classList.add('hidden');
      renderApp();
      addLog(`Bulk import complete. ${limit} roster slots updated.`, 'green');
    }

    // self-healing overlap prevention coordinate mapper
    function ensureAllActivePlayersHaveSlots() {
      let activePlayers = state.squad.filter(p => p.status === 'active');
      
      if (activePlayers.length < 11) {
        const benched = state.squad.filter(p => p.status === 'benched');
        const needed = 11 - activePlayers.length;
        for (let i = 0; i < Math.min(needed, benched.length); i++) {
          benched[i].status = 'active';
          addLog(`[AUTO] Activated benched player "${benched[i].name || 'Player'}" to complete the 11-man team.`, 'green');
        }
        activePlayers = state.squad.filter(p => p.status === 'active');
      } else if (activePlayers.length > 11) {
        const excess = activePlayers.length - 11;
        for (let i = 0; i < excess; i++) {
          const playerToBench = activePlayers[activePlayers.length - 1 - i];
          playerToBench.status = 'benched';
          playerToBench.positionId = null;
          addLog(`[AUTO] Benched player "${playerToBench.name || 'Player'}" to maintain exactly 11 active on-field players.`, 'amber');
        }
        activePlayers = state.squad.filter(p => p.status === 'active');
      }

      const usedSlots = new Set();
      
      // Pass 1: Retain players who already have valid, unique assignments
      activePlayers.forEach(p => {
        if (p.positionId && fieldingPositions.some(s => s.id === p.positionId) && !usedSlots.has(p.positionId)) {
          usedSlots.add(p.positionId);
        } else {
          p.positionId = null;
        }
      });

      // Pass 2: Assign vacant slots to players without one
      activePlayers.forEach(p => {
        if (!p.positionId) {
          const vacantSlot = fieldingPositions.find(s => !usedSlots.has(s.id));
          if (vacantSlot) {
            p.positionId = vacantSlot.id;
            usedSlots.add(vacantSlot.id);
            updatePlayerRoleFromPosition(p);
            addLog(`[AUTO] Placed "${p.name || 'Fielder'}" at vacant position: ${vacantSlot.name}`, 'green');
          }
        }
      });
    }

