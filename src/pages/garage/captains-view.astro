        addLog(`Navigated to Step 2: Tactical Board and Pitch sandbox active.`, 'green');
      }
      renderApp();
    }

    // Apply specific preset strategy coordinate layout mappings
    function applyPresetStrategy(strategyId) {
      let mapping = [];
      let isPP = true;
      
      if (strategyId === 'aggressive') {
        mapping = [
          'wk', 'bowler', 'slip1', 'slip2', 'gully',
          'silly_point', 'silly_mid_off', 'silly_mid_on',
          'point', 'cover', 'mid_wicket'
        ];
        isPP = true;
      } else if (strategyId === 'balanced') {
        mapping = [
          'wk', 'bowler', 'point', 'cover', 'mid_off',
          'mid_on', 'mid_wicket', 'square_leg', 'slip1',
          'deep_cover', 'deep_mid_wicket'
        ];
        isPP = false;
      } else if (strategyId === 'defensive') {
        mapping = [
          'wk', 'bowler', 'point', 'cover', 'extra_cover',
          'mid_off', 'mid_on', 'mid_wicket', 'square_leg',
          'deep_cover', 'deep_mid_wicket'
        ];
        isPP = false;
      }

      const activePlayers = state.squad.filter(p => p.status === 'active');
      activePlayers.forEach((player, i) => {
        if (i < mapping.length) {
          player.positionId = mapping[i];
          updatePlayerRoleFromPosition(player);
        }
      });

      state.matchContext.isPowerplay = isPP;
      if (elPowerplayToggle) {
        if (isPP) {
          elPowerplayToggle.classList.add('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'POWERPLAY ACTIVE';
        } else {
          elPowerplayToggle.classList.remove('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'NON-POWERPLAY';
        }
      }
    }

    function applyTimelineStage(stageIndex) {
      state.currentPlaybookStage = stageIndex;
      const stageData = playbookStages[stageIndex];
      if (!stageData) return;

      // Update match context
      state.matchContext.isPowerplay = stageData.isPowerplay;
      state.matchContext.batterHandedness = stageData.batterHandedness;
      
      // Update UI Toggles & Selects to match
      if (elPowerplayToggle) {
        if (state.matchContext.isPowerplay) {
          elPowerplayToggle.classList.add('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'POWERPLAY ACTIVE';
        } else {
          elPowerplayToggle.classList.remove('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'NON-POWERPLAY';
        }
      }

      if (elHandednessToggle) {
        if (state.matchContext.batterHandedness === 'LHB') {
          elHandednessToggle.classList.add('active-state');
          elHandednessToggle.querySelector('.handedness-badge').innerText = 'LHB';
          elHandednessToggle.querySelector('.toggle-text').innerText = 'LEFT-HANDED';
        } else {
          elHandednessToggle.classList.remove('active-state');
          elHandednessToggle.querySelector('.handedness-badge').innerText = 'RHB';
          elHandednessToggle.querySelector('.toggle-text').innerText = 'RIGHT-HANDED';
        }
      }

      // Map squad players to these positions
      // We sort the active players so WK goes to 'wk' (first in positions),
      // Bowler goes to 'bowler' (second in positions), and others go to remaining fielders positions
      const activeWK = state.squad.find(p => p.status === 'active' && p.role === 'WK');
      const activeBowler = state.squad.find(p => p.status === 'active' && p.role === 'Bowler');
      const activeFielders = state.squad.filter(p => p.status === 'active' && p.id !== (activeWK ? activeWK.id : null) && p.id !== (activeBowler ? activeBowler.id : null));
      
      const sortedActive = [];
      if (activeWK) sortedActive.push(activeWK);
      if (activeBowler) sortedActive.push(activeBowler);
      activeFielders.forEach(f => sortedActive.push(f));

      // Make sure we have exactly 11 active players
      const allActive = state.squad.filter(p => p.status === 'active');
      while (sortedActive.length < 11 && allActive.length > 0) {
        const next = allActive.find(p => !sortedActive.includes(p));
        if (next) sortedActive.push(next);
        else break;
      }

      // Assign position IDs to each active player from the stage positions
      const stagePositions = stageData.positions;
      sortedActive.forEach((player, idx) => {
        if (idx < stagePositions.length) {
          player.positionId = stagePositions[idx];
          updatePlayerRoleFromPosition(player);
        }
      });

      // Update current Bowler ID if Bowler exists
      const currentBowler = state.squad.find(p => p.status === 'active' && p.role === 'Bowler');
      if (currentBowler) {
        state.matchContext.currentBowlerId = currentBowler.id;
      }

      // Repopulate Bowler dropdown
      populateBowlerSelect();

      // Update timeline step labels UI active state
      document.querySelectorAll('.timeline-label').forEach(lbl => {
        lbl.classList.remove('active');
        if (parseInt(lbl.dataset.step) === stageIndex) {
          lbl.classList.add('active');
        }
      });

      // Synchronize input range slider value
      const elRangeSlider = document.getElementById('playbook-range-slider');
      if (elRangeSlider) {
        elRangeSlider.value = stageIndex;
      }

      // Update the Guide commentary card UI
      const elPlaybookStageTag = document.getElementById('playbook-stage-tag');
      const elPlaybookStrategyTitle = document.getElementById('playbook-strategy-title');
      const elPlaybookStrategyPhase = document.getElementById('playbook-strategy-phase');
      const elPlaybookStrategyExplanation = document.getElementById('playbook-strategy-explanation');

      if (elPlaybookStageTag) elPlaybookStageTag.innerText = stageData.tag;
      if (elPlaybookStrategyTitle) elPlaybookStrategyTitle.innerText = stageData.title;
      if (elPlaybookStrategyPhase) elPlaybookStrategyPhase.innerText = `PHASE: ${stageData.phase}`;
      if (elPlaybookStrategyExplanation) elPlaybookStrategyExplanation.innerText = stageData.explanation;

      // Add detailed diagnostic log
      addLog(`[PLAYBOOK] Slide preset activated: Stage ${stageIndex} - ${stageData.title}`, 'green');
      addLog(`[PLAYBOOK] Applied phase: ${stageData.phase}. Powerplay: ${stageData.isPowerplay ? 'Active' : 'Ended'}. Batter Strike: ${stageData.batterHandedness}`, 'green');

      // Clear any violation banners since preset layouts are inherently legal
      hideRulesBanner();

      // Render updated field tokens and UI counters
      renderApp();
    }

    // ─── SVG layer visibility helpers (use SVG display attr, not CSS style) ──
    function svgShow(el) { if (el) el.removeAttribute('display'); }
    function svgHide(el) { if (el) el.setAttribute('display', 'none'); }

    // ─── Over Flip Economy ──────────────────────────────────────────────
    function calcFlipDist(posId) {
      const pos = fieldingPositions.find(p => p.id === posId);
      if (!pos) return 0;
      // Distance a fielder runs when bowling end swaps = |2*(y - 50)|
      return Math.abs(2 * (pos.y - 50));
    }

    function renderOverFlipArrows() {
      const layer = document.getElementById('over-flip-arrows-layer');
      if (!layer) return;
      layer.innerHTML = '';
      if (!state.isOverFlipActive) { svgHide(layer); return; }
      svgShow(layer);

      state.squad.forEach(player => {
        if (player.status === 'benched' || !player.positionId) return;
        if (player.positionId === 'wk' || player.positionId === 'bowler') return;
        const pos = fieldingPositions.find(p => p.id === player.positionId);
        if (!pos) return;
        const dist = calcFlipDist(player.positionId);
        if (dist < 3) return; // negligible — near y=50
        const toY = 100 - pos.y;
        const color = dist > 35 ? '#e55555' : dist > 18 ? '#e8b86a' : '#7dd3a0';
        const markerId = dist > 35 ? 'arrow-red' : dist > 18 ? 'arrow-amber' : 'arrow-green';

        // Dashed travel line
        const SVG_NS = 'http://www.w3.org/2000/svg';
        const line = document.createElementNS(SVG_NS, 'line');
        line.setAttribute('x1', String(pos.x));
        line.setAttribute('y1', String(pos.y));
        line.setAttribute('x2', String(pos.x));
        line.setAttribute('y2', String(toY));
        line.setAttribute('stroke', color);
        line.setAttribute('stroke-width', '0.9');
        line.setAttribute('stroke-opacity', '0.8');
        line.setAttribute('marker-end', `url(#${markerId})`);
        line.setAttribute('stroke-dasharray', '1.8 1');
        layer.appendChild(line);

        // Landing ring at destination
        const circ = document.createElementNS(SVG_NS, 'circle');
        circ.setAttribute('cx', String(pos.x));
        circ.setAttribute('cy', String(toY));
        circ.setAttribute('r', '2');
        circ.setAttribute('fill', 'none');
        circ.setAttribute('stroke', color);
        circ.setAttribute('stroke-width', '0.5');
        circ.setAttribute('stroke-opacity', '0.6');
        layer.appendChild(circ);
      });
    }

    function updateFlipStats() {
      const elTotalRun = document.getElementById('flip-total-run');
      const elSprintCount = document.getElementById('flip-sprint-count');
      const elBreakdownList = document.getElementById('flip-breakdown-list');
      if (!elBreakdownList) return;

      const rows = [];
      let totalDist = 0, sprintCount = 0;

      state.squad.forEach(player => {
        if (player.status === 'benched' || !player.positionId) return;
        if (player.positionId === 'wk' || player.positionId === 'bowler') return;
        const pos = fieldingPositions.find(p => p.id === player.positionId);
        if (!pos) return;
        const dist = calcFlipDist(player.positionId);
        totalDist += dist;
        if (dist > 35) sprintCount++;
        rows.push({ name: player.name, abbr: pos.abbr, dist });
      });

      rows.sort((a, b) => b.dist - a.dist);

      // Always show live numbers even when overlay is off
      if (elTotalRun) elTotalRun.textContent = Math.round(totalDist) + ' u';
      if (elSprintCount) elSprintCount.textContent = String(sprintCount);

      // Breakdown list only shown when overlay active
      elBreakdownList.innerHTML = rows.map(r => {
        const color = r.dist > 35 ? '#e55555' : r.dist > 18 ? '#e8b86a' : '#7dd3a0';
        const pct = Math.min(100, Math.round((r.dist / 50) * 100)); // max dist ~50
        const shortName = r.name.split(' ').pop();
        return `<div class="flip-row">
          <span class="flip-name">${shortName}</span>
          <span class="flip-abbr">${r.abbr}</span>
          <div class="flip-bar-bg"><div class="flip-bar-fill" style="width:${pct}%;background:${color}"></div></div>
          <span class="flip-dist" style="color:${color}">${Math.round(r.dist)}</span>
        </div>`;
      }).join('');

      elBreakdownList.classList.toggle('is-visible', state.isOverFlipActive);
    }

    // ─── Boundary Coverage ──────────────────────────────────────────────
    // Draws thick arc SEGMENTS along the boundary rope, not pie wedges.
    // Each of 16 sectors is colored green (covered) or red (gap).
    function renderBoundaryCoverage() {
      const layer = document.getElementById('boundary-arcs-layer');
      if (!layer) return;
      layer.innerHTML = '';
      if (!state.isBoundaryMapActive) { svgHide(layer); return; }
      svgShow(layer);

      const SVG_NS = 'http://www.w3.org/2000/svg';
      const SECTORS = 16;
      const R = RADIUS_BOUNDARY;   // 46
      const cx = 50, cy = 50;
      const COVER_RADIUS = 14;     // fielder must be within 14 units of boundary point
      const GAP_FRAC = 0.08;       // 8% gap between segments for visual clarity

      for (let i = 0; i < SECTORS; i++) {
        const a0 = (i / SECTORS) * Math.PI * 2 - Math.PI / 2;
        const a1 = ((i + 1) / SECTORS) * Math.PI * 2 - Math.PI / 2;
        const aMid = (a0 + a1) / 2;
        const arcSpan = a1 - a0;
        const aStart = a0 + arcSpan * GAP_FRAC;
        const aEnd   = a1 - arcSpan * GAP_FRAC;

        // Sample midpoint of boundary arc to check coverage
        const px = cx + R * Math.cos(aMid);
        const py = cy + R * Math.sin(aMid);

        let covered = false;
        for (const player of state.squad) {
          if (player.status === 'benched' || !player.positionId) continue;
          const fp = fieldingPositions.find(p => p.id === player.positionId);
          if (!fp) continue;
          const dx = fp.x - px, dy = fp.y - py;
          if (Math.sqrt(dx * dx + dy * dy) < COVER_RADIUS) { covered = true; break; }
        }

        // Arc start/end points
        const xs = cx + R * Math.cos(aStart);
        const ys = cy + R * Math.sin(aStart);
        const xe = cx + R * Math.cos(aEnd);
        const ye = cy + R * Math.sin(aEnd);

        const arc = document.createElementNS(SVG_NS, 'path');
        arc.setAttribute('d', `M ${xs.toFixed(2)} ${ys.toFixed(2)} A ${R} ${R} 0 0 1 ${xe.toFixed(2)} ${ye.toFixed(2)}`);
        arc.setAttribute('fill', 'none');
        arc.setAttribute('stroke', covered ? '#7dd3a0' : '#e55555');
        arc.setAttribute('stroke-width', '2.4');
        arc.setAttribute('stroke-opacity', covered ? '0.55' : '0.85');
        arc.setAttribute('stroke-linecap', 'round');
        layer.appendChild(arc);
      }
    }

    // ─── Bowler Guard ───────────────────────────────────────────────────
    // Highlights the five bowler-protection positions with rings + updates sidebar pills.
    function renderBowlerGuard() {
      const layer = document.getElementById('bowler-guard-layer');
      if (!layer) return;
      layer.innerHTML = '';

      // Always update sidebar pills (regardless of map toggle)
      const GUARD_IDS = ['fine_leg', 'third_man', 'short_fine_leg', 'deep_fine_leg', 'deep_third_man'];
      const guardStrip = document.getElementById('bowler-guard-strip');
      if (guardStrip) {
        guardStrip.querySelectorAll('.guard-pos-pill').forEach(pill => {
          const posId = pill.dataset.pos;
          const isCov = state.squad.some(p => p.positionId === posId && p.status === 'active');
          pill.classList.toggle('is-covered', isCov);
          pill.classList.toggle('is-empty', !isCov);
        });
      }

      if (!state.isBoundaryMapActive) { svgHide(layer); return; }
      svgShow(layer);

      const SVG_NS = 'http://www.w3.org/2000/svg';
      GUARD_IDS.forEach(posId => {
        const pos = fieldingPositions.find(p => p.id === posId);
        if (!pos) return;
        const isCov = state.squad.some(p => p.positionId === posId && p.status === 'active');

        // Outer pulsing ring
        const ring = document.createElementNS(SVG_NS, 'circle');
        ring.setAttribute('cx', String(pos.x));
        ring.setAttribute('cy', String(pos.y));
        ring.setAttribute('r', '4.5');
        ring.setAttribute('fill', isCov ? 'rgba(125,211,160,0.1)' : 'rgba(232,184,106,0.12)');
        ring.setAttribute('stroke', isCov ? '#7dd3a0' : '#e8b86a');
        ring.setAttribute('stroke-width', '0.7');
        ring.setAttribute('stroke-opacity', '0.75');
        if (!isCov) ring.setAttribute('stroke-dasharray', '1.2 0.9');
        layer.appendChild(ring);

        // Small center dot
        const dot = document.createElementNS(SVG_NS, 'circle');
        dot.setAttribute('cx', String(pos.x));
        dot.setAttribute('cy', String(pos.y));
        dot.setAttribute('r', '0.8');
        dot.setAttribute('fill', isCov ? 'rgba(125,211,160,0.5)' : 'rgba(232,184,106,0.5)');
        layer.appendChild(dot);
      });
    }

    // Main Master Redraw Routine
    function renderApp() {
      ensureAllActivePlayersHaveSlots();

      if (state.selectedPlayerId) {
        elFieldBounds.classList.add('has-selection');
      } else {
        elFieldBounds.classList.remove('has-selection');
      }

      renderRosterSetupWizard();
      renderRosterStep2();
      renderSlots();
      renderTokens();
      renderBench();
      updateCounters();
      renderOverFlipArrows();
      renderBoundaryCoverage();
      renderBowlerGuard();
      updateFlipStats();
    }

    // Event Wire Binding Listeners

    // Step 1 Match formats button selectors
    document.querySelectorAll('.format-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.format-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        state.matchContext.format = btn.dataset.format;
        if (elMatchFormat) elMatchFormat.value = state.matchContext.format;
        addLog(`Match format set to ${state.matchContext.format}`);
      });
    });

    // Step 1 Strategy preset selectors cards
    document.querySelectorAll('.strategy-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.strategy-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        state.selectedStrategy = card.dataset.strategy;
        addLog(`Opening Strategy Preset selected: ${state.selectedStrategy.toUpperCase()}`);
      });
    });

    // Step 1 Quick Roster Actions
    if (elWizardClearNames) {
      elWizardClearNames.addEventListener('click', () => {
        state.squad.forEach(p => p.name = '');
        addLog(`Cleared all squad player names. ready for manual entry.`, 'amber');
        renderApp();
      });
    }

    if (elWizardBulkImportToggle) {
      elWizardBulkImportToggle.addEventListener('click', () => {
        if (elWizardBulkBox) {
          elWizardBulkBox.classList.toggle('hidden');
        }
      });
    }

    if (elWizardApplyBulk) {
      elWizardApplyBulk.addEventListener('click', handleBulkImportStep1);
    }

    // Generate Board Action Button
    if (elProceedToFieldBtn) {
      elProceedToFieldBtn.addEventListener('click', () => {
        // Capture setup values to store
        const teamVal = document.getElementById('team-name-input-s1').value.trim() || 'My Team';
        const gameVal = document.getElementById('game-name-input-s1').value.trim() || 'Match 1';
        if (elTeamNameInput) elTeamNameInput.value = teamVal;
        if (elGameNameInput) elGameNameInput.value = gameVal;

        // Apply selected Opening StrategyPreset
        applyPresetStrategy(state.selectedStrategy);

        // Sync timeline playbooks slider to match opening strategy selection
        if (state.selectedStrategy === 'aggressive') {
          state.currentPlaybookStage = 1;
        } else if (state.selectedStrategy === 'balanced') {
          state.currentPlaybookStage = 2;
        } else if (state.selectedStrategy === 'defensive') {
          state.currentPlaybookStage = 4;
        }
        
        // Sync range slider element value
        const elRangeSlider = document.getElementById('playbook-range-slider');
        if (elRangeSlider) {
          elRangeSlider.value = state.currentPlaybookStage;
        }
        
        // Sync labels active class
        document.querySelectorAll('.timeline-label').forEach(lbl => {
          lbl.classList.remove('active');
          if (parseInt(lbl.dataset.step) === state.currentPlaybookStage) {
            lbl.classList.add('active');
          }
        });
        
        // Sync the Strategy Playbook Guide card
        const stageData = playbookStages[state.currentPlaybookStage];
        if (stageData) {
          const elPlaybookStageTag = document.getElementById('playbook-stage-tag');
          const elPlaybookStrategyTitle = document.getElementById('playbook-strategy-title');
          const elPlaybookStrategyPhase = document.getElementById('playbook-strategy-phase');
          const elPlaybookStrategyExplanation = document.getElementById('playbook-strategy-explanation');

          if (elPlaybookStageTag) elPlaybookStageTag.innerText = stageData.tag;
          if (elPlaybookStrategyTitle) elPlaybookStrategyTitle.innerText = stageData.title;
          if (elPlaybookStrategyPhase) elPlaybookStrategyPhase.innerText = `PHASE: ${stageData.phase}`;
          if (elPlaybookStrategyExplanation) elPlaybookStrategyExplanation.innerText = stageData.explanation;
        }

        // Transition step screen views
        goToStep(2);
        addLog(`Tactical Strategy Board successfully populated using strategy presets!`, 'green');
      });
    }

    // Step 2 Control Settings sync
    if (elMatchFormat) {
      elMatchFormat.addEventListener('change', (e) => {
        state.matchContext.format = e.target.value;
        document.querySelectorAll('.format-btn').forEach(btn => {
          if (btn.dataset.format === state.matchContext.format) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
        addLog(`Match format updated: ${state.matchContext.format}`);
      });
    }

    if (elPowerplayToggle) {
      elPowerplayToggle.addEventListener('click', () => {
        state.matchContext.isPowerplay = !state.matchContext.isPowerplay;
        if (state.matchContext.isPowerplay) {
          elPowerplayToggle.classList.add('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'POWERPLAY ACTIVE';
          addLog(`Powerplay ACTIVATED. max 2 outside 30yd circle.`, 'green');
        } else {
          elPowerplayToggle.classList.remove('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'NON-POWERPLAY';
          addLog(`Powerplay DEACTIVATED. max 5 outside 30yd circle.`, 'amber');
        }
        renderApp();
      });
    }

    if (elHandednessToggle) {
      elHandednessToggle.addEventListener('click', () => {
        const isRHB = state.matchContext.batterHandedness === 'RHB';
        state.matchContext.batterHandedness = isRHB ? 'LHB' : 'RHB';
        
        if (state.matchContext.batterHandedness === 'LHB') {
          elHandednessToggle.classList.add('active-state');
          elHandednessToggle.querySelector('.handedness-badge').innerText = 'LHB';
          elHandednessToggle.querySelector('.toggle-text').innerText = 'LEFT-HANDED';
          addLog(`Mirroring field positions: Flipping vertical pitch line for LHB...`, 'green');
        } else {
          elHandednessToggle.classList.remove('active-state');
          elHandednessToggle.querySelector('.handedness-badge').innerText = 'RHB';
          elHandednessToggle.querySelector('.toggle-text').innerText = 'RIGHT-HANDED';
          addLog(`Restoring field positions: Restoring vertical pitch line for RHB...`, 'green');
        }
        renderApp();
      });
    }

    if (elBowlerSelect) {
      elBowlerSelect.addEventListener('change', (e) => {
        const targetBowlerId = e.target.value;
        const targetBowler = state.squad.find(p => p.id === targetBowlerId);
        if (targetBowler) {
          assignPlayerToSlot(targetBowler, 'bowler');
        }
      });
    }

    if (elBackToRosterBtn) {
      elBackToRosterBtn.addEventListener('click', () => {
        goToStep(1);
      });
    }
    if (elStepIndicator1) {
      elStepIndicator1.addEventListener('click', () => goToStep(1));
    }
    if (elStepIndicator2) {
      elStepIndicator2.addEventListener('click', () => goToStep(2));
    }

    // Strategy Storage Action Triggers
    if (elSaveStrategyBtn) elSaveStrategyBtn.addEventListener('click', saveCurrentStrategy);
    if (elLoadStrategyBtn) elLoadStrategyBtn.addEventListener('click', loadStrategy);
    if (elDeleteStrategyBtn) elDeleteStrategyBtn.addEventListener('click', deleteStrategy);

    // Reset Strategy Trigger
    if (elResetBtn) {
      elResetBtn.addEventListener('click', () => {
        addLog(`Resetting strategizing board to default template...`, 'amber');
        
        state.squad = JSON.parse(JSON.stringify(defaultRoster));
        state.selectedPlayerId = null;
        state.selectedSlotId = null;
        hideSelectionBanner();
        state.matchContext.format = 'T20';
        state.matchContext.isPowerplay = true;
        state.matchContext.batterHandedness = 'RHB';
        state.matchContext.currentBowlerId = 'p2';
        state.selectedStrategy = 'aggressive';
        state.currentPlaybookStage = null;

        if (elMatchFormat) elMatchFormat.value = 'T20';
        document.querySelectorAll('.format-btn').forEach(btn => {
          btn.classList.remove('active');
          if (btn.dataset.format === 'T20') btn.classList.add('active');
        });

        document.querySelectorAll('.strategy-card').forEach(btn => {
          btn.classList.remove('active');
          if (btn.dataset.strategy === 'aggressive') btn.classList.add('active');
        });

        const s1Team = document.getElementById('team-name-input-s1');
        const s1Game = document.getElementById('game-name-input-s1');
        if (s1Team) s1Team.value = 'My Team';
        if (s1Game) s1Game.value = 'Match 1';
        if (elTeamNameInput) elTeamNameInput.value = 'My Team';
        if (elGameNameInput) elGameNameInput.value = 'Match 1';
        
        if (elPowerplayToggle) {
          elPowerplayToggle.classList.add('active-state');
          elPowerplayToggle.querySelector('.toggle-text').innerText = 'POWERPLAY ACTIVE';
        }

        if (elHandednessToggle) {
          elHandednessToggle.classList.remove('active-state');
          elHandednessToggle.querySelector('.handedness-badge').innerText = 'RHB';
          elHandednessToggle.querySelector('.toggle-text').innerText = 'RIGHT-HANDED';
        }

        // Reset Playbook range slider & timeline labels
        const elPlaybookRangeSlider = document.getElementById('playbook-range-slider');
        if (elPlaybookRangeSlider) {
          elPlaybookRangeSlider.value = 1;
        }
        document.querySelectorAll('.timeline-label').forEach(lbl => {
          lbl.classList.remove('active');
          if (parseInt(lbl.dataset.step) === 1) {
            lbl.classList.add('active');
          }
        });

        // Sync strategy playbook guide card to Stage 1
        const stageData = playbookStages[1];
        if (stageData) {
          const elPlaybookStageTag = document.getElementById('playbook-stage-tag');
          const elPlaybookStrategyTitle = document.getElementById('playbook-strategy-title');
          const elPlaybookStrategyPhase = document.getElementById('playbook-strategy-phase');
          const elPlaybookStrategyExplanation = document.getElementById('playbook-strategy-explanation');

          if (elPlaybookStageTag) elPlaybookStageTag.innerText = stageData.tag;
          if (elPlaybookStrategyTitle) elPlaybookStrategyTitle.innerText = stageData.title;
          if (elPlaybookStrategyPhase) elPlaybookStrategyPhase.innerText = `PHASE: ${stageData.phase}`;
          if (elPlaybookStrategyExplanation) elPlaybookStrategyExplanation.innerText = stageData.explanation;
        }

        populateBowlerSelect();
        hideRulesBanner();
        renderApp();
        addLog(`Roster and field successfully restored to default setups.`, 'green');
      });
    }

    if (elClearLogsBtnS2) {
      elClearLogsBtnS2.addEventListener('click', () => {
        if (elTerminalConsoleS2) elTerminalConsoleS2.innerHTML = '<div class="log-line text-green">[LOG CLEAR] Terminal buffer cleared.</div>';
      });
    }

    // Playbook Timeline interaction slider range handler
    const elPlaybookRangeSlider = document.getElementById('playbook-range-slider');
    if (elPlaybookRangeSlider) {
      elPlaybookRangeSlider.addEventListener('input', (e) => {
        const stageIndex = parseInt(e.target.value);
        applyTimelineStage(stageIndex);
      });
    }

    // Make timeline labels clickable directly
    document.querySelectorAll('.timeline-label').forEach(lbl => {
      lbl.addEventListener('click', () => {
        const step = parseInt(lbl.dataset.step);
        applyTimelineStage(step);
      });
    });

    // ─── Flip Economy Toggle ────────────────────────────────────────────
    function syncFlipUI() {
      const label = state.isOverFlipActive ? 'HIDE' : 'SHOW';
      const elFlipSidebarBtn = document.getElementById('toggle-flip-btn');
      const elFlipHudBtn = document.getElementById('toggle-flip-hud-btn');
      if (elFlipSidebarBtn) elFlipSidebarBtn.textContent = label;
      if (elFlipHudBtn) elFlipHudBtn.classList.toggle('is-active', state.isOverFlipActive);
    }

    const elFlipHudBtn = document.getElementById('toggle-flip-hud-btn');
    const elFlipSidebarBtn = document.getElementById('toggle-flip-btn');

    function toggleFlip() {
      state.isOverFlipActive = !state.isOverFlipActive;
      addLog(state.isOverFlipActive ? '[FLIP] Over-flip arrows ON.' : '[FLIP] Over-flip arrows OFF.', state.isOverFlipActive ? 'green' : 'amber');
      syncFlipUI();
      renderApp();
    }

    if (elFlipHudBtn) elFlipHudBtn.addEventListener('click', toggleFlip);
    if (elFlipSidebarBtn) elFlipSidebarBtn.addEventListener('click', toggleFlip);

    // ─── Boundary Map Toggle ────────────────────────────────────────────
    const elBoundaryBtn = document.getElementById('toggle-boundary-btn');
    if (elBoundaryBtn) {
      elBoundaryBtn.addEventListener('click', () => {
        state.isBoundaryMapActive = !state.isBoundaryMapActive;
        addLog(state.isBoundaryMapActive ? '[BOUNDARY] Coverage map ON.' : '[BOUNDARY] Coverage map OFF.', state.isBoundaryMapActive ? 'green' : 'amber');
        elBoundaryBtn.classList.toggle('is-active', state.isBoundaryMapActive);
        renderApp();
      });
    }

    // Initial boots execution
    populateBowlerSelect();
    loadSavedStrategiesList();
    ensureAllActivePlayersHaveSlots();
    renderApp();
    addLog(`Strategizer initialized successfully. Step 1 Active.`, 'green');
  }

  // Run initial boot routine immediately
  init();

  // Astro page swap rerun bindings hooks
  document.addEventListener('astro:page-load', () => {
    init();
  });
</script>
