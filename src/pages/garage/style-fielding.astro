  }
  .position-item-btn {
    background: rgba(20, 24, 21, 0.4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--ink-secondary, #9da29e);
    font-size: 9px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
  }
  .position-item-btn:hover {
    border-color: var(--accent, #7dd3a0);
    color: #ffffff;
    background: rgba(125, 211, 160, 0.04);
  }
  .pos-item-abbr {
    font-family: var(--font-mono), monospace;
    font-weight: bold;
