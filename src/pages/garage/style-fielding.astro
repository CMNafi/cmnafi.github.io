  }
  .pos-item-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-left: 0.4rem;
    flex: 1;
  }

  /* --- Timeline Footer Range Slider --- */
  .playbook-master-timeline {
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    padding: 0 2rem 3rem;
  }
  @media (max-width: 1024px) {
    .playbook-master-timeline {
      padding: 0 1rem 2rem;
    }
  }

  .timeline-slider-card {
    background: var(--surface-raised, #101411);
    border: 1px solid var(--surface-line, rgba(255,255,255,0.06));
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .timeline-card-title {
    font-family: var(--font-mono), monospace;
    font-size: 10px;
    font-weight: 700;
    color: var(--ink-tertiary, #6c726e);
    letter-spacing: 0.15em;
    margin: 0;
    text-transform: uppercase;
  }

  .timeline-step-labels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    text-align: center;
    position: relative;
  }
  .timeline-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink-tertiary, #6c726e);
    cursor: pointer;
    transition: all 0.3s;
  }
  .timeline-label.active {
    color: var(--accent, #7dd3a0);
  }
  
  .step-dot {
    width: 8px;
    height: 8px;
    background: var(--surface-line, rgba(255,255,255,0.12));
    border-radius: 50%;
    border: 2px solid var(--surface-raised, #101411);
    transition: all 0.3s;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.1);
  }
  .timeline-label.active .step-dot {
    background: var(--accent, #7dd3a0);
    box-shadow: 0 0 8px var(--accent, #7dd3a0);
    transform: scale(1.3);
  }
  .step-title {
    font-family: var(--font-mono), monospace;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 0.05em;
  }

  .timeline-range-container {
    position: relative;
    width: 100%;
    margin-top: -0.85rem;
    padding: 0 12%; /* Perfect spacing align with dots */
    z-index: 10;
  }
  @media (max-width: 600px) {
    .timeline-range-container {
      padding: 0 8%;
    }
  }

  /* Range input customization */
  .timeline-slider-element {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: var(--surface-line, rgba(255,255,255,0.12));
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  .timeline-slider-element::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent, #7dd3a0);
    border: 4px solid var(--surface-raised, #101411);
    box-shadow: 0 0 10px rgba(125, 211, 160, 0.8);
    transition: transform 0.1s;
  }
  .timeline-slider-element::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }
  .timeline-slider-element::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent, #7dd3a0);
    border: 4px solid var(--surface-raised, #101411);
    box-shadow: 0 0 10px rgba(125, 211, 160, 0.8);
  }

  /* --- Premium Tooltip style --- */
  .playbook-tooltip {
    position: absolute;
    background: rgba(12, 15, 13, 0.95);
    border: 1px solid var(--accent, #7dd3a0);
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-family: var(--font-mono), monospace;
    font-size: 9px;
    color: #ffffff;
    pointer-events: none;
    z-index: 1000;
    box-shadow: 0 4px 15px rgba(0,0,0,0.5), 0 0 10px rgba(125, 211, 160, 0.15);
    transition: opacity 0.15s;
    transform: translate(-50%, -120%);
  }
  .playbook-tooltip.hidden-tooltip {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  function initPlaybook() {
    const elBounds = document.getElementById('playbook-field-bounds');
    if (!elBounds) return;

    if (elBounds.dataset.initialized === 'true') return;
    elBounds.dataset.initialized = 'true';

    // 41 Preset Fielding Positions Coordinate Mappings
    const fieldingPositions = [
      { id: 'wk', name: 'Wicket Keeper', abbr: 'WK', x: 50, y: 65 },
      { id: 'bowler', name: 'Bowler', abbr: 'BW', x: 50, y: 37.5 },
      { id: 'slip1', name: 'First Slip', abbr: '1SL', x: 46, y: 63 },
      { id: 'slip2', name: 'Second Slip', abbr: '2SL', x: 42, y: 61 },
      { id: 'slip3', name: 'Third Slip', abbr: '3SL', x: 38, y: 59 },
      { id: 'slip4', name: 'Fourth Slip', abbr: '4SL', x: 34, y: 57 },
      { id: 'gully', name: 'Gully', abbr: 'GL', x: 35, y: 55 },
      { id: 'fly_slip', name: 'Fly Slip', abbr: 'FSL', x: 43, y: 67 },
      { id: 'leg_slip', name: 'Leg Slip', abbr: 'LSL', x: 54, y: 62 },
      { id: 'leg_gully', name: 'Leg Gully', abbr: 'LGL', x: 62, y: 56 },
      { id: 'silly_point', name: 'Silly Point', abbr: 'SPT', x: 43, y: 53 },
      { id: 'point', name: 'Point', abbr: 'PT', x: 22, y: 52 },
      { id: 'backward_point', name: 'Backward Point', abbr: 'BPT', x: 24, y: 56 },
      { id: 'deep_point', name: 'Deep Point', abbr: 'DPT', x: 10, y: 50 },
      { id: 'deep_backward_point', name: 'Deep Backward Point', abbr: 'DBP', x: 15, y: 68 },
      { id: 'silly_cover', name: 'Silly Cover', abbr: 'SCV', x: 42, y: 47 },
      { id: 'cover', name: 'Cover', abbr: 'CV', x: 27, y: 43 },
      { id: 'sweeper_cover', name: 'Sweeper Cover', abbr: 'SWC', x: 14, y: 28 },
      { id: 'deep_cover', name: 'Deep Cover', abbr: 'DCV', x: 12, y: 35 },
      { id: 'extra_cover', name: 'Extra Cover', abbr: 'XCV', x: 33, y: 36 },
      { id: 'deep_extra_cover', name: 'Deep Extra Cover', abbr: 'DXC', x: 18, y: 22 },
      { id: 'silly_mid_off', name: 'Silly Mid-off', abbr: 'SMO', x: 46, y: 46 },
      { id: 'mid_off', name: 'Mid-off', abbr: 'MFO', x: 42, y: 34 },
      { id: 'long_off', name: 'Long-off', abbr: 'LOF', x: 35, y: 12 },
      { id: 'silly_mid_on', name: 'Silly Mid-on', abbr: 'SMN', x: 54, y: 46 },
      { id: 'mid_on', name: 'Mid-on', abbr: 'MON', x: 58, y: 34 },
      { id: 'long_on', name: 'Long-on', abbr: 'LON', x: 65, y: 12 },
      { id: 'short_mid_wicket', name: 'Short Mid-wicket', abbr: 'SMW', x: 58, y: 48 },
      { id: 'mid_wicket', name: 'Mid-wicket', abbr: 'MW', x: 68, y: 42 },
      { id: 'deep_mid_wicket', name: 'Deep Mid-wicket', abbr: 'DMW', x: 82, y: 35 },
      { id: 'cow_corner', name: 'Cow Corner', abbr: 'CC', x: 74, y: 21 },
      { id: 'short_leg', name: 'Short Leg', abbr: 'SLG', x: 57, y: 53 },
      { id: 'square_leg', name: 'Square Leg', abbr: 'SQL', x: 75, y: 52 },
      { id: 'deep_square_leg', name: 'Deep Square Leg', abbr: 'DSL', x: 90, y: 50 },
      { id: 'backward_square_leg', name: 'Backward Square Leg', abbr: 'BSL', x: 73, y: 58 },
      { id: 'deep_backward_square', name: 'Deep Backward Square Leg', abbr: 'DBS', x: 88, y: 61 },
      { id: 'short_fine_leg', name: 'Short Fine Leg', abbr: 'SFL', x: 60, y: 65 },
      { id: 'fine_leg', name: 'Fine Leg', abbr: 'FL', x: 68, y: 72 },
      { id: 'deep_fine_leg', name: 'Deep Fine Leg', abbr: 'DFL', x: 78, y: 84 },
      { id: 'third_man', name: 'Third Man', abbr: 'TM', x: 30, y: 72 },
      { id: 'deep_third_man', name: 'Deep Third Man', abbr: 'DTM', x: 20, y: 84 }
    ];

    // Master playbooks steps variations
    const playbookStages = {
      1: {
        title: 'THE CLASSIC SLIP ATTACK',
        tag: 'STAGE 1',
        phase: 'POWERPLAY (OVERS 1-6)',
        isPowerplay: true,
        batterHandedness: 'RHB',
        positions: ['wk', 'bowler', 'slip1', 'slip2', 'slip3', 'gully', 'silly_point', 'point', 'cover', 'mid_wicket', 'mid_on'],
        explanation: 'In the initial powerplay phase, restrictions limit the defense to a maximum of 2 fielders outside the 30-yard circle. Capturing early wickets is key. In this ultra-aggressive layout, the captain deploys 3 slips, a gully, and a silly point, leaving the outfield completely unprotected. It applies maximum psychological pressure and locks down catching angles near the bat.'
      },
      2: {
        title: 'BALANCED MID-OVERS RING',
        tag: 'STAGE 2',
        phase: 'MID-OVERS (OVERS 7-15)',
        isPowerplay: false,
        batterHandedness: 'RHB',
        positions: ['wk', 'bowler', 'slip1', 'point', 'cover', 'mid_off', 'mid_on', 'mid_wicket', 'square_leg', 'deep_cover', 'deep_mid_wicket'],
        explanation: 'Once the powerplay ends, up to 5 fielders are allowed outside the 30-yard circle. This balanced mid-overs ring is the standard defensive blueprint. The slips are reduced to 1, and 2 boundary riders (Deep Cover, Deep Mid-wicket) are sent deep to protect the major batting hitting arcs, while the remaining 7 fielders form a restrictive ring to dry up singles.'
      },
      3: {
        title: 'THE LEFT-HANDER TRAP',
        tag: 'STAGE 3',
        phase: 'MID-OVERS (OVERS 7-15)',
        isPowerplay: false,
        batterHandedness: 'LHB',
        positions: ['wk', 'bowler', 'slip1', 'point', 'cover', 'mid_off', 'mid_on', 'mid_wicket', 'square_leg', 'deep_cover', 'deep_mid_wicket'],
        explanation: 'A side change in the batter (LHB strike) triggers an instant horizontal mirror transition about the vertical pitch axis (x = 50). This visually showcases mirroring: the off-side fielders (Point, Cover, Deep Cover) glide seamlessly to the opposite side to form the LHB off-side ring, while the slip catcher slides to the left-hand slip angle, neutralizing the change of strike.'
      },
      4: {
        title: 'DEATH OVERS SHIELD',
        tag: 'STAGE 4',
        phase: 'DEATH OVERS (OVERS 16-20)',
        isPowerplay: false,
        batterHandedness: 'RHB',
        positions: ['wk', 'bowler', 'point', 'cover', 'mid_wicket', 'short_fine_leg', 'deep_cover', 'long_off', 'long_on', 'deep_mid_wicket', 'deep_fine_leg'],
        explanation: 'During the final death overs, batters hit aggressively with high lofted shots. To minimize boundaries, the captain deploys the maximum allowed 5 boundary riders (Deep Cover, Long-off, Long-on, Deep Mid-wicket, Deep Fine Leg). The remaining fielders operate as a protection ring. Bowlers are instructed to bowl yorkers or wide-lines matching this layout.'
      }
    };

    // State
    const state = {
      currentStage: 1,
      batterHandedness: 'RHB',
      isPowerplay: true,
      showGrid: false
    };

    // DOM Caches
    const elTokensContainer = document.getElementById('playbook-tokens-container');
    const elGridOverlay = document.getElementById('all-positions-grid-overlay');
    const elRangeSlider = document.getElementById('playbook-range-slider');
    const elHandednessBtn = document.getElementById('playbook-handedness-toggle');
    const elPowerplayBtn = document.getElementById('playbook-powerplay-toggle');
    const elOverlayBtn = document.getElementById('playbook-overlay-toggle');
    const elTooltip = document.getElementById('playbook-tooltip');

    // Text DOMs
    const elStageTag = document.getElementById('current-stage-tag');
    const elStrategyTitle = document.getElementById('strategy-title');
    const elTelePhase = document.getElementById('telemetry-phase');
    const elTeleStrike = document.getElementById('telemetry-strike');
    const elTeleOutside = document.getElementById('telemetry-outside');
    const elExplanation = document.getElementById('strategy-explanation');
    const elOutsideCount = document.getElementById('outside-circle-count');
    const elOutsideLimit = document.getElementById('outside-circle-limit');
    const elPositionsList = document.getElementById('squad-positions-flex');

    // 1. Initial Position Overlay Grid
    function renderPositionGrid() {
      if (!elGridOverlay) return;
      elGridOverlay.innerHTML = '';
      fieldingPositions.forEach(pos => {
        const dot = document.createElement('div');
        dot.className = 'grid-position-dot';
        dot.dataset.id = pos.id;
        dot.innerText = pos.abbr;
        
        // Handle Handedness horizontal mirroring for background dots
        let xCoord = pos.x;
        if (state.batterHandedness === 'LHB') {
          xCoord = 100 - pos.x;
        }

        dot.style.left = `${xCoord}%`;
        dot.style.top = `${pos.y}%`;
        
        // Tooltip handlers
        dot.addEventListener('mouseenter', (e) => {
          showTooltip(pos.name + ` (${pos.abbr})`, xCoord, pos.y);
        });
        dot.addEventListener('mouseleave', hideTooltip);

        elGridOverlay.appendChild(dot);
      });
    }

    // 2. Render and Animate the 11 Fielders
    function renderFielders() {
      if (!elTokensContainer) return;

      const stageData = playbookStages[state.currentStage];
      const activePositions = stageData.positions;
      
      // Calculate how many are outside the 30-yard circle
      let outsideCount = 0;
      
      activePositions.forEach((posId, idx) => {
        const posData = fieldingPositions.find(p => p.id === posId);
        if (!posData) return;

        // Euclidean distance from center (50, 50)
        const dist = Math.sqrt(Math.pow(posData.x - 50, 2) + Math.pow(posData.y - 50, 2));
        if (dist > 28) {
          outsideCount++;
        }

        // Check if token already exists in DOM to animate smoothly
        let token = elTokensContainer.querySelector(`.player-token[data-idx="${idx}"]`);
        if (!token) {
          token = document.createElement('div');
          token.className = 'player-token';
          token.dataset.idx = idx;

          const label = document.createElement('span');
          label.className = 'player-name-label';
          token.appendChild(label);

          // Click to highlight position item list
          token.addEventListener('click', (e) => {
            e.stopPropagation();
            highlightListItem(posId);
          });

          elTokensContainer.appendChild(token);
        }

        // Determine token roles and styles
        token.className = 'player-token';
        if (posId === 'wk') {
          token.classList.add('token-wk');
          token.childNodes[0].textContent = 'WK';
          token.querySelector('.player-name-label').innerText = 'Wicket Keeper';
        } else if (posId === 'bowler') {
          token.classList.add('token-bowler');
          token.childNodes[0].textContent = 'BW';
          token.querySelector('.player-name-label').innerText = 'Bowler';
        } else {
          token.classList.add('token-fielder');
          token.childNodes[0].textContent = posData.abbr;
          token.querySelector('.player-name-label').innerText = posData.name;
        }

        token.dataset.id = posId;

        // Perform Horizontal Reflection if LHB
        let targetX = posData.x;
        if (state.batterHandedness === 'LHB') {
          targetX = 100 - posData.x;
        }

        token.style.left = `${targetX}%`;
        token.style.top = `${posData.y}%`;

        // Tooltip hover actions
        token.addEventListener('mouseenter', () => {
          showTooltip(posData.name + ` (${posData.abbr})`, targetX, posData.y);
        });
        token.addEventListener('mouseleave', hideTooltip);
      });

      // Update telemetries
      elOutsideCount.innerText = outsideCount;
      elOutsideLimit.innerText = state.isPowerplay ? '2' : '5';
      elTeleOutside.innerText = `${outsideCount} OUTSIDE`;
    }

    // 3. Highlight list items and flash tokens
    function highlightListItem(posId) {
      document.querySelectorAll('.position-item-btn').forEach(btn => {
        if (btn.dataset.id === posId) {
          btn.style.borderColor = 'var(--accent)';
          btn.style.background = 'rgba(125, 211, 160, 0.1)';
          setTimeout(() => {
            btn.style.borderColor = '';
            btn.style.background = '';
          }, 1500);
        }
      });

      // Flash player token
      const token = elTokensContainer.querySelector(`.player-token[data-id="${posId}"]`);
      if (token) {
        token.classList.add('flash-glow');
        setTimeout(() => {
          token.classList.remove('flash-glow');
        }, 1500);
      }
    }

    // 4. Update the detailed Explanation commentary side cards
    function renderCommentary() {
      const stageData = playbookStages[state.currentStage];
      
      elStageTag.innerText = stageData.tag;
      elStrategyTitle.innerText = stageData.title;
      elTelePhase.innerText = state.isPowerplay ? 'POWERPLAY (OVERS 1-6)' : 'NON-POWERPLAY (OVERS 7-20)';
      elTeleStrike.innerText = state.batterHandedness;
      elExplanation.innerText = stageData.explanation;

      // Populate list of positions
      if (elPositionsList) {
        elPositionsList.innerHTML = '';
        stageData.positions.forEach(posId => {
          const posData = fieldingPositions.find(p => p.id === posId);
          if (!posData) return;

          const btn = document.createElement('button');
          btn.className = 'position-item-btn';
          btn.dataset.id = posId;

          const abbr = document.createElement('span');
          abbr.className = 'pos-item-abbr';
          abbr.innerText = posData.abbr;

          const name = document.createElement('span');
          name.className = 'pos-item-name';
          name.innerText = posData.name;

          btn.appendChild(abbr);
          btn.appendChild(name);

          btn.addEventListener('click', () => {
            highlightListItem(posId);
          });

          elPositionsList.appendChild(btn);
        });
      }
    }

    // Tooltip Helpers
    function showTooltip(text, xPct, yPct) {
      if (!elTooltip) return;
      elTooltip.innerText = text;
      elTooltip.style.left = `${xPct}%`;
      elTooltip.style.top = `${yPct}%`;
      elTooltip.classList.remove('hidden-tooltip');
    }
    function hideTooltip() {
      if (elTooltip) {
        elTooltip.classList.add('hidden-tooltip');
      }
    }

    // Synchronize Timeline with Manual Controls
    function syncControls() {
      const stageData = playbookStages[state.currentStage];
      
      state.batterHandedness = stageData.batterHandedness;
      state.isPowerplay = stageData.isPowerplay;

      // Handedness toggle update
      if (elHandednessBtn) {
        const badge = elHandednessBtn.querySelector('.toggle-badge');
        const txt = elHandednessBtn.querySelector('.toggle-text');
        
        badge.innerText = state.batterHandedness;
        txt.innerText = state.batterHandedness === 'RHB' ? 'RIGHT-HANDED' : 'LEFT-HANDED';
        
        if (state.batterHandedness === 'LHB') {
          elHandednessBtn.classList.add('active-state');
        } else {
          elHandednessBtn.classList.remove('active-state');
        }
      }

      // Powerplay toggle update
      if (elPowerplayBtn) {
        const txt = elPowerplayBtn.querySelector('.toggle-text');
        txt.innerText = state.isPowerplay ? 'POWERPLAY ACTIVE' : 'NON-POWERPLAY';
        
        if (state.isPowerplay) {
          elPowerplayBtn.classList.add('active-state');
        } else {
          elPowerplayBtn.classList.remove('active-state');
        }
      }

      // Slider timeline labels update active states
      document.querySelectorAll('.timeline-label').forEach(lbl => {
        lbl.classList.remove('active');
        if (parseInt(lbl.dataset.step) === state.currentStage) {
          lbl.classList.add('active');
        }
      });
    }

    // Initialize Redraw Routine
    function drawPlaybook() {
      syncControls();
      renderPositionGrid();
      renderFielders();
      renderCommentary();
    }

    // Timeline Slider Range handler
    if (elRangeSlider) {
      elRangeSlider.addEventListener('input', (e) => {
        state.currentStage = parseInt(e.target.value);
        drawPlaybook();
      });
    }

    // Make timeline labels clickable directly
    document.querySelectorAll('.timeline-label').forEach(lbl => {
      lbl.addEventListener('click', () => {
        const step = parseInt(lbl.dataset.step);
        state.currentStage = step;
        if (elRangeSlider) elRangeSlider.value = step;
        drawPlaybook();
      });
    });

    // Manual controls: Handedness Switch
    if (elHandednessBtn) {
      elHandednessBtn.addEventListener('click', () => {
        state.batterHandedness = state.batterHandedness === 'RHB' ? 'LHB' : 'RHB';
        drawPlaybook();
      });
    }

    // Manual controls: Powerplay Switch
    if (elPowerplayBtn) {
      elPowerplayBtn.addEventListener('click', () => {
        state.isPowerplay = !state.isPowerplay;
        drawPlaybook();
      });
    }

    // Manual controls: Show Grid Switch
    if (elOverlayBtn) {
      elOverlayBtn.addEventListener('click', () => {
        state.showGrid = !state.showGrid;
        if (state.showGrid) {
          elOverlayBtn.classList.add('active-state');
          elGridOverlay.classList.remove('hidden-grid');
        } else {
          elOverlayBtn.classList.remove('active-state');
          elGridOverlay.classList.add('hidden-grid');
        }
      });
    }

    // Draw initial playbook instance
    drawPlaybook();
  }

  // Bind to dynamic page-loads and hard refreshes
  initPlaybook();
  document.addEventListener('astro:page-load', initPlaybook);
</script>
