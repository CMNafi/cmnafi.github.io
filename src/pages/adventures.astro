---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
---

<BaseLayout
  title="Adventures"
  description="Field notes from time away from the desk: travel, movement, moments on the way, and stories still settling."
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Adventures"
      title="Stories gathered while moving"
      description="A future home for travel notes, off-routine observations, and the kinds of moments that sharpen the rest of the work."
    />

    <div class="panel current-brewing narrow-stack">
      <p>
        This section is still brewing. It will hold reflections from trips, city walks, detours, and the small scenes that end up changing how I think.
      </p>
      <p>
        For now, the best place to follow what is in motion is the <a href="/now">Now page</a>, alongside the <a href="/blog">blog</a> and ongoing <a href="/projects">projects</a>.
      </p>
    </div>
  </section>
</BaseLayout>
