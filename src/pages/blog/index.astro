---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import InterestWorldNav from '@/components/InterestWorldNav.astro';
import { getInterestSectionByCategory, interestSections } from '@/data/interests';
import { formatDate } from '@/utils/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft && ['Books', 'Cricket'].includes(data.category))).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const timelineEntries = posts.map((post) => ({
  post,
  section: getInterestSectionByCategory(post.data.category)
}));

const filters = ['All', ...interestSections.map((section) => section.id)];
---

<BaseLayout title="Timeline" description="The public archive now stays simple: cricket writing and the books I have kept notes on.">
  <div class="timeline-page">
<section class="page-section timeline-page__hero">
      <div class="timeline-page__intro">
        <p class="eyebrow">Timeline</p>
        <h1>The public archive stays simple now.</h1>
        <p>
          This page keeps only the writing I still want to stand behind in public: cricket match stories and the book
          notes that earned a place on the shelf. Anything looser lives under TBD.
        </p>
      </div>

      <InterestWorldNav current="timeline" />
    </section>

    <section class="page-section panel timeline-page__panel">
      <div class="timeline-page__controls" role="tablist" aria-label="Timeline world filters">
        {filters.map((filter, index) => (
          <button class="directory-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-timeline-filter={filter}>
            {filter === 'All' ? 'All entries' : interestSections.find((section) => section.id === filter)?.title}
          </button>
        ))}

        <label class="search-input">
          <span class="sr-only">Search timeline</span>
          <input type="search" placeholder="Search title or tag" data-timeline-search />
        </label>
      </div>

      <div class="timeline-stream">
        {timelineEntries.map(({ post, section }) => (
          <article
            class="timeline-stream__entry"
            data-world={section.id}
            data-search={`${post.data.title} ${post.data.tags.join(' ')}`.toLowerCase()}
            style={`--entry-accent:${section.palette.accent}; --entry-border:${section.palette.border}; --entry-glow:${section.palette.glow};`}
          >
            <div class="timeline-stream__date">
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
            </div>
            <div class="timeline-stream__line" aria-hidden="true"></div>
            <div class="panel timeline-stream__card">
              <div class="timeline-stream__meta">
                <span class="timeline-stream__world">{section.title}</span>
                <span>{post.data.readingTime}</span>
              </div>
              <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <div class="timeline-stream__footer">
                <div class="tag-row">
                  {post.data.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
                </div>
                <a href={section.href}>Enter {section.title}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>

  <script>
    const initTimelineFilters = () => {
      const buttons = Array.from(document.querySelectorAll('[data-timeline-filter]'));
      const searchInput = document.querySelector('[data-timeline-search]');
      const entries = Array.from(document.querySelectorAll('.timeline-stream__entry'));
      let activeFilter = 'All';
      let searchTerm = '';

      const applyFilters = () => {
        entries.forEach((entry) => {
          const world = entry.getAttribute('data-world');
          const searchText = entry.getAttribute('data-search') || '';
          const matchesFilter = activeFilter === 'All' || world === activeFilter;
          const matchesSearch = searchText.includes(searchTerm);
          entry.toggleAttribute('hidden', !(matchesFilter && matchesSearch));
        });
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          activeFilter = button.getAttribute('data-timeline-filter') || 'All';
          buttons.forEach((candidate) => candidate.setAttribute('aria-selected', String(candidate === button)));
          applyFilters();
        });
      });

      searchInput?.addEventListener('input', (event) => {
        searchTerm = event.target.value.toLowerCase().trim();
        applyFilters();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimelineFilters, { once: true });
    } else {
      initTimelineFilters();
    }
  </script>
</BaseLayout>

<style>
  .timeline-page {
    position: relative;
    padding-bottom: 4rem;
  }

  .timeline-page__hero {
    display: grid;
    gap: 1rem;
    padding-top: clamp(2rem, 6vw, 4rem);
  }

  .timeline-page__intro {
    max-width: 42rem;
  }

  .timeline-page__intro h1,
  .timeline-stream__card h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .timeline-page__intro h1 {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    margin-bottom: 0.75rem;
  }

  .timeline-page__intro p,
  .timeline-stream__card p {
    margin: 0;
    color: rgba(243, 237, 225, 0.74);
    line-height: 1.78;
  }

  .timeline-page__panel {
    display: grid;
    gap: 1.2rem;
    padding: clamp(1.1rem, 3vw, 1.6rem);
  }

  .timeline-page__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .timeline-stream {
    display: grid;
    gap: 1rem;
  }

  .timeline-stream__entry {
    display: grid;
    grid-template-columns: auto 1.2rem minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .timeline-stream__date {
    min-width: 10rem;
    padding-top: 0.65rem;
  }

  .timeline-stream__date time,
  .timeline-stream__world {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    font-family: 'Manrope', sans-serif;
  }

  .timeline-stream__date time {
    padding: 0.34rem 0.7rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--entry-accent);
    background: color-mix(in srgb, var(--entry-accent) 12%, transparent);
    border: 1px solid var(--entry-border);
  }

  .timeline-stream__line {
    position: relative;
  }

  .timeline-stream__line::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(180deg, var(--entry-accent), rgba(243, 237, 225, 0.08));
    opacity: 0.5;
  }

  .timeline-stream__line::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 1rem;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
    transform: translateX(-50%);
    background: var(--entry-accent);
    box-shadow: 0 0 0 10px color-mix(in srgb, var(--entry-accent) 18%, transparent);
  }

  .timeline-stream__card {
    display: grid;
    gap: 0.75rem;
    padding: 1.15rem;
    border-radius: 24px;
    border-color: var(--entry-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top right, var(--entry-glow), transparent 36%);
  }

  .timeline-stream__meta,
  .timeline-stream__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: space-between;
    align-items: center;
  }

  .timeline-stream__meta {
    justify-content: flex-start;
  }

  .timeline-stream__meta span:last-child {
    color: rgba(243, 237, 225, 0.6);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .timeline-stream__world {
    padding: 0.3rem 0.65rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--entry-accent);
    background: color-mix(in srgb, var(--entry-accent) 12%, transparent);
    border: 1px solid var(--entry-border);
  }

  .timeline-stream__card h2 {
    font-size: clamp(1.6rem, 3vw, 2rem);
    line-height: 1.06;
  }

  .timeline-stream__footer a {
    color: var(--entry-accent);
  }

  @media (max-width: 720px) {
    .timeline-stream__entry {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .timeline-stream__date {
      min-width: 0;
      padding-top: 0;
    }

    .timeline-stream__line {
      display: none;
    }
  }
</style>
