---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { starterFormAdvFirms } from '@/data/form-adv/firms';
import { starterFormAdvSnapshots } from '@/data/form-adv/snapshots';

const differentiators = [
  {
    title: 'Source-first',
    description: 'The official IAPD summary, ADV PDF, and CRS PDF stay central instead of getting buried under product chrome.'
  },
  {
    title: 'Live-ready',
    description: 'V3 can read a Supabase-backed current-firms view and fall back safely to seeded coverage if that layer is not online yet.'
  },
  {
    title: 'Change-aware',
    description: 'Seeded snapshot history and live snapshot lookups help surface what changed instead of forcing every review to start from zero.'
  },
  {
    title: 'Built for diligence',
    description: 'Watchlists, compare, memo output, and CSV export are designed around the first 10 minutes of real manager triage.'
  }
] as const;

const sourceLinks = [
  {
    label: 'SEC Form ADV data',
    href: 'https://www.sec.gov/foia-services/frequently-requested-documents/form-adv-data',
    note: 'The official SEC page for adviser datasets and filing access.'
  },
  {
    label: 'IAPD',
    href: 'https://adviserinfo.sec.gov/',
    note: 'The authoritative public search flow for adviser records and reports.'
  },
  {
    label: 'Investor.gov',
    href: 'https://www.investor.gov/investment-professionals',
    note: 'A public explainer on how to verify advisers and registration status.'
  }
] as const;

const starterStats = [
  { label: 'Starter firms', value: String(starterFormAdvFirms.length) },
  { label: 'Seeded snapshots', value: String(starterFormAdvSnapshots.length) },
  { label: 'Workspace', value: 'Watchlist + compare' },
  { label: 'Output', value: 'Memo + CSV' }
] as const;

const supabaseEnv = {
  supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL ?? '',
  supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''
};
---

<BaseLayout
  title="Form ADV Data Finder V3"
  description="A live-ready Form ADV research workspace with source-pack jumps, current-firm search, snapshot history, compare, watchlists, and export."
>
  <section class="page-section adv-page">
    <div class="panel adv-hero">
      <SectionHeading
        eyebrow="Research app"
        title="Form ADV Data Finder V3"
        description="A live-ready front door for adviser diligence: current-firm search when the data layer is available, seeded fallback when it is not, and a workspace that keeps the research moving."
      />
      <p class="adv-hero__lead">
        I built this version for the moment when you have a few adviser names, a few open questions, and no patience for the usual tab maze. V3 keeps the official documents central, but now it can also support a live current-firms layer, seeded snapshot history, and change-aware triage instead of making every pass start from zero.
      </p>

      <div class="adv-hero__stats" aria-label="Form ADV Data Finder stats">
        {starterStats.map((item) => (
          <div class="adv-stat">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>

      <div class="adv-hero__actions">
        <a class="button button-primary" href="/projects/apps">Back to apps</a>
        <a class="button button-ghost" href="/projects/form-adv-data-finder">Read case study</a>
      </div>
    </div>

    <div class="adv-grid">
      <article class="panel adv-panel">
        <p class="eyebrow">Why this version is different</p>
        <div class="adv-differentiators">
          {differentiators.map((item) => (
            <div class="adv-differentiator">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="panel adv-panel">
        <p class="eyebrow">Official backbone</p>
        <ul class="adv-source-list">
          {sourceLinks.map((item) => (
            <li>
              <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
              <p>{item.note}</p>
            </li>
          ))}
        </ul>
      </article>
    </div>

    <section class="panel adv-workspace" aria-labelledby="adv-workspace-heading">
      <div class="adv-workspace__header">
        <div>
          <p class="eyebrow">Workspace</p>
          <h2 id="adv-workspace-heading">Search, shortlist, compare, export.</h2>
          <p>
            Paste a CRD, an adviser summary URL, or part of a firm name. V3 will use the live current-firms table if it is available, fall back to seeded coverage if it is not, and still give you the official source pack immediately.
          </p>
        </div>
      </div>

      <article class="panel adv-status-panel" id="adv-status-panel">
        <p class="adv-empty">Checking whether the live Form ADV layer is available.</p>
      </article>

      <div class="adv-controls">
        <label class="adv-field adv-field--grow">
          <span>Firm name, CRD, or adviser URL</span>
          <input
            id="adv-search-input"
            type="search"
            placeholder="Try 300050, Gamma, or an adviserinfo summary URL"
            autocomplete="off"
          />
        </label>

        <label class="adv-field adv-field--compact">
          <span>Coverage</span>
          <select id="adv-coverage-filter">
            <option value="all">All firms</option>
            <option value="fees">Fee detail</option>
            <option value="services">Service detail</option>
            <option value="brochure">Brochure audiences</option>
            <option value="states">State registrations</option>
          </select>
        </label>

        <label class="adv-field adv-field--compact">
          <span>Sort</span>
          <select id="adv-sort-filter">
            <option value="score">Coverage score</option>
            <option value="name">Firm name</option>
            <option value="crd">CRD</option>
          </select>
        </label>

        <label class="adv-field adv-field--compact">
          <span>Signal</span>
          <select id="adv-signal-filter">
            <option value="all">All signals</option>
            <option value="changed">Changed recently</option>
            <option value="disclosures">Has disclosures</option>
            <option value="retail">Retail-facing</option>
            <option value="institutional">Institutional</option>
            <option value="multistate">Multi-state</option>
          </select>
        </label>

        <div class="adv-control-actions">
          <button class="button button-ghost adv-clear-btn" type="button" id="adv-clear-search">Clear</button>
          <button class="button button-ghost adv-clear-btn" type="button" id="adv-refresh-live">Refresh live</button>
        </div>
      </div>

      <div class="adv-bottom-grid">
        <div class="adv-column">
          <article class="panel adv-generated" id="adv-generated-panel">
            <p class="adv-empty">Enter a CRD or firm name to generate the official source pack and, when available, the latest tracked change summary.</p>
          </article>

          <article class="panel adv-workspace-panel" id="adv-workspace-panel">
            <div class="adv-workspace-panel__summary">
              <div>
                <strong id="adv-watchlist-count">0</strong>
                <span>Watchlist</span>
              </div>
              <div>
                <strong id="adv-compare-count">0</strong>
                <span>Compare</span>
              </div>
              <div>
                <strong id="adv-memo-count">0</strong>
                <span>Memo rows</span>
              </div>
            </div>

            <div class="adv-workspace-panel__actions">
              <button class="button button-primary" type="button" id="adv-copy-memo">Copy memo</button>
              <button class="button button-ghost" type="button" id="adv-download-csv">Download CSV</button>
              <button class="button button-ghost" type="button" id="adv-clear-workspace">Clear workspace</button>
            </div>
          </article>
        </div>

        <div class="adv-column adv-column--wide">
          <div class="adv-results-head">
            <div>
              <p class="eyebrow">Research surface</p>
              <h3 id="adv-results-title">Starter firms ready for triage</h3>
            </div>
            <button class="button button-ghost" type="button" id="adv-reset-compare">Reset compare</button>
          </div>

          <div class="adv-results" id="adv-results"></div>
        </div>
      </div>

      <div class="adv-bottom-grid adv-bottom-grid--final">
        <article class="panel adv-compare" id="adv-compare-panel">
          <p class="adv-empty">Add up to three firms to compare the key details side by side.</p>
        </article>

        <article class="panel adv-memo">
          <div class="adv-memo__head">
            <div>
              <p class="eyebrow">Draft memo</p>
              <h3>Research handoff text</h3>
            </div>
            <p>This updates from your watchlist and compare tray so you can move faster into notes or a real diligence doc.</p>
          </div>
          <pre id="adv-memo-output">No firms in the workspace yet.</pre>
        </article>
      </div>
    </section>
  </section>

  <script id="adv-firm-data" type="application/json" set:html={JSON.stringify(starterFormAdvFirms)}></script>
  <script id="adv-snapshot-data" type="application/json" set:html={JSON.stringify(starterFormAdvSnapshots)}></script>
  <script id="adv-supabase-env" type="application/json" set:html={JSON.stringify(supabaseEnv)}></script>
</BaseLayout>
<script>
  import { createClient } from '@supabase/supabase-js';

  const storageKeys = {
    watchlist: 'adv-data-finder-watchlist-v3',
    compare: 'adv-data-finder-compare-v3'
  };

  const parseJsonNode = (id) => {
    const node = document.getElementById(id);
    return node ? JSON.parse(node.textContent || '[]') : [];
  };

  const starterFirms = parseJsonNode('adv-firm-data');
  const starterSnapshots = parseJsonNode('adv-snapshot-data');
  const env = parseJsonNode('adv-supabase-env');

  const searchInput = document.getElementById('adv-search-input');
  const coverageFilter = document.getElementById('adv-coverage-filter');
  const sortFilter = document.getElementById('adv-sort-filter');
  const signalFilter = document.getElementById('adv-signal-filter');
  const clearSearchButton = document.getElementById('adv-clear-search');
  const refreshLiveButton = document.getElementById('adv-refresh-live');
  const resultsNode = document.getElementById('adv-results');
  const generatedPanel = document.getElementById('adv-generated-panel');
  const comparePanel = document.getElementById('adv-compare-panel');
  const memoOutput = document.getElementById('adv-memo-output');
  const watchlistCount = document.getElementById('adv-watchlist-count');
  const compareCount = document.getElementById('adv-compare-count');
  const memoCount = document.getElementById('adv-memo-count');
  const copyMemoButton = document.getElementById('adv-copy-memo');
  const downloadCsvButton = document.getElementById('adv-download-csv');
  const clearWorkspaceButton = document.getElementById('adv-clear-workspace');
  const resetCompareButton = document.getElementById('adv-reset-compare');
  const resultsTitle = document.getElementById('adv-results-title');
  const statusPanel = document.getElementById('adv-status-panel');

  const normalize = (value) => (value || '').toString().toLowerCase().trim();

  const escapeHtml = (value) =>
    (value || '')
      .toString()
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const buildLinks = (crd) => ({
    summary: `https://adviserinfo.sec.gov/firm/summary/${crd}`,
    advPdf: `https://reports.adviserinfo.sec.gov/reports/ADV/${crd}/PDF/${crd}.pdf`,
    crsPdf: `https://reports.adviserinfo.sec.gov/crs/crs_${crd}.pdf`
  });

  const extractCRD = (input) => {
    const text = (input || '').trim();
    if (!text) return '';
    const summaryMatch = text.match(/firm\/summary\/(\d+)/i);
    if (summaryMatch) return summaryMatch[1];
    const pdfMatch = text.match(/\/(\d{4,})\.pdf/i);
    if (pdfMatch) return pdfMatch[1];
    const digitMatch = text.match(/\b(\d{4,})\b/);
    return digitMatch ? digitMatch[1] : '';
  };

  const loadRecordStore = (key) => {
    try {
      const raw = localStorage.getItem(key);
      return raw ? JSON.parse(raw) : {};
    } catch {
      return {};
    }
  };

  const watchlistStore = loadRecordStore(storageKeys.watchlist);
  const compareStore = loadRecordStore(storageKeys.compare);

  const state = {
    supabase: null,
    liveReady: false,
    liveLoading: false,
    liveError: '',
    dataMode: 'seeded',
    lastSyncLabel: '',
    currentResults: [],
    currentCache: {},
    seededHistory: {},
    historyCache: {},
    refreshTimer: null
  };

  const persistWorkspace = () => {
    localStorage.setItem(storageKeys.watchlist, JSON.stringify(watchlistStore));
    localStorage.setItem(storageKeys.compare, JSON.stringify(compareStore));
  };

  const getPriorityLabel = (score) => {
    if (score >= 82) return 'High signal';
    if (score >= 62) return 'Strong starter';
    return 'Source pack ready';
  };

  const scoreFirm = (firm) => {
    let score = 25;
    if (firm.serviceSnapshot) score += 16;
    if (firm.feeSnapshot) score += 16;
    if (firm.brochureAudiences?.length) score += 8;
    if (firm.stateRegistrations?.length) score += 8;
    if ((firm.disclosureCount || 0) > 0) score += 8;
    if (firm.latestChanges?.length) score += 8;
    if (firm.aumBucket) score += 5;
    if (firm.headquarters) score += 3;
    if (firm.phone) score += 3;
    score += Math.min((firm.sourceCoverage?.length || 0) * 4, 12);
    return Math.min(score, 100);
  };

  const getNextRead = (firm) =>
    firm.nextRead || 'Start with the source pack, verify identity, then move to registration, services, and disclosures.';

  const matchesCoverage = (firm, coverage) => {
    if (coverage === 'all') return true;
    if (coverage === 'fees') return Boolean(firm.feeSnapshot);
    if (coverage === 'services') return Boolean(firm.serviceSnapshot);
    if (coverage === 'brochure') return Boolean(firm.brochureAudiences?.length);
    if (coverage === 'states') return Boolean(firm.stateRegistrations?.length);
    return true;
  };

  const matchesSignal = (firm, signal) => {
    if (signal === 'all') return true;
    if (signal === 'changed') return Boolean((firm.latestChanges || []).length);
    if (signal === 'disclosures') return (firm.disclosureCount || 0) > 0;
    if (signal === 'retail') return (firm.clientFocus || []).some((item) => normalize(item).includes('retail'));
    if (signal === 'institutional') return (firm.clientFocus || []).some((item) => normalize(item).includes('institution'));
    if (signal === 'multistate') return (firm.stateRegistrations || []).length >= 5;
    return true;
  };

  const sortFirms = (firms, sortValue) => {
    const sorted = [...firms];
    sorted.sort((left, right) => {
      if (sortValue === 'name') return left.name.localeCompare(right.name);
      if (sortValue === 'crd') return left.crd.localeCompare(right.crd);
      return scoreFirm(right) - scoreFirm(left);
    });
    return sorted;
  };

  const groupSeededHistory = () => {
    starterSnapshots.forEach((snapshot) => {
      if (!state.seededHistory[snapshot.crd]) state.seededHistory[snapshot.crd] = [];
      state.seededHistory[snapshot.crd].push(snapshot);
    });

    Object.keys(state.seededHistory).forEach((crd) => {
      state.seededHistory[crd].sort((left, right) => String(right.snapshotDate).localeCompare(String(left.snapshotDate)));
    });
  };

  const hydrateFirmFromSnapshot = (snapshot, previousSnapshot = null) => ({
    name: snapshot.firmName,
    crd: snapshot.crd,
    secFile: snapshot.secNumber || '',
    aliases: snapshot.aliases || [],
    headquarters: snapshot.headquarters || '',
    phone: snapshot.phone || '',
    website: snapshot.website || '',
    registrationSnapshot: snapshot.registrationSnapshot,
    serviceSnapshot: snapshot.serviceSnapshot || '',
    feeSnapshot: snapshot.feeSnapshot || '',
    brochureAudiences: snapshot.brochureAudiences || [],
    stateRegistrations: snapshot.stateRegistrations || [],
    focusTags: snapshot.focusTags || [],
    nextRead: snapshot.nextRead || '',
    notes: snapshot.notes || [],
    sourceCoverage: snapshot.sourceCoverage || [],
    aumBucket: snapshot.aumBucket || '',
    clientFocus: snapshot.clientFocus || [],
    officeCount: snapshot.officeCount || null,
    disclosureCount: snapshot.disclosureCount || 0,
    latestChanges: snapshot.latestChanges || (previousSnapshot ? ['No normalized field changes detected against the previous snapshot.'] : ['First tracked snapshot in this workspace.']),
    lastUpdated: snapshot.snapshotDate || '',
    links: snapshot.links || buildLinks(snapshot.crd),
    sourceMode: 'seeded'
  });

  const seededFirmLookup = {};

  const buildSeededFirms = () => {
    const firms = [];
    Object.entries(state.seededHistory).forEach(([crd, snapshots]) => {
      const latest = snapshots[0];
      const previous = snapshots[1] || null;
      const hydrated = hydrateFirmFromSnapshot(latest, previous);
      seededFirmLookup[crd] = hydrated;
      firms.push(hydrated);
    });

    starterFirms.forEach((firm) => {
      if (seededFirmLookup[firm.crd]) return;
      const hydrated = {
        ...firm,
        name: firm.name,
        lastUpdated: '',
        disclosureCount: 0,
        latestChanges: ['Starter coverage only. No snapshot history tracked yet.'],
        aumBucket: '',
        clientFocus: [],
        officeCount: null,
        sourceMode: 'seeded'
      };
      seededFirmLookup[firm.crd] = hydrated;
      firms.push(hydrated);
    });

    return firms;
  };

  groupSeededHistory();
  const seededFirms = buildSeededFirms();

  const toLiveFirm = (row) => ({
    name: row.firm_name,
    crd: row.crd,
    secFile: row.sec_number || '',
    aliases: row.aliases || [],
    headquarters: row.headquarters || '',
    phone: row.phone || '',
    website: row.website || '',
    registrationSnapshot: row.registration_snapshot || 'Current row from live Form ADV table.',
    serviceSnapshot: row.service_snapshot || '',
    feeSnapshot: row.fee_snapshot || '',
    brochureAudiences: row.brochure_audiences || [],
    stateRegistrations: row.state_registrations || [],
    focusTags: row.focus_tags || [],
    nextRead: row.next_read || '',
    notes: row.notes || [],
    sourceCoverage: row.source_coverage || ['Live Form ADV current view'],
    aumBucket: row.aum_bucket || '',
    clientFocus: row.client_focus || [],
    officeCount: row.office_count ?? null,
    disclosureCount: row.disclosure_count || 0,
    latestChanges: row.latest_changes || [],
    lastUpdated: row.snapshot_date || '',
    links: buildLinks(row.crd),
    sourceMode: 'live'
  });

  const getWorkspaceRecords = () => {
    const records = {};
    Object.values(watchlistStore).forEach((firm) => {
      if (firm?.crd) records[firm.crd] = firm;
    });
    Object.values(compareStore).forEach((firm) => {
      if (firm?.crd) records[firm.crd] = firm;
    });
    return Object.values(records);
  };

  const buildMemoText = () => {
    const firms = getWorkspaceRecords();
    if (!firms.length) return 'No firms in the workspace yet.';

    const lines = ['# Form ADV Research Memo', '', `Data mode: ${state.dataMode === 'live' ? 'Live current-firms view' : 'Seeded fallback'}`, ''];
    firms.forEach((firm) => {
      lines.push(`## ${firm.name} (${firm.crd})`);
      lines.push(`- Coverage score: ${scoreFirm(firm)} / 100 (${getPriorityLabel(scoreFirm(firm))})`);
      lines.push(`- Source mode: ${firm.sourceMode || state.dataMode}`);
      if (firm.lastUpdated) lines.push(`- Last snapshot: ${firm.lastUpdated}`);
      lines.push(`- Registration: ${firm.registrationSnapshot}`);
      if (firm.serviceSnapshot) lines.push(`- Services: ${firm.serviceSnapshot}`);
      if (firm.feeSnapshot) lines.push(`- Fees: ${firm.feeSnapshot}`);
      if ((firm.stateRegistrations || []).length) lines.push(`- States: ${firm.stateRegistrations.join(', ')}`);
      if ((firm.clientFocus || []).length) lines.push(`- Client focus: ${firm.clientFocus.join(', ')}`);
      if ((firm.latestChanges || []).length) lines.push(`- Latest changes: ${firm.latestChanges.join(' | ')}`);
      lines.push(`- Next read: ${getNextRead(firm)}`);
      lines.push(`- IAPD summary: ${firm.links.summary}`);
      lines.push(`- ADV PDF: ${firm.links.advPdf}`);
      lines.push(`- CRS PDF: ${firm.links.crsPdf}`);
      lines.push('');
    });

    return lines.join('\n');
  };

  const renderStatusPanel = () => {
    if (!statusPanel) return;

    if (state.liveLoading) {
      statusPanel.innerHTML = '<p class="adv-empty">Checking the live Form ADV current-firms view.</p>';
      return;
    }

    const copy = state.liveReady
      ? `Live current-firms view connected. Results are coming from Supabase, and snapshot history will be pulled on demand. ${state.lastSyncLabel ? `Last checked ${state.lastSyncLabel}.` : ''}`
      : `Seeded fallback is active. ${state.liveError || 'To unlock live search, apply supabase/form_adv_firm_snapshots.sql and import the SEC adviser dataset into Supabase.'}`;

    statusPanel.innerHTML = `
      <div class="adv-status-panel__grid">
        <div>
          <p class="eyebrow">Data mode</p>
          <h3>${state.liveReady ? 'Live current-firms view' : 'Seeded fallback'}</h3>
          <p>${escapeHtml(copy)}</p>
        </div>
        <div class="adv-status-panel__meta">
          <div><strong>${state.currentResults.length}</strong><span>Visible results</span></div>
          <div><strong>${state.liveReady ? 'Yes' : 'No'}</strong><span>Live table</span></div>
          <div><strong>${getWorkspaceRecords().length}</strong><span>Workspace firms</span></div>
        </div>
      </div>
    `;
  };

  const cacheFirm = (firm) => {
    state.currentCache[firm.crd] = firm;
    return firm;
  };

  const getFirmFromInput = (rawInput) => {
    const query = normalize(rawInput);
    const crd = extractCRD(rawInput);
    if (crd && state.currentCache[crd]) return state.currentCache[crd];
    if (crd && watchlistStore[crd]) return watchlistStore[crd];
    if (crd && compareStore[crd]) return compareStore[crd];

    const candidates = [...Object.values(state.currentCache), ...Object.values(watchlistStore), ...Object.values(compareStore), ...seededFirms];
    return candidates.find((firm) => {
      const haystacks = [firm.name, firm.crd, firm.headquarters, ...(firm.aliases || []), ...(firm.focusTags || [])].map(normalize);
      return haystacks.some((item) => item.includes(query) || query.includes(item));
    });
  };

  const getHistoryForCRD = async (crd) => {
    if (!crd) return [];
    if (state.historyCache[crd]) return state.historyCache[crd];

    if (state.liveReady && state.supabase) {
      const { data, error } = await state.supabase
        .from('form_adv_firm_snapshots')
        .select('*')
        .eq('crd', crd)
        .order('snapshot_date', { ascending: false })
        .limit(8);

      if (!error && data?.length) {
        state.historyCache[crd] = data.map(toLiveFirm);
        return state.historyCache[crd];
      }
    }

    state.historyCache[crd] = (state.seededHistory[crd] || []).map((snapshot, index, all) =>
      hydrateFirmFromSnapshot(snapshot, all[index + 1] || null)
    );
    return state.historyCache[crd];
  };

  const buildTimelineMarkup = (history) => {
    if (!history.length) return '';
    return `
      <div class="adv-timeline">
        <p class="eyebrow">Tracked snapshots</p>
        <div class="adv-timeline__list">
          ${history
            .map(
              (firm) => `
                <div class="adv-timeline__item">
                  <strong>${escapeHtml(firm.lastUpdated || 'Undated')}</strong>
                  <span>${escapeHtml((firm.latestChanges || []).join(' | ') || 'No change notes yet.')}</span>
                </div>
              `
            )
            .join('')}
        </div>
      </div>
    `;
  };

  const renderGeneratedPanel = async () => {
    if (!generatedPanel) return;

    const rawInput = searchInput instanceof HTMLInputElement ? searchInput.value.trim() : '';
    if (!rawInput) {
      generatedPanel.innerHTML = '<p class="adv-empty">Enter a CRD or firm name to generate the official source pack and, when available, the latest tracked change summary.</p>';
      return;
    }

    const crd = extractCRD(rawInput);
    let firm = getFirmFromInput(rawInput);

    if (!firm && crd && state.liveReady && state.supabase) {
      const { data } = await state.supabase
        .from('form_adv_current_firms')
        .select('*')
        .eq('crd', crd)
        .limit(1)
        .maybeSingle();
      if (data) firm = cacheFirm(toLiveFirm(data));
    }

    const targetCRD = firm?.crd || crd;
    if (!targetCRD) {
      generatedPanel.innerHTML = `
        <p class="eyebrow">Need a CRD</p>
        <h3>No direct source pack yet</h3>
        <p class="adv-generated__copy">I can still search by firm name, but I need a CRD or adviser summary URL to build the official links cleanly.</p>
      `;
      return;
    }

    const links = firm?.links || buildLinks(targetCRD);
    const history = await getHistoryForCRD(targetCRD);
    const latestChanges = firm?.latestChanges?.length ? firm.latestChanges.join(' | ') : 'No tracked change note yet.';

    generatedPanel.innerHTML = `
      <p class="eyebrow">Official source pack</p>
      <h3>${escapeHtml(firm?.name || `CRD ${targetCRD}`)}</h3>
      <p class="adv-generated__copy">${escapeHtml(
        firm?.registrationSnapshot || 'This is the fastest clean path into the public filing stack.'
      )}</p>
      <div class="adv-link-grid">
        <a class="adv-link-card" href="${links.summary}" target="_blank" rel="noreferrer">
          <strong>IAPD summary</strong>
          <span>Firm identity, registration picture, and quick routing.</span>
        </a>
        <a class="adv-link-card" href="${links.advPdf}" target="_blank" rel="noreferrer">
          <strong>ADV PDF</strong>
          <span>Primary filing detail and operating context.</span>
        </a>
        <a class="adv-link-card" href="${links.crsPdf}" target="_blank" rel="noreferrer">
          <strong>CRS PDF</strong>
          <span>Retail-facing service and fee summary when available.</span>
        </a>
      </div>
      <p class="adv-next-read"><strong>Suggested first read:</strong> ${escapeHtml(
        firm ? getNextRead(firm) : 'Open the summary page first, confirm identity, then move into the ADV PDF.'
      )}</p>
      <p class="adv-next-read"><strong>Latest tracked change:</strong> ${escapeHtml(latestChanges)}</p>
      ${buildTimelineMarkup(history)}
    `;
  };

  const renderWorkspace = () => {
    const workspaceFirms = getWorkspaceRecords();
    if (watchlistCount) watchlistCount.textContent = String(Object.keys(watchlistStore).length);
    if (compareCount) compareCount.textContent = String(Object.keys(compareStore).length);
    if (memoCount) memoCount.textContent = String(workspaceFirms.length);
    if (memoOutput) memoOutput.textContent = buildMemoText();
  };

  const renderCompare = () => {
    if (!comparePanel) return;
    const firms = Object.values(compareStore);
    if (!firms.length) {
      comparePanel.innerHTML = '<p class="adv-empty">Add up to three firms to compare the key details side by side.</p>';
      return;
    }

    comparePanel.innerHTML = `
      <div class="adv-compare__head">
        <div>
          <p class="eyebrow">Compare</p>
          <h3>Side-by-side diligence view</h3>
        </div>
        <p>Keep this to two or three firms so the differences stay obvious.</p>
      </div>
      <div class="adv-compare__table-wrap">
        <table class="adv-compare__table">
          <thead>
            <tr>
              <th>Field</th>
              ${firms.map((firm) => `<th>${escapeHtml(firm.name)}</th>`).join('')}
            </tr>
          </thead>
          <tbody>
            <tr><td>CRD</td>${firms.map((firm) => `<td>${escapeHtml(firm.crd)}</td>`).join('')}</tr>
            <tr><td>Coverage score</td>${firms.map((firm) => `<td>${scoreFirm(firm)} / 100</td>`).join('')}</tr>
            <tr><td>Last snapshot</td>${firms.map((firm) => `<td>${escapeHtml(firm.lastUpdated || 'Starter only')}</td>`).join('')}</tr>
            <tr><td>Registration snapshot</td>${firms.map((firm) => `<td>${escapeHtml(firm.registrationSnapshot)}</td>`).join('')}</tr>
            <tr><td>Services</td>${firms.map((firm) => `<td>${escapeHtml(firm.serviceSnapshot || 'Not surfaced yet.')}</td>`).join('')}</tr>
            <tr><td>Fees</td>${firms.map((firm) => `<td>${escapeHtml(firm.feeSnapshot || 'Not surfaced yet.')}</td>`).join('')}</tr>
            <tr><td>AUM bucket</td>${firms.map((firm) => `<td>${escapeHtml(firm.aumBucket || 'Not surfaced yet.')}</td>`).join('')}</tr>
            <tr><td>Disclosures</td>${firms.map((firm) => `<td>${escapeHtml(String(firm.disclosureCount || 0))}</td>`).join('')}</tr>
            <tr><td>States</td>${firms.map((firm) => `<td>${escapeHtml((firm.stateRegistrations || []).join(', ') || 'Not surfaced yet.')}</td>`).join('')}</tr>
            <tr><td>Latest changes</td>${firms.map((firm) => `<td>${escapeHtml((firm.latestChanges || []).join(' | ') || 'No change notes yet.')}</td>`).join('')}</tr>
            <tr><td>Next read</td>${firms.map((firm) => `<td>${escapeHtml(getNextRead(firm))}</td>`).join('')}</tr>
          </tbody>
        </table>
      </div>
    `;
  };

  const renderResults = () => {
    if (!resultsNode) return;

    const rawQuery = searchInput instanceof HTMLInputElement ? searchInput.value.trim() : '';
    if (resultsTitle) {
      resultsTitle.textContent = rawQuery
        ? `${state.currentResults.length} ${state.dataMode} firms match this search`
        : `${state.dataMode === 'live' ? 'Live' : 'Seeded'} firms ready for triage`;
    }

    if (!state.currentResults.length) {
      resultsNode.innerHTML = '<p class="adv-empty">No firms matched this combination yet. Try a broader search or paste a CRD to generate the official source pack directly.</p>';
      return;
    }

    resultsNode.innerHTML = state.currentResults
      .map((firm) => {
        const score = scoreFirm(firm);
        const isSaved = Boolean(watchlistStore[firm.crd]);
        const isCompared = Boolean(compareStore[firm.crd]);

        return `
          <article class="adv-card">
            <div class="adv-card__head">
              <div>
                <p class="adv-card__eyebrow">${escapeHtml(getPriorityLabel(score))}</p>
                <h3>${escapeHtml(firm.name)}</h3>
                <p class="adv-card__meta">CRD ${escapeHtml(firm.crd)}${firm.headquarters ? ` · ${escapeHtml(firm.headquarters)}` : ''}</p>
              </div>
              <div class="adv-card__score">
                <strong>${score}</strong>
                <span>coverage</span>
              </div>
            </div>

            <p class="adv-card__summary">${escapeHtml(firm.registrationSnapshot)}</p>

            <div class="adv-tag-row">
              ${(firm.focusTags || []).map((tag) => `<span>${escapeHtml(tag)}</span>`).join('')}
              ${firm.aumBucket ? `<span>${escapeHtml(firm.aumBucket)}</span>` : ''}
              ${(firm.disclosureCount || 0) > 0 ? `<span>${escapeHtml(`${firm.disclosureCount} disclosures`)}</span>` : ''}
            </div>

            <dl class="adv-card__details">
              <div>
                <dt>Services</dt>
                <dd>${escapeHtml(firm.serviceSnapshot || 'This surface does not have service detail yet.')}</dd>
              </div>
              <div>
                <dt>Signals</dt>
                <dd>${escapeHtml(
                  [
                    firm.lastUpdated ? `Snapshot ${firm.lastUpdated}` : '',
                    (firm.clientFocus || []).length ? `Client focus: ${firm.clientFocus.join(', ')}` : '',
                    (firm.stateRegistrations || []).length ? `${firm.stateRegistrations.length} states surfaced` : '',
                    `${firm.disclosureCount || 0} disclosures`
                  ]
                    .filter(Boolean)
                    .join(' · ') || 'No additional signal layer yet.'
                )}</dd>
              </div>
              <div>
                <dt>Latest changes</dt>
                <dd>${escapeHtml((firm.latestChanges || []).join(' | ') || 'No change notes yet.')}</dd>
              </div>
            </dl>

            <p class="adv-card__next"><strong>Next read:</strong> ${escapeHtml(getNextRead(firm))}</p>

            <div class="adv-card__links">
              <a href="${firm.links.summary}" target="_blank" rel="noreferrer">Summary</a>
              <a href="${firm.links.advPdf}" target="_blank" rel="noreferrer">ADV PDF</a>
              <a href="${firm.links.crsPdf}" target="_blank" rel="noreferrer">CRS PDF</a>
            </div>

            <div class="adv-card__actions">
              <button class="adv-action-btn" type="button" data-action="watchlist" data-crd="${firm.crd}">
                ${isSaved ? 'Remove from watchlist' : 'Save to watchlist'}
              </button>
              <button class="adv-action-btn" type="button" data-action="compare" data-crd="${firm.crd}">
                ${isCompared ? 'Remove from compare' : 'Add to compare'}
              </button>
              <button class="adv-action-btn" type="button" data-action="copy-pack" data-crd="${firm.crd}">
                Copy source pack
              </button>
            </div>
          </article>
        `;
      })
      .join('');
  };

  const copyText = async (value) => {
    try {
      await navigator.clipboard.writeText(value);
    } catch {
      const area = document.createElement('textarea');
      area.value = value;
      document.body.appendChild(area);
      area.select();
      document.execCommand('copy');
      area.remove();
    }
  };

  const downloadCsv = () => {
    const firms = getWorkspaceRecords();
    if (!firms.length) return;

    const rows = [
      ['name', 'crd', 'source_mode', 'last_snapshot', 'coverage_score', 'registration_snapshot', 'service_snapshot', 'disclosure_count', 'summary_url', 'adv_pdf', 'crs_pdf'],
      ...firms.map((firm) => [
        firm.name,
        firm.crd,
        firm.sourceMode || state.dataMode,
        firm.lastUpdated || '',
        String(scoreFirm(firm)),
        firm.registrationSnapshot,
        firm.serviceSnapshot || '',
        String(firm.disclosureCount || 0),
        firm.links.summary,
        firm.links.advPdf,
        firm.links.crsPdf
      ])
    ];

    const csv = rows.map((row) => row.map((cell) => `"${String(cell).replaceAll('"', '""')}"`).join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = 'form-adv-workspace-v3.csv';
    document.body.appendChild(anchor);
    anchor.click();
    anchor.remove();
    URL.revokeObjectURL(url);
  };

  const saveWorkspaceRecord = (store, firm) => {
    store[firm.crd] = { ...firm };
  };

  const fetchLiveResults = async () => {
    if (!state.supabase) return [];

    const rawQuery = searchInput instanceof HTMLInputElement ? searchInput.value.trim() : '';
    const crd = extractCRD(rawQuery);
    let query = state.supabase
      .from('form_adv_current_firms')
      .select('*')
      .order('snapshot_date', { ascending: false })
      .limit(rawQuery ? 24 : 12);

    if (crd) {
      query = query.eq('crd', crd);
    } else if (rawQuery) {
      query = query.or(`firm_name.ilike.%${rawQuery}%,legal_name.ilike.%${rawQuery}%`);
    }

    const { data, error } = await query;
    if (error) throw new Error(error.message);
    return (data || []).map((row) => cacheFirm(toLiveFirm(row)));
  };

  const getSeededResults = () => {
    const rawQuery = searchInput instanceof HTMLInputElement ? searchInput.value : '';
    const query = normalize(rawQuery);
    return seededFirms.filter((firm) => {
      const haystacks = [
        firm.name,
        firm.crd,
        firm.headquarters || '',
        firm.registrationSnapshot,
        firm.serviceSnapshot || '',
        firm.feeSnapshot || '',
        ...(firm.aliases || []),
        ...(firm.focusTags || []),
        ...(firm.stateRegistrations || [])
      ].map(normalize);

      return !query || haystacks.some((item) => item.includes(query));
    });
  };

  const applyClientFilters = (firms) => {
    const coverage = coverageFilter instanceof HTMLSelectElement ? coverageFilter.value : 'all';
    const sortValue = sortFilter instanceof HTMLSelectElement ? sortFilter.value : 'score';
    const signalValue = signalFilter instanceof HTMLSelectElement ? signalFilter.value : 'all';
    return sortFirms(firms.filter((firm) => matchesCoverage(firm, coverage) && matchesSignal(firm, signalValue)), sortValue);
  };

  const refresh = async () => {
    state.liveLoading = true;
    renderStatusPanel();

    try {
      const results = state.liveReady ? await fetchLiveResults() : getSeededResults();
      state.dataMode = state.liveReady ? 'live' : 'seeded';
      state.currentResults = applyClientFilters(results);
      state.lastSyncLabel = new Date().toLocaleString();
    } catch (error) {
      state.liveReady = false;
      state.liveError = error?.message || 'Live read failed.';
      state.dataMode = 'seeded';
      state.currentResults = applyClientFilters(getSeededResults());
    }

    state.liveLoading = false;
    persistWorkspace();
    renderResults();
    renderCompare();
    renderWorkspace();
    renderStatusPanel();
    await renderGeneratedPanel();
  };

  const queueRefresh = () => {
    if (state.refreshTimer) window.clearTimeout(state.refreshTimer);
    state.refreshTimer = window.setTimeout(() => {
      refresh();
    }, 180);
  };

  const initLive = async () => {
    if (!(env.supabaseUrl && env.supabaseAnonKey)) {
      state.liveError = 'PUBLIC_SUPABASE_URL or PUBLIC_SUPABASE_ANON_KEY is missing.';
      return;
    }

    try {
      state.supabase = createClient(env.supabaseUrl, env.supabaseAnonKey);
      const { error } = await state.supabase.from('form_adv_current_firms').select('crd').limit(1);
      if (error) {
        state.liveReady = false;
        state.liveError = error.message;
        return;
      }
      state.liveReady = true;
      state.liveError = '';
    } catch (error) {
      state.liveReady = false;
      state.liveError = error?.message || 'Could not initialize the live Form ADV layer.';
    }
  };

  document.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const actionButton = target.closest('[data-action]');
    if (!(actionButton instanceof HTMLElement)) return;

    const action = actionButton.dataset.action;
    const crd = actionButton.dataset.crd;
    if (!crd) return;
    const firm = state.currentCache[crd] || watchlistStore[crd] || compareStore[crd] || seededFirmLookup[crd];
    if (!firm) return;

    if (action === 'watchlist') {
      if (watchlistStore[crd]) delete watchlistStore[crd];
      else saveWorkspaceRecord(watchlistStore, firm);
      await refresh();
      return;
    }

    if (action === 'compare') {
      if (compareStore[crd]) delete compareStore[crd];
      else if (Object.keys(compareStore).length < 3) saveWorkspaceRecord(compareStore, firm);
      await refresh();
      return;
    }

    if (action === 'copy-pack') {
      await copyText(`${firm.name} (${firm.crd})\nSummary: ${firm.links.summary}\nADV PDF: ${firm.links.advPdf}\nCRS PDF: ${firm.links.crsPdf}`);
    }
  });

  searchInput?.addEventListener('input', queueRefresh);
  coverageFilter?.addEventListener('change', queueRefresh);
  sortFilter?.addEventListener('change', queueRefresh);
  signalFilter?.addEventListener('change', queueRefresh);
  clearSearchButton?.addEventListener('click', async () => {
    if (searchInput instanceof HTMLInputElement) searchInput.value = '';
    await refresh();
    searchInput?.focus();
  });
  refreshLiveButton?.addEventListener('click', async () => {
    await initLive();
    await refresh();
  });
  resetCompareButton?.addEventListener('click', async () => {
    Object.keys(compareStore).forEach((key) => delete compareStore[key]);
    await refresh();
  });
  clearWorkspaceButton?.addEventListener('click', async () => {
    Object.keys(watchlistStore).forEach((key) => delete watchlistStore[key]);
    Object.keys(compareStore).forEach((key) => delete compareStore[key]);
    await refresh();
  });
  copyMemoButton?.addEventListener('click', async () => {
    if (memoOutput) await copyText(memoOutput.textContent || '');
  });
  downloadCsvButton?.addEventListener('click', downloadCsv);

  await initLive();
  await refresh();
</script>
