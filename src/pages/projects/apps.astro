---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';

const appCards = [
  {
    eyebrow: 'Flagship app',
    title: 'Manager Search',
    href: '/apps/manager-search',
    status: 'Building now',
    description:
      'The tool I wanted for jumping from a manager name to the filings, identifiers, and holdings context that actually matter.'
  },
  {
    eyebrow: 'Live tool',
    title: 'Form ADV Search',
    href: 'https://aistudio.google.com/apps/22413b76-84f4-492f-9424-602e8a68d040',
    status: 'Live',
    description:
      'A faster way to search Form ADV filings without getting trapped in the SEC interface first.',
    external: true
  },
  {
    eyebrow: 'Next build',
    title: '13F Data Finder',
    href: '/projects/13f-data-finder',
    status: 'Brewing',
    description:
      'A holdings research tool for the questions I kept asking and answering too manually.'
  }
] as const;
---

<BaseLayout title="Apps" description="The projects that already have a clearer interface or are closest to becoming usable tools.">
  <SiteTreeHeader
    branch="projects"
    currentHref="/apps"
    title="Apps"
    description="The more interface-heavy side of my project work."
  />

  <section class="page-section apps-overview">
    <div class="panel apps-intro">
      <SectionHeading
        eyebrow="Apps"
        title="The tools that wanted a working interface."
        description="Some project ideas are still mostly notes. The ones here are the closest to being usable products."
      />
    </div>

    <div class="apps-grid">
      {appCards.map((app) => (
        <a
          class="panel app-card"
          href={app.href}
          target={app.external ? '_blank' : undefined}
          rel={app.external ? 'noreferrer' : undefined}
        >
          <div class="app-card__meta">
            <span>{app.eyebrow}</span>
            <small>{app.status}</small>
          </div>
          <h2>{app.title}</h2>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
