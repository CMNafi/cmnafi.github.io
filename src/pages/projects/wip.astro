---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
const appCards = [
  {
    eyebrow: 'Flagship app',
    title: 'Manager Search',
    href: '/projects/wip/manager-search',
    status: 'Building now',
    description:
      'The tool I wanted for jumping from a manager name to the filings, identifiers, and holdings context that actually matter.'
  },
  {
    eyebrow: 'Live tool',
    title: 'Form ADV Data Finder',
    href: '/projects/wip/form-adv-data-finder',
    status: 'V3 live on-site',
    description:
      'A live-ready ADV workspace with source-pack jumps, current-firm search, snapshot history, compare, watchlists, and memo export.'
  },
  {
    eyebrow: 'Live beta',
    title: '13F Data Finder',
    href: '/projects/wip/13f-finder',
    status: 'V1 live on-site',
    description:
      'A holdings research tool for the questions I kept asking and answering too manually.'
  }
] as const;
---

<BaseLayout title="Work in Progress" description="The actual deployed experimental tools and frontend applications mapped out of the notes.">
<section class="page-section apps-overview">
    <div class="panel apps-intro">
      <SectionHeading
        eyebrow="Work in Progress"
        title="The tools currently being iterated on."
        description="These aren't just case-studies; they are live, working tools bridging financial documents into actual interfaces."
      />
    </div>

    <div class="apps-grid">
      {appCards.map((app) => (
        <a
          class="panel app-card"
          href={app.href}
          target={app.external ? '_blank' : undefined}
          rel={app.external ? 'noreferrer' : undefined}
        >
          <div class="app-card__meta">
            <span>{app.eyebrow}</span>
            <small>{app.status}</small>
          </div>
          <h2>{app.title}</h2>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
