---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';

const capabilities = [
  'Resolve firms through SEC CIK and FINRA CRD identifiers.',
  'Pull the latest Form ADV operating profile and most recent 13F cover page data.',
  'Collapse raw holdings into a ranked top-positions view instead of sending unfiltered JSON to an LLM.',
  'Generate a concise narrative summary for diligence, research, and manager triage.'
];

const workflow = [
  'Search for a manager name or identifier.',
  'Confirm the matched entity and open the SEC / IAPD links.',
  'Review the top holdings, operational profile, and filing status.',
  'Read an AI-generated narrative built only from pruned and labeled inputs.'
];
---

<BaseLayout
  title="Manager Search"
  description="A manager research tool for getting from a name to the filings, holdings, and context I actually want to see."
>
  <SiteTreeHeader
    branch="projects"
    currentHref="/apps/manager-search"
    title="Manager Search"
    description="A finance research tool built around the workflow I wanted to move faster."
  />

  <section class="page-section app-detail">
    <div class="panel app-detail__hero">
      <SectionHeading
        eyebrow="Manager research"
        title="Manager Search"
        description="A tool for turning a manager name into something more useful than a pile of disconnected filing tabs."
      />
      <p class="app-detail__lead">
        This app exists because I wanted a faster path from a name lookup to the actual diligence picture: identifiers, filings, holdings, and enough context to keep asking better questions.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/apps">Back to apps</a>
        <a class="button button-ghost" href="/projects">Browse projects</a>
      </div>
    </div>

    <div class="app-detail__grid">
      <article class="panel app-detail__card">
        <p class="eyebrow">Core capabilities</p>
        <ul>
          {capabilities.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="panel app-detail__card">
        <p class="eyebrow">Workflow</p>
        <ol>
          {workflow.map((item) => <li>{item}</li>)}
        </ol>
      </article>
    </div>
  </section>
</BaseLayout>
