---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';
---

<BaseLayout title="Notes" description="Short-form notes are coming soon.">
  <SiteTreeHeader
    branch="timeline"
    currentHref="/notes"
    title="Notes"
    description="A shorter-form layer for quick observations, fragments, and smaller ideas that don’t need a full essay."
  />

  <section class="page-section narrow-stack">
    <div class="panel prose">
      <p class="eyebrow">Coming soon</p>
      <h1>Notes</h1>
      <p>A quieter space for quick observations, fragments, and compact ideas will live here.</p>
    </div>
  </section>
</BaseLayout>
