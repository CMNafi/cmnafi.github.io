---
import { siteConfig } from '@/config/site';

const destination = '/interests/movies';
const canonical = new URL(destination, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${destination}`} />
    <link rel="canonical" href={canonical} />
    <title>Redirecting to Movies</title>
  </head>
  <body>
    <p>Redirecting to <a href={destination}>Movies</a>.</p>
  </body>
</html>
