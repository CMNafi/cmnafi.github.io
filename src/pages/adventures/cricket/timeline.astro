---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CricketTimeline from '@/components/cricket/CricketTimeline.astro';
import { timelineByDate } from '@/data/cricket';
---

<BaseLayout
  title="Cricket Timeline"
  description="Chronological cricket journey for Nafi C M, combining teams, seasons, milestones, matches, and personal notes into one sports biography timeline."
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Timeline"
      title="A sports biography built from matches, teams, and memory"
      description="The goal is not just chronology. It is to make transitions, milestones, and lived moments readable as one evolving cricket story."
    />
    <CricketTimeline items={timelineByDate} />
  </section>
</BaseLayout>
