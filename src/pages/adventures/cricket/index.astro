---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import CricketHero from '@/components/cricket/CricketHero.astro';
import MilestoneStrip from '@/components/cricket/MilestoneStrip.astro';
import SourceBadge from '@/components/cricket/SourceBadge.astro';
import { careerSnapshotCards, cricketCareerSummary, cricketMilestones, cricketPlayerProfile, matchesByDate } from '@/data/cricket';

const standoutInnings = matchesByDate.filter((match) => (match.battingRuns ?? 0) >= 50);
const standoutSpells = matchesByDate.filter((match) => (match.wickets ?? 0) >= 4);
const teamList = cricketPlayerProfile.teams.join(', ');

const linkBlocks = [
  { href: '/adventures/cricket/records', title: 'Records', copy: 'Headline totals, partial season snapshots, and the deeper batting and bowling ledger.' },
  { href: '/adventures/cricket/matches', title: 'Matches', copy: 'Search the match archive and expand rows for notes, source status, and stat detail.' },
  { href: '/adventures/cricket/highlights', title: 'Highlights', copy: 'A tighter page for standout innings, wicket spells, and editorial cricket notes.' },
  { href: '/adventures/cricket/teams', title: 'Teams', copy: 'Follow the team chapters behind the runs, wickets, and season changes.' },
  { href: '/adventures/cricket/timeline', title: 'Timeline', copy: 'Trace the longer cricket story across formats, years, and transitions.' }
];
---

<BaseLayout
  title="Cricket Adventure"
  description="A personal cricket home for C M Nafi, centered on headline totals, standout innings, standout spells, and the archive behind them."
>
  <section class="page-section page-section-hero">
    <CricketHero
      player={cricketPlayerProfile}
      stats={careerSnapshotCards}
      statusLabel="Headline totals refreshed"
      sourceStatus={cricketCareerSummary.sourceStatus}
    />
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Why This Page Exists"
      title="Cricket belongs under Adventures because it has shaped how I compete, travel, and remember time."
      description="The page is deliberately simple: lead with the headline record, keep only the standout batting and bowling days near the top, and let the deeper archive sit one click away."
    />
    <div class="two-up cricket-story-grid">
      <article class="panel cricket-note-card">
        <p class="eyebrow">Personal note</p>
        <h3>A cricket page should read like a life chapter, not just a score dump.</h3>
        <p>
          Cricket has been routine, pressure, team-building, travel, and memory. The reason it sits inside Adventures is
          simple: the sport has always carried more than numbers for me.
        </p>
        <p>
          I want this page to hold the days that clearly changed a game or stayed with me after the season moved on. That
          is why the front page now keeps only the big run days and the big wicket days in view.
        </p>
      </article>

      <article class="panel cricket-note-card">
        <p class="eyebrow">Player snapshot</p>
        <h3>The quick read for anyone opening this page for the first time.</h3>
        <ul class="cricket-identity-list">
          <li>
            <span>Headline record</span>
            <strong>1772 runs and 63 wickets</strong>
          </li>
          <li>
            <span>Current chapter</span>
            <strong>{cricketPlayerProfile.currentTeam}</strong>
          </li>
          <li>
            <span>Teams carried into the archive</span>
            <strong>{teamList}</strong>
          </li>
          <li>
            <span>Public reference</span>
            <strong>Player ID {cricketPlayerProfile.playerId}</strong>
          </li>
        </ul>
        <a class="button button-secondary" href={cricketPlayerProfile.profileUrl} target="_blank" rel="noreferrer">Open CricClubs profile</a>
      </article>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Career markers"
      title="The important numbers stay visible even while the full scorecard archive keeps growing."
      description="Totals are refreshed, the standout match entries are preserved, and the deeper breakdown pages remain ready for more imports later."
    />
    <MilestoneStrip milestones={cricketMilestones} />
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Big run days"
      title="The innings worth keeping near the top of the page."
      description="Not every score belongs on the front page. These are the batting days that most clearly deserve to stay in view."
    />
    <div class="two-up-grid">
      {standoutInnings.map((match) => (
        <article class="panel cricket-performance-card">
          <div class="cricket-performance-card__top">
            <div>
              <p class="eyebrow">Batting highlight</p>
              <h3>{match.battingRuns} runs</h3>
              <p>{match.team} / {match.seasonLabel}</p>
            </div>
            <SourceBadge status={match.dataStatus} />
          </div>
          <p class="cricket-performance-card__summary">
            {match.competition}{match.opponent !== 'TBD from import' ? ` vs ${match.opponent}` : ''}
          </p>
          <div class="highlight-card__statline">
            {match.battingRuns} runs
            {match.balls !== null ? ` off ${match.balls}` : ''}
            {match.strikeRate !== null ? ` / SR ${match.strikeRate}` : ''}
          </div>
          <p>{match.personalNote}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="page-section two-up">
    <div>
      <SectionHeading
        eyebrow="Big wicket days"
        title="The spells that made the all-round story obvious."
        description="These are the bowling performances that most clearly changed the mood of a game and deserve to stay close to the headline record."
      />
      <div class="panel-stack">
        {standoutSpells.map((match) => (
          <article class="panel cricket-performance-card">
            <div class="cricket-performance-card__top">
              <div>
                <p class="eyebrow">Bowling highlight</p>
                <h3>{match.wickets}/{match.runsConceded ?? '-'}</h3>
                <p>{match.team} / {match.seasonLabel}</p>
              </div>
              <SourceBadge status={match.dataStatus} />
            </div>
            <p class="cricket-performance-card__summary">
              {match.competition}{match.opponent !== 'TBD from import' ? ` vs ${match.opponent}` : ''}
            </p>
            <div class="highlight-card__statline">
              {match.wickets} wickets
              {match.runsConceded !== null ? ` for ${match.runsConceded}` : ''}
              {match.economy !== null ? ` / Economy ${match.economy}` : ''}
            </div>
            <p>{match.personalNote}</p>
          </article>
        ))}
      </div>
    </div>

    <article class="panel records-note-card cricket-focus-card">
      <p class="eyebrow">Archive method</p>
      <h3>Front page first, full record next.</h3>
      <p>
        The goal here is clarity. A first-time visitor should understand quickly that cricket is a serious part of my
        story, without getting buried under every partial import and every unfinished scorecard.
      </p>
      <p>
        The deeper pages still hold season cards, team chapters, and expandable match rows. This landing page now stays
        focused on the matches where the runs were big or the wickets mattered most.
      </p>
      <a class="button button-secondary" href="/adventures/cricket/records">Open full record view</a>
    </article>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Archive map"
      title="Five clear doors keep the cricket section easy to browse."
      description="The front page is now selective on purpose. Everything else lives in a deeper page that can keep expanding without crowding the story."
    />
    <div class="five-link-grid">
      {linkBlocks.map((block) => (
        <a class="panel archive-link-card" href={block.href}>
          <h3>{block.title}</h3>
          <p>{block.copy}</p>
          <span>Open -&gt;</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
