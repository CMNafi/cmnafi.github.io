---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import TeamCard from '@/components/cricket/TeamCard.astro';
import SeasonCard from '@/components/cricket/SeasonCard.astro';
import { cricketSeasons, cricketTeams } from '@/data/cricket';

const currentTeams = cricketTeams.filter((team) => team.current);
const pastTeams = cricketTeams.filter((team) => !team.current);
---

<BaseLayout
  title="Cricket Teams"
  description="Team history for the personal cricket archive of Nafi C M, including current and past teams, competitions, and season snapshots."
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Teams"
      title="A team journey told as chapters, not just roster labels"
      description="This page keeps current and past teams distinct while preserving aliases, competitions, season cards, and aggregate stats when they are available."
    />
  </section>

  <section class="page-section two-up">
    <div>
      <SectionHeading eyebrow="Current" title="Present badge" description="The live chapter gets the clearest placement so future imports can accumulate around it." />
      <div class="narrow-stack compact-stack">
        {currentTeams.map((team) => <TeamCard team={team} />)}
      </div>
    </div>
    <div>
      <SectionHeading eyebrow="Past" title="Earlier chapters" description="Aliases and past teams stay explicit to protect the integrity of the longer cricket story." />
      <div class="narrow-stack compact-stack">
        {pastTeams.map((team) => <TeamCard team={team} />)}
      </div>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading eyebrow="Season cards" title="Competition history" description="Each season card can be expanded later with logos, galleries, and manual notes without changing the core structure." />
    <div class="three-up-grid">
      {cricketSeasons.map((season) => <SeasonCard season={season} />)}
    </div>
  </section>
</BaseLayout>
