---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import RecordTabs from '@/components/cricket/RecordTabs.astro';
import MilestoneStrip from '@/components/cricket/MilestoneStrip.astro';
import SeasonCard from '@/components/cricket/SeasonCard.astro';
import StatComparisonChart from '@/components/cricket/StatComparisonChart.astro';
import { chartSeries, cricketCareerSummary, cricketMilestones, cricketSeasons, cricketTeams } from '@/data/cricket';

const byTeam = cricketTeams.filter((team) => team.aggregateStats.matches !== null || team.current);
---

<BaseLayout
  title="Cricket Records"
  description="Detailed batting, bowling, fielding, team, competition, and season records for the personal cricket archive of Nafi C M."
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Records"
      title="Deep stats with enough warmth to still feel personal"
      description="This page is structured for full career depth later, but useful right now with public totals, seeded snapshots, milestones, and elegant visual summaries."
    />
    <div class="hero-actions">
      <a class="button button-primary" href="/adventures/cricket/">Open main cricket page</a>
      <a class="button button-secondary" href="/adventures/cricket/matches">Open match archive</a>
    </div>
    <RecordTabs summary={cricketCareerSummary} seasons={cricketSeasons} />
  </section>

  <section class="page-section">
    <SectionHeading eyebrow="Milestone tracker" title="Headline markers stay close to the deeper record" description="Milestones help the archive read like a career story, not just a stack of tables." />
    <MilestoneStrip milestones={cricketMilestones} />
  </section>

  <section class="page-section chart-grid-two-up">
    <StatComparisonChart title="Runs by season" subtitle="Known batting volume across current seeded snapshots" series={chartSeries.runsBySeason} />
    <StatComparisonChart title="Wickets by season" subtitle="Current bowling impact across the available archive" series={chartSeries.wicketsBySeason} />
    <StatComparisonChart title="Strike rate trend" subtitle="Tempo by season snapshot" series={chartSeries.strikeRateTrend} />
    <StatComparisonChart title="Batting average trend" subtitle="Average as the story moves between teams" series={chartSeries.battingAverageTrend} />
  </section>

  <section class="page-section two-up">
    <div>
      <SectionHeading eyebrow="By season" title="Season cards" description="Each entry preserves what is known now while keeping schema room for later detail." />
      <div class="narrow-stack compact-stack">
        {cricketSeasons.map((season) => <SeasonCard season={season} />)}
      </div>
    </div>
    <div>
      <SectionHeading eyebrow="By team" title="Team record view" description="Even partial snapshots get organized into team-shaped chapters for easier maintenance." />
      <div class="record-grid-table panel">
        {byTeam.map((team) => (
          <div>
            <span>{team.teamName}</span>
            <strong>
              {team.aggregateStats.runs ?? '—'} runs · {team.aggregateStats.wickets ?? '—'} wickets
            </strong>
          </div>
        ))}
      </div>
      <div class="panel records-note-card">
        <p class="eyebrow">Best performances</p>
        <ul>
          <li>Best known score: 63 for TB Bengal Tigers.</li>
          <li>Best known spell: 4/30 for SWAT in the TPL 2024 Fall Series.</li>
          <li>Best known fielding marker: 2 catches vs Allies on February 19, 2026.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
