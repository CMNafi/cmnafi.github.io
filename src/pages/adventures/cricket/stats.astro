---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cricket Stats"
  description="The cricket stats page now lives inside the main Cricket page."
>
  <section class="page-section">
    <div class="panel" style="display:grid; gap:1rem; max-width:42rem;">
      <p class="eyebrow">Cricket</p>
      <h1 style="margin:0;">The main cricket page now holds the live stats and admin console.</h1>
      <p style="margin:0; color:rgba(237, 241, 225, 0.74); line-height:1.7;">
        You are being sent to the unified cricket page. If the redirect does not fire automatically, use the link below.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/adventures/cricket/">Open cricket page</a>
      </div>
    </div>
  </section>

  <script>
    if (typeof window !== 'undefined') {
      window.location.replace('/adventures/cricket/');
    }
  </script>
</BaseLayout>
