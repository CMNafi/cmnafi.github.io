---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { siteConfig } from '@/config/site';
import { cricketPlayerProfile, matchesByDate } from '@/data/cricket';
import { fromLegacyMatchRecord } from '@/lib/cricket-stats';
import { formatDate } from '@/utils/format';

const fallbackGames = matchesByDate.map((match) => fromLegacyMatchRecord(match));
const cricketPosts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'Cricket')).sort(
  (a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime()
);
const storySlugs = cricketPosts.map((post) => post.slug).sort();
const mappedPosts = cricketPosts.map((post, index) => {
  const angle = cricketPosts.length === 1 ? -90 : 210 - (index * 240) / (cricketPosts.length - 1);
  const radians = (angle * Math.PI) / 180;
  const left = 50 + Math.cos(radians) * 29;
  const top = 50 + Math.sin(radians) * 22;

  return { post, left, top };
});
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
const adminEmail = siteConfig.email;
---

<BaseLayout
  title="Cricket"
  description="A cleaner cricket page with a field view, a live match log, and an admin-only entry flow backed by Supabase."
>
  <div class="cricket-simple-page">
    <section class="page-section cricket-simple-hero">
      <div class="cricket-simple-hero__copy">
        <p class="eyebrow">Interests / Cricket</p>
        <h1>Cricket</h1>
        <p>
          One page, one structure: the field first, the live stats right under it, and the admin entry close enough to
          use without digging through extra panels.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#cricket-summary">Jump to stats</a>
          <a class="button button-secondary" href="#cricket-admin">Go to admin entry</a>
        </div>
      </div>

      <aside class="panel cricket-simple-hero__card">
        <p class="eyebrow">Player reference</p>
        <h2>{cricketPlayerProfile.name}</h2>
        <ul>
          <li><span>Player ID</span><strong>{cricketPlayerProfile.playerId}</strong></li>
          <li><span>Current team</span><strong>{cricketPlayerProfile.currentTeam}</strong></li>
          <li><span>Admin account</span><strong>{adminEmail}</strong></li>
        </ul>
      </aside>
    </section>

    <section class="page-section panel cricket-simple-field">
      <div class="cricket-simple-field__copy">
        <p class="eyebrow">Field view</p>
        <h2>The match stories live around the circle.</h2>
        <p>
          This keeps the cricket page grounded in the field itself. Hover a point for the memory; open the story when you
          want the full match behind it.
        </p>
      </div>

      <div class="cricket-ground">
        <div class="cricket-ground__oval"></div>
        <div class="cricket-ground__inner-circle"></div>
        <div class="cricket-ground__pitch">
          <span class="cricket-ground__crease cricket-ground__crease--top"></span>
          <span class="cricket-ground__crease cricket-ground__crease--bottom"></span>
          <span class="cricket-ground__stumps cricket-ground__stumps--top"></span>
          <span class="cricket-ground__stumps cricket-ground__stumps--bottom"></span>
        </div>

        {mappedPosts.map(({ post, left, top }) => (
          <a class="cricket-ground__node" href={`/blog/${post.slug}`} style={`left:${left}%; top:${top}%;`}>
            <span class="cricket-ground__dot"></span>
            <span class="cricket-ground__tooltip">
              <strong>{post.data.title}</strong>
              <small>{formatDate(post.data.publishedAt)}</small>
              <span>{post.data.description}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="page-section" id="cricket-summary">
      <SectionHeading eyebrow="Stats" title="Live cricket stats, kept simple" description="No extra dashboard clutter. Just the live summary, the match log, and the story link when a post exists." />
      <div class="cricket-stats-banner panel" data-cricket-stats-banner><p>Loading live cricket stats.</p></div>
      <div class="cricket-simple-summary" data-summary-cards></div>
    </section>

    <section class="page-section" id="cricket-log">
      <SectionHeading eyebrow="Match log" title="Every match in one stream" description="Filter by year or team, then open the story if there is one." />
      <div class="cricket-stats-filters panel" data-cricket-filters>
        <label class="search-input cricket-stats-filters__search">
          <span class="sr-only">Search games</span>
          <input type="search" placeholder="Search opponent, venue, or note" data-cricket-filter-search />
        </label>
        <label><span>Year</span><select data-cricket-filter-year></select></label>
        <label><span>Team</span><select data-cricket-filter-team></select></label>
      </div>
      <div class="panel cricket-stats-log" data-cricket-log></div>
    </section>

    <section class="page-section" id="cricket-admin">
      <SectionHeading eyebrow="Admin entry" title="Add a match" description={`Sign in with ${adminEmail} to add or edit records directly from this page.`} />
      <div class="panel cricket-admin" data-cricket-admin></div>
    </section>
  </div>

  <datalist id="cricket-story-slugs">{storySlugs.map((slug) => <option value={slug} />)}</datalist>
  <script id="cricket-stats-env" type="application/json" set:html={JSON.stringify({ supabaseUrl, supabaseAnonKey, adminEmail })}></script>
  <script id="cricket-stats-fallback" type="application/json" set:html={JSON.stringify(fallbackGames)}></script>
  <script type="module">
    import { createClient } from '@supabase/supabase-js';
    import { aggregateCricketGames, cricketEntryFields, emptyCricketGame, normalizeCricketGame, toSupabasePayload } from '../../../lib/cricket-stats';

    const env = JSON.parse(document.getElementById('cricket-stats-env')?.textContent || '{}');
    const fallbackGames = JSON.parse(document.getElementById('cricket-stats-fallback')?.textContent || '[]').map(normalizeCricketGame);
    const banner = document.querySelector('[data-cricket-stats-banner]');
    const summaryRoot = document.querySelector('[data-summary-cards]');
    const filtersRoot = document.querySelector('[data-cricket-filters]');
    const logRoot = document.querySelector('[data-cricket-log]');
    const adminRoot = document.querySelector('[data-cricket-admin]');

    const formatValue = (value, digits = 0, fallback = 'Open') => {
      if (value === null || value === undefined || Number.isNaN(value)) return fallback;
      return digits > 0 ? Number(value).toFixed(digits) : `${value}`;
    };

    const adminDefaults = {
      team: ['TB Bengal Tigers', 'SWAT', 'St Pete Shields', 'Bengals'],
      format: ['Leather ball', 'Tennis ball', 'Unknown'],
      competition: ['TCL', 'Titan Cup', 'League match', 'Archive memory']
    };

    const deriveSeasonLabel = (gameDate) => {
      if (!gameDate) return '';
      const [year] = String(gameDate).split('-');
      return year || '';
    };

    const validateAdminForm = (form) => {
      const errors = [];
      if (!form.gameDate) errors.push('Date is required.');
      if (!form.team?.trim()) errors.push('Team is required.');
      [['runs', form.runs], ['balls', form.balls], ['wickets', form.wickets], ['catches', form.catches], ['runOuts', form.runOuts], ['overs', form.overs], ['runsConceded', form.runsConceded], ['distanceDrivenMiles', form.distanceDrivenMiles]].forEach(([label, value]) => {
        if (value !== null && value !== undefined && value !== '' && Number(value) < 0) errors.push(`${label} cannot be negative.`);
      });
      if (form.balls === 0 && form.runs !== null && form.runs !== undefined) errors.push('Balls cannot be zero when runs are recorded.');
      return errors;
    };

    const setBanner = (html, tone = 'info') => {
      if (!banner) return;
      banner.setAttribute('data-tone', tone);
      banner.innerHTML = html;
    };

    const renderSummary = (summary) => {
      if (!summaryRoot) return;
      const cards = [
        ['Matches', summary.matches],
        ['Runs', summary.runs],
        ['Wickets', summary.wickets],
        ['Catches', summary.catches],
        ['Best score', summary.bestScore ?? 'Open'],
        ['Best spell', summary.bestBowling ?? 'Open'],
        ['Miles driven', summary.totalDriveMiles ? `${formatValue(summary.totalDriveMiles, 1)} mi` : 'Open'],
        ['Avg drive', summary.averageDriveMiles !== null ? `${formatValue(summary.averageDriveMiles, 1)} mi` : 'Open']
      ];

      summaryRoot.innerHTML = cards.map(([label, value]) => `<div class="panel cricket-simple-summary__card"><span>${label}</span><strong>${value}</strong></div>`).join('');
    };

    const renderFilterOptions = (filters) => {
      if (!filtersRoot) return;
      const apply = (selector, values) => {
        const select = filtersRoot.querySelector(selector);
        if (!select) return;
        const current = select.value;
        select.innerHTML = ['<option value="">All</option>'].concat(values.map((value) => `<option value="${value}">${value}</option>`)).join('');
        if (values.includes(current)) select.value = current;
      };
      apply('[data-cricket-filter-year]', filters.years);
      apply('[data-cricket-filter-team]', filters.teams);
    };

    const filterGames = (games) => {
      const search = filtersRoot?.querySelector('[data-cricket-filter-search]')?.value?.trim().toLowerCase() ?? '';
      const year = filtersRoot?.querySelector('[data-cricket-filter-year]')?.value ?? '';
      const team = filtersRoot?.querySelector('[data-cricket-filter-team]')?.value ?? '';
      return games.filter((game) => {
        const haystack = [game.opponent, game.venue, game.personalNote, game.result, game.team].join(' ').toLowerCase();
        return (!search || haystack.includes(search)) && (!year || String(game.gameDate).startsWith(year)) && (!team || game.team === team);
      });
    };

    const renderLog = (games) => {
      if (!logRoot) return;
      if (!games.length) {
        logRoot.innerHTML = `<div class="cricket-stats-empty"><h3>No games match the current filters.</h3><p>Reset the filters or add a new match in the admin panel.</p></div>`;
        return;
      }
      logRoot.innerHTML = `
        <div class="cricket-log-table-wrap">
          <table class="cricket-log-table">
            <thead><tr><th>Date</th><th>Team</th><th>Opponent</th><th>Runs</th><th>Wickets</th><th>Catches</th><th>Drive</th><th>Story</th></tr></thead>
            <tbody>
              ${games.map((game) => `
                <tr>
                  <td><strong>${game.gameDate}</strong><small>${game.competition ?? 'Open'}</small></td>
                  <td>${game.team}</td>
                  <td>${game.opponent ?? 'TBD'}</td>
                  <td>${game.runs ?? '—'}${game.balls ? ` <small>off ${game.balls}</small>` : ''}</td>
                  <td>${game.wickets ?? '—'}</td>
                  <td>${game.catches ?? 0}</td>
                  <td>${game.distanceDrivenMiles !== null ? `${formatValue(game.distanceDrivenMiles, 1)} mi` : '—'}</td>
                  <td>${game.storySlug ? `<a href="/blog/${game.storySlug}">Open</a>` : '<span class="cricket-log-table__muted">None</span>'}</td>
                </tr>
                <tr class="cricket-log-table__detail-row">
                  <td colspan="8">
                    <div class="cricket-log-table__detail-grid">
                      <div><span>Result</span><strong>${game.result ?? 'Open'}</strong></div>
                      <div><span>Venue</span><strong>${game.venue ?? 'Open'}</strong></div>
                      <div><span>Format</span><strong>${game.format ?? 'Open'}</strong></div>
                      <div><span>Bowling</span><strong>${game.overs ?? '—'} overs · ${game.runsConceded ?? '—'} conceded</strong></div>
                    </div>
                    ${game.personalNote ? `<p class="cricket-log-table__note">${game.personalNote}</p>` : ''}
                  </td>
                </tr>`).join('')}
            </tbody>
          </table>
        </div>`;
    };

    const defaultStatus = 'manually added';
    const makeFormState = (game = emptyCricketGame()) => ({ ...emptyCricketGame(), ...game, sourceStatus: game.sourceStatus || defaultStatus });

    const state = {
      supabase: null,
      session: null,
      games: fallbackGames,
      filteredGames: fallbackGames,
      form: makeFormState(),
      editingId: null,
      saving: false,
      adminError: '',
      adminValidation: [],
      isFallback: true,
      carriedDefaults: { team: '', seasonLabel: '', competition: '', format: '', venue: '' }
    };

    const applyCarriedDefaults = () => ({ ...emptyCricketGame(), ...state.carriedDefaults, catches: 0, runOuts: 0, sourceStatus: defaultStatus });

    const renderAdmin = () => {
      if (!adminRoot) return;
      if (!state.supabase) {
        adminRoot.innerHTML = `<div class="cricket-admin__message"><h3>Supabase setup required</h3><p>Add <code>PUBLIC_SUPABASE_URL</code> and <code>PUBLIC_SUPABASE_ANON_KEY</code> to enable the live admin workflow.</p></div>`;
        return;
      }
      if (!state.session) {
        adminRoot.innerHTML = `
          <form class="cricket-admin__login" data-admin-login>
            <div><label>Email</label><input type="email" name="email" autocomplete="username" required /></div>
            <div><label>Password</label><input type="password" name="password" autocomplete="current-password" required /></div>
            <p class="cricket-admin__hint">Admin account: <strong>${env.adminEmail ?? 'nafi@cmnafi.com'}</strong></p>
            <button class="button button-primary" type="submit">Sign in as admin</button>
            ${state.adminError ? `<p class="cricket-admin__error">${state.adminError}</p>` : ''}
          </form>`;
        adminRoot.querySelector('[data-admin-login]')?.addEventListener('submit', async (event) => {
          event.preventDefault();
          const formData = new FormData(event.currentTarget);
          state.adminError = '';
          const { error } = await state.supabase.auth.signInWithPassword({ email: String(formData.get('email') ?? ''), password: String(formData.get('password') ?? '') });
          if (error) {
            state.adminError = error.message;
            renderAdmin();
            return;
          }
          await refreshFromSupabase();
        });
        return;
      }
      const form = state.form;
      adminRoot.innerHTML = `
        <div class="cricket-admin__header"><div><p class="eyebrow">Signed in</p><h3>Add or update a match</h3><p>Signed in as <strong>${state.session?.user?.email ?? env.adminEmail ?? 'admin'}</strong>.</p></div><button class="button button-ghost" type="button" data-admin-signout>Sign out</button></div>
        ${state.adminError ? `<p class="cricket-admin__error">${state.adminError}</p>` : ''}
        ${state.adminValidation.length ? `<div class="cricket-admin__validation">${state.adminValidation.map((item) => `<p>${item}</p>`).join('')}</div>` : ''}
        <div class="cricket-admin__quickfills">
          <div><span>Team</span><div class="cricket-admin__chip-row">${adminDefaults.team.map((team) => `<button type="button" class="button button-ghost" data-admin-fill="team" data-admin-value="${team}">${team}</button>`).join('')}</div></div>
          <div><span>Format</span><div class="cricket-admin__chip-row">${adminDefaults.format.map((format) => `<button type="button" class="button button-ghost" data-admin-fill="format" data-admin-value="${format}">${format}</button>`).join('')}</div></div>
          <div><span>Competition</span><div class="cricket-admin__chip-row">${adminDefaults.competition.map((competition) => `<button type="button" class="button button-ghost" data-admin-fill="competition" data-admin-value="${competition}">${competition}</button>`).join('')}</div></div>
        </div>
        <div class="cricket-admin__entry-table-wrap"><table class="cricket-admin__entry-table"><thead><tr><th>Date</th><th>Team</th><th>Opponent</th><th>Runs</th><th>Balls</th><th>Wickets</th><th>Catches</th><th>Drive (mi)</th><th>Story slug</th></tr></thead><tbody><tr>
          <td><input name="gameDate" type="date" value="${form.gameDate || ''}" /></td>
          <td><input name="team" type="text" value="${form.team || ''}" placeholder="SWAT" /></td>
          <td><input name="opponent" type="text" value="${form.opponent || ''}" placeholder="Opponent" /></td>
          <td><input name="runs" type="number" min="0" value="${form.runs ?? ''}" /></td>
          <td><input name="balls" type="number" min="0" value="${form.balls ?? ''}" /></td>
          <td><input name="wickets" type="number" min="0" value="${form.wickets ?? ''}" /></td>
          <td><input name="catches" type="number" min="0" value="${form.catches ?? 0}" /></td>
          <td><input name="distanceDrivenMiles" type="number" min="0" step="0.1" value="${form.distanceDrivenMiles ?? ''}" /></td>
          <td><input name="storySlug" list="cricket-story-slugs" type="text" value="${form.storySlug || ''}" placeholder="blog slug" /></td>
        </tr></tbody></table></div>
        <div class="cricket-admin__details-grid">
          <label><span>Season label</span><input name="seasonLabel" type="text" value="${form.seasonLabel || ''}" placeholder="2026" /></label>
          <label><span>Competition</span><input name="competition" type="text" value="${form.competition || ''}" placeholder="TCL" /></label>
          <label><span>Format</span><input name="format" type="text" value="${form.format || ''}" placeholder="Leather ball" /></label>
          <label><span>Venue</span><input name="venue" type="text" value="${form.venue || ''}" placeholder="Temple Terrace" /></label>
          <label><span>Result</span><input name="result" type="text" value="${form.result || ''}" placeholder="Won by 3 runs" /></label>
          <label><span>Overs</span><input name="overs" type="number" min="0" step="0.1" value="${form.overs ?? ''}" /></label>
          <label><span>Runs conceded</span><input name="runsConceded" type="number" min="0" value="${form.runsConceded ?? ''}" /></label>
          <label><span>Run outs</span><input name="runOuts" type="number" min="0" value="${form.runOuts ?? 0}" /></label>
          <label><span>Scorecard URL</span><input name="scorecardUrl" type="url" value="${form.scorecardUrl || ''}" placeholder="https://..." /></label>
          <label class="cricket-admin__note-field"><span>Personal note</span><textarea name="personalNote" rows="4" placeholder="Short note for the archive">${form.personalNote || ''}</textarea></label>
        </div>
        <div class="cricket-admin__draft panel">
          <div><span>Season</span><strong>${form.seasonLabel || deriveSeasonLabel(form.gameDate) || 'Open'}</strong></div>
          <div><span>Strike rate</span><strong>${form.runs !== null && form.balls ? formatValue((form.runs / form.balls) * 100, 2) : 'Open'}</strong></div>
          <div><span>Economy</span><strong>${form.runsConceded !== null && form.overs ? formatValue(form.runsConceded / form.overs, 2) : 'Open'}</strong></div>
          <div><span>Drive</span><strong>${form.distanceDrivenMiles !== null && form.distanceDrivenMiles !== undefined ? `${formatValue(form.distanceDrivenMiles, 1)} mi` : 'Open'}</strong></div>
        </div>
        <div class="hero-actions cricket-admin__actions"><button class="button button-primary" type="button" data-admin-save>${state.saving ? 'Saving...' : (state.editingId ? 'Update game' : 'Add game')}</button><button class="button button-secondary" type="button" data-admin-save-next>${state.saving ? 'Saving...' : 'Save and add next'}</button><button class="button button-secondary" type="button" data-admin-reset>Reset form</button></div>`;

      adminRoot.querySelector('[data-admin-signout]')?.addEventListener('click', async () => {
        await state.supabase.auth.signOut();
        state.session = null;
        state.editingId = null;
        state.form = makeFormState();
        renderAdmin();
      });

      adminRoot.querySelectorAll('[name]').forEach((field) => {
        field.addEventListener('input', (event) => {
          const target = event.currentTarget;
          const name = target.getAttribute('name');
          if (!name || !cricketEntryFields.includes(name)) return;
          let value = target.value;
          if (target.type === 'number') value = value === '' ? null : Number(value);
          const nextForm = { ...state.form, [name]: value };
          if (name === 'gameDate' && !state.form.seasonLabel) nextForm.seasonLabel = deriveSeasonLabel(value);
          state.form = nextForm;
          state.adminValidation = validateAdminForm(state.form);
        });
      });

      adminRoot.querySelectorAll('[data-admin-fill]').forEach((button) => {
        button.addEventListener('click', () => {
          const field = button.getAttribute('data-admin-fill');
          const value = button.getAttribute('data-admin-value') ?? '';
          if (!field || !cricketEntryFields.includes(field)) return;
          state.form = { ...state.form, [field]: value };
          state.adminValidation = validateAdminForm(state.form);
          renderAdmin();
        });
      });

      adminRoot.querySelector('[data-admin-reset]')?.addEventListener('click', () => {
        state.editingId = null;
        state.form = applyCarriedDefaults();
        state.adminError = '';
        state.adminValidation = [];
        renderAdmin();
      });

      const saveGame = async (mode = 'stay') => {
        state.adminValidation = validateAdminForm(state.form);
        if (state.adminValidation.length) {
          state.adminError = 'Please fix the entry checks before saving.';
          renderAdmin();
          return;
        }
        state.saving = true;
        state.adminError = '';
        renderAdmin();
        const payload = toSupabasePayload({ ...state.form, sourceStatus: defaultStatus });
        const response = state.editingId
          ? await state.supabase.from('cricket_games').update(payload).eq('id', state.editingId)
          : await state.supabase.from('cricket_games').insert(payload);
        state.saving = false;
        if (response.error) {
          state.adminError = response.error.message;
          renderAdmin();
          return;
        }
        state.carriedDefaults = { team: state.form.team || '', seasonLabel: state.form.seasonLabel || deriveSeasonLabel(state.form.gameDate), competition: state.form.competition || '', format: state.form.format || '', venue: state.form.venue || '' };
        state.editingId = null;
        state.form = mode === 'next' ? applyCarriedDefaults() : makeFormState();
        state.adminValidation = [];
        await refreshFromSupabase();
      };

      adminRoot.querySelector('[data-admin-save]')?.addEventListener('click', async () => saveGame('stay'));
      adminRoot.querySelector('[data-admin-save-next]')?.addEventListener('click', async () => saveGame('next'));
    };

    const renderPublic = () => {
      const { summary, filters } = aggregateCricketGames(state.games);
      state.filteredGames = filterGames(state.games);
      renderSummary(summary);
      renderFilterOptions(filters);
      renderLog(state.filteredGames);
    };

    const refreshFromSupabase = async () => {
      if (!state.supabase) {
        state.isFallback = true;
        state.games = fallbackGames;
        renderPublic();
        renderAdmin();
        setBanner('<p>Showing the seeded archive while the live connection is unavailable.</p>', 'warning');
        return;
      }
      const { data, error } = await state.supabase.from('cricket_games').select('*').order('game_date', { ascending: false });
      if (error) {
        state.isFallback = true;
        state.games = fallbackGames;
        renderPublic();
        renderAdmin();
        setBanner(`<p>Supabase is configured, but the live table could not be read yet.</p><small>${error.message}</small>`, 'warning');
        return;
      }
      state.isFallback = false;
      state.games = (data || []).map(normalizeCricketGame);
      renderPublic();
      renderAdmin();
      setBanner('<p>Live Supabase data connected.</p>', 'success');
    };

    filtersRoot?.querySelectorAll('input, select').forEach((field) => {
      field.addEventListener('input', () => {
        state.filteredGames = filterGames(state.games);
        renderLog(state.filteredGames);
      });
    });

    const initSupabase = async () => {
      if (!(env.supabaseUrl && env.supabaseAnonKey)) {
        await refreshFromSupabase();
        return;
      }
      state.supabase = createClient(env.supabaseUrl, env.supabaseAnonKey);
      const { data } = await state.supabase.auth.getSession();
      state.session = data.session;
      state.supabase.auth.onAuthStateChange((_event, session) => {
        state.session = session;
        renderAdmin();
      });
      await refreshFromSupabase();
    };

    initSupabase();
  </script>

  <style>
    .cricket-simple-page { position: relative; padding-bottom: 4rem; }
    .cricket-simple-page::before { content: ""; position: fixed; inset: 0; pointer-events: none; z-index: 0; background: radial-gradient(circle at 16% 14%, rgba(156, 187, 118, 0.14), transparent 24%), radial-gradient(circle at 82% 18%, rgba(222, 194, 122, 0.08), transparent 20%), linear-gradient(180deg, rgba(8, 20, 10, 0.96), rgba(16, 34, 18, 0.98)); }
    .cricket-simple-page > * { position: relative; z-index: 1; }
