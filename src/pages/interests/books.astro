---
import { getCollection } from 'astro:content';

import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/utils/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'Books')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const leadBook = posts[0];
const spineWidths = ['4.1rem', '4.6rem', '5rem', '4.4rem', '5.2rem', '4.8rem'];
const spineColors = ['#5a3821', '#74472a', '#915b30', '#6b4728', '#b5773e', '#81512f'];
const shelfRows = Array.from({ length: Math.ceil(posts.length / 6) }, (_, rowIndex) =>
  posts.slice(rowIndex * 6, rowIndex * 6 + 6).map((post, columnIndex) => ({
    post,
    width: spineWidths[(rowIndex * 6 + columnIndex) % spineWidths.length],
    color: spineColors[(rowIndex * 6 + columnIndex) % spineColors.length]
  }))
);
---

<BaseLayout title="Books" description="A warm reading-room page for books, reading notes, and the posts that sit on the shelf.">
  <div class="books-world">
<section class="page-section books-world__hero">
      <div class="books-world__copy">
        <p class="eyebrow">Books</p>
        <h1>A shelf for the books that stay open in the mind.</h1>
        <p>
          This room is quieter by design. Each post sits on the shelf like a spine: compact from a distance, richer once
          you pull it closer.
        </p>
      </div>


    </section>

    <section class="page-section panel books-world__shelf-panel">
      <div class="books-world__shelf-layout">
        <div class="books-world__shelf-head">
          <p class="eyebrow">Shelf</p>
          <h2>A cleaner wall for the books that keep returning.</h2>
          <p>
            The shelf is arranged like a quiet room now: one anchor note, then the rest of the library in calmer rows.
          </p>
        </div>

        {leadBook && (
          <a class="panel books-world__feature" href={`/blog/${leadBook.slug}`}>
            <p class="eyebrow">Pulled From The Shelf</p>
            <h3>{leadBook.data.title}</h3>
            <p>{leadBook.data.description}</p>
            <div class="books-world__feature-meta">
              <span>{formatDate(leadBook.data.publishedAt)}</span>
              <span>{posts.length} books</span>
            </div>
          </a>
        )}

        <div class="books-world__library">
          {shelfRows.map((row) => (
            <div class="books-world__shelf-row">
              <div class="books-world__shelf-books">
                {row.map(({ post, width, color }) => (
                  <a
                    class="books-world__spine"
                    href={`/blog/${post.slug}`}
                    style={`--spine-width:${width}; --spine-color:${color};`}
                  >
                    <span>{post.data.title}</span>
                    <small>{post.data.publishedAt.getFullYear()}</small>
                  </a>
                ))}
              </div>
              <div class="books-world__shelf-board" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section books-world__catalog">
      <div class="books-world__catalog-head">
        <p class="eyebrow">Catalog</p>
        <h2>Every book still opens into a full note.</h2>
      </div>

      <div class="books-world__catalog-list">
        {posts.map((post) => (
          <a class="panel books-world__catalog-item" href={`/blog/${post.slug}`}>
            <div class="books-world__catalog-date">
              <p>{formatDate(post.data.publishedAt)}</p>
            </div>
            <div class="books-world__catalog-copy">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .books-world {
    position: relative;
    padding-bottom: 4rem;
  }

  .books-world::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 16% 14%, rgba(226, 186, 116, 0.14), transparent 24%),
      linear-gradient(180deg, rgba(54, 35, 24, 0.96), rgba(19, 13, 10, 0.99));
  }

  .books-world > * {
    position: relative;
    z-index: 1;
  }

  .books-world__hero {
    display: grid;
    gap: 1rem;
    padding-top: clamp(2rem, 6vw, 4rem);
  }

  .books-world__copy {
    max-width: 40rem;
  }

  .books-world__copy h1,
  .books-world__shelf-head h2,
  .books-world__feature h3,
  .books-world__catalog-item h3,
  .books-world__catalog-head h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .books-world__copy h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 0.96;
    margin-bottom: 0.7rem;
  }

  .books-world__copy p,
  .books-world__feature p,
  .books-world__catalog-item p,
  .books-world__shelf-head p:last-child {
    margin: 0;
    color: rgba(246, 231, 202, 0.8);
    line-height: 1.8;
  }

  .books-world__shelf-panel {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    border-color: rgba(226, 186, 116, 0.2);
    background:
      linear-gradient(180deg, rgba(74, 45, 24, 0.92), rgba(27, 18, 12, 0.97)),
      radial-gradient(circle at top, rgba(226, 186, 116, 0.1), transparent 64%);
  }

  .books-world__shelf-layout {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.35fr);
    align-items: start;
  }

  .books-world__shelf-head h2 {
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    line-height: 1.03;
    margin-bottom: 0.55rem;
  }

  .books-world__feature {
    display: grid;
    gap: 0.75rem;
    padding: 1.1rem;
    border-radius: 24px;
    border-color: rgba(226, 186, 116, 0.18);
    background:
      linear-gradient(180deg, rgba(89, 54, 31, 0.9), rgba(34, 22, 15, 0.96)),
      radial-gradient(circle at top right, rgba(226, 186, 116, 0.12), transparent 36%);
  }

  .books-world__feature h3 {
    font-size: clamp(2rem, 4vw, 2.65rem);
    line-height: 1;
  }

  .books-world__feature-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .books-world__feature-meta span {
    display: inline-flex;
    align-items: center;
    padding: 0.34rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(226, 186, 116, 0.18);
    color: rgba(246, 231, 202, 0.72);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .books-world__library {
    display: grid;
    gap: 1rem;
  }

  .books-world__shelf-row {
    display: grid;
    gap: 0.45rem;
  }

  .books-world__shelf-books {
    display: flex;
    align-items: end;
    gap: 0.32rem;
    padding-inline: 0.35rem;
    overflow-x: auto;
  }

  .books-world__shelf-board {
    height: 0.9rem;
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(99, 64, 36, 0.86), rgba(61, 37, 22, 0.96));
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .books-world__spine {
    width: var(--spine-width);
    min-width: var(--spine-width);
    height: 12.2rem;
    border-radius: 12px 12px 4px 4px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--spine-color) 82%, white 8%), var(--spine-color));
    border: 1px solid rgba(0, 0, 0, 0.18);
    padding: 0.9rem 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow:
      inset -1px 0 0 rgba(0, 0, 0, 0.2),
      0 10px 18px rgba(0, 0, 0, 0.16);
    transition: transform 180ms ease, filter 180ms ease, box-shadow 180ms ease;
  }

  .books-world__spine:hover,
  .books-world__spine:focus-visible {
    transform: translateY(-7px);
    filter: brightness(1.08);
    box-shadow:
      inset -1px 0 0 rgba(0, 0, 0, 0.2),
      0 18px 28px rgba(0, 0, 0, 0.22);
    outline: none;
  }

  .books-world__spine span,
  .books-world__spine small {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .books-world__spine span {
    font-family: 'Fraunces', 'Times New Roman', serif;
    color: #f7ebd2;
    line-height: 1.14;
    font-size: 0.92rem;
  }

  .books-world__spine small {
    color: rgba(247, 235, 210, 0.66);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.66rem;
  }

  .books-world__catalog {
    display: grid;
    gap: 0.95rem;
  }

  .books-world__catalog-head h2 {
    font-size: clamp(1.75rem, 4vw, 2.4rem);
    line-height: 1.04;
    margin-top: 0.2rem;
  }

  .books-world__catalog-list {
    display: grid;
    gap: 0.8rem;
  }

  .books-world__catalog-item {
    display: grid;
    grid-template-columns: minmax(8.5rem, auto) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1rem 1.05rem;
    border-radius: 22px;
    border-color: rgba(226, 186, 116, 0.18);
    background: linear-gradient(180deg, rgba(57, 35, 20, 0.94), rgba(23, 16, 11, 0.97));
  }

  .books-world__catalog-date p {
    color: rgba(226, 186, 116, 0.88);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .books-world__catalog-copy {
    display: grid;
    gap: 0.38rem;
  }

  .books-world__catalog-item h3 {
    font-size: clamp(1.35rem, 3vw, 1.8rem);
    line-height: 1.05;
  }

  @media (max-width: 980px) {
    .books-world__shelf-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .books-world__catalog-item {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }
  }

  @media (max-width: 640px) {
    .books-world__spine {
      height: 10.5rem;
      min-width: max(var(--spine-width), 3.8rem);
    }

    .books-world__spine span {
      font-size: 0.84rem;
    }

    .books-world__shelf-books {
      padding-inline: 0.1rem;
    }
  }
</style>
