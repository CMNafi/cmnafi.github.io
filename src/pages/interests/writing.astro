---
import { getCollection } from 'astro:content';
import InterestWorldNav from '@/components/InterestWorldNav.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';
import { formatDate } from '@/utils/format';

const posts = (await getCollection(
  'blog',
  ({ data }) => !data.draft && ['Essays', 'Games', 'Notes', 'Product', 'Travel'].includes(data.category)
)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title="Writing"
  description="Essays, notebook pages, and the thoughts that did not fit anywhere else on the site."
>
  <div class="writing-world">
    <SiteTreeHeader
      branch="interests"
      currentHref="/interests/writing"
      title="Writing"
      description="The notebook side of the site: essays, drafts, product notes, and the thoughts that needed paper first."
    />

    <section class="page-section writing-world__hero">
      <div class="writing-world__copy">
        <p class="eyebrow">Writing</p>
        <h1>Notebook pages, essays, and thoughts that would not leave me alone.</h1>
        <p>
          This is where I put the pieces that feel less like reviews and more like thinking out loud: games, product
          frustrations, notes on taste, and the entries that start as scribbles before they become anything cleaner.
        </p>
      </div>

      <InterestWorldNav current="writing" />
    </section>

    <section class="page-section writing-world__stack">
      <div class="writing-world__grid">
        {posts.map((post, index) => (
          <a
            class="panel writing-world__card"
            href={`/blog/${post.slug}`}
            style={`--paper-rotation:${index % 2 === 0 ? '-1.8deg' : '1.2deg'};`}
          >
            <p>{formatDate(post.data.publishedAt)}</p>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <div class="writing-world__meta">
              <span>{post.data.category}</span>
              <span>{post.data.readingTime}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .writing-world {
    position: relative;
    padding-bottom: 4rem;
  }

  .writing-world::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 15% 14%, rgba(184, 156, 241, 0.12), transparent 24%),
      radial-gradient(circle at 78% 18%, rgba(133, 105, 190, 0.1), transparent 18%),
      linear-gradient(180deg, rgba(18, 12, 29, 0.98), rgba(10, 8, 17, 0.99));
  }

  .writing-world > * {
    position: relative;
    z-index: 1;
  }

  .writing-world__hero {
    display: grid;
    gap: 1rem;
    padding-top: clamp(2rem, 6vw, 4rem);
  }

  .writing-world__copy {
    max-width: 42rem;
  }

  .writing-world__copy h1,
  .writing-world__card h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .writing-world__copy h1 {
    font-size: clamp(2.9rem, 6vw, 4.7rem);
    line-height: 0.96;
    margin-bottom: 0.75rem;
  }

  .writing-world__copy p,
  .writing-world__card p {
    margin: 0;
    color: rgba(240, 232, 251, 0.8);
    line-height: 1.8;
  }

  .writing-world__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .writing-world__card {
    display: grid;
    gap: 0.7rem;
    padding: 1.25rem;
    border-radius: 26px;
    background:
      linear-gradient(180deg, rgba(242, 233, 252, 0.92), rgba(228, 218, 247, 0.92)),
      radial-gradient(circle at top right, rgba(184, 156, 241, 0.16), transparent 36%);
    border-color: rgba(184, 156, 241, 0.22);
    color: #1c1228;
    transform: rotate(var(--paper-rotation));
    transition: transform 180ms ease, box-shadow 180ms ease;
    box-shadow: 0 22px 50px rgba(5, 3, 10, 0.3);
  }

  .writing-world__card:hover,
  .writing-world__card:focus-visible {
    transform: rotate(0deg) translateY(-4px);
    outline: none;
  }

  .writing-world__card p,
  .writing-world__meta span {
    color: rgba(35, 22, 54, 0.8);
  }

  .writing-world__card p:first-child {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
  }

  .writing-world__card h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.04;
  }

  .writing-world__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.3rem;
  }

  .writing-world__meta span {
    display: inline-flex;
    padding: 0.32rem 0.62rem;
    border-radius: 999px;
    border: 1px solid rgba(70, 48, 101, 0.16);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .writing-world__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
