---
import { getCollection } from 'astro:content';
import InterestWorldNav from '@/components/InterestWorldNav.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';
import { formatDate } from '@/utils/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'Tech')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const nodePositions = [
  { x: 15, y: 20 },
  { x: 42, y: 18 },
  { x: 72, y: 22 },
  { x: 88, y: 45 },
  { x: 65, y: 50 },
  { x: 35, y: 52 },
  { x: 12, y: 55 },
  { x: 28, y: 78 },
  { x: 55, y: 80 },
  { x: 80, y: 76 },
];

const traces = [
  { x1: 15, y1: 20, x2: 42, y2: 18 },
  { x1: 42, y1: 18, x2: 72, y2: 22 },
  { x1: 72, y1: 22, x2: 88, y2: 45 },
  { x1: 88, y1: 45, x2: 65, y2: 50 },
  { x1: 65, y1: 50, x2: 35, y2: 52 },
  { x1: 35, y1: 52, x2: 12, y2: 55 },
  { x1: 12, y1: 55, x2: 28, y2: 78 },
  { x1: 28, y1: 78, x2: 55, y2: 80 },
  { x1: 55, y1: 80, x2: 80, y2: 76 },
  { x1: 42, y1: 18, x2: 35, y2: 52 },
  { x1: 65, y1: 50, x2: 55, y2: 80 },
];

const mappedPosts = posts.slice(0, nodePositions.length).map((post, index) => ({
  post,
  x: nodePositions[index].x,
  y: nodePositions[index].y,
}));
---

<BaseLayout
  title="Tech"
  description="Systems, tools, and the builds that start as traces on a board before they become real."
>
  <div class="tech-world">
    <SiteTreeHeader
      branch="interests"
      currentHref="/interests/tech"
      title="Tech"
      description="The circuit board branch, where systems thinking and builds get their own room."
    />

    <section class="page-section tech-world__hero">
      <div class="tech-world__copy">
        <p class="eyebrow">Tech</p>
        <h1>Every system starts with a trace.</h1>
        <p>
          This section is for the builds, tools, and system-level thinking that deserves more than a
          tweet — the kind of work that connects through layers.
        </p>
      </div>

      <InterestWorldNav current="tech" />
    </section>

    <section class="page-section panel tech-world__stage">
      <div class="tech-world__stage-head">
        <p class="eyebrow">Board</p>
        <h2>Posts as components on a circuit board.</h2>
        <p>Hover a node for a quick preview. Traces connect the ideas.</p>
      </div>

      <div class="tech-world__board">
        <svg class="tech-world__traces" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          {traces.map(({ x1, y1, x2, y2 }) => (
            <line
              x1={x1} y1={y1} x2={x2} y2={y2}
              stroke="rgba(57, 255, 20, 0.15)"
              stroke-width="0.4"
              stroke-linecap="round"
            />
          ))}
        </svg>

        {posts.length > 0 ? (
          mappedPosts.map(({ post, x, y }) => (
            <a
              class="tech-world__component"
              href={`/blog/${post.slug}`}
              style={`left:${x}%; top:${y}%;`}
            >
              <span class="tech-world__dot"></span>
              <span class="tech-world__tooltip">
                <strong>{post.data.title}</strong>
                <small>{formatDate(post.data.publishedAt)}</small>
                <span>{post.data.description}</span>
              </span>
            </a>
          ))
        ) : (
          nodePositions.map(({ x, y }) => (
            <div
              class="tech-world__component tech-world__component--placeholder"
              style={`left:${x}%; top:${y}%;`}
            >
              <span class="tech-world__dot"></span>
            </div>
          ))
        )}

        {posts.length === 0 && (
          <div class="tech-world__empty-label">
            <p>Components arriving soon.</p>
          </div>
        )}
      </div>
    </section>

    {posts.length > 0 && (
      <section class="page-section tech-world__ledger">
        <div class="tech-world__ledger-grid">
          {posts.map((post) => (
            <a class="panel tech-world__ledger-card" href={`/blog/${post.slug}`}>
              <p>{formatDate(post.data.publishedAt)}</p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .tech-world {
    position: relative;
    padding-bottom: 4rem;
  }

  .tech-world::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 20% 14%, rgba(57, 255, 20, 0.08), transparent 24%),
      radial-gradient(circle at 78% 18%, rgba(57, 255, 20, 0.05), transparent 18%),
      linear-gradient(180deg, rgba(8, 12, 8, 0.98), rgba(4, 6, 4, 0.99));
  }

  .tech-world > * {
    position: relative;
    z-index: 1;
  }

  .tech-world__hero {
    display: grid;
    gap: 1rem;
    padding-top: clamp(2rem, 6vw, 4rem);
  }

  .tech-world__copy {
    max-width: 42rem;
  }

  .tech-world__copy h1,
  .tech-world__stage h2,
  .tech-world__ledger-card h3 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .tech-world__copy h1 {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    margin-bottom: 0.7rem;
  }

  .tech-world__copy p,
  .tech-world__stage p,
  .tech-world__ledger-card p {
    margin: 0;
    color: rgba(212, 245, 212, 0.78);
    line-height: 1.78;
  }

  .tech-world__stage {
    display: grid;
    gap: 1.25rem;
    padding: clamp(1.2rem, 3vw, 1.7rem);
    background:
      linear-gradient(180deg, rgba(12, 18, 12, 0.92), rgba(6, 8, 6, 0.97)),
      radial-gradient(circle at top, rgba(57, 255, 20, 0.05), transparent 62%);
    border-color: rgba(57, 255, 20, 0.16);
  }

  .tech-world__stage h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    line-height: 1.02;
    margin-bottom: 0.6rem;
  }

  .tech-world__board {
    position: relative;
    width: 100%;
    min-height: 32rem;
    border-radius: 24px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 50%, rgba(57, 255, 20, 0.03), transparent 54%),
      repeating-linear-gradient(
        0deg,
        rgba(57, 255, 20, 0.02) 0,
        rgba(57, 255, 20, 0.02) 2%,
        transparent 2%,
        transparent 10%
      ),
      repeating-linear-gradient(
        90deg,
        rgba(57, 255, 20, 0.02) 0,
        rgba(57, 255, 20, 0.02) 2%,
        transparent 2%,
        transparent 10%
      ),
      linear-gradient(180deg, rgba(10, 16, 10, 0.96), rgba(6, 10, 6, 0.98));
    box-shadow: inset 0 0 0 1px rgba(57, 255, 20, 0.06);
  }

  .tech-world__traces {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .tech-world__component {
    position: absolute;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 1.6rem;
    height: 1.6rem;
    z-index: 2;
  }

  .tech-world__dot {
    width: 0.9rem;
    height: 0.9rem;
    border-radius: 50%;
    background: #39ff14;
    box-shadow: 0 0 12px rgba(57, 255, 20, 0.35), 0 0 0 0 rgba(57, 255, 20, 0.18);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .tech-world__component--placeholder .tech-world__dot {
    opacity: 0.25;
    box-shadow: 0 0 6px rgba(57, 255, 20, 0.15);
  }

  .tech-world__tooltip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.85rem);
    transform: translateX(-50%) translateY(0.3rem);
    width: min(16rem, 62vw);
    display: grid;
    gap: 0.3rem;
    padding: 0.8rem 0.9rem;
    border-radius: 16px;
    background: rgba(6, 10, 6, 0.96);
    border: 1px solid rgba(57, 255, 20, 0.2);
    color: #d4f5d4;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease, transform 180ms ease;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    z-index: 10;
  }

  .tech-world__tooltip strong {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 1.08rem;
  }

  .tech-world__tooltip small {
    color: rgba(57, 255, 20, 0.66);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.68rem;
  }

  .tech-world__tooltip span {
    color: rgba(212, 245, 212, 0.78);
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .tech-world__component:hover .tech-world__dot,
  .tech-world__component:focus-visible .tech-world__dot {
    transform: scale(1.3);
    box-shadow: 0 0 18px rgba(57, 255, 20, 0.5), 0 0 0 10px rgba(57, 255, 20, 0.1);
  }

  .tech-world__component:not(.tech-world__component--placeholder):hover .tech-world__tooltip,
  .tech-world__component:not(.tech-world__component--placeholder):focus-visible .tech-world__tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .tech-world__empty-label {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    z-index: 5;
  }

  .tech-world__empty-label p {
    padding: 0.7rem 1.2rem;
    border-radius: 16px;
    background: rgba(6, 10, 6, 0.88);
    border: 1px solid rgba(57, 255, 20, 0.16);
    color: rgba(57, 255, 20, 0.8);
    font-size: 0.88rem;
    letter-spacing: 0.06em;
  }

  .tech-world__ledger {
    margin-top: 1.25rem;
  }

  .tech-world__ledger-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.9rem;
  }

  .tech-world__ledger-card {
    display: grid;
    gap: 0.6rem;
    padding: 1rem;
    border-radius: 22px;
    border-color: rgba(57, 255, 20, 0.14);
    background: linear-gradient(180deg, rgba(12, 18, 12, 0.92), rgba(6, 8, 6, 0.96));
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .tech-world__ledger-card:hover,
  .tech-world__ledger-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(57, 255, 20, 0.26);
    outline: none;
  }

  .tech-world__ledger-card > p:first-child {
    color: rgba(57, 255, 20, 0.8);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .tech-world__board {
      min-height: 24rem;
      border-radius: 18px;
    }

    .tech-world__tooltip {
      width: min(13rem, 70vw);
    }
  }
</style>
