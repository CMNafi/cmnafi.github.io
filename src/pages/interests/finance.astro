---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate } from '@/utils/format';

const posts = (await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'Finance'
)).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title="Finance"
  description="Breakdowns of companies, structural economics, options plays, and market mechanics."
>
  <div class="finance-world">
    <div class="finance-bg-overlay"></div>
    
    <section class="page-section finance-world__hero">
      <div class="finance-world__copy">
        <p class="eyebrow">Finance</p>
        <h1>Market mechanics, venture math, and structural economics.</h1>
        <p>
          I am continually fascinated by the hidden plumbing of the world. This is where I map out company deep dives, financial models, covered call strategies, and the invisible gears that drive Silicon Valley.
        </p>
      </div>
    </section>

    <section class="page-section finance-world__stack">
      <div class="finance-world__grid">
        {posts.map((post, index) => (
          <a
            class="panel finance-world__card group"
            href={`/blog/${post.slug}`}
          >
            <div class="card-content">
              <p class="card-date">{formatDate(post.data.publishedAt)}</p>
              <h2>{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
              <div class="finance-world__meta">
                <span>{post.data.category}</span>
                <span class="meta-dot">•</span>
                <span>{post.data.readingTime}</span>
              </div>
            </div>
            
            <div class="ticker-ribbon">
              <span>{post.data.tags ? post.data.tags.filter(t => t).slice(0,3).join(' / ').toUpperCase() : 'ANALYSIS'}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .finance-world {
    position: relative;
    padding-bottom: 4rem;
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
  }

  .finance-bg-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 80% 20%, rgba(16, 185, 129, 0.08), transparent 35%),
      radial-gradient(circle at 10% 80%, rgba(52, 211, 153, 0.05), transparent 45%),
      linear-gradient(180deg, #0a0e12, #05070a);
  }
  
  .finance-world > * {
    position: relative;
    z-index: 1;
  }

  .finance-world__hero {
    display: grid;
    gap: 1rem;
    padding-top: clamp(2rem, 6vw, 4rem);
    margin-bottom: 3rem;
  }

  .finance-world__copy {
    max-width: 48rem;
  }

  .eyebrow {
    color: #10B981;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    font-family: 'DM Sans', sans-serif;
  }

  .finance-world__copy h1 {
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    font-family: 'Fraunces', serif;
    letter-spacing: -0.03em;
    color: #F3F3F1;
  }

  .finance-world__copy p:not(.eyebrow) {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #9CA3AF;
  }

  .finance-world__grid {
    display: grid;
    gap: 1.5rem;
  }
  
  @media (min-width: 768px) {
    .finance-world__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .finance-world__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #111827;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.5rem;
    padding: 2rem;
    text-decoration: none;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
    overflow: hidden;
    position: relative;
  }

  .finance-world__card:hover {
    transform: translateY(-4px);
    border-color: #10B981;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(16, 185, 129, 0.2);
  }

  .card-date {
    font-family: 'DM Sans', monospace;
    font-size: 0.8rem;
    color: #10B981;
    margin-bottom: 1rem;
  }

  .finance-world__card h2 {
    font-size: 1.8rem;
    line-height: 1.2;
    margin-top: 0;
    margin-bottom: 1rem;
    font-family: 'Fraunces', serif;
    color: #F9FAFB;
    transition: color 0.3s;
  }
  
  .finance-world__card:hover h2 {
    color: #34D399;
  }

  .card-desc {
    color: #9CA3AF;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 2.5rem;
  }

  .finance-world__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    color: #6B7280;
    letter-spacing: 0.05em;
    margin-top: auto;
  }
  
  .meta-dot {
    color: #374151;
  }

  /* Decorative Ticker Tape */
  .ticker-ribbon {
    position: absolute;
    top: 1.5rem;
    right: -2rem;
    background: #064E3B;
    color: #34D399;
    font-family: monospace;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.25rem 3rem;
    transform: rotate(45deg);
    opacity: 0.8;
  }
</style>
