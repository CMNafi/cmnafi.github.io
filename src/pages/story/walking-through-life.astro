---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { journeySegments, lifeJourneyDestinations } from '@/data/life-journey';
---

<BaseLayout
  title="My Journey"
  description="The path from Dinajpur to Tampa — education, work, and everything in between. A segmented timeline of the places, institutions, and roles that shaped C M Nafi."
>
  <div class="journey-page">
    <!-- Hero -->
    <section class="page-section journey-hero">
      <p class="eyebrow">Journey / Timeline</p>
      <h1>The path so far</h1>
      <p class="journey-hero__lead">
        From Bangladesh to Tampa — through military school, a global education, and into the world of data, finance, and public work.
        Each chapter clickable, each milestone a turning point.
      </p>
      <div class="journey-hero__nav">
        {journeySegments.map((segment) => (
          <a class="journey-hero__nav-chip" href={`#${segment.id}`}>
            <span class={`journey-hero__nav-icon journey-hero__nav-icon--${segment.icon}`} aria-hidden="true"></span>
            {segment.label}
            <span class="journey-hero__nav-count">{segment.items.length}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Timeline segments -->
    {journeySegments.map((segment, segIdx) => (
      <section id={segment.id} class="page-section journey-segment">
        <div class="journey-segment__header">
          <span class={`journey-segment__icon journey-segment__icon--${segment.icon}`} aria-hidden="true"></span>
          <h2 class="journey-segment__title">{segment.label}</h2>
          <span class="journey-segment__count">{segment.items.length} milestones</span>
        </div>

        <div class="journey-timeline">
          <div class="journey-timeline__line" aria-hidden="true"></div>

          {segment.items.map((item, idx) => {
            const isClickable = !!item.href;
            const Tag = isClickable ? 'a' : 'div';
            return (
              <Tag
                class={`journey-card panel ${isClickable ? 'journey-card--link' : ''}`}
                {...(isClickable ? { href: item.href } : {})}
                {...(isClickable && item.href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                style={`--card-delay: ${idx * 0.08}s`}
                data-journey-card
              >
                <div class="journey-card__dot" aria-hidden="true">
                  <span class="journey-card__dot-ring"></span>
                  <span class="journey-card__dot-core"></span>
                </div>

                <div class="journey-card__period">{item.period}</div>

                <div class="journey-card__body">
                  <div class="journey-card__heading">
                    <h3>{item.title}</h3>
                    {isClickable && (
                      <span class="journey-card__arrow" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    )}
                  </div>
                  <p class="journey-card__subtitle">{item.subtitle}</p>
                  <p class="journey-card__location">{item.location}</p>
                  <p class="journey-card__description">{item.description}</p>

                  <div class="journey-card__highlights">
                    {item.highlights.map((h) => (
                      <span class="journey-card__highlight">{h}</span>
                    ))}
                  </div>

                  {item.tags && (
                    <div class="journey-card__tags">
                      {item.tags.map((tag) => (
                        <span class="journey-card__tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </Tag>
            );
          })}
        </div>
      </section>
    ))}

    <!-- Destinations -->
    <section class="page-section journey-destinations">
      <SectionHeading
        eyebrow="Continue"
        title="Where the journey leads next"
        description="The walk opens into the rest of the site — each destination carries a different part of the same person."
      />
      <div class="journey-destination-grid">
        {lifeJourneyDestinations.map((dest) => (
          <a class="panel journey-destination-card" href={dest.href}>
            <h3>{dest.title}</h3>
            <p>{dest.description}</p>
            <span class="journey-destination-card__arrow">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script>
    const cards = document.querySelectorAll('[data-journey-card]');
    if (cards.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -60px 0px' }
      );
      cards.forEach((card) => observer.observe(card));
    }
  </script>
</BaseLayout>
