---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import DirectoryCard from '@/components/DirectoryCard.astro';
import HighlightCard from '@/components/cricket/HighlightCard.astro';
import CricketTimeline from '@/components/cricket/CricketTimeline.astro';
import { cricketHighlights, cricketTimeline } from '@/data/cricket';

const adventureCategories = [
  {
    title: 'Cricket',
    slug: '/adventures/cricket',
    description: 'The deepest record on the site: teams, matches, seasons, milestones, and the stories I still remember clearly.',
    category: 'Adventures',
    status: 'live',
    icon: '🏏'
  },
  {
    title: 'Travel notes',
    slug: '/adventures',
    description: 'A future home for trips, walks, detours, and the places that deserve more than a photo dump.',
    category: 'Adventures',
    status: 'brewing',
    icon: '✈️'
  },
  {
    title: 'Photo journals',
    slug: '/adventures',
    description: 'A later layer for photos and visual fragments once I know how I want them to live here.',
    category: 'Adventures',
    status: 'coming soon',
    icon: '📷'
  }
];

const recentHighlights = cricketHighlights.slice(0, 3);
const timelinePreview = cricketTimeline.slice(-3).reverse();
---

<BaseLayout
  title="Adventures"
  description="The part of the site that keeps score of the life outside work, starting with cricket."
>
<section class="page-section page-section-hero">
    <div class="panel adventures-landing-hero">
      <p class="eyebrow">Adventures</p>
      <h1>The parts of life I do not want to treat like side notes.</h1>
      <p class="hero-description">
        This section starts with cricket because cricket has earned it. Over time it will also hold trips, photos, and the kinds of memories that keep their shape years later.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/adventures/cricket">Enter cricket archive</a>
        <a class="button button-secondary" href="/adventures/cricket/timeline">Open the timeline</a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Adventure domains"
      title="Cricket comes first, but it is not the only part of life worth keeping."
      description="This section is meant to grow slowly and honestly, starting with the archive that already matters most."
    />
    <div class="spotlight-grid">
      {adventureCategories.map((item) => <DirectoryCard item={item} />)}
    </div>
  </section>

  <section class="page-section two-up cricket-spotlight-grid">
    <article class="panel cricket-spotlight-card">
      <p class="eyebrow">Flagship archive</p>
      <h2>Cricket is the center of gravity here.</h2>
      <p>
        Built around teams, matches, season snapshots, and personal notes, the cricket section works as both record and memory. I wanted it to keep the numbers without losing the feeling.
      </p>
      <div class="tag-row">
        <span class="tag-chip">player profile</span>
        <span class="tag-chip">match history</span>
        <span class="tag-chip">highlights</span>
        <span class="tag-chip">timeline storytelling</span>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href="/adventures/cricket/records">View records</a>
        <a class="button button-ghost" href="/adventures/cricket/highlights">Read stories</a>
      </div>
    </article>

    <article class="panel panel-stack">
      <SectionHeading
        eyebrow="Recent highlights"
        title="A quick look at the stories I do not want to lose"
        description="The stats matter, but the context is what makes me keep coming back to them."
      />
      <div class="narrow-stack">
        {recentHighlights.map((highlight) => <HighlightCard highlight={highlight} />)}
      </div>
    </article>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Timeline preview"
      title="The shape of the journey matters as much as the totals"
      description="A small look at how separate match memories start turning into a longer sporting life."
    />
    <CricketTimeline items={timelinePreview} />
  </section>
</BaseLayout>
