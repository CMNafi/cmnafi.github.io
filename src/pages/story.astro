---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Pull the journey collection
const rawChapters = (await getCollection('journey')).sort((a, b) => a.data.order - b.data.order);
const chapters = await Promise.all(
  rawChapters.map(async (entry, index) => {
    const { Content } = await render(entry);
    return {
      entry,
      Content,
      step: String(index + 1).padStart(2, '0'),
      index
    };
  })
);
---
<BaseLayout title="My Story" description="A horizontal timeline of my personal and professional journey.">
  <div class="story-page" data-mode="professional">
    
    <!-- FIXED TOP CONTAINER -->
    <header class="story-header">
      <div class="story-header__content">
        <h1>My Story</h1>
        <!-- Professional Desc -->
        <p class="story-header__desc mode-professional">
          The route behind the work. Tracing the path through institutional finance, systems, and product discipline.
        </p>
        <!-- Personal Desc -->
        <p class="story-header__desc mode-personal">
          The personal reading. Leaving home early, widening the world, and becoming more at ease with movement and identity.
        </p>
        
        <div class="story-mode-toggle">
          <button type="button" class="mode-btn is-active" data-mode-toggle="professional">Professional</button>
          <button type="button" class="mode-btn" data-mode-toggle="personal">Personal</button>
        </div>
      </div>
      
      <div class="story-header__image">
        <img class="mode-professional" src="/journey-professional.jpg" alt="Professional Portrait" />
        <img class="mode-personal" src="/journey-personal.jpeg" alt="Personal Portrait" />
      </div>
    </header>

    <!-- HORIZONTAL SCROLL TIMELINE -->
    <div class="story-timeline-wrapper" id="timeline-wrapper">
      <div class="story-timeline-track" id="timeline-track">
        
        {chapters.map(({ entry, Content, step }) => (
          <article class="timeline-card">
            <div class="card-meta">
              <span class="card-step">{step}</span>
              <span class="card-year">{entry.data.period}</span>
            </div>
            
            <div class="card-header">
              <h2 class="card-place">{entry.data.place}</h2>
              <p class="card-org">{entry.data.organization}</p>
              
              <p class="card-theme mode-professional">{entry.data.theme}</p>
              <p class="card-theme mode-personal">{entry.data.personalTheme ?? entry.data.theme}</p>
            </div>

            <div class="card-summary mode-professional">
              <p>{entry.data.professionalSummary ?? entry.data.summary}</p>
            </div>
            <div class="card-summary mode-personal">
              <p>{entry.data.personalSummary ?? entry.data.summary}</p>
            </div>

            <div class="card-content">
              <Content />
            </div>
          </article>
        ))}

        <article class="timeline-card timeline-card--end">
          <div class="card-header">
            <h2 class="card-place">The Present</h2>
            <p class="card-org">What's Next</p>
          </div>
          <div class="card-summary">
            <p>Once the route is visible, the rest of the site reads as smartly connected surfaces.</p>
          </div>
          <div class="card-links">
            <a href="/interests" class="story-next-btn">Explore Interests &rarr;</a>
            <a href="/projects" class="story-next-btn">View Projects &rarr;</a>
            <a href="/connect" class="story-next-btn">Get in Touch &rarr;</a>
          </div>
        </article>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  :root {
    --bg-dark: #111;
    --text-main: #f3ede1;
    --text-muted: #b8ad9a;
    --accent: #d39a59;
  }

  /* Structural Flex to stick header and scroll content */
  .story-page {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: var(--bg-dark);
    color: var(--text-main);
    overflow: hidden; /* Prevent body scroll on Desktop */
  }

  /* mode toggling */
  [data-mode='professional'] .mode-personal { display: none !important; }
  [data-mode='personal'] .mode-professional { display: none !important; }

  /* --- HEADER (Fixed Top) --- */
  .story-header {
    flex-shrink: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2.5rem 5vw;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    background: rgba(15, 15, 15, 0.98);
    z-index: 50;
  }

  .story-header__content {
    max-width: 700px;
  }

  .story-header h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .story-header__desc {
    font-family: 'Manrope', sans-serif;
    font-size: 1.15rem;
    color: var(--text-muted);
    margin: 0 0 1.8rem;
    line-height: 1.6;
  }

  .story-mode-toggle {
    display: inline-flex;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50px;
    padding: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mode-btn {
    background: transparent;
    color: rgba(255, 255, 255, 0.6);
    border: none;
    padding: 0.7rem 1.8rem;
    border-radius: 40px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .mode-btn.is-active, .mode-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  /* Portrait Images */
  .story-header__image {
    flex-shrink: 0;
  }

  .story-header__image img {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 0 35px rgba(255, 255, 255, 0.05);
  }

  /* --- HORIZONTAL TRACK --- */
  .story-timeline-wrapper {
    flex-grow: 1;
    overflow-x: auto;
    overflow-y: hidden;
    /* Smooth native scroll */
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
  }

  /* Hide scrollbar visually but keep functionally */
  .story-timeline-wrapper::-webkit-scrollbar { height: 8px; }
  .story-timeline-wrapper::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
  .story-timeline-wrapper::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 4px; }

  .story-timeline-track {
    display: flex;
    padding: 4rem 5vw;
    gap: 3.5rem;
    min-width: max-content;
    height: 100%;
    align-items: stretch;
  }

  /* --- CARDS --- */
  .timeline-card {
    width: 500px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    overflow-y: auto; /* internal scrolling for long markdown */
    transition: background 0.3s, transform 0.3s, border-color 0.3s;
  }
  
  .timeline-card::-webkit-scrollbar { width: 4px; }
  .timeline-card::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); }

  .timeline-card:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-8px);
    border-color: rgba(34, 211, 238, 0.3);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .card-step {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--accent);
    font-family: 'DM Sans', sans-serif;
    font-weight: 800;
    font-size: 1.15rem;
  }

  .card-year {
    font-family: 'DM Sans', sans-serif;
    color: var(--text-muted);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .card-header {
    margin-bottom: 1.5rem;
  }

  .card-place {
    font-family: 'Fraunces', serif;
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    color: #fff;
    line-height: 1.1;
  }

  .card-org {
    font-family: 'Sora', sans-serif;
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 1.2rem;
  }

  .card-theme {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    border-radius: 30px;
    background: rgba(211, 154, 89, 0.15);
    color: var(--accent);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .card-summary {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    color: #e4d2b8;
    line-height: 1.6;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .card-content {
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Format Markdown Content inside card */
  .card-content :global(p) { margin-bottom: 1rem; }
  .card-content :global(h2), .card-content :global(h3) { 
    color: #fff; 
    margin: 1.5rem 0 0.5rem; 
    font-family: 'Sora', sans-serif;
  }
  .card-content :global(ul) { padding-left: 1.5rem; margin-bottom: 1rem; list-style-type: disc; }
  .card-content :global(li) { margin-bottom: 0.6rem; }

  .timeline-card--end {
    justify-content: center;
    border-style: dashed;
    background: transparent;
  }
  .timeline-card--end:hover { background: rgba(255,255,255,0.02); }

  .card-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .story-next-btn {
    display: block;
    padding: 1.2rem 2rem;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    text-decoration: none;
    border-radius: 40px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    text-align: center;
    transition: background 0.3s, transform 0.3s;
  }
  .story-next-btn:hover {
    background: #fff;
    color: #000;
    transform: translateX(10px);
  }

  /* Mobile Adjustments */
  @media (max-width: 900px) {
    .story-page { height: auto; overflow: visible; }
    .story-header { flex-direction: column-reverse; gap: 2.5rem; text-align: center; padding: 2rem 1.5rem; }
    .story-timeline-wrapper { overflow: visible; }
    .story-timeline-track { flex-direction: column; padding: 2rem 1.5rem; width: 100%; min-width: 0; gap: 2rem; }
    .timeline-card { width: 100%; overflow: visible; padding: 1.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Setup Mode Toggles
    const wrapper = document.querySelector('.story-page');
    const toggleBtns = document.querySelectorAll('[data-mode-toggle]');

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active class on buttons
        toggleBtns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        
        // Update mode on wrapper
        const mode = btn.getAttribute('data-mode-toggle');
        wrapper.setAttribute('data-mode', mode);
      });
    });

    // 2. Mouse Wheel to Horizontal Scroll Hijack (Desktop only)
    const trackWrapper = document.getElementById('timeline-wrapper');
    if (trackWrapper && window.innerWidth > 900) {
      trackWrapper.addEventListener('wheel', (evt) => {
        // Only hijack vertical scroll if purely vertical
        if (evt.deltaY !== 0 && evt.deltaX === 0) {
          evt.preventDefault();
          // Map vertical scroll distance exactly onto horizontal axis
          trackWrapper.scrollLeft += evt.deltaY;
        }
      });
    }
  });
</script>
