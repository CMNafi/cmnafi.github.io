---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { journeyStops } from '@/data/strategy-map';

const routeCountries = ['Bangladesh', 'China', 'USA'];
const defaultStop = journeyStops[0];
const nextPaths = [
  {
    title: 'Interests',
    href: '/interests',
    description: 'Cricket, books, movies, writing, and the archive arranged as timelines.'
  },
  {
    title: 'Projects',
    href: '/projects',
    description: 'Tools, products, and systems built from that same foundation.'
  },
  {
    title: 'Connect',
    href: '/connect',
    description: 'A direct path for thoughtful conversations and collaboration.'
  }
];

const svgWidth = 1000;
const svgHeight = 620;
const routePoints = journeyStops
  .map((stop) => `${(Number.parseFloat(stop.mapX) / 100) * svgWidth},${(Number.parseFloat(stop.mapY) / 100) * svgHeight}`)
  .join(' ');
---

<BaseLayout title="Journey" description="A geographic journey from Bangladesh to Tampa, tracing the route through study, work, and financial intelligence.">
  <div class="journey-page">
    <section class="page-section journey-intro">
      <div class="journey-intro__copy">
        <p class="eyebrow">Journey</p>
        <h1>The route stays visible.</h1>
        <p>
          From Bangladesh to China to the United States, this page follows the places that shaped the current work in fintech,
          product systems, and writing.
        </p>
        <a class="button button-primary" href="#journey-route">Follow the route</a>
      </div>

      <aside class="panel journey-intro__route-card">
        <p class="eyebrow">Route</p>
        <h2>{routeCountries.join(' -> ')}</h2>
        <p>
          Origins, expansion, study, research, institutional finance, and the current base all sit on the same line.
        </p>
      </aside>
    </section>

    <section class="page-section journey-route" id="journey-route">
      <div
        class="panel journey-stage"
        data-journey-stage
        style={`--focus-x:${defaultStop.mapX}; --focus-y:${defaultStop.mapY};`}
      >
        <div class="journey-stage__topline">
          <span class="journey-stage__badge">Live map</span>
          <span class="journey-stage__route">{routeCountries.join(' -> ')}</span>
        </div>

        <div class="journey-stage__current">
          <span class="journey-stage__step" data-stage-step>{defaultStop.step}</span>
          <div>
            <p class="journey-stage__eyebrow" data-stage-organization>{defaultStop.organization}</p>
            <h2 data-stage-place>{defaultStop.place}</h2>
            <p class="journey-stage__summary" data-stage-summary>{defaultStop.summary}</p>
          </div>
        </div>

        <div class="journey-globe">
          <svg class="journey-globe__svg" viewBox={`0 0 ${svgWidth} ${svgHeight}`} preserveAspectRatio="xMidYMid meet" aria-hidden="true">
            <defs>
              <radialGradient id="journeyGlow" cx="50%" cy="48%" r="58%">
                <stop offset="0%" stop-color="rgba(211, 154, 89, 0.18)" />
                <stop offset="70%" stop-color="rgba(211, 154, 89, 0.04)" />
                <stop offset="100%" stop-color="transparent" />
              </radialGradient>
              <linearGradient id="journeyRouteGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="rgba(211, 154, 89, 0.56)" />
                <stop offset="55%" stop-color="rgba(243, 237, 225, 0.7)" />
                <stop offset="100%" stop-color="rgba(126, 134, 157, 0.56)" />
              </linearGradient>
            </defs>

            <rect x="0" y="0" width={svgWidth} height={svgHeight} fill="url(#journeyGlow)" opacity="0.9" />
            <ellipse cx="500" cy="310" rx="350" ry="220" fill="rgba(255,255,255,0.02)" stroke="rgba(243, 237, 225, 0.08)" stroke-width="1.2" />
            <ellipse cx="500" cy="310" rx="350" ry="140" fill="none" stroke="rgba(243, 237, 225, 0.09)" stroke-width="1" />
            <ellipse cx="500" cy="310" rx="230" ry="220" fill="none" stroke="rgba(243, 237, 225, 0.08)" stroke-width="1" />
            <ellipse cx="500" cy="310" rx="120" ry="220" fill="none" stroke="rgba(243, 237, 225, 0.06)" stroke-width="0.9" />

            <path d="M210 250 C290 220 360 205 430 215 C470 220 520 205 570 180 C630 150 700 150 785 190" fill="none" stroke="rgba(243, 237, 225, 0.12)" stroke-width="1.1" />
            <path d="M220 350 C280 320 340 315 390 330 C460 350 540 350 610 320 C680 290 730 290 790 315" fill="none" stroke="rgba(243, 237, 225, 0.1)" stroke-width="1" />
            <path d="M270 190 C260 240 255 300 280 355" fill="none" stroke="rgba(243, 237, 225, 0.08)" stroke-width="1" />
            <path d="M720 190 C695 250 695 330 720 390" fill="none" stroke="rgba(243, 237, 225, 0.08)" stroke-width="1" />

            <polyline
              class="journey-globe__route-line"
              points={routePoints}
              fill="none"
              stroke="url(#journeyRouteGradient)"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>

          <div class="journey-globe__focus" aria-hidden="true"></div>

          {journeyStops.map((stop) => (
            <button
              type="button"
              class:list={['journey-globe__node', stop.id === defaultStop.id && 'is-active']}
              style={`left:${stop.mapX}; top:${stop.mapY};`}
              data-journey-node={stop.id}
              data-node-target={`journey-stop-${stop.id}`}
              aria-label={`Jump to ${stop.place}`}
            >
              <span class="journey-globe__dot"></span>
              <span class="journey-globe__node-label">{stop.organization}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="journey-scroll">
        {journeyStops.map((stop) => (
          <article
            class:list={['panel', 'journey-stop', stop.id === defaultStop.id && 'is-active']}
            id={`journey-stop-${stop.id}`}
            data-stop-id={stop.id}
            data-stop-step={stop.step}
            data-stop-place={stop.place}
            data-stop-organization={stop.organization}
            data-stop-summary={stop.summary}
            data-stop-map-x={stop.mapX}
            data-stop-map-y={stop.mapY}
          >
            <p class="journey-stop__eyebrow">{stop.step} / {stop.region}</p>
            <div class="journey-stop__header">
              <div>
                <h3>{stop.title}</h3>
                <p class="journey-stop__place">{stop.place}</p>
              </div>
              <span class="journey-stop__organization">{stop.organization}</span>
            </div>
            <p class="journey-stop__summary">{stop.summary}</p>
            <p class="journey-stop__body">{stop.narrative}</p>
            <p class="journey-stop__atlas">{stop.atlasLabel}</p>
          </article>
        ))}

        <section class="panel journey-close">
          <p class="eyebrow">After the route</p>
          <h2>The rest of the site extends from here.</h2>
          <p>
            Writing, projects, and public work make more sense once the route is visible.
          </p>

          <div class="journey-close__grid">
            {nextPaths.map((path) => (
              <a class="journey-close__card" href={path.href}>
                <span>{path.title}</span>
                <p>{path.description}</p>
              </a>
            ))}
          </div>
        </section>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .journey-page {
    position: relative;
    padding-bottom: 4rem;
  }

  .journey-page::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 20% 18%, rgba(211, 154, 89, 0.1), transparent 28%),
      radial-gradient(circle at 82% 14%, rgba(126, 134, 157, 0.08), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 28%, transparent 72%, rgba(255, 255, 255, 0.012));
  }

  .journey-page > * {
    position: relative;
    z-index: 1;
  }

  .journey-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.75fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: end;
    padding-top: clamp(2rem, 6vw, 4rem);
    padding-bottom: 2rem;
  }

  .journey-intro__copy {
    display: grid;
    gap: 1.15rem;
    max-width: 42rem;
  }

  .journey-intro__copy h1,
  .journey-intro__route-card h2,
  .journey-stage__current h2,
  .journey-stop h3,
  .journey-close h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .journey-intro__copy h1 {
    font-size: clamp(3rem, 6vw, 5.1rem);
    line-height: 0.96;
    max-width: 9ch;
  }

  .journey-intro__copy p,
  .journey-intro__route-card p,
  .journey-stage__summary,
  .journey-stop__summary,
  .journey-stop__body,
  .journey-close > p,
  .journey-close__card p {
    margin: 0;
    color: rgba(243, 237, 225, 0.74);
    line-height: 1.8;
  }

  .journey-intro__route-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.5rem;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top, rgba(211, 154, 89, 0.09), transparent 62%);
  }

  .journey-intro__route-card h2 {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.08;
  }

  .journey-route {
    display: grid;
    grid-template-columns: minmax(320px, 0.9fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: start;
  }

  .journey-stage {
    position: sticky;
    top: 5.75rem;
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 30px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top, rgba(211, 154, 89, 0.07), transparent 64%);
    overflow: hidden;
  }

  .journey-stage__topline,
  .journey-stage__current {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .journey-stage__topline {
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .journey-stage__badge,
  .journey-stage__route,
  .journey-stop__organization,
  .journey-stop__atlas {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.34rem 0.7rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-family: 'Manrope', sans-serif;
  }

  .journey-stage__badge {
    color: var(--accent);
    background: rgba(211, 154, 89, 0.12);
    border: 1px solid rgba(211, 154, 89, 0.28);
  }

  .journey-stage__route,
  .journey-stop__atlas {
    color: rgba(243, 237, 225, 0.62);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(243, 237, 225, 0.08);
  }

  .journey-stage__step {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(211, 154, 89, 0.11);
    border: 1px solid rgba(211, 154, 89, 0.28);
    color: var(--accent);
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    flex-shrink: 0;
  }

  .journey-stage__eyebrow,
  .journey-stop__eyebrow {
    margin: 0 0 0.4rem;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .journey-stage__current h2 {
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    line-height: 1.05;
    margin-bottom: 0.55rem;
  }

  .journey-globe {
    position: relative;
    min-height: 25rem;
    border-radius: 24px;
    border: 1px solid rgba(243, 237, 225, 0.08);
    background: linear-gradient(180deg, rgba(9, 11, 16, 0.9), rgba(13, 14, 20, 0.75));
    overflow: hidden;
    isolation: isolate;
  }

  .journey-globe::before {
    content: "";
    position: absolute;
    inset: 10% 18%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(211, 154, 89, 0.12), transparent 70%);
    filter: blur(28px);
    opacity: 0.8;
  }

  .journey-globe__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .journey-globe__route-line {
    stroke-dasharray: 14 10;
    animation: route-drift 14s linear infinite;
    opacity: 0.92;
  }

  .journey-globe__focus {
    position: absolute;
    left: var(--focus-x);
    top: var(--focus-y);
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    border: 1px solid rgba(211, 154, 89, 0.32);
    background: radial-gradient(circle, rgba(211, 154, 89, 0.18), rgba(211, 154, 89, 0.03) 58%, transparent 70%);
    transform: translate(-50%, -50%);
    transition: left 420ms cubic-bezier(0.22, 1, 0.36, 1), top 420ms cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .journey-globe__node {
    position: absolute;
    display: grid;
    gap: 0.45rem;
    transform: translate(-50%, -50%);
    border: 0;
    padding: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    text-align: left;
  }

  .journey-globe__dot {
    width: 0.95rem;
    height: 0.95rem;
    border-radius: 50%;
    background: rgba(243, 237, 225, 0.75);
    box-shadow: 0 0 0 0 rgba(211, 154, 89, 0.28);
    transition: background 220ms ease, transform 220ms ease, box-shadow 220ms ease;
  }

  .journey-globe__node-label {
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 220ms ease, transform 220ms ease;
    color: rgba(243, 237, 225, 0.9);
    font-size: 0.66rem;
    font-family: 'Manrope', sans-serif;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .journey-globe__node:hover .journey-globe__dot,
  .journey-globe__node:focus-visible .journey-globe__dot,
  .journey-globe__node.is-active .journey-globe__dot {
    background: var(--accent);
    transform: scale(1.2);
    box-shadow: 0 0 0 12px rgba(211, 154, 89, 0.12);
  }

  .journey-globe__node:hover .journey-globe__node-label,
  .journey-globe__node:focus-visible .journey-globe__node-label,
  .journey-globe__node.is-active .journey-globe__node-label {
    opacity: 1;
    transform: translateY(0);
  }

  .journey-globe__node:focus-visible {
    outline: none;
  }

  .journey-scroll {
    display: grid;
    gap: 1rem;
  }

  .journey-stop {
    display: grid;
    gap: 1rem;
    padding: 1.4rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(18, 15, 13, 0.92), rgba(18, 15, 13, 0.8));
    opacity: 0.78;
    transform: translateY(18px);
    transition: opacity 320ms ease, transform 320ms ease, border-color 320ms ease, background 320ms ease;
  }

  .journey-stop.is-visible,
  .journey-stop.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .journey-stop.is-active {
    border-color: rgba(211, 154, 89, 0.28);
    background: linear-gradient(180deg, rgba(24, 19, 15, 0.96), rgba(18, 15, 13, 0.88));
  }

  .journey-stop__header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  .journey-stop h3,
  .journey-close h2 {
    font-size: clamp(1.45rem, 2.8vw, 2rem);
    line-height: 1.08;
  }

  .journey-stop__place {
    margin: 0.35rem 0 0;
    color: rgba(243, 237, 225, 0.92);
    font-size: 0.96rem;
  }

  .journey-stop__organization {
    color: var(--accent);
    background: rgba(211, 154, 89, 0.12);
    border: 1px solid rgba(211, 154, 89, 0.24);
    flex-shrink: 0;
  }

  .journey-close {
    display: grid;
    gap: 1rem;
    padding: 1.6rem;
    border-radius: 28px;
  }

  .journey-close__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .journey-close__card {
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
    border-radius: 18px;
    border: 1px solid rgba(243, 237, 225, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .journey-close__card span {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 1.1rem;
    color: rgba(243, 237, 225, 0.96);
  }

  .journey-close__card:hover,
  .journey-close__card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(211, 154, 89, 0.24);
    background: rgba(255, 255, 255, 0.04);
    outline: none;
  }

  @keyframes route-drift {
    from {
      stroke-dashoffset: 0;
    }

    to {
      stroke-dashoffset: -240;
    }
  }

  @media (max-width: 960px) {
    .journey-intro,
    .journey-route {
      grid-template-columns: 1fr;
    }

    .journey-stage {
      position: sticky;
      top: 4.8rem;
      z-index: 3;
    }

    .journey-globe {
      min-height: 20rem;
    }

    .journey-close__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .journey-intro__copy h1 {
      font-size: clamp(2.4rem, 10vw, 3.3rem);
      max-width: 10ch;
    }

    .journey-stage,
    .journey-stop,
    .journey-close,
    .journey-intro__route-card {
      padding: 1rem;
      border-radius: 22px;
    }

    .journey-stage__topline,
    .journey-stage__current,
    .journey-stop__header {
      flex-direction: column;
    }

    .journey-stage__step {
      width: 2.6rem;
      height: 2.6rem;
      font-size: 0.78rem;
    }

    .journey-globe {
      min-height: 16rem;
    }

    .journey-globe__focus {
      width: 5.25rem;
      height: 5.25rem;
    }

    .journey-globe__node-label {
      font-size: 0.58rem;
      letter-spacing: 0.1em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .journey-globe__route-line {
      animation: none;
    }

    .journey-globe__focus,
    .journey-stop,
    .journey-globe__dot,
    .journey-globe__node-label,
    .journey-close__card {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const stage = document.querySelector('[data-journey-stage]');
    const stops = Array.from(document.querySelectorAll('[data-stop-id]'));
    const nodes = Array.from(document.querySelectorAll('[data-journey-node]'));
    const stepField = document.querySelector('[data-stage-step]');
    const organizationField = document.querySelector('[data-stage-organization]');
    const placeField = document.querySelector('[data-stage-place]');
    const summaryField = document.querySelector('[data-stage-summary]');

    if (!stage || !stops.length) {
      return;
    }

    const activateStop = (stop) => {
      const { stopId, stopStep, stopPlace, stopOrganization, stopSummary, stopMapX, stopMapY } = stop.dataset;

      stage.dataset.activeStop = stopId ?? '';

      if (stopMapX && stopMapY) {
        stage.style.setProperty('--focus-x', stopMapX);
        stage.style.setProperty('--focus-y', stopMapY);
      }

      if (stepField && stopStep) {
        stepField.textContent = stopStep;
      }

      if (organizationField && stopOrganization) {
        organizationField.textContent = stopOrganization;
      }

      if (placeField && stopPlace) {
        placeField.textContent = stopPlace;
      }

      if (summaryField && stopSummary) {
        summaryField.textContent = stopSummary;
      }

      stops.forEach((entry) => {
        entry.classList.toggle('is-active', entry === stop);
      });

      nodes.forEach((node) => {
        node.classList.toggle('is-active', node.dataset.journeyNode === stopId);
      });
    };

    const ratios = new Map();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          ratios.set(entry.target, entry.isIntersecting ? entry.intersectionRatio : 0);

          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });

        let bestStop = stops[0];
        let bestRatio = -1;

        stops.forEach((stop) => {
          const ratio = ratios.get(stop) ?? 0;
          if (ratio > bestRatio) {
            bestStop = stop;
            bestRatio = ratio;
          }
        });

        if (bestStop) {
          activateStop(bestStop);
        }
      },
      {
        threshold: [0, 0.2, 0.4, 0.6, 0.8],
        rootMargin: '-18% 0px -42% 0px'
      }
    );

    stops.forEach((stop) => observer.observe(stop));
    activateStop(stops[0]);

    nodes.forEach((node) => {
      node.addEventListener('click', () => {
        const targetId = node.dataset.nodeTarget;
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) {
          return;
        }

        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        activateStop(target);
      });
    });
  });
</script>
