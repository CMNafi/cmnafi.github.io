---
import WorldCupLayout from '../../../layouts/WorldCupLayout.astro';
---
<WorldCupLayout title="World Cup 2026 · Bracket Predictor">
  <header class="hdr">
    <h1 class="neon-title">⚽ FIFA WORLD CUP 2026</h1>
    <p class="neon-subtitle">BRACKET PREDICTOR · USA · CANADA · MEXICO · JUN 11 – JUL 19</p>
  </header>

  <div class="tabs">
    <button class="tab on" id="tg-btn">🏟 GROUP STAGE</button>
    <button class="tab" id="tk-btn">🏆 KNOCKOUT</button>
  </div>

  <div class="view on" id="groups-view"></div>
  <div class="view" id="ko-view"></div>

  <style is:global>
    :root {
      --neon-cyan: #0ff;
      --neon-pink: #f0f;
      --neon-green: #39ff14;
      --neon-yellow: #fe0;
      --neon-red: #ff3131;
      --bg: #050508;
      --card: #101018;
      --border: #1e1e2c;
      --accent: var(--neon-cyan);
      --text: #dde;
      --sub: #666;
      --r: 8px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', system-ui, sans-serif;
    }

    .hdr {
      padding: 2rem 1rem;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }
    .neon-title {
      font-size: 2rem;
      font-weight: 800;
      color: var(--neon-cyan);
      letter-spacing: 0.1em;
      text-shadow: 0 0 10px var(--neon-cyan);
      margin: 0;
    }
    .neon-subtitle {
      font-size: 0.8rem;
      color: var(--sub);
      margin-top: 0.5rem;
      letter-spacing: 0.06em;
    }

    .tabs {
      display: flex;
      gap: 12px;
      justify-content: center;
      padding: 1.5rem;
      border-bottom: 1px solid var(--border);
    }
    .tab {
      background: none;
      border: 1px solid var(--border);
      color: var(--sub);
      padding: 8px 24px;
      border-radius: 30px;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      transition: 0.2s;
    }
    .tab.on {
      background: var(--neon-cyan);
      color: #000;
      border-color: var(--neon-cyan);
      box-shadow: 0 0 15px var(--neon-cyan);
    }

    .view { display: none; padding: 2rem; }
    .view.on { display: block; }

    /* Groups Grid */
    .gg {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .gc {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    .gh {
      background: rgba(0, 255, 255, 0.1);
      color: var(--neon-cyan);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      text-align: center;
    }
    .tr {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      transition: background 0.2s;
    }
    .tr:last-child { border-bottom: none; }
    
    .rk { font-size: 0.7rem; font-weight: 700; color: var(--sub); width: 28px; }
    .rk.g { color: var(--neon-green); text-shadow: 0 0 5px var(--neon-green); }
    .rk.s { color: var(--neon-yellow); }
    
    .fl { font-size: 1.2rem; line-height: 1; }
    .nm { flex: 1; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    
    .arr {
      background: none;
      border: 1px solid var(--border);
      color: var(--sub);
      width: 22px;
      height: 22px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.6rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.15s;
    }
    .arr:hover:not(:disabled) { border-color: var(--neon-cyan); color: var(--neon-cyan); }
    .arr:disabled { opacity: 0.1; cursor: default; }

    /* Thirds Panel */
    .tp {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 1.5rem;
      max-width: 1000px;
      margin: 0 auto 2rem;
    }
    .tph { font-size: 1rem; font-weight: 700; color: var(--neon-cyan); letter-spacing: 0.1em; margin-bottom: 0.5rem; }
    .tps { font-size: 0.8rem; color: var(--sub); margin-bottom: 1rem; }
    .tgrid { display: flex; flex-wrap: wrap; gap: 8px; }
    .tc {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
      transition: 0.15s;
    }
    .tc.sel { border-color: var(--neon-green); background: rgba(57, 255, 20, 0.1); color: var(--neon-green); box-shadow: 0 0 10px rgba(57,255,20,0.2); }
    .tc.dis { opacity: 0.2; pointer-events: none; }

    /* Bracket Styling */
    .bwrap { overflow-x: auto; padding: 1rem 0; cursor: grab; }
    .bwrap:active { cursor: grabbing; }
    .bracket { display: flex; min-width: max-content; align-items: stretch; gap: 0; }
    .bcol { display: flex; flex-direction: column; min-width: 200px; border-right: 1px solid var(--border); }
    .bcol:last-child { border-right: none; }
    .blbl { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; color: var(--neon-cyan); text-align: center; padding: 12px 8px; border-bottom: 1px solid var(--border); background: rgba(0,255,255,0.02); }
    .bms { flex: 1; display: flex; flex-direction: column; justify-content: space-evenly; padding: 12px; gap: 8px; }
    .bm { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r); overflow: hidden; }
    .bt { display: flex; align-items: center; gap: 8px; padding: 8px 12px; cursor: pointer; min-height: 38px; transition: 0.15s; font-size: 0.9rem; }
    .bt:hover:not(.e):not(.w) { background: rgba(0,255,255,0.05); }
    .bt.w { background: rgba(57, 255, 20, 0.1); color: var(--neon-green); font-weight: 700; text-shadow: 0 0 8px var(--neon-green); border-left: 3px solid var(--neon-green); }
    .bt.e { color: #333; font-style: italic; cursor: default; }
    .bd { height: 1px; background: var(--border); }
    .bf { font-size: 1.2rem; }

    /* Champion */
    .cc { display: flex; flex-direction: column; min-width: 240px; border-left: 2px solid var(--neon-pink); }
    .cbox { flex: 1; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .cin { background: var(--card); border: 2px solid var(--neon-pink); border-radius: 12px; padding: 2.5rem 1.5rem; text-align: center; box-shadow: 0 0 30px rgba(255,0,255,0.1); }
    .ctr { font-size: 4rem; margin-bottom: 1rem; filter: drop-shadow(0 0 10px rgba(255,255,0,0.3)); }
    .cflag { font-size: 3rem; margin-bottom: 0.5rem; }
    .cname { font-size: 1.2rem; font-weight: 800; color: var(--neon-pink); text-shadow: 0 0 10px var(--neon-pink); }
    .ctbd { font-size: 0.9rem; color: var(--sub); line-height: 1.6; }

    .rbtn {
      display: block;
      margin: 2rem auto 0;
      background: none;
      border: 1px solid var(--border);
      color: var(--sub);
      padding: 10px 24px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      transition: 0.2s;
    }
    .rbtn:hover { border-color: var(--neon-red); color: var(--neon-red); box-shadow: 0 0 10px rgba(255,49,49,0.2); }

    /* New Button Styles */
    .neon-btn {
      font-family: 'JetBrains Mono', monospace;
      font-weight: bold;
      text-transform: uppercase;
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s;
      letter-spacing: 1px;
    }
    .neon-btn-primary {
      background: var(--neon-cyan);
      color: #000;
      border: none;
      box-shadow: 0 0 15px var(--neon-cyan);
    }
    .neon-btn-primary:hover {
      box-shadow: 0 0 25px var(--neon-cyan);
      transform: translateY(-2px);
    }
  </style>

  <script is:inline>
    const G = {
      A:[['Mexico','🇲🇽'],['South Africa','🇿🇦'],['South Korea','🇰🇷'],['Czechia','🇨🇿']],
      B:[['Canada','🇨🇦'],['Switzerland','🇨🇭'],['Qatar','🇶🇦'],['Bosnia','🇧🇦']],
      C:[['Brazil','🇧🇷'],['Morocco','🇲🇦'],['Haiti','🇭🇹'],['Scotland','🏴󠁧󠁢󠁳󠁤󠁴󠁿']],
      D:[['USA','🇺🇸'],['Paraguay','🇵🇾'],['Australia','🇦🇺'],['Türkiye','🇹🇷']],
      E:[['Germany','🇩🇪'],['Curaçao','🇨🇼'],['Ivory Coast','🇨🇮'],['Ecuador','🇪🇨']],
      F:[['Netherlands','🇳🇱'],['Japan','🇯🇵'],['Sweden','🇸🇪'],['Tunisia','🇹🇳']],
      G:[['Belgium','🇧🇪'],['Egypt','🇪🇬'],['Iran','🇮🇷'],['New Zealand','🇳🇿']],
      H:[['Spain','🇪🇸'],['Cape Verde','🇨🇻'],['Saudi Arabia','🇸🇦'],['Uruguay','🇺🇾']],
      I:[['France','🇫🇷'],['Senegal','🇸🇳'],['Norway','🇳🇴'],['Iraq','🇮🇶']],
      J:[['Argentina','🇦🇷'],['Algeria','🇩🇿'],['Austria','🇦🇹'],['Jordan','🇯🇴']],
      K:[['Portugal','🇵🇹'],['DR Congo','🇨🇩'],['Uzbekistan','🇺🇿'],['Colombia','🇨🇴']],
      L:[['England','🏴󠁧󠁢󠁥󠁮󠁧󠁿'],['Croatia','🇭🇷'],['Ghana','🇬🇭'],['Panama','🇵🇦']],
    };
    const GK = Object.keys(G);
    const RDS = ['R32','R16','QF','SF','Final'];
    const R32S = [
      [['w','A'],['t',0]], [['r','A'],['r','H']],
      [['w','B'],['t',1]], [['r','B'],['r','F']],
      [['w','C'],['t',2]], [['r','C'],['r','K']],
      [['w','D'],['t',3]], [['r','D'],['r','J']],
      [['w','E'],['t',4]], [['r','E'],['r','I']],
      [['w','F'],['r','L']], [['w','G'],['t',5]],
      [['w','H'],['t',6]], [['w','I'],['t',7]],
      [['w','J'],['r','G']], [['w','K'],['w','L']]
    ];

    let S = { rank: Object.fromEntries(GK.map(g => [g, [0,1,2,3]])), third: [], ko: {} };
    
    const sv = () => { try { localStorage.setItem('wc26_state', JSON.stringify(S)) } catch(e) {} };
    const load = () => { try { const d = JSON.parse(localStorage.getItem('wc26_state')); if(d && d.rank) S = d; } catch(e) {} };
    const gt = (g, p) => G[g][S.rank[g][p]];

    function r32t(mi, si) {
      const [type, ref] = R32S[mi][si];
      if(type==='w') return gt(ref, 0);
      if(type==='r') return gt(ref, 1);
      if(type==='t') { const g2 = S.third[ref]; return g2 ? gt(g2, 2) : null; }
      return null;
    }
    
    function mteams(round, mi) {
      if(round === 'R32') return [r32t(mi, 0), r32t(mi, 1)];
      const prev = RDS[RDS.indexOf(round) - 1];
      return [S.ko[`${prev}_${mi*2}`] || null, S.ko[`${prev}_${mi*2+1}`] || null];
    }
    
    function advance(round, mi, team) {
      S.ko[`${round}_${mi}`] = team;
      let m = mi;
      RDS.slice(RDS.indexOf(round) + 1).forEach(r => { m = Math.floor(m / 2); delete S.ko[`${r}_${m}`]; });
      sv(); renderKO();
    }
    
    function mvt(g, idx, dir) {
      const r = S.rank[g], ni = idx + dir;
      if(ni < 0 || ni > 3) return;
      [r[idx], r[ni]] = [r[ni], r[idx]];
      S.ko = {}; sv(); renderGroups();
    }
    
    function tog3(g) {
      if(S.third.includes(g)) S.third = S.third.filter(x => x !== g);
      else { if(S.third.length >= 8) return; S.third.push(g); }
      S.ko = {}; sv(); renderKO();
    }

    function sw(viewId) {
      document.querySelectorAll('.view').forEach(v => v.classList.remove('on'));
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('on'));
      document.getElementById(`${viewId}-view`).classList.add('on');
      document.getElementById(viewId === 'groups' ? 'tg-btn' : 'tk-btn').classList.add('on');
      if(viewId === 'ko') renderKO();
    }

    function resetAll() {
      if(!confirm('Reset all predictions?')) return;
      S = { rank: Object.fromEntries(GK.map(g => [g, [0,1,2,3]])), third: [], ko: {} };
      sv(); renderGroups();
      if(document.getElementById('ko-view').classList.contains('on')) renderKO();
    }

    function saveAndContinue() {
      sv();
      sw('ko');
      // Scroll to top of knockout view
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderGroups() {
      const rl = ['1ST','2ND','3RD','4TH'], rc = ['g','s','',''];
      document.getElementById('groups-view').innerHTML = `
        <div class="gg">${GK.map(g => `
          <div class="gc">
            <div class="gh">GROUP ${g}</div>
            ${S.rank[g].map((ti, pos) => {
              const [nm, fl] = G[g][ti];
              return `<div class="tr">
                <span class="rk ${rc[pos]}">${rl[pos]}</span>
                <span class="fl">${fl}</span>
                <span class="nm">${nm}</span>
                <button class="arr" onclick="mvt('${g}',${pos},-1)"${pos===0?' disabled':''}>▲</button>
                <button class="arr" onclick="mvt('${g}',${pos},1)"${pos===3?' disabled':''}>▼</button>
              </div>`;
            }).join('')}
          </div>`).join('')}
        </div>
        <div class="controls-footer" style="text-align: center; margin-top: 2rem; display: flex; justify-content: center; gap: 1rem;">
          <button class="neon-btn neon-btn-primary" onclick="saveAndContinue()">Save & Continue to Knockouts →</button>
          <button class="rbtn" onclick="resetAll()" style="margin: 0;">↺ Reset All</button>
        </div>`;
    }

    function renderKO() {
      const thirds = GK.map(g => ({ g, t: gt(g, 2) }));
      const tpanel = `<div class="tp">
        <div class="tph">THIRD-PLACE QUALIFIERS</div>
        <div class="tps">Select the 8 third-place teams that advance to the Round of 32 · ${S.third.length}/8 selected</div>
        <div class="tgrid">${thirds.map(({ g, t }) => {
          const sel = S.third.includes(g), dis = !sel && S.third.length >= 8;
          return `<div class="tc${sel ? ' sel' : ''}${dis ? ' dis' : ''}" onclick="tog3('${g}')">
            ${t[1]} Grp ${g} · ${t[0]}</div>`;
        }).join('')}</div></div>`;

      const rcounts = [16, 8, 4, 2, 1];
      const rlbls = ['ROUND OF 32','ROUND OF 16','QTR-FINALS','SEMI-FINALS','FINAL'];

      function trow(t, side, round, mi) {
        if(!t) return `<div class="bt e">TBD</div>`;
        const win = S.ko[`${round}_${mi}`];
        const isW = win && win[0] === t[0] && win[1] === t[1];
        return `<div class="bt${isW ? ' w' : ''}" data-r="${round}" data-mi="${mi}" data-s="${side}">
          <span class="bf">${t[1]}</span><span>${t[0]}</span></div>`;
      }

      const cols = RDS.map((round, ri) => {
        const count = rcounts[ri];
        const ms = Array.from({ length: count }, (_, mi) => {
          const [ta, tb] = mteams(round, mi);
          return `<div class="bm">${trow(ta, 'a', round, mi)}<div class="bd"></div>${trow(tb, 'b', round, mi)}</div>`;
        }).join('');
        return `<div class="bcol"><div class="blbl">${rlbls[ri]}</div><div class="bms">${ms}</div></div>`;
      }).join('');

      const fw = S.ko['Final_0'];
      const champ = `<div class="cc">
        <div class="blbl">CHAMPION</div>
        <div class="cbox"><div class="cin">
          <div class="ctr">🏆</div>
          ${fw ? `<div class="cflag">${fw[1]}</div><div class="cname">${fw[0]}</div>`
            : `<div class="ctbd">Predict your<br>winner</div>`}
        </div></div></div>`;

      document.getElementById('ko-view').innerHTML = tpanel + `
        <div class="bwrap"><div class="bracket">${cols}${champ}</div></div>
        <button class="rbtn" onclick="resetAll()">↺ Reset All Predictions</button>`;
    }

    // Event Delegation for advance
    document.addEventListener('click', e => {
      const bt = e.target.closest('.bt');
      if(!bt || bt.classList.contains('e')) return;
      const { r, mi, s } = bt.dataset;
      if(!r) return;
      const [ta, tb] = mteams(r, parseInt(mi));
      const team = s === 'a' ? ta : tb;
      if(team) advance(r, parseInt(mi), team);
    });

    // Tab Listeners
    document.getElementById('tg-btn').onclick = () => sw('groups');
    document.getElementById('tk-btn').onclick = () => sw('ko');

    // Init
    load();
    renderGroups();
  </script>
</WorldCupLayout>
