---
import { getCollection } from 'astro:content';
import WorldCupLayout from '../../../layouts/WorldCupLayout.astro';
import TeamFlagChip from '../../../components/worldcup/TeamFlagChip.astro';

export async function getStaticPaths() {
  const teams = await getCollection('wc-teams');
  return teams.map(team => ({
    params: { slug: team.slug },
    props: { team },
  }));
}

const { team } = Astro.props;
const { Content } = await team.render();

// Squad fallback generator
let squad = team.data.squad || [];
if (squad.length === 0) {
  // Generate a mock 23-man squad
  const positions: ('GK' | 'DEF' | 'MID' | 'FWD')[] = [
    'GK', 'GK', 'GK',
    'DEF', 'DEF', 'DEF', 'DEF', 'DEF', 'DEF', 'DEF', 'DEF',
    'MID', 'MID', 'MID', 'MID', 'MID', 'MID',
    'FWD', 'FWD', 'FWD', 'FWD', 'FWD', 'FWD'
  ];
  
  let counts = { GK: 0, DEF: 0, MID: 0, FWD: 0 };
  squad = positions.map((pos) => {
    const idx = counts[pos];
    counts[pos]++;
    
    let name = '';
    let club = 'Elite Club';
    
    // Customize generic squad names based on country
    const prefix = team.data.name;
    if (pos === 'GK') {
      name = `${prefix} GK ${idx + 1}`;
    } else if (pos === 'DEF') {
      name = `${prefix} Defender ${idx + 1}`;
    } else if (pos === 'MID') {
      name = `${prefix} Midfielder ${idx + 1}`;
    } else {
      name = `${prefix} Forward ${idx + 1}`;
    }
    
    return {
      name,
      position: pos,
      club,
      isKeyPlayer: idx === 0
    };
  });
}

const groupedSquad = {
  GK: squad.filter(p => p.position === 'GK'),
  DEF: squad.filter(p => p.position === 'DEF'),
  MID: squad.filter(p => p.position === 'MID'),
  FWD: squad.filter(p => p.position === 'FWD'),
};

const positionNames = {
  GK: 'Goalkeepers',
  DEF: 'Defenders',
  MID: 'Midfielders',
  FWD: 'Forwards'
};
---
<WorldCupLayout title={`${team.data.name} | World Cup 2026 Corner`}>
  <header style="margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--wc-border);">
    <a href="/world-cup-2026/teams" style="color: var(--wc-muted); text-decoration: none; font-size: 0.9em; margin-bottom: 1rem; display: inline-block;">← Back to Teams</a>
    
    <div style="display: flex; align-items: center; gap: 1.5rem; margin-top: 1rem;">
      <div style="font-size: 4rem; line-height: 1;">
        <TeamFlagChip teamName={team.data.name} teamCode={team.data.code} size="lg" hideCode={true} />
      </div>
      <div>
        <h1 style="margin: 0; font-size: 2.5rem;">{team.data.name}</h1>
        <div style="display: flex; gap: 1rem; color: var(--wc-muted); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; margin-top: 0.5rem; flex-wrap: wrap;">
          <span>GROUP {team.data.group}</span>
          <span>•</span>
          <span>FIFA RANK: #{team.data.fifaRanking || 'N/A'}</span>
          <span>•</span>
          <span>COACH: {team.data.coach || 'TBD'}</span>
        </div>
      </div>
    </div>
  </header>

  <div style="display: grid; grid-template-columns: 1fr 300px; gap: 3rem; align-items: start;">
    
    <!-- Left Column: Tactical Preview -->
    <article class="tactical-preview" style="font-size: 1.1rem; line-height: 1.6; color: var(--wc-ink);">
      <h2 style="font-size: 1.2rem; color: var(--wc-highlight); text-transform: uppercase; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; border-bottom: 1px solid var(--wc-border); padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
        Tactical Preview
      </h2>
      <Content />
    </article>

    <!-- Right Column: Squad List -->
    <aside class="squad-list">
      <h2 style="font-size: 1.2rem; color: var(--wc-highlight); text-transform: uppercase; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; border-bottom: 1px solid var(--wc-border); padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
        The 26-Man Squad
      </h2>
      
      {squad.length === 0 ? (
        <div style="background: var(--wc-surface); border: 1px solid var(--wc-border); padding: 1.5rem; border-radius: 4px; text-align: center; color: var(--wc-muted);">
          Squad data for {team.data.name} is currently brewing and will be published closer to the tournament.
        </div>
      ) : (
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {['GK', 'DEF', 'MID', 'FWD'].map(pos => (
            groupedSquad[pos].length > 0 ? (
              <div>
                <h3 style="font-size: 0.85rem; color: var(--wc-muted); margin-bottom: 0.5rem; border-bottom: 1px dashed var(--wc-border); padding-bottom: 0.25rem;">
                  {positionNames[pos]}
                </h3>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem;">
                  {groupedSquad[pos].map(player => (
                    <li style="display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; padding: 0.25rem 0;">
                      <span style={player.isKeyPlayer ? 'color: var(--wc-accent); font-weight: bold;' : 'color: var(--wc-ink);'}>
                        {player.name} {player.isKeyPlayer ? '★' : ''}
                      </span>
                      <span style="color: var(--wc-muted); font-size: 0.8rem; text-align: right;">
                        {player.club}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ) : null
          ))}
        </div>
      )}
    </aside>
  </div>

  <!-- Interactive Best XI Lineup Builder Section -->
  <section id="lineup-builder" style="border-top: 1px solid var(--wc-border); padding-top: 3.5rem; margin-top: 4rem; margin-bottom: 4rem;">
    <header style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.5rem; color: var(--wc-highlight); font-family: 'PP Editorial New', serif; font-weight: normal; margin-bottom: 0.5rem;">
        Tactical Lineup Builder
      </h2>
      <p style="color: var(--wc-muted); font-size: 0.95rem; max-width: 600px; margin: 0;">
        Construct your team's Best XI. Choose your formation, click on any position on the tactical pitch, and select players from the official squad list.
      </p>
    </header>

    <div class="lineup-layout" style="display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; align-items: start; background: rgba(12, 12, 12, 0.6); border: 1px solid var(--wc-border); padding: 2rem; border-radius: 6px; backdrop-filter: blur(10px);">
      
      <!-- Left Column: Soccer Pitch -->
      <div style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; width: 100%;">
        <!-- Pitch Header Controls -->
        <div style="display: flex; gap: 1rem; align-items: center; width: 100%; justify-content: space-between; flex-wrap: wrap;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <label for="formation-select" style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--wc-muted); letter-spacing: 0.05em;">FORMATION</label>
            <select id="formation-select" style="background: #111; color: #fff; border: 1px solid var(--wc-border); padding: 0.5rem 1.5rem 0.5rem 1rem; border-radius: 2px; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; cursor: pointer; outline: none; transition: border-color 0.2s;">
              <option value="4-3-3">4-3-3</option>
              <option value="4-4-2">4-4-2</option>
              <option value="3-5-2">3-5-2</option>
              <option value="4-2-3-1">4-2-3-1</option>
              <option value="3-4-3">3-4-3</option>
            </select>
          </div>
          
          <div style="display: flex; gap: 0.75rem;">
            <button id="btn-reset" style="background: transparent; color: var(--wc-muted); border: 1px solid var(--wc-border); padding: 0.5rem 1.25rem; border-radius: 2px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; letter-spacing: 0.05em;">
              RESET
            </button>
            <button id="btn-share" style="background: var(--wc-accent, #e10600); color: #fff; border: none; padding: 0.5rem 1.25rem; border-radius: 2px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; cursor: pointer; font-weight: bold; transition: all 0.2s; letter-spacing: 0.05em;">
              SHARE TEAM
            </button>
          </div>
        </div>

        <!-- Soccer Pitch Container -->
        <div class="soccer-pitch" style="position: relative; width: 100%; max-width: 480px; height: 580px; background: radial-gradient(circle at center, #1b3d17 0%, #0d200b 100%); border: 3px solid rgba(255,255,255,0.25); border-radius: 6px; overflow: hidden; box-shadow: inset 0 0 50px rgba(0,0,0,0.7), 0 10px 30px rgba(0,0,0,0.5);">
          <!-- Mow Stripes for authentic turf feel -->
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column;">
            {Array.from({ length: 10 }).map((_, i) => (
              <div style={`flex: 1; width: 100%; background: ${i % 2 === 0 ? 'rgba(255,255,255,0.015)' : 'transparent'}; border-bottom: 1px dashed rgba(255,255,255,0.01);`} />
            ))}
          </div>

          <!-- Chalk Line Markings -->
          <!-- Outer border margin -->
          <div style="position: absolute; top: 15px; bottom: 15px; left: 15px; right: 15px; border: 1.5px solid rgba(255,255,255,0.2); pointer-events: none;"></div>
          <!-- Center line -->
          <div style="position: absolute; top: 50%; left: 15px; right: 15px; height: 1.5px; background: rgba(255,255,255,0.2); transform: translateY(-50%); pointer-events: none;"></div>
          <!-- Center Circle -->
          <div style="position: absolute; top: 50%; left: 50%; width: 110px; height: 110px; border: 1.5px solid rgba(255,255,255,0.2); border-radius: 50%; transform: translate(-50%, -50%); pointer-events: none;"></div>
          <div style="position: absolute; top: 50%; left: 50%; width: 6px; height: 6px; background: rgba(255,255,255,0.3); border-radius: 50%; transform: translate(-50%, -50%); pointer-events: none;"></div>
          
          <!-- Top Penalty Area -->
          <div style="position: absolute; top: 15px; left: 50%; width: 200px; height: 75px; border: 1.5px solid rgba(255,255,255,0.2); border-top: none; transform: translateX(-50%); pointer-events: none;"></div>
          <div style="position: absolute; top: 15px; left: 50%; width: 90px; height: 25px; border: 1.5px solid rgba(255,255,255,0.2); border-top: none; transform: translateX(-50%); pointer-events: none;"></div>
          <div style="position: absolute; top: 90px; left: 50%; width: 60px; height: 30px; border: 1.5px solid rgba(255,255,255,0.2); border-radius: 50%; border-top: none; transform: translateX(-50%); pointer-events: none; clip-path: inset(15px 0 0 0);"></div>
          <div style="position: absolute; top: 65px; left: 50%; width: 4px; height: 4px; background: rgba(255,255,255,0.3); border-radius: 50%; transform: translateX(-50%); pointer-events: none;"></div>

          <!-- Bottom Penalty Area -->
          <div style="position: absolute; bottom: 15px; left: 50%; width: 200px; height: 75px; border: 1.5px solid rgba(255,255,255,0.2); border-bottom: none; transform: translateX(-50%); pointer-events: none;"></div>
          <div style="position: absolute; bottom: 15px; left: 50%; width: 90px; height: 25px; border: 1.5px solid rgba(255,255,255,0.2); border-bottom: none; transform: translateX(-50%); pointer-events: none;"></div>
          <div style="position: absolute; bottom: 90px; left: 50%; width: 60px; height: 30px; border: 1.5px solid rgba(255,255,255,0.2); border-radius: 50%; border-bottom: none; transform: translateX(-50%); pointer-events: none; clip-path: inset(0 0 15px 0);"></div>
          <div style="position: absolute; bottom: 65px; left: 50%; width: 4px; height: 4px; background: rgba(255,255,255,0.3); border-radius: 50%; transform: translateX(-50%); pointer-events: none;"></div>

          <!-- Interactive Spots Layer -->
          <div id="pitch-spots" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10;">
            <!-- Spots loaded dynamically by JS -->
          </div>
        </div>
      </div>

      <!-- Right Column: Sidebar Selector -->
      <div style="display: flex; flex-direction: column; gap: 1.5rem; height: 100%; width: 100%;">
        <div id="selection-panel" style="border: 1px solid var(--wc-border); padding: 1.5rem; border-radius: 4px; background: #070707; flex-grow: 1; display: flex; flex-direction: column; min-height: 480px; box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
          
          <!-- Empty State (No spot selected) -->
          <div id="panel-empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; text-align: center; color: var(--wc-muted); flex-grow: 1; padding: 3rem 0;">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="1.5" fill="none" style="margin-bottom: 1.25rem; opacity: 0.4; color: var(--wc-highlight);">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; margin-bottom: 0.5rem; color: #fff; letter-spacing: 0.05em; text-transform: uppercase;">AWAITING SELECTION</p>
            <p style="font-size: 0.8rem; line-height: 1.4; max-width: 220px; margin: 0;">Select any position spot on the pitch to assign a player from the squad list.</p>
          </div>

          <!-- Active Selection State -->
          <div id="panel-active-state" style="display: none; flex-direction: column; height: 100%; flex-grow: 1;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
              <h3 id="active-position-title" style="font-size: 0.95rem; margin: 0; color: var(--wc-highlight); font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.05em;">
                Assign ST
              </h3>
              <span id="spot-status-badge" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--wc-muted); border: 1px solid var(--wc-border); padding: 1px 6px; border-radius: 2px;">
                EMPTY
              </span>
            </div>
            
            <!-- Filters & Search -->
            <div style="display: flex; gap: 0.25rem; margin-bottom: 1rem; border-bottom: 1px solid var(--wc-border); padding-bottom: 0.5rem;">
              <button id="filter-btn-pos" class="filter-tab active-tab" style="background: transparent; border: none; color: var(--wc-accent, #e10600); font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; cursor: pointer; padding: 0.25rem 0.5rem; font-weight: bold; letter-spacing: 0.02em;">ROLE MATCH</button>
              <button id="filter-btn-all" class="filter-tab" style="background: transparent; border: none; color: var(--wc-muted); font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; cursor: pointer; padding: 0.25rem 0.5rem; letter-spacing: 0.02em;">ALL PLAYERS</button>
            </div>

            <div style="position: relative; margin-bottom: 1rem;">
              <input type="text" id="player-search" placeholder="Search squad..." style="width: 100%; background: #121212; border: 1px solid var(--wc-border); color: #fff; padding: 0.5rem 0.75rem; border-radius: 2px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; outline: none; transition: border-color 0.2s;">
            </div>

            <!-- Scrollable Player List -->
            <div id="players-list-scroll" style="overflow-y: auto; max-height: 290px; display: flex; flex-direction: column; gap: 0.4rem; padding-right: 0.25rem;">
              <!-- Players loaded dynamically by JS -->
            </div>
          </div>

        </div>
      </div>
      
    </div>
  </section>

  <!-- Serialized Squad Data & Lineup Builder Script -->
  <script is:inline define:vars={{ squadData: squad, teamName: team.data.name }}>
    // Coordination positions for absolute styling
    const formations = {
      '4-3-3': [
        { role: 'GK', label: 'GK', bottom: 5, left: 50 },
        { role: 'DEF', label: 'LB', bottom: 22, left: 15 },
        { role: 'DEF', label: 'LCB', bottom: 18, left: 38 },
        { role: 'DEF', label: 'RCB', bottom: 18, left: 62 },
        { role: 'DEF', label: 'RB', bottom: 22, left: 85 },
        { role: 'MID', label: 'LCM', bottom: 45, left: 25 },
        { role: 'MID', label: 'CM', bottom: 40, left: 50 },
        { role: 'MID', label: 'RCM', bottom: 45, left: 75 },
        { role: 'FWD', label: 'LW', bottom: 75, left: 20 },
        { role: 'FWD', label: 'ST', bottom: 82, left: 50 },
        { role: 'FWD', label: 'RW', bottom: 75, left: 80 }
      ],
      '4-4-2': [
        { role: 'GK', label: 'GK', bottom: 5, left: 50 },
        { role: 'DEF', label: 'LB', bottom: 22, left: 15 },
        { role: 'DEF', label: 'LCB', bottom: 18, left: 38 },
        { role: 'DEF', label: 'RCB', bottom: 18, left: 62 },
        { role: 'DEF', label: 'RB', bottom: 22, left: 85 },
        { role: 'MID', label: 'LM', bottom: 48, left: 15 },
        { role: 'MID', label: 'LCM', bottom: 44, left: 38 },
        { role: 'MID', label: 'RCM', bottom: 44, left: 62 },
        { role: 'MID', label: 'RM', bottom: 48, left: 85 },
        { role: 'FWD', label: 'LST', bottom: 80, left: 35 },
        { role: 'FWD', label: 'RST', bottom: 80, left: 65 }
      ],
      '3-5-2': [
        { role: 'GK', label: 'GK', bottom: 5, left: 50 },
        { role: 'DEF', label: 'LCB', bottom: 19, left: 25 },
        { role: 'DEF', label: 'CB', bottom: 17, left: 50 },
        { role: 'DEF', label: 'RCB', bottom: 19, left: 75 },
        { role: 'MID', label: 'LWB', bottom: 42, left: 12 },
        { role: 'MID', label: 'LCM', bottom: 46, left: 35 },
        { role: 'MID', label: 'CDM', bottom: 36, left: 50 },
        { role: 'MID', label: 'RCM', bottom: 46, left: 65 },
        { role: 'MID', label: 'RWB', bottom: 42, left: 88 },
        { role: 'FWD', label: 'LST', bottom: 80, left: 35 },
        { role: 'FWD', label: 'RST', bottom: 80, left: 65 }
      ],
      '4-2-3-1': [
        { role: 'GK', label: 'GK', bottom: 5, left: 50 },
        { role: 'DEF', label: 'LB', bottom: 22, left: 15 },
        { role: 'DEF', label: 'LCB', bottom: 18, left: 38 },
        { role: 'DEF', label: 'RCB', bottom: 18, left: 62 },
        { role: 'DEF', label: 'RB', bottom: 22, left: 85 },
        { role: 'MID', label: 'LDM', bottom: 38, left: 35 },
        { role: 'MID', label: 'RDM', bottom: 38, left: 65 },
        { role: 'MID', label: 'LAM', bottom: 58, left: 20 },
        { role: 'MID', label: 'CAM', bottom: 62, left: 50 },
        { role: 'MID', label: 'RAM', bottom: 58, left: 80 },
        { role: 'FWD', label: 'ST', bottom: 82, left: 50 }
      ],
      '3-4-3': [
        { role: 'GK', label: 'GK', bottom: 5, left: 50 },
        { role: 'DEF', label: 'LCB', bottom: 20, left: 25 },
        { role: 'DEF', label: 'CB', bottom: 17, left: 50 },
        { role: 'DEF', label: 'RCB', bottom: 20, left: 75 },
        { role: 'MID', label: 'LM', bottom: 48, left: 15 },
        { role: 'MID', label: 'LCM', bottom: 44, left: 38 },
        { role: 'MID', label: 'RCM', bottom: 44, left: 62 },
        { role: 'MID', label: 'RM', bottom: 48, left: 85 },
        { role: 'FWD', label: 'LW', bottom: 78, left: 20 },
        { role: 'FWD', label: 'ST', bottom: 82, left: 50 },
        { role: 'FWD', label: 'RW', bottom: 78, left: 80 }
      ]
    };

    // Script State
    let selectedFormation = '4-3-3';
    let assignedPlayers = {}; // maps spot index to player object
    let activeSpotIndex = null;
    let filterMode = 'pos'; // 'pos' or 'all'
    let searchQuery = '';

    // DOM Elements
    const formationSelect = document.getElementById('formation-select');
    const pitchSpotsContainer = document.getElementById('pitch-spots');
    const btnReset = document.getElementById('btn-reset');
    const btnShare = document.getElementById('btn-share');
    const panelEmptyState = document.getElementById('panel-empty-state');
    const panelActiveState = document.getElementById('panel-active-state');
    const activePositionTitle = document.getElementById('active-position-title');
    const spotStatusBadge = document.getElementById('spot-status-badge');
    const playersListScroll = document.getElementById('players-list-scroll');
    const playerSearchInput = document.getElementById('player-search');
    const filterBtnPos = document.getElementById('filter-btn-pos');
    const filterBtnAll = document.getElementById('filter-btn-all');

    function init() {
      if (!formationSelect) return; // safeguard for standard static compiles

      // Clear previous event listeners to avoid duplicates on hot-reloads
      formationSelect.replaceWith(formationSelect.cloneNode(true));
      const newFormationSelect = document.getElementById('formation-select');
      newFormationSelect.addEventListener('change', (e) => {
        selectedFormation = e.target.value;
        assignedPlayers = {}; // reset on formation change to keep things clean
        activeSpotIndex = null;
        renderPitch();
        showEmptyState();
      });

      btnReset.addEventListener('click', () => {
        assignedPlayers = {};
        activeSpotIndex = null;
        renderPitch();
        showEmptyState();
      });

      btnShare.addEventListener('click', () => {
        const assignedCount = Object.keys(assignedPlayers).length;
        if (assignedCount === 0) {
          alert('Assign some players to your pitch first!');
          return;
        }

        let summary = `My ${teamName} Best XI (${selectedFormation}):\n`;
        const activeFormation = formations[selectedFormation];
        activeFormation.forEach((spot, idx) => {
          const player = assignedPlayers[idx];
          summary += `- ${spot.label}: ${player ? player.name : '(Empty)'}\n`;
        });

        // Copy to clipboard
        navigator.clipboard.writeText(summary).then(() => {
          alert('Best XI Lineup copied to clipboard! Share it with your friends.');
        }).catch(err => {
          alert('Could not copy automatically. Here is your lineup:\n\n' + summary);
        });
      });

      playerSearchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value;
        renderRoster();
      });

      filterBtnPos.addEventListener('click', () => {
        filterMode = 'pos';
        filterBtnPos.classList.add('active-tab');
        filterBtnPos.style.color = 'var(--wc-accent, #e10600)';
        filterBtnPos.style.fontWeight = 'bold';
        filterBtnAll.classList.remove('active-tab');
        filterBtnAll.style.color = 'var(--wc-muted)';
        renderRoster();
      });

      filterBtnAll.addEventListener('click', () => {
        filterMode = 'all';
        filterBtnAll.classList.add('active-tab');
        filterBtnAll.style.color = 'var(--wc-accent, #e10600)';
        filterBtnAll.style.fontWeight = 'bold';
        filterBtnPos.classList.remove('active-tab');
        filterBtnPos.style.color = 'var(--wc-muted)';
        renderRoster();
      });

      renderPitch();
    }

    function renderPitch() {
      if (!pitchSpotsContainer) return;
      pitchSpotsContainer.innerHTML = '';
      const activeFormation = formations[selectedFormation];

      activeFormation.forEach((spot, idx) => {
        const player = assignedPlayers[idx];
        const spotDiv = document.createElement('div');
        spotDiv.className = 'player-pitch-spot';
        if (activeSpotIndex === idx) {
          spotDiv.classList.add('active');
        }

        spotDiv.style.position = 'absolute';
        spotDiv.style.bottom = `${spot.bottom}%`;
        spotDiv.style.left = `${spot.left}%`;
        spotDiv.style.transform = 'translate(-50%, 50%)';
        spotDiv.style.cursor = 'pointer';
        spotDiv.style.display = 'flex';
        spotDiv.style.flexDirection = 'column';
        spotDiv.style.alignItems = 'center';
        spotDiv.style.zIndex = '20';
        spotDiv.style.transition = 'all 0.25s ease';

        // Badge markup
        const badge = document.createElement('div');
        badge.className = 'spot-badge';
        badge.style.width = '38px';
        badge.style.height = '38px';
        badge.style.borderRadius = '50%';
        badge.style.border = player ? '2px solid var(--wc-accent, #e10600)' : '2.5px dashed rgba(255,255,255,0.4)';
        badge.style.background = player ? 'rgba(225, 6, 0, 0.15)' : 'rgba(0,0,0,0.55)';
        badge.style.display = 'flex';
        badge.style.alignItems = 'center';
        badge.style.justifyContent = 'center';
        badge.style.color = player ? '#fff' : 'rgba(255,255,255,0.7)';
        badge.style.fontFamily = "'JetBrains Mono', monospace";
        badge.style.fontSize = '0.78rem';
        badge.style.fontWeight = 'bold';
        badge.style.boxShadow = player ? '0 0 10px rgba(225, 6, 0, 0.4)' : '0 3px 6px rgba(0,0,0,0.3)';
        badge.style.transition = 'all 0.2s';
        
        badge.textContent = spot.label;

        // Label/Player name markup
        const label = document.createElement('span');
        label.className = 'spot-player-name';
        label.style.marginTop = '4px';
        label.style.fontFamily = "'JetBrains Mono', monospace";
        label.style.fontSize = '0.66rem';
        label.style.color = player ? '#fff' : 'rgba(255,255,255,0.45)';
        label.style.background = player ? 'rgba(0,0,0,0.85)' : 'rgba(0,0,0,0.4)';
        label.style.padding = '1px 5px';
        label.style.borderRadius = '1px';
        label.style.whiteSpace = 'nowrap';
        label.style.maxWidth = '80px';
        label.style.overflow = 'hidden';
        label.style.textOverflow = 'ellipsis';
        label.style.border = player ? '1px solid rgba(225, 6, 0, 0.3)' : '1px solid transparent';
        label.style.textAlign = 'center';
        
        label.textContent = player ? player.name.split(' ').pop() : 'Empty';

        spotDiv.appendChild(badge);
        spotDiv.appendChild(label);

        // Click Handler
        spotDiv.addEventListener('click', () => {
          activeSpotIndex = idx;
          
          // Clear active glows and add to this one
          document.querySelectorAll('.player-pitch-spot').forEach(el => el.classList.remove('active'));
          spotDiv.classList.add('active');

          showActivePanel(spot, idx);
        });

        pitchSpotsContainer.appendChild(spotDiv);
      });
    }

    function showEmptyState() {
      panelEmptyState.style.display = 'flex';
      panelActiveState.style.display = 'none';
    }

    function showActivePanel(spot, idx) {
      panelEmptyState.style.display = 'none';
      panelActiveState.style.display = 'flex';

      activePositionTitle.textContent = `Assign ${spot.label}`;
      
      const player = assignedPlayers[idx];
      spotStatusBadge.textContent = player ? player.name.toUpperCase() : 'EMPTY';
      spotStatusBadge.style.color = player ? 'var(--wc-accent, #e10600)' : 'var(--wc-muted)';
      spotStatusBadge.style.borderColor = player ? 'rgba(225, 6, 0, 0.3)' : 'var(--wc-border)';

      renderRoster();
    }

    function renderRoster() {
      if (!playersListScroll) return;
      playersListScroll.innerHTML = '';
      const spot = formations[selectedFormation][activeSpotIndex];
      if (!spot) return;

      const q = searchQuery.toLowerCase().trim();

      squadData.forEach((player) => {
        // Filters
        if (filterMode === 'pos' && player.position !== spot.role) {
          return; // Skip role mismatch
        }

        if (q && !player.name.toLowerCase().includes(q) && !player.club.toLowerCase().includes(q)) {
          return; // Skip search query mismatch
        }

        // Check if player is assigned elsewhere or to this spot
        let assignedSpotLabel = null;
        let assignedToThisSpot = false;
        let previousSpotIdx = null;

        Object.keys(assignedPlayers).forEach((key) => {
          if (assignedPlayers[key].name === player.name) {
            previousSpotIdx = parseInt(key, 10);
            assignedSpotLabel = formations[selectedFormation][previousSpotIdx].label;
            if (previousSpotIdx === activeSpotIndex) {
              assignedToThisSpot = true;
            }
          }
        });

        // Row markup
        const row = document.createElement('div');
        row.style.display = 'flex';
        row.style.justifyContent = 'space-between';
        row.style.alignItems = 'center';
        row.style.padding = '0.5rem 0.75rem';
        row.style.border = '1px solid var(--wc-border)';
        row.style.borderRadius = '2px';
        row.style.background = assignedToThisSpot ? 'rgba(225, 6, 0, 0.08)' : '#0f0f0f';
        row.style.cursor = 'pointer';
        row.style.transition = 'all 0.15s ease';
        
        if (assignedToThisSpot) {
          row.style.borderColor = 'rgba(225, 6, 0, 0.4)';
        }

        row.addEventListener('mouseenter', () => {
          row.style.background = assignedToThisSpot ? 'rgba(225, 6, 0, 0.12)' : '#161616';
        });

        row.addEventListener('mouseleave', () => {
          row.style.background = assignedToThisSpot ? 'rgba(225, 6, 0, 0.08)' : '#0f0f0f';
        });

        // Left Column: Player Name & Club
        const leftCol = document.createElement('div');
        leftCol.style.display = 'flex';
        leftCol.style.flexDirection = 'column';
        leftCol.style.gap = '2px';

        const nameSpan = document.createElement('span');
        nameSpan.style.fontSize = '0.85rem';
        nameSpan.style.fontWeight = 'bold';
        nameSpan.style.color = player.isKeyPlayer ? 'var(--wc-accent, #e10600)' : '#fff';
        nameSpan.textContent = player.name + (player.isKeyPlayer ? ' ★' : '');

        const clubSpan = document.createElement('span');
        clubSpan.style.fontSize = '0.72rem';
        clubSpan.style.color = 'var(--wc-muted)';
        clubSpan.textContent = `${player.position} · ${player.club}`;

        leftCol.appendChild(nameSpan);
        leftCol.appendChild(clubSpan);

        // Right Column: Selection status / Actions
        const rightCol = document.createElement('div');
        rightCol.style.display = 'flex';
        rightCol.style.alignItems = 'center';
        rightCol.style.gap = '0.5rem';

        if (assignedToThisSpot) {
          const badge = document.createElement('span');
          badge.style.fontFamily = "'JetBrains Mono', monospace";
          badge.style.fontSize = '0.62rem';
          badge.style.background = 'var(--wc-accent, #e10600)';
          badge.style.color = '#fff';
          badge.style.padding = '1px 5px';
          badge.style.borderRadius = '1px';
          badge.textContent = 'SELECTED';
          rightCol.appendChild(badge);
        } else if (assignedSpotLabel) {
          const badge = document.createElement('span');
          badge.style.fontFamily = "'JetBrains Mono', monospace";
          badge.style.fontSize = '0.62rem';
          badge.style.border = '1px dashed rgba(255,255,255,0.2)';
          badge.style.color = 'var(--wc-muted)';
          badge.style.padding = '1px 5px';
          badge.style.borderRadius = '1px';
          badge.textContent = `IN ${assignedSpotLabel}`;
          rightCol.appendChild(badge);
        }

        row.appendChild(leftCol);
        row.appendChild(rightCol);

        // Click Handler
        row.addEventListener('click', () => {
          if (assignedToThisSpot) {
            // Unassign
            delete assignedPlayers[activeSpotIndex];
          } else {
            // If already assigned elsewhere, swap/remove from previous spot
            if (previousSpotIdx !== null) {
              delete assignedPlayers[previousSpotIdx];
            }
            // Assign to active spot
            assignedPlayers[activeSpotIndex] = player;
          }

          renderPitch();
          
          // Re-trigger active panel update
          const spot = formations[selectedFormation][activeSpotIndex];
          showActivePanel(spot, activeSpotIndex);
        });

        playersListScroll.appendChild(row);
      });

      if (playersListScroll.children.length === 0) {
        const emptyRow = document.createElement('div');
        emptyRow.style.textAlign = 'center';
        emptyRow.style.padding = '2rem 0';
        emptyRow.style.color = 'var(--wc-muted)';
        emptyRow.style.fontSize = '0.8rem';
        emptyRow.textContent = 'No matching players available.';
        playersListScroll.appendChild(emptyRow);
      }
    }

    // Initialize on script load
    document.addEventListener('DOMContentLoaded', init);
    // Dynamic run to handle Astro view transition triggers as fallback
    init();
  </script>

  <style>
    @media (max-width: 900px) {
      div[style*="grid-template-columns"] {
        grid-template-columns: 1fr !important;
      }
    }
    .tactical-preview p {
      margin-bottom: 1.5rem;
    }
  </style>

  <!-- Glowing pulse effects styling -->
  <style is:global>
    .player-pitch-spot.active .spot-badge {
      border-color: var(--wc-accent, #e10600) !important;
      background: rgba(225, 6, 0, 0.22) !important;
      box-shadow: 0 0 25px rgba(225, 6, 0, 0.9), inset 0 0 10px rgba(225, 6, 0, 0.5) !important;
      transform: scale(1.12);
      animation: pulse-glow-soccer 1.6s infinite ease-in-out;
    }

    @keyframes pulse-glow-soccer {
      0% { box-shadow: 0 0 10px rgba(225, 6, 0, 0.5), inset 0 0 5px rgba(225, 6, 0, 0.3); }
      50% { box-shadow: 0 0 30px rgba(225, 6, 0, 0.95), inset 0 0 15px rgba(225, 6, 0, 0.6); }
      100% { box-shadow: 0 0 10px rgba(225, 6, 0, 0.5), inset 0 0 5px rgba(225, 6, 0, 0.3); }
    }

    /* Modern scrollbar for roster list */
    #players-list-scroll::-webkit-scrollbar {
      width: 4px;
    }
    #players-list-scroll::-webkit-scrollbar-track {
      background: rgba(0,0,0,0.3);
    }
    #players-list-scroll::-webkit-scrollbar-thumb {
      background: var(--wc-border);
      border-radius: 2px;
    }
    #players-list-scroll::-webkit-scrollbar-thumb:hover {
      background: var(--wc-muted);
    }

    /* Style active state selector tabs */
    .filter-tab {
      transition: all 0.15s ease;
    }
    .filter-tab:hover {
      color: #fff !important;
    }
    
    .lineup-layout {
      box-sizing: border-box;
    }
    .lineup-layout * {
      box-sizing: border-box;
    }

    @media (max-width: 820px) {
      .lineup-layout {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
    }
  </style>
</WorldCupLayout>
