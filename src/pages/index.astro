  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* Perimeter scan — a thin accent trace orbits the card border on hover */
  @property --scan-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .material-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(from var(--scan-angle),
      transparent 0deg,
      transparent 300deg,
      var(--accent-dim) 330deg,
      var(--accent) 358deg,
      transparent 360deg);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-instrument);
    pointer-events: none;
    z-index: 3;
  }

  .material-card:hover::after {
    opacity: 1;
    animation: border-scan 2.4s linear infinite;
  }

  @keyframes border-scan {
    to { --scan-angle: 360deg; }
  }

  /* Countdown digits tick into place when they change */
  .countdown-num.tick {
    animation: digit-tick 320ms var(--ease-instrument);
  }

  @keyframes digit-tick {
    from { transform: translateY(-8px); opacity: 0.2; }
    to   { transform: translateY(0); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-section::after,
    .material-card::after {
      display: none !important;
    }

    .js-reveal {
      opacity: 1 !important;
      animation: none !important;
