---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { execSync } from 'child_process';
import SectorBadge from '@/components/telemetry/SectorBadge.astro';

const projects = await getCollection('projects');
const notes = await getCollection('field-notes');

// Current Project - Most recently updated active project
const activeProjects = projects
  .filter(p => p.data.status === 'live' || p.data.status === 'brewing')
  .sort((a, b) => {
    const timeA = a.data.updatedAt?.valueOf() || a.data.startedAt?.valueOf() || 0;
    const timeB = b.data.updatedAt?.valueOf() || b.data.startedAt?.valueOf() || 0;
    return timeB - timeA;
  });
const featuredProject = activeProjects[0] || projects[0];

// Latest Field Note (non-draft)
const latestNote = notes
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())[0];

const sectors = [
  { id: '[G]', name: 'Garage', href: '/garage', label: 'Engineering Showcase', spec: `${projects.length} CHASSIS LOGGED` },
  { id: '[FN]', name: 'Field Notes', href: '/field-notes', label: 'Capital & Technical Telemetry', spec: `${notes.length} LOGS DEPLOYED` },
  { id: '[S]', name: 'Story', href: '/story', label: 'Biography & Ethos', spec: 'SPECIFICATION 1.0.0' },
  { id: '[C]', name: 'Connect', href: '/connect', label: 'Parc Fermé & Feeds', spec: 'COMMS STACK ACTIVE' }
];

// Compile build-time Git hash
let commitSha = 'unknown';
try {
  commitSha = execSync('git rev-parse HEAD', { stdio: ['ignore', 'pipe', 'ignore'] }).toString().trim().slice(0, 7);
} catch (e) {}
---

<BaseLayout title="Home" hideHeader={true}>
  <!-- Real-time scroll telemetry progress line -->
  <div class="scroll-telemetry-rail">
    <div id="scroll-progress-indicator" class="scroll-progress-bar"></div>
  </div>

  <main class="showroom-container">
    <!-- Bespoke Jony Ive Monogram Header -->
    <header class="showroom-header">
      <div class="monogram">
        <span class="m-serif">C M Nafi</span>
        <span class="m-breath-dot">•</span>
        <div class="compass-dial" id="compass-dial" title="Scroll compass">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" fill="currentColor"></polygon>
          </svg>
        </div>
      </div>
      <div class="header-specs">
        <span class="h-spec" id="scroll-percentage-display">[ 00% SCROLL ]</span>
        <span class="h-divider">/</span>
        <span class="h-spec monospace" id="header-telemetry-coords">25.6279° N</span>
      </div>
    </header>

    <!-- Main Typographic Intro -->
    <section class="intro-section">
      <div class="canvas-wrapper">
        <canvas id="telemetry-canvas"></canvas>
      </div>
      
      <div class="intro-content">
        <h1 class="intro-headline scramble-header" id="hero-headline" data-text="engineering, finance, technology — and everything I find interesting in between.">
          engineering, finance, technology — and everything I find interesting in between.
        </h1>
        <p class="intro-lead">
          Solutions Engineer at <a href="/story#stint-dasseti" class="standout-link inline-stint">Dasseti</a>. Previously <a href="/story#stint-blackrock" class="standout-link inline-stint">BlackRock</a>, <a href="/story#stint-mayoclinic" class="standout-link inline-stint">Mayo Clinic</a>, <a href="/story#stint-skybridge" class="standout-link inline-stint">SkyBridge</a>. Long-form essays on the businesses and deals shaping <a href="/field-notes/sovereign-wealth-invasion" class="standout-link inline-essay">global capital</a> — and the occasional <a href="/field-notes/seven-to-defend-swat-vs-royal-phoenix" class="standout-link inline-cricket">last-over thriller</a>.
        </p>
      </div>
    </section>

    <!-- Sector Divider -->
    <div class="sector-divider">
      <SectorBadge variant="sector1" label="SECTOR 1 // DRIVER.BIOGRAPHY" />
      <span class="sector-divider-dash"></span>
    </div>

    <!-- Promoted Specimen: Driver Biography -->
    <section class="story-glimpse-section">
      <div class="section-label-row">
        <span class="section-label">DRIVER PROFILE PROMOTION</span>
        <div class="spec-status">
          <span class="status-indicator live pulsing-indicator" style="background-color: var(--accent); box-shadow: 0 0 8px var(--accent);"></span>
          <span class="status-text monospace">[ PROFILE ACTIVE ]</span>
        </div>
      </div>
      
      <div class="material-card story-promoted">
        <div class="pedestal-content">
          <div class="pedestal-left">
            <span class="pedestal-category monospace">DRIVER BIOGRAPHY</span>
            <h2 class="pedestal-title scramble-header" data-text="C M Nafi Biography">
              <a href="/story">
                C M Nafi Biography
              </a>
            </h2>
            <p class="pedestal-summary">
              Working at the intersection of institutional capital and the fintech data infrastructure that moves it. Grew up in Bangladesh, moved to China on scholarship at sixteen, studied data science in Iowa, and now engineering systems from Florida. A short feedback loop of building tools and shipping writing.
            </p>
            <div class="pedestal-actions" style="margin-top: 1.5rem;">
              <a href="/story" class="milled-btn">
                ENTER DRIVER BIOGRAPHY <span class="arrow">→</span>
              </a>
            </div>
          </div>
          
          <div class="pedestal-right story-visualizer-column">
            <!-- Dynamic Route Telemetry Visualizer -->
            <div class="route-visualizer-container">
              <span class="spec-label">ROUTE TELEMETRY SCANNER</span>
              <div class="route-canvas-wrapper">
                <canvas id="story-route-canvas"></canvas>
              </div>
              <div class="route-telemetry monospace">
                <div class="telemetry-stat">
                  <span class="lbl">ACTIVE SECTOR</span>
                  <span class="val" id="story-telemetry-sector">DINAJPUR → CHANGSHU</span>
                </div>
                <div class="telemetry-stat">
                  <span class="lbl">DISPLACEMENT</span>
                  <span class="val">13,870 KM</span>
                </div>
                <div class="telemetry-stat" style="text-align: right;">
                  <span class="lbl">SCAN SPEED</span>
                  <span class="val" id="story-telemetry-speed">MACH 0.82</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sector Divider -->
    <div class="sector-divider">
      <SectorBadge variant="sector2" label="SECTOR 2 // CAIA.TELEMETRY" />
      <span class="sector-divider-dash"></span>
    </div>

    <!-- Promoted Specimen: CAIA Corner -->
    <section class="caia-corner-section">
      <div class="section-label-row">
        <span class="section-label">ALTERNATIVE PORTFOLIO DEPLOYMENT</span>
        <div class="spec-status">
          <span class="status-indicator brewing pulsing-indicator" style="background-color: var(--caia-accent-main); box-shadow: 0 0 8px var(--caia-accent-main);"></span>
          <span class="status-text monospace" style="color: var(--caia-accent-main);">[ ANALYSIS ACTIVE ]</span>
        </div>
      </div>
      
      <div class="material-card caia-promoted">
        <div class="pedestal-content">
          <div class="pedestal-left">
            <span class="pedestal-category monospace" style="color: var(--caia-highlight-main);">FINANCIAL ALTERNATIVES</span>
            <h2 class="pedestal-title scramble-header" data-text="CAIA Corner Portal">
              <a href="/caia">
                CAIA Corner Portal
              </a>
            </h2>
            <p class="pedestal-summary">
              A structured, exam-aligned study tool and public knowledge hub for alternative investments. Deconstructing hedge funds, private equity, private debt, real assets, and portfolio allocation models.
            </p>
            <div class="pedestal-actions" style="margin-top: 1.5rem;">
              <a href="/caia" class="milled-btn milled-btn-caia">
                EXPLORE CAIA KNOWLEDGE <span class="arrow">→</span>
              </a>
            </div>
          </div>
          
          <div class="pedestal-right caia-visualizer-column">
            <!-- Dynamic Alternative Frontier Visualizer -->
            <div class="frontier-visualizer-container">
              <span class="spec-label">ALTERNATIVE FRONTIER MATRIX</span>
              <div class="frontier-canvas-wrapper">
                <canvas id="frontier-canvas"></canvas>
              </div>
              <div class="frontier-telemetry monospace">
                <div class="telemetry-stat">
                  <span class="lbl">DIVERSIFICATION COEFF</span>
                  <span class="val" id="caia-telemetry-coef">ρ = 0.28</span>
                </div>
                <div class="telemetry-stat">
                  <span class="lbl">SHARPE RATIO</span>
                  <span class="val" id="caia-telemetry-sharpe">SR = 1.42</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sector Divider -->
    <div class="sector-divider">
      <SectorBadge variant="sector2b" label="SECTOR 2B // EVENT.FEED" />
      <span class="sector-divider-dash"></span>
    </div>

    <!-- Promoted Specimen: World Cup 2026 Telemetry -->
    <section class="world-cup-section">
      <div class="section-label-row">
        <span class="section-label">PROMOTED ACTIVE FEED</span>
        <div class="spec-status">
          <span class="status-indicator live pulsing-indicator" style="background-color: var(--accent); box-shadow: 0 0 8px var(--accent);"></span>
          <span class="status-text monospace">[ TELEMETRY LIVE ]</span>
        </div>
      </div>
      
      <div class="material-card world-cup-promoted">
        <div class="pedestal-content">
          <div class="pedestal-left">
            <span class="pedestal-category monospace">SPECIAL DEPLOYMENT</span>
            <h2 class="pedestal-title scramble-header" data-text="World Cup 2026 Portal">
              <a href="/world-cup-2026">
                World Cup 2026 Portal
              </a>
            </h2>
            <p class="pedestal-summary">
              Tracking match tables, teams, schedules, and live telemetry for the smart fan. Zero clutter, pure performance statistics.
            </p>
            <div class="pedestal-actions" style="margin-top: 1.5rem;">
              <a href="/world-cup-2026" class="milled-btn">
                ENTER WORLD CUP PORTAL <span class="arrow">→</span>
              </a>
            </div>
          </div>
          
          <div class="pedestal-right wc-countdown-column">
            <div class="countdown-container">
              <span class="spec-label">COUNTDOWN TO KICKOFF</span>
              <div class="countdown-timer monospace" id="wc-countdown">
                <div class="countdown-segment"><span class="countdown-num" id="wc-days">00</span><span class="countdown-lbl">D</span></div>
                <div class="countdown-segment"><span class="countdown-num" id="wc-hours">00</span><span class="countdown-lbl">H</span></div>
                <div class="countdown-segment"><span class="countdown-num" id="wc-mins">00</span><span class="countdown-lbl">M</span></div>
                <div class="countdown-segment"><span class="countdown-num" id="wc-secs">00</span><span class="countdown-lbl">S</span></div>
              </div>
              <div class="countdown-target monospace">TARGET: 2026-06-11 17:00:00 UTC</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sector Divider -->
    <div class="sector-divider">
      <SectorBadge variant="sector3" label="SECTOR 3 // CHAMBERS" />
      <span class="sector-divider-dash"></span>
    </div>

    <!-- Showcase Grid: Main Directories -->
    <section class="showroom-grid-section">
      <div class="section-label-row">
        <span class="section-label">DIALS & DIRECTORIES</span>
        <span class="section-spec monospace">4 ACTIVE CHAMBERS</span>
      </div>
      
      <div class="showroom-grid">
        {sectors.map(s => (
          <a href={s.href} class="material-card sector-card">
            <div class="sector-card-inner">
              <div class="sector-top">
                <span class="sector-id monospace">{s.id}</span>
                <span class="arrow">→</span>
              </div>
              
              <div class="sector-middle">
                <h3 class="sector-title">{s.name}</h3>
                <p class="sector-description">{s.label}</p>
              </div>
              <div class="sector-bottom">
                <span class="sector-spec-val monospace">
                  {s.id === '[G]' ? (
                    <><span class="stat-roll" data-target={projects.length}>0</span> CHASSIS LOGGED</>
                  ) : s.id === '[FN]' ? (
                    <><span class="stat-roll" data-target={notes.length}>0</span> LOGS DEPLOYED</>
                  ) : (
                    s.spec
                  )}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Sector Divider -->
    <div class="sector-divider">
      <SectorBadge variant="sector4" label="SECTOR 4 // METRICS" />
      <span class="sector-divider-dash"></span>
    </div>

    <!-- Showcase Article: Latest Field Note -->
    {latestNote && (
      <section class="latest-log-section">
        <div class="section-label-row">
          <span class="section-label">LATEST TELEMETRY LOG</span>
          <span class="section-spec monospace">{latestNote.data.category.toUpperCase()}</span>
        </div>
        
        <div class="material-card log-card">
          <div class="log-card-inner">
            <div class="log-header">
              <span class="log-date monospace">{latestNote.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span class="log-reading-time monospace">{latestNote.data.readingTime.toUpperCase()} READ</span>
            </div>
            <h2 class="log-title scramble-header" data-text={latestNote.data.title}>
              <a href={`/field-notes/${latestNote.slug}`}>{latestNote.data.title}</a>
            </h2>
            <p class="log-excerpt">{latestNote.data.excerpt || latestNote.data.description}</p>
            <div class="log-actions">
              <a href={`/field-notes/${latestNote.slug}`} class="milled-btn-secondary">
                OPEN TELEMETRY REPORT <span class="arrow">→</span>
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Simple authentic Jony Ive footer with F1 telemetry upgrades -->
    <footer class="showroom-footer">
      <div class="footer-left">
        <span class="copyright">© 2026 C M Nafi. All rights reserved.</span>
        <span class="footer-tagline">Crafted with materials of absolute simplicity.</span>
      </div>
      <div class="footer-metrics monospace" style="font-size: 10px; color: var(--ink-tertiary); display: flex; gap: 1rem; flex-wrap: wrap;">
        <span>BUILD: <a href="https://github.com/CMNafi/cmnafi.github.io" target="_blank" class="standout-link" style="color: var(--accent); border-bottom: 1px dotted var(--accent-dim);">{commitSha}</a></span>
        <span>LCP: 0.84s</span>
        <span>WEIGHT: 87KB</span>
        <span>TELEMETRY: <a href="/api/now.json" class="standout-link" style="color: var(--accent); border-bottom: 1px dotted var(--accent-dim);">[ /api/now ]</a></span>
      </div>
      <div class="footer-right">
        <a href="https://github.com/CMNafi" target="_blank" rel="noopener noreferrer" class="footer-link">GITHUB</a>
        <span class="footer-dot">•</span>
        <a href="https://www.linkedin.com/in/cm-nafi/" target="_blank" rel="noopener noreferrer" class="footer-link">LINKEDIN</a>
        <span class="footer-dot">•</span>
        <a href="mailto:nafi@cmnafi.com" class="footer-link">EMAIL</a>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* --- PREMIUM JONY IVE STYLING --- */
  :root {
    --caia-accent-main: #7AAE99;
    --caia-highlight-main: #D4A857;
  }

  /* Monogram & Breath Dot */
  .m-breath-dot {
    color: var(--apple-silver);
    font-size: 1.1rem;
    margin: 0 0.1rem;
    animation: breathPulse 4s ease-in-out infinite;
    display: inline-block;
  }

  .m-arrow {
    color: rgba(255, 255, 255, 0.3);
    font-size: 1.1rem;
    font-family: var(--font-mono);
    transition: color 0.3s ease;
  }
  
  .monogram:hover .m-arrow {
    color: var(--text-warm-white);
  }

  @keyframes breathPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1.0; }
  }

  /* Scroll percentage active green flash */
  #scroll-percentage-display {
    transition: color 150ms ease, text-shadow 150ms ease;
  }
  #scroll-percentage-display.is-active {
    color: var(--accent) !important;
    text-shadow: 0 0 5px var(--accent-glow);
  }

  /* Interactive Compass Needle Dial */
  .compass-dial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-sand-gray);
    width: 18px;
    height: 18px;
    vertical-align: middle;
    transition: color 150ms var(--ease-instrument);
    cursor: pointer;
  }
  .monogram:hover .compass-dial {
    color: var(--accent);
  }
  .compass-dial svg {
    width: 100%;
    height: 100%;
    transition: transform 150ms var(--ease-mechanical);
    transform: rotate(var(--needle-deg, 0deg));
  }
  .compass-dial.is-active svg {
    color: var(--accent);
    filter: drop-shadow(0 0 4px var(--accent-glow));
  }
  .compass-dial.is-idle svg {
    animation: idle-rotate 30s linear infinite;
  }
  @keyframes idle-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Sector Dividers */
  .sector-divider {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    margin: 2rem 0;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-tertiary);
    letter-spacing: 0.15em;
    user-select: none;
  }
  .sector-divider-label {
    flex-shrink: 0;
    font-weight: 500;
  }
  .sector-divider-dash {
    flex-grow: 1;
    height: 1px;
    background-image: linear-gradient(to right, var(--surface-line) 60%, transparent 40%);
    background-size: 8px 1px;
    background-repeat: repeat-x;
  }

  /* Fixed scroll progress indicator */
  .scroll-telemetry-rail {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.02);
    z-index: 990;
    pointer-events: none;
  }

  .scroll-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), var(--accent));
    box-shadow: 0 0 8px var(--accent-glow);
    transition: width 0.05s linear;
  }

  /* Base showroom container styling */
  .showroom-container {
    background-color: var(--paddock-black);
    color: var(--text-warm-white);
    min-height: 100vh;
    padding: clamp(3rem, 8vw, 8rem) clamp(1.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 10vw, 8rem);
    position: relative;
    overflow: hidden;
    max-width: 1200px;
    margin: 0 auto;
    z-index: 1;
  }

  /* Background grid with 1.5s fade-in */
  .showroom-container::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.012) 1px, transparent 1px);
    background-size: 50px 50px;
    background-position: center top;
    pointer-events: none;
    z-index: -1;
    opacity: 0;
    animation: gridFadeIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes gridFadeIn {
    to { opacity: 1; }
  }

  /* Exquisite monogram header style */
  .showroom-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--titanium-border);
    padding-bottom: 1.5rem;
    position: relative;
    z-index: 10;
  }

  .monogram {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .m-serif {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text-warm-white);
  }

  .header-specs {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-sand-gray);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
  }

  .h-divider {
    opacity: 0.3;
  }

  .monospace {
    font-family: var(--font-mono);
  }

  /* Clean typographic intro section */
  .intro-section {
    position: relative;
    z-index: 5;
    padding: 2rem 0;
    display: flex;
    align-items: center;
  }

  /* Subliminal Wave Canvas wrapper */
  .canvas-wrapper {
    position: absolute;
    inset: -3rem -4rem -3rem -4rem;
    pointer-events: none;
    z-index: 1;
    opacity: 0.85;
  }

  #telemetry-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .intro-content {
    max-width: 860px;
    position: relative;
    z-index: 2;
    will-change: transform;
  }

  .intro-headline {
    font-family: "Fraunces", Georgia, serif;
    font-size: clamp(2rem, 5.5vw, 3.8rem);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--text-warm-white);
    margin: 0 0 2rem 0;
  }

  .intro-lead {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.65;
    color: var(--text-sand-gray);
    margin: 0;
    max-width: 680px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .showroom-container.loaded .intro-lead {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.6s;
  }

  /* Pedestal and general section layouts */
  .pedestal-section,
  .world-cup-section,
  .showroom-grid-section,
  .latest-log-section {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    position: relative;
    z-index: 5;
  }

  .section-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    padding-bottom: 0.8rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--text-sand-gray);
  }

  .section-spec {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.25);
  }

  .spec-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .status-indicator.live {
    background-color: var(--accent);
