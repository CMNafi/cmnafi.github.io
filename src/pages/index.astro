---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import BrewingJourney from '@/components/BrewingJourney.astro';
import DirectoryTabs from '@/components/DirectoryTabs.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FeaturedPostCard from '@/components/FeaturedPostCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { homepageConfig } from '@/config/homepage';
import directories from '@/data/directories.json';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const projects = (await getCollection('projects')).sort((a, b) => b.data.priority - a.data.priority);
const latestPost = blogPosts[0];
const featuredProject = projects.find((project) => project.data.featured) ?? projects[0];
const homepageProject = projects.find((project) => project.slug === 'homepage') ?? featuredProject;

const directoryItems = directories
  .filter((item) => item.visibility)
  .sort((a, b) => a.order - b.order)
  .map((item) => ({
    ...item,
    count:
      item.title === 'Blog' ? blogPosts.length : item.title === 'Projects' ? projects.length : undefined
  }));

const spotlightItems = directoryItems
  .filter((item) => ['Blog', 'Projects', 'Adventures'].includes(item.title))
  .sort((a, b) => ['Blog', 'Projects', 'Adventures'].indexOf(a.title) - ['Blog', 'Projects', 'Adventures'].indexOf(b.title));

const stageChapters = homepageConfig.processChapters.slice(0, 4);
---

<BaseLayout>
  <div class="home-story home-v2">
    <div class="home-brew-line" aria-hidden="true">
      <span class="home-brew-line__core"></span>
      <span class="home-brew-line__pulse home-brew-line__pulse-a"></span>
      <span class="home-brew-line__pulse home-brew-line__pulse-b"></span>
      <span class="home-brew-line__pulse home-brew-line__pulse-c"></span>
    </div>

    <section class="page-section page-section-hero">
      <Hero hero={homepageConfig.hero} processChapters={homepageConfig.processChapters} />
    </section>

    <section class="page-section page-section-story">
      <SectionHeading
        eyebrow="Process chapters"
        title="Bean intake to finished serve"
        description="A four-step brewing narrative keeps the homepage readable, intentional, and consistent across sections."
      />
      <BrewingJourney chapters={stageChapters} />
    </section>

    <section class="page-section home-v2-doors">
      <SectionHeading
        eyebrow="High-visibility destinations"
        title="Three clear doors stay in reach"
        description="Whether you want to read, build, or explore, each path remains obvious in the flow of the page."
      />
      <div class="home-v2-doors__grid">
        {spotlightItems.map((item) => (
          <a class="home-v2-door panel" href={item.slug}>
            <div class="home-v2-door__top">
              <span>{item.icon}</span>
              <small>{item.category}</small>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <div class="home-v2-door__meta">
              <span>{item.count ? `${item.count} entries` : 'Open section'}</span>
              <strong>Enter</strong>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="page-section page-section-directory">
      <SectionHeading
        eyebrow="Directory"
        title="Everything pours into one organized system"
        description="Tabs keep navigation practical while preserving the same coffeehouse visual language."
      />
      <DirectoryTabs tabs={[...homepageConfig.directoryTabs]} items={directoryItems} />
    </section>

    <section class="page-section two-up home-focus-grid">
      <div>
        <SectionHeading
          eyebrow="Currently brewing"
          title="Active work on the counter"
          description="The next wave of writing and products in progress."
        />
        <div class="panel current-brewing story-panel">
          <ul>
            {homepageConfig.currentBrewing.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <div>
        <SectionHeading
          eyebrow="Studio canisters"
          title="Reusable containers for what comes next"
          description="Consistent buckets keep expansion easy as new sections are added."
        />
        <div class="canister-grid">
          {homepageConfig.focusCanisters.map((item) => (
            <article class="canister panel story-panel">
              <span>{item.label}</span>
              <p>{item.value}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section page-section-selected">
      <SectionHeading
        eyebrow="Already served"
        title="Selected entries"
        description={homepageConfig.selectedEntryIntro}
      />
      <div class="two-up selected-grid">
        {homepageConfig.featuredBands.latestWriting && latestPost && (
          <div>
            <SectionHeading eyebrow="Latest writing" title={latestPost.data.title} description={latestPost.data.excerpt} />
            <FeaturedPostCard post={latestPost} />
          </div>
        )}
        {homepageConfig.featuredBands.featuredProject && featuredProject && (
          <div>
            <SectionHeading eyebrow="Featured project" title={featuredProject.data.title} description={featuredProject.data.summary} />
            <ProjectCard project={featuredProject} />
          </div>
        )}
      </div>
    </section>

    <section class="page-section page-section-codex-projects">
      <SectionHeading
        eyebrow="Codex project"
        title="Homepage"
        description="The live front door for cmnafi.com, kept aligned with the latest coffeehouse design system."
      />
      <div class="project-grid">
        <ProjectCard project={homepageProject} />
      </div>
    </section>
  </div>
</BaseLayout>
