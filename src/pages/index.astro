---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { strategyMapChapters } from '@/data/strategy-map';

const routePlaces = strategyMapChapters.map((chapter) => chapter.place.split(',')[0]);
const secondaryPaths = [
  {
    title: 'Writing',
    href: '/writing',
    description: 'Essays, notes, and reflections with a quieter editorial pace.'
  },
  {
    title: 'Projects',
    href: '/projects',
    description: 'Tools, research products, and public builds shaped around financial intelligence.'
  },
  {
    title: 'Connect',
    href: '/connect',
    description: 'A direct path for conversation, collaboration, and thoughtful introductions.'
  }
];
---

<BaseLayout description="A global journey into fintech - the personal website of C M Nafi.">
  <div class="home-cover">
    <section class="page-section home-hero">
      <div class="home-hero__copy">
        <p class="eyebrow">C M Nafi</p>
        <h1>A global journey into fintech.</h1>
        <p class="home-hero__body">
          From Bangladesh to Tampa, building a life across movement, systems, and financial intelligence.
        </p>

        <div class="home-hero__actions">
          <a class="button button-primary" href="/story">Start the journey</a>
          <a class="home-hero__subtle-link" href="/projects">View projects</a>
        </div>
      </div>

      <aside class="panel route-preview">
        <p class="eyebrow">The route</p>
        <h2>{routePlaces.join(' -> ')}</h2>

        <div class="route-preview__visual" aria-hidden="true">
          <div class="route-preview__track">
            {routePlaces.map((place, index) => (
              <span class:list={['route-preview__node', index === routePlaces.length - 1 && 'is-current']}>
                <span class="route-preview__pulse"></span>
              </span>
            ))}
          </div>
        </div>

        <ol class="route-preview__stops">
          {routePlaces.map((place) => (
            <li>{place}</li>
          ))}
        </ol>

        <a class="route-preview__link" href="/story">Explore full journey &rarr;</a>
      </aside>
    </section>

    <section class="page-section panel journey-teaser">
      <div class="journey-teaser__intro">
        <p class="eyebrow">Journey</p>
        <h2>The journey comes first.</h2>
        <p>
          Everything else on the site extends from it: writing, projects, and public work.
        </p>
      </div>

      <div class="journey-teaser__grid">
        {strategyMapChapters.map((chapter) => (
          <article class="journey-stop">
            <span class="journey-stop__step">{chapter.step}</span>
            <div>
              <h3>{chapter.place}</h3>
              <p class="journey-stop__theme">{chapter.theme}</p>
              <p class="journey-stop__signal">{chapter.signal}</p>
            </div>
          </article>
        ))}
      </div>

      <a class="button button-primary journey-teaser__cta" href="/story">Read the full journey</a>
    </section>

    <section class="page-section home-secondary">
      <div class="home-secondary__header">
        <p class="eyebrow">Elsewhere</p>
        <p class="home-secondary__copy">
          Writing, projects, and public contact remain available, but they stay secondary to the journey.
        </p>
      </div>

      <div class="home-secondary__grid">
        {secondaryPaths.map((path) => (
          <a class="panel home-secondary__card" href={path.href}>
            <span>{path.title}</span>
            <p>{path.description}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-cover {
    position: relative;
    padding-bottom: 4rem;
  }

  .home-cover::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 18% 18%, rgba(211, 154, 89, 0.12), transparent 30%),
      radial-gradient(circle at 78% 16%, rgba(126, 134, 157, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 30%, transparent 70%, rgba(255, 255, 255, 0.012));
  }

  .home-cover > * {
    position: relative;
    z-index: 1;
  }

  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
    min-height: calc(100vh - 8rem);
    padding-top: clamp(2rem, 6vw, 5rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .home-hero__copy {
    display: grid;
    gap: 1.4rem;
    max-width: 38rem;
  }

  .home-hero h1,
  .journey-teaser h2,
  .route-preview h2,
  .journey-stop h3 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .home-hero h1 {
    font-size: clamp(3.5rem, 7vw, 6.2rem);
    line-height: 0.94;
    max-width: 9ch;
  }

  .home-hero__body,
  .journey-teaser__intro p,
  .journey-stop__signal,
  .home-secondary__copy,
  .home-secondary__card p,
  .route-preview__stops {
    margin: 0;
    color: rgba(243, 237, 225, 0.72);
    line-height: 1.8;
  }

  .home-hero__body {
    max-width: 32rem;
    font-size: 1.05rem;
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .home-hero__subtle-link,
  .route-preview__link {
    color: rgba(243, 237, 225, 0.84);
    font-size: 0.96rem;
    letter-spacing: 0.02em;
    transition: color 180ms ease, transform 180ms ease;
  }

  .home-hero__subtle-link:hover,
  .route-preview__link:hover {
    color: var(--accent);
  }

  .route-preview {
    display: grid;
    gap: 1rem;
    padding: 1.4rem;
    border-radius: 30px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top, rgba(211, 154, 89, 0.08), transparent 64%);
  }

  .route-preview h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.08;
    max-width: 14ch;
  }

  .route-preview__visual {
    padding: 0.6rem 0 0.2rem;
  }

  .route-preview__track {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    align-items: center;
    gap: 0.4rem;
  }

  .route-preview__track::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(243, 237, 225, 0.16), rgba(211, 154, 89, 0.82), rgba(243, 237, 225, 0.16));
    transform: translateY(-50%);
    opacity: 0.8;
  }

  .route-preview__node {
    position: relative;
    z-index: 1;
    justify-self: center;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(243, 237, 225, 0.18);
    background: rgba(243, 237, 225, 0.18);
    box-shadow: 0 0 0 0 rgba(211, 154, 89, 0.12);
  }

  .route-preview__node.is-current {
    background: var(--accent);
    border-color: rgba(211, 154, 89, 0.56);
    box-shadow: 0 0 0 10px rgba(211, 154, 89, 0.08);
  }

  .route-preview__pulse {
    position: absolute;
    inset: -0.45rem;
    border-radius: 999px;
    border: 1px solid rgba(211, 154, 89, 0.22);
    opacity: 0;
    animation: routePulse 8s ease-in-out infinite;
  }

  .route-preview__node.is-current .route-preview__pulse {
    animation-duration: 4.8s;
    opacity: 1;
  }

  .route-preview__stops {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.65rem;
    padding: 0;
    font-size: 0.77rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .route-preview__stops li {
    color: rgba(243, 237, 225, 0.58);
  }

  .journey-teaser {
    display: grid;
    gap: 1.6rem;
    padding: clamp(1.5rem, 3vw, 2.2rem);
    margin-top: 0.5rem;
  }

  .journey-teaser__intro {
    max-width: 38rem;
  }

  .journey-teaser h2 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.02;
    margin-bottom: 0.75rem;
  }

  .journey-teaser__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .journey-stop {
    display: grid;
    gap: 0.8rem;
    padding: 1rem 0.95rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .journey-stop__step {
    width: 2.3rem;
    height: 2.3rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(243, 237, 225, 0.82);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .journey-stop h3 {
    font-size: 1.2rem;
    line-height: 1.14;
    margin-bottom: 0.45rem;
  }

  .journey-stop__theme {
    margin: 0 0 0.45rem;
    color: var(--accent);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .journey-stop__signal {
    font-size: 0.95rem;
  }

  .journey-teaser__cta {
    justify-self: start;
  }

  .home-secondary {
    display: grid;
    gap: 1rem;
    margin-top: 1.6rem;
  }

  .home-secondary__header {
    max-width: 34rem;
  }

  .home-secondary__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .home-secondary__card {
    display: grid;
    gap: 0.7rem;
    padding: 1.15rem;
    border-radius: 24px;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .home-secondary__card:hover {
    transform: translateY(-2px);
    border-color: rgba(211, 154, 89, 0.22);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.025)),
      radial-gradient(circle at top left, rgba(211, 154, 89, 0.06), transparent 68%);
  }

  .home-secondary__card span {
    color: rgba(243, 237, 225, 0.92);
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 1.45rem;
    letter-spacing: -0.03em;
  }

  :global(.ambient--one),
  :global(.ambient--two) {
    opacity: 0.24;
  }

  :global(.grain) {
    opacity: 0.035;
  }

  :global(.nav-list a[data-nav-item='journey']) {
    color: var(--text);
    border-color: rgba(211, 154, 89, 0.18);
    background: rgba(211, 154, 89, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  :global(.nav-list a[data-nav-item='journey']::after) {
    opacity: 0.92;
    transform: scaleX(1);
  }

  @keyframes routePulse {
    0%,
    100% {
      transform: scale(0.82);
      opacity: 0;
    }

    48% {
      transform: scale(1.06);
      opacity: 0.55;
    }
  }

  @media (max-width: 1100px) {
    .home-hero,
    .journey-teaser__grid,
    .home-secondary__grid {
      grid-template-columns: 1fr;
    }

    .home-hero {
      min-height: auto;
      padding-top: 2rem;
    }

    .route-preview {
      max-width: 40rem;
    }

    .route-preview__stops {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .home-hero {
      gap: 1.25rem;
      padding-bottom: 1.4rem;
    }

    .home-hero h1 {
      font-size: clamp(2.9rem, 13vw, 4.1rem);
    }

    .home-hero__body {
      font-size: 1rem;
    }

    .route-preview,
    .journey-teaser,
    .home-secondary__card {
      padding: 1rem;
      border-radius: 22px;
    }

    .route-preview__stops {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      font-size: 0.72rem;
    }

    .journey-teaser h2 {
      font-size: 2rem;
    }

    .journey-stop {
      padding-inline: 0;
    }

    .home-hero__actions {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .route-preview__pulse,
    .home-secondary__card,
    .home-hero__subtle-link,
    .route-preview__link {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
