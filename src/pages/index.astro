---
import BaseLayout from '@/layouts/BaseLayout.astro';

const interests = [
  { name: 'Cricket', icon: '🏏', color: '#4ADE80', href: '/interests/cricket', tooltip: 'Match stories & pressure finishes', lane: 1, speed: '8s', delay: '0s' },
  { name: 'Books', icon: '📚', color: '#F59E0B', href: '/interests/books', tooltip: 'Biographies & ideas that deepen over time', lane: 2, speed: '11s', delay: '2s' },
  { name: 'Movies', icon: '🎬', color: '#EF4444', href: '/interests/movies', tooltip: 'Film notes & scenes that keep their voltage', lane: 1, speed: '13s', delay: '4s' },
  { name: 'Writing', icon: '✍️', color: '#A78BFA', href: '/interests/writing', tooltip: 'Essays, systems & unfinished thoughts', lane: 2, speed: '9s', delay: '6s' },
  { name: 'Finance', icon: '📈', color: '#22D3EE', href: '#', tooltip: 'Markets, investing & financial thinking', lane: 3, speed: '7s', delay: '1s' },
  { name: 'Tech', icon: '💻', color: '#F472B6', href: '#', tooltip: 'Code, tools & the tech landscape', lane: 3, speed: '12s', delay: '5s' },
  { name: 'Data Science', icon: '🧠', color: '#FB923C', href: '#', tooltip: 'Models, analysis & making sense of data', lane: 4, speed: '10s', delay: '3s' },
];

const lanes = [
  { dir: 'ltr', items: interests.filter(i => i.lane === 1) },
  { dir: 'rtl', items: interests.filter(i => i.lane === 2) },
  { dir: 'ltr', items: interests.filter(i => i.lane === 3) },
  { dir: 'rtl', items: interests.filter(i => i.lane === 4) },
];
---

<BaseLayout description="Hi, I am Nafi. Brewing exciting topics — cricket, books, movies, writing, finance, tech & data science.">

  <!-- HERO SECTION -->
  <section class="hero">
    <div class="hero__inner">
      <img
        class="hero__photo"
        src="/profile.jpg"
        alt="C M Nafi"
        width="140"
        height="140"
        loading="eager"
      />
      <div class="hero__text">
        <h1 class="hero__headline" aria-label="Hi, I am Nafi.">
          <span class="hero__letter" style="--i:0">H</span><span class="hero__letter" style="--i:1">i</span><span class="hero__letter" style="--i:2">,</span><span class="hero__letter hero__letter--space" style="--i:3">&nbsp;</span><span class="hero__letter" style="--i:4">I</span><span class="hero__letter hero__letter--space" style="--i:5">&nbsp;</span><span class="hero__letter" style="--i:6">a</span><span class="hero__letter" style="--i:7">m</span><span class="hero__letter hero__letter--space" style="--i:8">&nbsp;</span><span class="hero__letter" style="--i:9">N</span><span class="hero__letter" style="--i:10">a</span><span class="hero__letter" style="--i:11">f</span><span class="hero__letter" style="--i:12">i</span><span class="hero__letter" style="--i:13">.</span>
        </h1>
        <p class="hero__sub">Brewing exciting topics. Welcome to my personal blog.</p>
      </div>
    </div>
  </section>

  <!-- F1 RACING STRIP -->
  <section class="f1-section" aria-label="Nafi's interests — animated showcase">
    <p class="f1-section__label">What I'm Into</p>
    <div class="f1-track">
      <div class="f1-track__lines" aria-hidden="true"></div>
      {lanes.map((lane) => (
        <div class={`f1-lane f1-lane--${lane.dir}`}>
          {lane.items.map((item) => (
            <a
              href={item.href}
              class={`f1-item f1-item--${lane.dir}`}
              style={`--speed:${item.speed};--delay:${item.delay};--accent:${item.color};`}
              data-tooltip={item.tooltip}
            >
              <span class="f1-item__accent" aria-hidden="true"></span>
              <span class="f1-item__icon">{item.icon}</span>
              <span class="f1-item__label">{item.name}</span>
            </a>
          ))}
        </div>
      ))}
    </div>
    <div class="f1-mobile-link">
      <a href="/interests">See all interests &rarr;</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========== HERO ========== */
  .hero {
    padding: 4rem 1.5rem 2rem;
  }

  .hero__inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    max-width: var(--max-width, 1180px);
    margin: 0 auto;
  }

  .hero__photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(228, 210, 184, 0.15);
    flex-shrink: 0;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Stagger letter animation */
  .hero__headline {
    font-family: 'Sora', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
    color: var(--text, #f3ede1);
  }

  .hero__letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: letter-in 0.08s ease forwards;
    animation-delay: calc(var(--i) * 0.07s);
  }

  .hero__letter--space {
    width: 0.3em;
  }

  @keyframes letter-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__sub {
    font-family: 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--muted, #b8ad9a);
    margin: 0;
    opacity: 0;
    animation: fade-up 0.6s ease forwards;
    animation-delay: 1.2s;
    line-height: 1.5;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile hero: centered stack */
  @media (max-width: 640px) {
    .hero {
      padding: 3rem 1.5rem 1.5rem;
    }

    .hero__inner {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .hero__photo {
      width: 120px;
      height: 120px;
    }
  }

  /* ========== F1 SECTION ========== */
  .f1-section {
    padding: 2rem 0 4rem;
  }

  .f1-section__label {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted, #b8ad9a);
    opacity: 0.55;
    text-align: center;
    margin: 0 0 2rem;
  }

  /* Track container */
  .f1-track {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 1rem 0;
  }

  /* Subtle lane markers */
  .f1-track__lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 71px,
      rgba(228, 210, 184, 0.05) 71px,
      rgba(228, 210, 184, 0.05) 72px
    );
    /* depth gradient */
    mask-image: linear-gradient(to bottom, transparent, white 20%, white 80%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, white 20%, white 80%, transparent);
  }

  /* Individual lane */
  .f1-lane {
    position: relative;
    height: 72px;
    margin-bottom: 16px;
    overflow: hidden;
    contain: layout;
  }

  .f1-lane:last-child {
    margin-bottom: 0;
  }

  /* ========== RACING PILL ========== */
  .f1-item {
    position: absolute;
    top: 50%;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0 1.25rem 0 0;
    height: 56px;
    min-width: 180px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-decoration: none;
    color: var(--text, #f3ede1);
    will-change: transform;
    cursor: pointer;
    z-index: 1;
    transition: transform 0.25s ease, background 0.25s ease, z-index 0s;
  }

  /* Accent bar */
  .f1-item__accent {
    width: 5px;
    height: 100%;
    border-radius: 50px 0 0 50px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .f1-item__icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-left: 0.8rem;
    flex-shrink: 0;
  }

  .f1-item__label {
    font-family: 'Sora', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-weight: 600;
    font-size: 0.92rem;
    white-space: nowrap;
  }

  /* Speed trail */
  .f1-item::after {
    content: '';
    position: absolute;
    top: 0;
    height: 100%;
    width: 80px;
    opacity: 0.2;
    border-radius: inherit;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .f1-item--ltr::after {
    right: 100%;
    background: linear-gradient(to right, transparent, var(--accent));
  }

  .f1-item--rtl::after {
    left: 100%;
    background: linear-gradient(to left, transparent, var(--accent));
  }

  /* LTR animation */
  .f1-item--ltr {
    transform: translateY(-50%);
    animation: race-ltr var(--speed) linear infinite;
    animation-delay: var(--delay);
  }

  @keyframes race-ltr {
    0% { left: -280px; }
    100% { left: calc(100% + 280px); }
  }

  /* RTL animation */
  .f1-item--rtl {
    transform: translateY(-50%);
    animation: race-rtl var(--speed) linear infinite;
    animation-delay: var(--delay);
  }

  @keyframes race-rtl {
    0% { right: -280px; }
    100% { right: calc(100% + 280px); }
  }

  /* Hover: pause + scale + tooltip */
  .f1-item:hover {
    animation-play-state: paused;
    transform: translateY(-50%) scale(1.08);
    background: rgba(255, 255, 255, 0.12);
    z-index: 10;
  }

  .f1-item:hover::after {
    opacity: 0;
  }

  /* Tooltip */
  .f1-item::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.5rem 0.9rem;
    border-radius: 10px;
    background: rgba(25, 22, 20, 0.92);
    border: 1px solid rgba(228, 210, 184, 0.12);
    color: var(--muted, #b8ad9a);
    font-family: 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.35;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 20;
  }

  .f1-item:hover::before {
    opacity: 1;
  }

  /* Focus styles */
  .f1-item:focus-visible {
    outline: 2px solid var(--accent, #d39a59);
    outline-offset: 3px;
    animation-play-state: paused;
    transform: translateY(-50%) scale(1.08);
    z-index: 10;
  }

  /* ========== MOBILE LINK ========== */
  .f1-mobile-link {
    display: none;
    text-align: center;
    margin-top: 1.5rem;
  }

  .f1-mobile-link a {
    font-family: 'Sora', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent, #d39a59);
    text-decoration: none;
    transition: opacity 0.18s ease;
  }

  .f1-mobile-link a:hover {
    opacity: 0.75;
  }

  /* ========== RESPONSIVE ========== */

  /* Tablet */
  @media (max-width: 1024px) {
    .f1-lane:nth-child(5) {
      display: none;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .f1-lane:nth-child(4),
    .f1-lane:nth-child(5) {
      display: none;
    }

    .f1-item {
      min-width: 150px;
      height: 50px;
      border-radius: 40px;
    }

    .f1-item__icon {
      font-size: 1.2rem;
    }

    .f1-item__label {
      font-size: 0.82rem;
    }

    .f1-mobile-link {
      display: block;
    }

    /* Hide tooltips on touch */
    .f1-item::before {
      display: none;
    }
  }

  /* ========== REDUCED MOTION: static grid ========== */
  @media (prefers-reduced-motion: reduce) {
    .hero__letter {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .hero__sub {
      opacity: 1;
      animation: none;
    }

    .f1-track {
      display: none;
    }

    .f1-section::after {
      content: '';
      display: block;
    }

    /* Show a static grid instead */
    .f1-section {
      padding: 2rem 1.5rem 4rem;
    }
  }
</style>

<!-- Static grid fallback for reduced-motion -->
<style>
  @media (prefers-reduced-motion: reduce) {
    .f1-track {
      display: flex !important;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      padding: 1rem 1.5rem;
      overflow: visible;
    }

    .f1-lane {
      display: contents !important;
      height: auto;
      overflow: visible;
    }

    .f1-item,
    .f1-item--ltr,
    .f1-item--rtl {
      position: static !important;
      transform: none !important;
      animation: none !important;
    }

    .f1-item::after {
      display: none;
    }

    .f1-item:hover {
      transform: scale(1.05) !important;
    }
  }
</style>
