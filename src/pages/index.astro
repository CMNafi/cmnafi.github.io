---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TelemetryGrid from '@/components/telemetry/TelemetryGrid.astro';
import StatusDot from '@/components/telemetry/StatusDot.astro';
import SectorBadge from '@/components/telemetry/SectorBadge.astro';
import LapTimer from '@/components/telemetry/LapTimer.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const notes = await getCollection('field-notes');

// Current Lap - Most recently updated active project
const liveProjects = projects
  .filter(p => p.data.status === 'live')
  .sort((a, b) => {
    const timeA = a.data.updatedAt?.valueOf() || a.data.startedAt?.valueOf() || 0;
    const timeB = b.data.updatedAt?.valueOf() || b.data.startedAt?.valueOf() || 0;
    return timeB - timeA;
  });
const currentLap = liveProjects[0];

// Latest Field Note
const latestNote = notes.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())[0];

const sectors = [
  { id: 'S1', name: 'GARAGE', href: '/garage', label: 'Projects & Apps' },
  { id: 'S2', name: 'FIELD NOTES', href: '/field-notes', label: 'Telemetry Log' },
  { id: 'S3', name: 'DRIVER', href: '/story', label: 'Biography' },
  { id: 'S4', name: 'PARC FERMÉ', href: '/connect', label: 'Comms' },
  { id: 'S5', name: 'CAIA CORNER', href: '/caia', label: 'Study Hub' }
];
---

<BaseLayout title="Pit Wall" hideHeader={true}>
  <main class="pit-wall">
    <div class="strategist-grid">
      
      <!-- HERO: Profile Block -->
      <section class="hero-block panel p-main">
        <div class="hero-top">
          <div class="driver-id">
            <span class="abbr">CMN</span>
            <LapTimer />
          </div>
          <h1 class="pilot-name">C M NAFI</h1>
          <h2 class="role">STRATEGIST // ENGINEER</h2>
        </div>
        <div class="hero-bottom">
          <p>I build systems, analyze capital flow, and write the telemetry of it all. You are viewing the global cockpit.</p>
        </div>
      </section>

      <!-- CURRENT LAP: Featured Project -->
      <section class="current-lap panel">
        {currentLap ? (
          <>
            <header class="panel-header">
              <span class="label">CURRENT LAP</span>
              <StatusDot state={currentLap.data.status as any} />
            </header>
            <div class="lap-data">
              <h3><a href={currentLap.data.liveUrl || `/garage/${currentLap.slug}`}>{currentLap.data.title}</a></h3>
              <p>{currentLap.data.summary}</p>
              <TelemetryGrid 
                updated={(currentLap.data.updatedAt || currentLap.data.startedAt)?.toLocaleDateString()}
                status={currentLap.data.status as any}
                stack={currentLap.data.stack?.slice(0, 2).join(', ') || 'N/A'}
                link={currentLap.data.liveUrl || `/garage/${currentLap.slug}`}
                linkLabel={currentLap.data.liveUrl ? "LAUNCH APP →" : "VIEW →"}
              />
            </div>
          </>
        ) : (
          <div class="lap-data no-live">
            <p class="placeholder-msg">NO CAR ON TRACK</p>
            <a href="/garage" class="sys-btn" style="margin-top: 1rem;">SEE THE GARAGE →</a>
          </div>
        )}
      </section>

      <!-- SECTORS: Navigation -->
      <section class="sectors-block panel">
        <header class="panel-header">
          <span class="label">SECTORS // NAVIGATION</span>
        </header>
        <div class="sector-nav">
          {sectors.map(s => (
            <a href={s.href} class="sector-button">
              <SectorBadge variant="sector1" label={s.id} />
              <div class="s-info">
                <span class="s-name">{s.name}</span>
                <span class="s-label">{s.label}</span>
              </div>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- LATEST TELEMETRY (Field Note) -->
      <section class="latest-note panel p-alt">
        <header class="panel-header">
          <span class="label">LATEST COMMS</span>
        </header>
        {latestNote && (
          <div class="note-data">
            <SectorBadge variant="p2" label={latestNote.data.category} />
            <h3 class="note-title"><a href={`/field-notes/${latestNote.slug}`}>{latestNote.data.title}</a></h3>
            <div class="note-telemetry">
               <span class="t-line">DATE: {latestNote.data.publishedAt.toLocaleDateString()}</span>
               <span class="t-line">READ: {latestNote.data.readingTime}</span>
            </div>
            <a href={`/field-notes/${latestNote.slug}`} class="sys-btn">READ LOG</a>
          </div>
        )}
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  .pit-wall {
    min-height: 100vh;
    background: var(--paddock-black);
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }

  .strategist-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
    max-width: 1200px;
    width: 100%;
  }

  .panel {
    background: var(--carbon);
    border: 1px solid var(--graphite);
    border-radius: var(--radius-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px dashed var(--graphite);
    padding-bottom: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .label {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 0.2rem;
  }

  /* HERO */
  .p-main { border-top: 3px solid var(--racing-red); grid-column: 1 / 2; grid-row: 1 / 2; }
  .driver-id { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .abbr { font-family: var(--font-mono); font-weight: 700; color: var(--pitlane-white); letter-spacing: 0.1em; }
  .pilot-name { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); color: var(--pitlane-white); margin: 0 0 0.5rem; line-height: 1; }
  .role { font-family: var(--font-mono); color: var(--accent); font-size: 0.9rem; margin: 0 0 2rem; letter-spacing: 0.2em; }
  .hero-bottom p { font-family: var(--font-body); color: var(--muted); font-size: 1.1rem; line-height: 1.6; margin: 0; max-width: 400px; }

  /* CURRENT LAP */
  .current-lap { grid-column: 2 / 3; grid-row: 1 / 2; }
  .lap-data h3 { font-family: var(--font-display); font-size: 2rem; color: var(--pitlane-white); margin: 0 0 0.5rem; }
  .lap-data h3 a { color: inherit; }
  .lap-data p { font-family: var(--font-body); color: var(--muted); margin: 0 0 2rem; line-height: 1.5; }

  /* SECTORS NAV */
  .sectors-block { grid-column: 1 / 2; grid-row: 2 / 3; }
  .sector-nav { display: flex; flex-direction: column; gap: 0.5rem; }
  .sector-button {
    display: flex; align-items: center; gap: 1.5rem;
    padding: 1rem 1.5rem; background: var(--paddock-black);
    border: 1px solid var(--graphite);
    border-radius: var(--radius-chip);
    text-decoration: none; transition: transform 0.2s, border-color 0.2s;
  }
  .sector-button:hover {
    transform: translateX(8px);
    border-color: var(--telemetry-green);
  }
  .s-info { display: flex; flex-direction: column; flex: 1; }
  .s-name { font-family: var(--font-display); color: var(--pitlane-white); font-size: 1.2rem; }
  .s-label { font-family: var(--font-mono); color: var(--muted); font-size: 0.75rem; letter-spacing: 0.1em; }
  .arrow { color: var(--telemetry-green); font-family: var(--font-mono); }

  /* LATEST COMMS */
  .p-alt { border-top: 3px solid var(--warning-amber); grid-column: 2 / 3; grid-row: 2 / 3; justify-content: space-between; }
  .note-title { font-family: var(--font-display); font-size: 1.8rem; color: var(--pitlane-white); margin: 1rem 0; }
  .note-title a { color: inherit; }
  .note-telemetry { display: flex; flex-direction: column; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.8rem; color: var(--muted); margin-bottom: 2rem; border-left: 2px solid var(--graphite); padding-left: 1rem; }
  .sys-btn {
    display: inline-block; font-family: var(--font-mono); background: var(--carbon); border: 1px solid var(--graphite);
    color: var(--pitlane-white); padding: 0.8rem 1.5rem; text-decoration: none; font-size: 0.8rem; letter-spacing: 0.1em;
    border-radius: var(--radius-chip); transition: 0.2s;
  }
  .sys-btn:hover { background: var(--pitlane-white); color: var(--paddock-black); }

  @media (max-width: 900px) {
    .strategist-grid { grid-template-columns: 1fr; }
    .p-main { grid-column: 1; grid-row: 1; }
    .current-lap { grid-column: 1; grid-row: 2; }
    .sectors-block { grid-column: 1; grid-row: 3; }
    .latest-note { grid-column: 1; grid-row: 4; }
  }
</style>
