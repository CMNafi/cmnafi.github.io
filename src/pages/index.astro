---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout description="From global foundations to financial intelligence — the personal site of C M Nafi.">
  <section class="home-hero">
    <a class="home-hero__eyebrow" href="/about">C M Nafi</a>
    <h1 class="home-hero__tagline">
      Global foundations.<br />
      Financial intelligence.<br />
      Work in motion.
    </h1>
    <div class="home-hero__actions">
      <a class="button button-primary" href="/brewing">See what I'm building</a>
      <a class="button button-ghost" href="/connect">Let's connect</a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 8rem);
    padding: 4rem 1.5rem;
    gap: 2rem;
  }

  .home-hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: var(--muted);
    transition: color 180ms ease;
  }

  .home-hero__eyebrow:hover {
    color: var(--accent);
  }

  .home-hero__tagline {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2.8rem, 6vw, 5.2rem);
    line-height: 1.12;
    letter-spacing: -0.04em;
    margin: 0;
    max-width: 16ch;
  }

  .home-hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 600px) {
    .home-hero__tagline {
      font-size: clamp(2.2rem, 10vw, 3.4rem);
    }

    .home-hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 18rem;
    }
  }
</style>
