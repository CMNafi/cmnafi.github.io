---
import BaseLayout from '@/layouts/BaseLayout.astro';

const interests = [
  { id: 'cricket', name: 'Cricket', icon: '🏏', color: '#4ADE80', href: '/interests/cricket', badge: '04' },
  { id: 'books', name: 'Books', icon: '📚', color: '#F59E0B', href: '/interests/books', badge: '12' },
  { id: 'movies', name: 'Movies', icon: '🎬', color: '#EF4444', href: '/interests/movies', badge: '77' },
  { id: 'writing', name: 'Writing', icon: '✍️', color: '#A78BFA', href: '/interests/writing', badge: '55' },
  { id: 'finance', name: 'Finance', icon: '📈', color: '#22D3EE', href: '#', badge: '11' },
  { id: 'tech', name: 'Tech', icon: '💻', color: '#F472B6', href: '#', badge: '33' },
  { id: 'data', name: 'Data', icon: '🧠', color: '#FB923C', href: '#', badge: '07' },
];

const dashboardNav = [
  { label: 'My Story', href: '/story' },
  { label: 'Interest', href: '/blog' },
  { label: 'Projects', href: '/projects' },
];
---
<BaseLayout description="Hi, I am Nafi. Brewing exciting topics. Welcome to my personal blog.">

  <!-- HERO SECTION -->
  <section class="hero-center" aria-label="Hero Section">
    <div class="hero-inner">
      <div class="hero-profile">
        <img src="/profile.jpg" alt="C M Nafi" width="160" height="160" loading="eager" />
      </div>
      <h1 class="hero-headline">
        {"Hi, I am Nafi.".split('').map((char, i) => (
          <span class={`hero-letter ${char === ' ' ? 'hero-letter--space' : ''}`} style={`--i:${i}`}>{char === ' ' ? '\u00A0' : char}</span>
        ))}
      </h1>
      <p class="hero-subline">Brewing exciting topics. Welcome to my personal blog.</p>
      
      <div class="hero-nav">
        {dashboardNav.map((item, i) => (
          <a href={item.href} class="hero-nav-btn" style={`--i:${i}`}>
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RACETRACK SECTION -->
  <section class="grand-prix" aria-label="The Interest Grand Prix">
    <div class="gp-header">
      <h2 class="gp-title">THE GRAND PRIX</h2>
      <p class="gp-subtitle">7 interests. 1 massive track. Overtaking allowed.</p>
      
      <button id="start-race-btn" class="gp-start-btn">START RACE</button>
    </div>

    <div class="track-area">
      <!-- SVG Track Background -->
      <svg class="track-svg" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice">
        <defs>
          <pattern id="checker" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect width="10" height="10" fill="#fff" />
            <rect x="10" width="10" height="10" fill="#111" />
            <rect y="10" width="10" height="10" fill="#111" />
            <rect x="10" y="10" width="10" height="10" fill="#fff" />
          </pattern>
        </defs>
        
        <!-- Thick Main Road -->
        <path d="M 50 150 C 400 150, 400 450, 800 450 C 1100 450, 1050 150, 1300 150" 
              fill="none" stroke="#222" stroke-width="200" stroke-linecap="round"/>
              
        <!-- Road Edges / Curbs -->
        <path d="M 50 150 C 400 150, 400 450, 800 450 C 1100 450, 1050 150, 1300 150" 
              fill="none" stroke="#e11d48" stroke-width="216" stroke-dasharray="30 30" stroke-linecap="round" style="opacity: 0.6; z-index: -1;"/>
        <path d="M 50 150 C 400 150, 400 450, 800 450 C 1100 450, 1050 150, 1300 150" 
              fill="none" stroke="#fff" stroke-width="216" stroke-dasharray="0 30 30 0" stroke-linecap="round" style="opacity: 0.6; z-index: -1;"/>
              
        <!-- Invisible Center Racing Line for JS Math -->
        <path id="racing-line" d="M 50 150 C 400 150, 400 450, 800 450 C 1100 450, 1050 150, 1150 150" 
              fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="4" stroke-dasharray="10 10"/>
        
        <!-- Start & Finish Lines overlapping the road -->
        <line x1="150" y1="50" x2="150" y2="250" stroke="url(#checker)" stroke-width="20" />
        <line x1="1100" y1="50" x2="1100" y2="250" stroke="url(#checker)" stroke-width="20" />
        <text x="1100" y="40" fill="#fff" font-family="Sora" font-weight="bold" font-size="20" text-anchor="middle">FINISH</text>
      </svg>

      <!-- Overlay for Countdown -->
      <div class="countdown-overlay" id="countdown-overlay">
        <div class="countdown-text" id="countdown-text">3</div>
      </div>

      <!-- Cars Container - Scaled by JS to match SVG coordinate system -->
      <div class="cars-layer" id="cars-layer">
        {interests.map((item, index) => (
          <a
            href={item.href}
            class="f1-car"
            id={`car-${item.id}`}
            data-index={index}
            data-id={item.id}
            data-name={item.name}
            data-href={item.href}
            target="_blank"
            style={`--accent: ${item.color};`}
          >
            <div class="f1-car__badge">{item.badge}</div>
            <div class="f1-car__icon">{item.icon}</div>
            <div class="f1-car__name">{item.name}</div>
          </a>
        ))}
      </div>
      
      <!-- Winner Transition Screen -->
      <div class="winner-screen" id="winner-screen">
        <div class="winner-content">
          <h2 class="winner-title">RACE FINISHED</h2>
          <div class="winner-card" id="winner-card">
            <span class="winner-card__icon" id="winner-icon"></span>
            <span class="winner-card__name" id="winner-name"></span>
          </div>
          <p class="winner-msg" id="winner-msg">Let's explore my journey.</p>
          <div class="winner-actions">
            <a href="#" class="winner-explore-btn" id="winner-explore-btn">Explore Now &rarr;</a>
            <button class="winner-replay-btn" id="winner-replay-btn">🔄 Race Again</button>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --track-bg: #111;
  }

  /* =========== HERO CENTER =========== */
  .hero-center {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-center::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(34, 211, 238, 0.08) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 900px;
  }

  .hero-profile {
    margin-bottom: 1rem;
  }

  .hero-profile img {
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.1);
    box-shadow: 0 0 40px rgba(34, 211, 238, 0.2);
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); box-shadow: 0 15px 40px rgba(34, 211, 238, 0.3); }
  }

  .hero-headline {
    font-family: 'Sora', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(3.2rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1.05;
    color: #f3ede1;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .hero-letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: letter-enter 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    animation-delay: calc(var(--i) * 0.04s + 0.2s);
  }
  .hero-letter--space { width: 0.2em; }

  @keyframes letter-enter {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-subline {
    font-family: 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    color: #b8ad9a;
    margin: 0;
    max-width: 600px;
    opacity: 0;
    animation: fade-up 0.8s ease forwards;
    animation-delay: 1s;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-nav {
    display: flex;
    gap: 1.2rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-nav-btn {
    font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
    padding: 0.8rem 2.2rem;
    border-radius: 40px;
    background: rgba(255,255,255,0.04);
    color: #f3ede1;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(10px);
    opacity: 0;
    animation: nav-enter 0.5s ease forwards;
    animation-delay: calc(var(--i) * 0.1s + 1.2s);
  }

  @keyframes nav-enter {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-nav-btn:hover {
    background: rgba(34, 211, 238, 0.12);
    border-color: rgba(34, 211, 238, 0.4);
    box-shadow: 0 0 25px rgba(34, 211, 238, 0.25);
    transform: translateY(-4px) scale(1.05);
  }

  /* =========== RACETRACK =========== */
  .grand-prix {
    padding: 2rem 1.5rem 6rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gp-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .gp-title {
    font-family: 'Sora', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem;
    color: #f3ede1;
  }

  .gp-subtitle {
    font-family: 'Manrope', sans-serif;
    font-size: 1.1rem;
    color: #b8ad9a;
    margin: 0 0 1.5rem;
  }

  .gp-start-btn {
    font-family: 'DM Sans', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    padding: 1rem 3rem;
    border-radius: 50px;
    background: #e11d48;
    color: white;
    border: none;
    cursor: pointer;
    box-shadow: 0 0 25px rgba(225, 29, 72, 0.4);
    transition: all 0.3s ease;
  }
  .gp-start-btn:hover {
    background: #be123c;
    box-shadow: 0 0 40px rgba(225, 29, 72, 0.6);
    transform: scale(1.05);
  }
  .gp-start-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    background: #555;
    box-shadow: none;
  }

  /* Single Track Rendering */
  .track-area {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    background: repeating-linear-gradient(to bottom, #141414, #141414 40px, #1a1a1a 40px, #1a1a1a 42px);
    border: 1px solid #333;
    border-radius: 24px;
    overflow: hidden;
    /* ensure scale transform orig matches layout */
  }

  .track-svg {
    position: absolute;
    inset: 0;
    width: 100%; 
    height: 100%;
  }

  /* Cars Overlay Grid */
  .cars-layer {
    position: absolute;
    top: 0; left: 0;
    width: 1200px;
    height: 600px;
    transform-origin: top left;
    pointer-events: none; /* Let SVG clicks pass if needed, but cars enable pointer-events */
  }

  /* F1 Car Architecture */
  .f1-car {
    position: absolute;
    /* top left mapped to 0 0 of the SVG coordinate system */
    top: 0; left: 0;
    display: flex;
    align-items: center;
    background: rgba(15, 15, 15, 0.95);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 0 1rem;
    height: 40px;
    width: 160px;
    text-decoration: none;
    color: #f3ede1;
    z-index: 10;
    will-change: transform;
    pointer-events: auto; /* clickable while racing or idle */
    transition: box-shadow 0.2s, background 0.2s;
  }

  .f1-car::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 26px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    z-index: -1;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  
  .f1-car:hover {
    box-shadow: 0 0 20px var(--accent);
    background: rgba(30, 30, 30, 0.95);
    z-index: 999 !important; /* Jump to top on hover */
  }

  .f1-car__badge {
    font-family: 'DM Sans', sans-serif;
    font-weight: 800;
    font-size: 0.8rem;
    color: var(--accent);
    margin-right: 0.5rem;
    width: 18px;
  }

  .f1-car__icon {
    font-size: 1.1rem;
    margin-right: 0.5rem;
    transform: translateY(-1px);
  }

  .f1-car__name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* Drafting / Speed trail */
  .f1-car::after {
    content: '';
    position: absolute;
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    height: 50%;
    width: 80px;
    background: linear-gradient(to right, transparent, var(--accent));
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .f1-car.is-racing::after {
    opacity: 0.8;
  }

  /* Overlays */
  .countdown-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .countdown-overlay.show { opacity: 1; }

  .countdown-text {
    font-family: 'Sora', sans-serif;
    font-size: 10rem;
    font-weight: 900;
    color: #fff;
    transform: scale(0.5);
    opacity: 0;
  }
  .countdown-text.animate {
    animation: count-boom 1s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  @keyframes count-boom {
    0% { transform: scale(0.5); opacity: 0; }
    30% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(1); opacity: 0; }
  }

  /* Winner Post-Race Screen */
  .winner-screen {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease;
  }
  .winner-screen.show {
    opacity: 1;
    pointer-events: auto;
  }

  .winner-content {
    text-align: center;
    transform: translateY(30px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .winner-screen.show .winner-content {
    transform: translateY(0) scale(1);
  }

  .winner-title {
    font-family: 'Sora', sans-serif;
    color: #facc15;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    letter-spacing: 0.15em;
    margin: 0 0 2rem;
    text-shadow: 0 0 20px rgba(250, 204, 21, 0.4);
  }

  .winner-card {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.5rem 3.5rem;
    border-radius: 60px;
    background: rgba(255,255,255,0.06);
    border: 3px solid var(--accent, #fff);
    box-shadow: 0 0 40px var(--accent, transparent), inset 0 0 20px var(--accent, transparent);
    margin-bottom: 1.5rem;
    will-change: transform;
    animation: winner-pulse 2s infinite alternate ease-in-out;
  }

  @keyframes winner-pulse {
    from { transform: scale(1); }
    to { transform: scale(1.03); }
  }

  .winner-card__icon { font-size: 3rem; }
  .winner-card__name { font-family: 'Sora', sans-serif; font-size: 3rem; font-weight: 800; color: #fff; }

  .winner-msg {
    font-family: 'Manrope', sans-serif;
    font-size: 1.5rem;
    color: #e4d2b8;
    margin-bottom: 3rem;
  }

  .winner-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .winner-explore-btn {
    background: var(--accent, #4ade80);
    color: #000;
    padding: 1.2rem 3.5rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 800;
    font-size: 1.2rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 20px var(--accent);
  }
  .winner-explore-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px var(--accent);
  }

  .winner-replay-btn {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.2);
    padding: 1.2rem 2.5rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .winner-replay-btn:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.4);
  }

  @media (max-width: 768px) {
    .track-area {
      aspect-ratio: 1 / 1; /* Squarer on mobile so scale fits better */
    }
    .winner-card { padding: 1rem 2rem; }
    .winner-card__icon { font-size: 2rem; }
    .winner-card__name { font-size: 2rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .f1-car { transition: none !important; }
    .winner-card { animation: none; }
    .hero-profile img { animation: none; }
    .hero-letter, .hero-subline, .hero-nav-btn { animation: none; opacity: 1; transform: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Basic elements
    const trackArea = document.querySelector('.track-area');
    const carsLayer = document.getElementById('cars-layer');
    const path = document.getElementById('racing-line');
    const startBtn = document.getElementById('start-race-btn');
    const countdownOverlay = document.getElementById('countdown-overlay');
    const countdownText = document.getElementById('countdown-text');
    
    // Winner screen elements
    const winnerScreen = document.getElementById('winner-screen');
    const winnerCard = document.getElementById('winner-card');
    const winnerIcon = document.getElementById('winner-icon');
    const winnerName = document.getElementById('winner-name');
    const winnerMsg = document.getElementById('winner-msg');
    const winnerExploreBtn = document.getElementById('winner-explore-btn');
    const winnerReplayBtn = document.getElementById('winner-replay-btn');

    if (!path || !carsLayer) return;

    // We mathematically scale the cars-layer to match the viewport container
    // Because the SVG viewBox goes from 0-1200, we wrote cars-layer to be 1200px.
    // CSS scale handles the mapping automatically!
    function handleResize() {
      const scale = trackArea.clientWidth / 1200;
      // Also scale height to match the aspect ratio shift on mobile if any
      const scaleY = trackArea.clientHeight / 600; 
      carsLayer.style.transform = `scale(${scale}, ${scaleY})`;
    }
    window.addEventListener('resize', handleResize);
    handleResize();

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const carsElements = Array.from(document.querySelectorAll('.f1-car'));
    const totalLength = path.getTotalLength();
    
    // Math logic for starting positions.
    // Start line is around X=150, which is length offset on the path.
    // The path starts at X=50, Y=150. Distance to X=150 is ~100 length units.
    const startOffsetLength = 100; // where cars line up
    const finishOffsetLength = totalLength - 100; // Finish line logic
    const raceDistance = finishOffsetLength - startOffsetLength;

    let cars = [];
    let isRacing = false;
    let raceReqId = null;

    function initCars() {
      cars = carsElements.map((el, i) => {
        el.classList.remove('is-racing');
        
        // Staggered grid formation at start offset
        const gridRow = Math.floor(i / 2);
        const isOutside = i % 2 !== 0; // Odd index outside line
        
        const startingLength = startOffsetLength - (gridRow * 35); // stagger back
        const lateralOffset = isOutside ? -45 : 45; // two columns
        
        const pt = path.getPointAtLength(startingLength);
        const ptNext = path.getPointAtLength(startingLength + 1);
        const angle = Math.atan2(ptNext.y - pt.y, ptNext.x - pt.x);
        const nx = Math.cos(angle - Math.PI/2);
        const ny = Math.sin(angle - Math.PI/2);
        
        const x = pt.x + nx * lateralOffset;
        const y = pt.y + ny * lateralOffset;
        
        el.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%) rotate(${angle}rad)`;
        
        return {
          el,
          id: el.getAttribute('data-id'),
          name: el.getAttribute('data-name'),
          href: el.getAttribute('data-href'),
          icon: el.querySelector('.f1-car__icon').textContent,
          color: el.style.getPropertyValue('--accent').trim(),
          
          progressRaw: startingLength, // length traversed
          lateralBase: lateralOffset,
          lateralCurrent: lateralOffset,
          speed: 0,
          drifting: 0, // lateral change per frame
          basePace: 2 + Math.random() * 1.5, // units per frame
          finished: false
        };
      });
      winnerScreen.classList.remove('show');
    }

    initCars();

    startBtn.addEventListener('click', startRaceSequence);
    winnerReplayBtn.addEventListener('click', () => {
      initCars();
      startRaceSequence();
    });

    function startRaceSequence() {
      if (isRacing) return;
      if (prefersReducedMotion) return; // Disallow heavy race animation if requested
      
      startBtn.disabled = true;
      startBtn.textContent = 'RACING...';
      
      cars.forEach(car => car.el.classList.add('is-racing'));
      
      countdownOverlay.classList.add('show');
      const counts = ['3', '2', '1', 'GO!'];
      let step = 0;

      function nextCount() {
        if (step >= counts.length) {
          countdownOverlay.classList.remove('show');
          isRacing = true;
          raceReqId = requestAnimationFrame(raceLoop);
          return;
        }
        countdownText.textContent = counts[step];
        countdownText.classList.remove('animate');
        void countdownText.offsetWidth;
        countdownText.classList.add('animate');
        
        countdownText.style.color = counts[step] === 'GO!' ? '#4ade80' : '#fff';
        countdownText.style.textShadow = counts[step] === 'GO!' ? '0 0 30px #4ade80' : '0 0 30px #e11d48';

        step++;
        setTimeout(nextCount, 1000);
      }
      nextCount();
    }

    function triggerWinner(winningCar) {
      isRacing = false;
      cancelAnimationFrame(raceReqId);
      
      // Setup Winner Screen
      winnerCard.style.setProperty('--accent', winningCar.color);
      winnerIcon.textContent = winningCar.icon;
      winnerName.textContent = winningCar.name;
      winnerMsg.textContent = `Let's explore my ${winningCar.name.toLowerCase()} journey.`;
      
      winnerExploreBtn.href = winningCar.href;
      winnerExploreBtn.style.setProperty('--accent', winningCar.color);
      
      // Delay slightly for dramatic effect
      setTimeout(() => {
        winnerScreen.classList.add('show');
        startBtn.textContent = 'START RACE';
        startBtn.disabled = false;
      }, 500);
    }

    function raceLoop() {
      if (!isRacing) return;
      
      let winnerFound = null;

      cars.forEach(car => {
        // AI Speed logic + slipstream drafting
        // Random microbursts
        if (Math.random() < 0.05) {
          car.basePace += (Math.random() * 0.8 - 0.3); // Burst
        }
        
        if (car.basePace < 1.5) car.basePace = 1.5;
        if (car.basePace > 4.5) car.basePace = 4.5;

        // Overtaking & Lane changes
        car.drifting += (Math.random() * 2 - 1) * 0.5;
        if (car.drifting > +2) car.drifting = +2;
        if (car.drifting < -2) car.drifting = -2;
        
        car.lateralCurrent += car.drifting;
        // Keep cars on the track (Track is ~200px wide, center is 0. So +/- 80px)
        if (car.lateralCurrent < -70) { car.lateralCurrent = -70; car.drifting *= -1; }
        if (car.lateralCurrent > 70) { car.lateralCurrent = 70; car.drifting *= -1; }

        car.progressRaw += car.basePace;

        if (car.progressRaw >= finishOffsetLength && !winnerFound) {
           winnerFound = car;
        }

        // Extrapolate transform
        let pt = path.getPointAtLength(car.progressRaw);
        let ptNext = path.getPointAtLength(Math.min(car.progressRaw + 1, totalLength));
        let angle = Math.atan2(ptNext.y - pt.y, ptNext.x - pt.x);
        
        let nx = Math.cos(angle - Math.PI/2);
        let ny = Math.sin(angle - Math.PI/2);
        
        let x = pt.x + nx * car.lateralCurrent;
        let y = pt.y + ny * car.lateralCurrent;

        car.el.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%) rotate(${angle}rad)`;
        car.el.style.zIndex = Math.floor(y); // Overlapping logic (closest to bottom overlaps)
      });

      if (winnerFound) {
        triggerWinner(winnerFound);
      } else {
        raceReqId = requestAnimationFrame(raceLoop);
      }
    }
  });
</script>
