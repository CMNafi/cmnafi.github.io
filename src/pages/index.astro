</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const chapters = document.querySelectorAll('.story-chapter');
    const phaseVisuals = document.querySelectorAll('.phase-visual');
    const indicators = document.querySelectorAll('.indicator');
    const labelPhase = document.querySelector('.stage-label__phase');
    const labelTitle = document.querySelector('.stage-label__title');

    const phaseNames = {
      '1': 'Foundation',
      '2': 'Global',
      '3': 'Academic',
      '4': 'Professional',
      '5': 'Identity'
    };

    let activePhase = '0';

    function setPhase(phase) {
      if (phase === activePhase) return;
      activePhase = phase;

      phaseVisuals.forEach((v) => v.setAttribute('opacity', '0'));
      const target = document.querySelector(`.phase-${phase}-visual`);
      if (target) target.setAttribute('opacity', '1');

      indicators.forEach((ind) => {
        ind.classList.toggle('is-active', ind.dataset.phase === phase);
      });

      if (labelPhase && labelTitle) {
        labelPhase.textContent = phase.padStart(2, '0');
        labelTitle.textContent = phaseNames[phase] || '';
      }
    }

    const visibilityObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
    );

    const phaseObserver = new IntersectionObserver(
      (entries) => {
        let best = null;
        let bestRatio = 0;
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
            best = entry.target;
            bestRatio = entry.intersectionRatio;
          }
        });
        if (best) setPhase(best.dataset.phase);
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1], rootMargin: '-20% 0px -30% 0px' }
    );

    chapters.forEach((ch) => {
      visibilityObserver.observe(ch);
      phaseObserver.observe(ch);
    });

    // Fade out scroll hint on first scroll
    const hint = document.querySelector('.hero-scroll-hint');
    if (hint) {
      let hidden = false;
      window.addEventListener('scroll', () => {
        if (!hidden && window.scrollY > 120) {
          hint.style.opacity = '0';
          hint.style.transition = 'opacity 600ms ease';
          hidden = true;
        }
      }, { passive: true });
    }

    setTimeout(() => setPhase('1'), 600);
  });
</script>
