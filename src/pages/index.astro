    letter-spacing: -0.01em;
    color: var(--text-warm-white);
    transition: color var(--dur-fast) var(--ease-mechanical);
  }

  .ticker-item:hover .ticker-title,
  .ticker-item:focus-visible .ticker-title {
    color: var(--accent);
  }

  .ticker-item:hover .ticker-date {
