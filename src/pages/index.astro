<script>
  import { rollupCounter } from '../scripts/counter';
  import { scrambleTo } from '../scripts/scramble';



  // Count up stats rollup on IntersectionObserver
  function initStatsRollup() {
    const rolls = document.querySelectorAll('.stat-roll');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const targetVal = parseInt(el.getAttribute('data-target') || '0', 10);
          rollupCounter(el, targetVal, 1200);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    rolls.forEach(el => observer.observe(el));
  }

  // Text Scramble on mount/observe
  function initScrambleHeaders() {
    // 1. Hero headline scramble
    const hero = document.getElementById('hero-headline');
    if (hero) {
      const text = hero.getAttribute('data-text') || hero.textContent || '';
      scrambleTo(hero, text, 900);
    }

    // 2. Intersection h2 scramble
    const headers = document.querySelectorAll('.scramble-header');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (el.id === 'hero-headline') return; // already done on mount
          const text = el.getAttribute('data-text') || el.textContent || '';
          scrambleTo(el, text, 600);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.2 });

    headers.forEach(el => observer.observe(el));
  }

  // Scroll compass needle dial logic
  function initScrollCompass() {
    const dial = document.getElementById('compass-dial');
    if (!dial) return;

    let isScrolling = false;
    let scrollTimeout: any = null;

    dial.classList.add('is-idle');

    function onScroll() {
      if (!isScrolling) {
        isScrolling = true;
        dial!.classList.remove('is-idle');
        dial!.classList.add('is-active');
      }

      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      
      if (scrollHeight > 0) {
        const percent = scrollTop / scrollHeight;
        const deg = percent * 180; // 0deg at top to 180deg at bottom
        dial!.style.setProperty('--needle-deg', `${deg}deg`);
      }

      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        isScrolling = false;
        dial!.classList.remove('is-active');
        dial!.classList.add('is-idle');
        dial!.style.removeProperty('--needle-deg');
      }, 200);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
      clearTimeout(scrollTimeout);
    }, { once: true });
  }

  // Driver biography route canvas visualizer
  function initStoryRouteCanvas() {
    const canvas = document.getElementById('story-route-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = 1;
    let animationId = 0;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx!.scale(dpr, dpr);
    }

    window.addEventListener('resize', resize);
    resize();

    // Checkpoints representing C M Nafi's journey
    const checkpoints = [
      { name: 'DINAJPUR', year: '2000', label: 'Dinajpur, BD', x: 0.15, y: 0.70, coord: '25.62° N' },
      { name: 'CHANGSHU', year: '2016', label: 'Changshu, CN', x: 0.40, y: 0.45, coord: '31.65° N' },
      { name: 'DECORAH', year: '2018', label: 'Decorah, IA', x: 0.65, y: 0.65, coord: '43.30° N' },
      { name: 'TAMPA', year: '2022', label: 'Tampa, FL', x: 0.88, y: 0.30, coord: '27.95° N' }
    ];

    let t = 0;

    function draw() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, width, height);
      t += 0.004; // slow elegant speed

      const paddingLeft = 25;
      const paddingBottom = 20;
      const paddingTop = 15;
      const paddingRight = 20;

      const graphWidth = width - paddingLeft - paddingRight;
      const graphHeight = height - paddingTop - paddingBottom;

      // Draw Grid Lines (Dashed, low contrast telemetry grid)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.03)';
      ctx.lineWidth = 1;
      ctx.setLineDash([2, 2]);

      // Vertical lines
      for (let i = 1; i <= 5; i++) {
        const x = paddingLeft + (graphWidth * i) / 6;
        ctx.beginPath();
        ctx.moveTo(x, paddingTop);
        ctx.lineTo(x, height - paddingBottom);
        ctx.stroke();
      }

      // Horizontal lines
      for (let i = 1; i <= 3; i++) {
        const y = paddingTop + (graphHeight * i) / 4;
        ctx.beginPath();
        ctx.moveTo(paddingLeft, y);
        ctx.lineTo(width - paddingRight, y);
        ctx.stroke();
      }

      // Trajectory curve (Sleek dashed line connecting nodes)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.15)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      
      checkpoints.forEach((pt, idx) => {
        const px = paddingLeft + graphWidth * pt.x;
        const py = paddingTop + graphHeight * pt.y;
        if (idx === 0) {
          ctx.moveTo(px, py);
        } else {
          // Draw elegant curved arcs instead of harsh lines
          const prevPt = checkpoints[idx - 1];
          const ppx = paddingLeft + graphWidth * prevPt.x;
          const ppy = paddingTop + graphHeight * prevPt.y;
          ctx.bezierCurveTo(ppx + graphWidth * 0.08, ppy - graphHeight * 0.1, px - graphWidth * 0.08, py + graphHeight * 0.1, px, py);
        }
      });
      ctx.stroke();
      ctx.setLineDash([]);

      // Draw checkpoints
      checkpoints.forEach((pt, idx) => {
        const px = paddingLeft + graphWidth * pt.x;
        const py = paddingTop + graphHeight * pt.y;

        // Pulse scale based on time
        const pulse = 1 + Math.sin(t * 10 + idx * 2) * 0.15;

        // Outer telemetry box / reticle
        ctx.strokeStyle = idx === 3 ? 'var(--accent)' : 'rgba(255, 255, 255, 0.2)';
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        ctx.arc(px, py, 6 * pulse, 0, Math.PI * 2);
        ctx.stroke();

        // Inner solid core
        ctx.fillStyle = idx === 3 ? 'var(--accent)' : 'rgba(255, 255, 255, 0.8)';
        ctx.beginPath();
        ctx.arc(px, py, 1.8, 0, Math.PI * 2);
        ctx.fill();

        // Checkpoint Label text
        ctx.fillStyle = idx === 3 ? 'var(--text-warm-white)' : 'rgba(255, 255, 255, 0.5)';
        ctx.font = '7.5px var(--font-mono), monospace';
        ctx.fillText(pt.name, px - 20, py - 10);
        
        ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
        ctx.font = '6px var(--font-mono), monospace';
        ctx.fillText(`${pt.year} // ${pt.coord}`, px - 20, py + 12);
      });

      // Calculate particle tracking position along spline trajectory
      // Since it's a smooth loop, let's cycle time parameter
      const cycle = (t * 0.8) % 3; // 3 segments total
      const segmentIndex = Math.floor(cycle);
      const segmentFactor = cycle - segmentIndex;

      const pStart = checkpoints[segmentIndex];
      const pEnd = checkpoints[segmentIndex + 1];

      // Dynamic calculation along bezier curve segment
      const px1 = paddingLeft + graphWidth * pStart.x;
      const py1 = paddingTop + graphHeight * pStart.y;
      const px2 = paddingLeft + graphWidth * pEnd.x;
      const py2 = paddingTop + graphHeight * pEnd.y;

      // Approximate bezier interpolation for sleek movement
      const c1x = px1 + graphWidth * 0.08;
      const c1y = py1 - graphHeight * 0.1;
      const c2x = px2 - graphWidth * 0.08;
      const c2y = py2 + graphHeight * 0.1;

      // De Casteljau's algorithm for cubic Bezier
      const mt = 1 - segmentFactor;
      const x = mt * mt * mt * px1 + 3 * mt * mt * segmentFactor * c1x + 3 * mt * segmentFactor * segmentFactor * c2x + segmentFactor * segmentFactor * segmentFactor * px2;
      const y = mt * mt * mt * py1 + 3 * mt * mt * segmentFactor * c1y + 3 * mt * segmentFactor * segmentFactor * c2y + segmentFactor * segmentFactor * segmentFactor * py2;

      // Particle shadow dot
      ctx.fillStyle = 'rgba(125, 211, 160, 0.2)'; // matching --accent
      ctx.beginPath();
      ctx.arc(x, y, 6, 0, Math.PI * 2);
      ctx.fill();

      // Core particle dot
      ctx.fillStyle = 'var(--accent)';
      ctx.beginPath();
      ctx.arc(x, y, 2.5, 0, Math.PI * 2);
      ctx.fill();

      // Update Telemetry panel labels
      const sectorEl = document.getElementById('story-telemetry-sector');
      const speedEl = document.getElementById('story-telemetry-speed');
      
      if (sectorEl) {
        sectorEl.textContent = `${pStart.name} → ${pEnd.name}`;
      }

      if (speedEl && Math.random() < 0.02) {
        const speedVal = (0.78 + Math.random() * 0.06).toFixed(2);
        speedEl.textContent = `MACH ${speedVal}`;
      }

      animationId = requestAnimationFrame(draw);
    }

    animationId = requestAnimationFrame(draw);

    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    };
  }

  // Scroll parallax and scroll telemetry display
  function initScrollBehavior() {
    const scrollDisplay = document.getElementById('scroll-percentage-display');
    const progressBar = document.getElementById('scroll-progress-indicator');
    const introContent = document.querySelector('.intro-content') as HTMLElement;
    const coordsEl = document.getElementById('header-telemetry-coords');
    
    let currentCoord = '25.6279° N';
    let flashTimeout: any = null;

    const sections = [
      { selector: '.intro-section', coord: '25.6279° N' },
      { selector: '.story-glimpse-section', coord: '31.6536° N' },
      { selector: '.caia-corner-section', coord: '38.9072° N' },
      { selector: '.world-cup-section', coord: '40.7128° N' },
      { selector: '.showroom-grid-section', coord: '43.3036° N' },
      { selector: '.latest-log-section', coord: '27.9506° N' },
      { selector: '.showroom-footer', coord: '00.0000° N' }
    ];

    function checkActiveSection() {
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      
      let activeCoord = '25.6279° N';
      
      if (scrollHeight > 0 && scrollTop >= scrollHeight - 30) {
        activeCoord = '00.0000° N';
      } else {
        let minDistance = Infinity;
        sections.forEach(sec => {
          const el = document.querySelector(sec.selector);
          if (el) {
            const rect = el.getBoundingClientRect();
            const dist = Math.abs(rect.top + rect.height / 2 - window.innerHeight / 2);
            if (dist < minDistance) {
              minDistance = dist;
              activeCoord = sec.coord;
            }
          }
        });
      }

      if (coordsEl && activeCoord !== currentCoord) {
        currentCoord = activeCoord;
        scrambleTo(coordsEl, activeCoord, 400);
      }
    }

    function updateScroll() {
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      
      if (scrollHeight > 0) {
        const progress = (scrollTop / scrollHeight) * 100;
        if (progressBar) progressBar.style.width = `${progress}%`;
        if (scrollDisplay) {
          const formatted = String(Math.round(progress)).padStart(2, '0');
          scrollDisplay.textContent = `[ ${formatted}% SCROLL ]`;
          
          scrollDisplay.classList.add('is-active');
          clearTimeout(flashTimeout);
          flashTimeout = setTimeout(() => {
            scrollDisplay.classList.remove('is-active');
          }, 200);
        }
      }
      
      if (introContent) {
        introContent.style.transform = `translate3d(0, ${scrollTop * 0.08}px, 0)`;
      }

      checkActiveSection();
    }
    
    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();
    
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', updateScroll);
      clearTimeout(flashTimeout);
    }, { once: true });
  }

  // CAIA Portfolio Frontier canvas visualization (finance & elegance)
  function initCaiaFrontierCanvas() {
    const canvas = document.getElementById('frontier-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = 1;
    let animationId = 0;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx!.scale(dpr, dpr);
    }

    window.addEventListener('resize', resize);
    resize();

    // Alternate asset classes
    const assets = [
      { name: 'PD', x: 0.15, y: 0.70, label: 'Private Debt', color: '#D4A857' },
      { name: 'HF', x: 0.35, y: 0.52, label: 'Hedge Funds', color: '#7AAE99' },
      { name: 'RA', x: 0.50, y: 0.60, label: 'Real Assets', color: '#7AAE99' },
      { name: 'PE', x: 0.75, y: 0.28, label: 'Private Equity', color: '#D4A857' }
    ];

    let t = 0;

    function draw() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, width, height);
      t += 0.008;

      const paddingLeft = 35;
      const paddingBottom = 25;
      const paddingTop = 15;
      const paddingRight = 15;

      const graphWidth = width - paddingLeft - paddingRight;
      const graphHeight = height - paddingTop - paddingBottom;

      // Draw Grid Lines (Dashed, low contrast)
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.03)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 3]);

      // Vertical lines
      for (let i = 1; i <= 4; i++) {
        const x = paddingLeft + (graphWidth * i) / 5;
        ctx.beginPath();
        ctx.moveTo(x, paddingTop);
        ctx.lineTo(x, height - paddingBottom);
        ctx.stroke();
      }

      // Horizontal lines
      for (let i = 1; i <= 3; i++) {
        const y = paddingTop + (graphHeight * i) / 4;
        ctx.beginPath();
        ctx.moveTo(paddingLeft, y);
        ctx.lineTo(width - paddingRight, y);
        ctx.stroke();
      }

      // Solid Axes
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.moveTo(paddingLeft, paddingTop - 5);
      ctx.lineTo(paddingLeft, height - paddingBottom);
      ctx.lineTo(width - paddingRight + 5, height - paddingBottom);
      ctx.stroke();

      // Axis Labels
      ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
      ctx.font = '7px var(--font-mono), monospace';
      ctx.textAlign = 'right';
      ctx.fillText('RISK (σ)', width - paddingRight, height - paddingBottom + 12);
      ctx.textAlign = 'left';
      ctx.fillText('RETURN (E[r])', paddingLeft + 4, paddingTop - 4);

      // 1. Efficient Frontier curve (glowing gold)
      const startX = paddingLeft + graphWidth * 0.10;
      const startY = paddingTop + graphHeight * 0.88;
      
      const cp1x = paddingLeft + graphWidth * 0.22;
      const cp1y = paddingTop + graphHeight * 0.26;
      
      const cp2x = paddingLeft + graphWidth * 0.58;
      const cp2y = paddingTop + graphHeight * 0.14;
      
      const endX = width - paddingRight - graphWidth * 0.05;
      const endY = paddingTop + graphHeight * 0.08;

      ctx.strokeStyle = 'rgba(212, 168, 87, 0.35)'; // caia-highlight-main
      ctx.lineWidth = 1.2;
      ctx.beginPath();
      ctx.moveTo(startX, startY);
      ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, endX, endY);
      ctx.stroke();

      // 2. Capital Market Line (CML) - Tangency to Frontier (elegant green)
      const rfY = paddingTop + graphHeight * 0.85; // risk free rate
      const tangentX = paddingLeft + graphWidth * 0.40;
      const tangentY = paddingTop + graphHeight * 0.28;
      
      ctx.strokeStyle = 'rgba(122, 174, 153, 0.2)'; // caia-accent-main
      ctx.lineWidth = 0.85;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      ctx.moveTo(paddingLeft, rfY);
      
      // Calculate tangency extension
      const slope = (tangentY - rfY) / (tangentX - paddingLeft);
      const endCmlX = paddingLeft + graphWidth * 0.85;
      const endCmlY = rfY + slope * (graphWidth * 0.85);
      ctx.lineTo(endCmlX, endCmlY);
      ctx.stroke();
      ctx.setLineDash([]);

      // risk free rate text
      ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
      ctx.font = '6px var(--font-mono), monospace';
      ctx.fillText('Rf (5%)', paddingLeft - 30, rfY + 2);

      // 3. Asset Dots
      assets.forEach((asset, idx) => {
        // slow orbital wobble for alternative assets simulation
        const angle = t * 1.2 + idx * (Math.PI / 2);
        const offsetX = Math.cos(angle) * 2;
        const offsetY = Math.sin(angle) * 2;

        const px = paddingLeft + graphWidth * asset.x + offsetX;
        const py = paddingTop + graphHeight * asset.y + offsetY;

        // dot border glow
        ctx.fillStyle = `${asset.color}18`;
        ctx.beginPath();
        ctx.arc(px, py, 5, 0, Math.PI * 2);
        ctx.fill();

        // solid dot
        ctx.fillStyle = asset.color;
        ctx.beginPath();
        ctx.arc(px, py, 2, 0, Math.PI * 2);
        ctx.fill();

        // Label text
        ctx.fillStyle = 'rgba(255, 255, 255, 0.45)';
        ctx.font = '7px var(--font-mono), monospace';
        ctx.fillText(asset.name, px + 5, py + 2.5);
      });

      // 4. Tangency Optimal Portfolio Dot M*
      const pulseRadius = 3.5 + Math.sin(t * 4) * 0.8;
      ctx.strokeStyle = '#7AAE99';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(tangentX, tangentY, pulseRadius, 0, Math.PI * 2);
      ctx.stroke();

      ctx.fillStyle = '#7AAE99';
      ctx.beginPath();
      ctx.arc(tangentX, tangentY, 1.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
      ctx.font = '6.5px var(--font-mono), monospace';
      ctx.fillText('PORTFOLIO M*', tangentX + 7, tangentY - 3);

      // Fluctuate display values slightly
      const coefEl = document.getElementById('caia-telemetry-coef');
      const sharpeEl = document.getElementById('caia-telemetry-sharpe');
      if (coefEl && sharpeEl && Math.random() < 0.03) {
        const coefVal = (0.28 + Math.sin(t) * 0.008).toFixed(2);
        const sharpeVal = (1.42 + Math.cos(t) * 0.009).toFixed(2);
        coefEl.textContent = `ρ = ${coefVal}`;
        sharpeEl.textContent = `SR = ${sharpeVal}`;
      }

      animationId = requestAnimationFrame(draw);
    }

    animationId = requestAnimationFrame(draw);

    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    };
  }

  // World Cup Live Kickoff Countdown
  function initWorldCupCountdown() {
    const target = new Date('2026-06-11T17:00:00Z').getTime();
    
    const dEl = document.getElementById('wc-days');
    const hEl = document.getElementById('wc-hours');
    const mEl = document.getElementById('wc-mins');
    const sEl = document.getElementById('wc-secs');

    if (!dEl || !hEl || !mEl || !sEl) return () => {};

    const d = dEl;
    const h = hEl;
    const m = mEl;
    const s = sEl;

    function update() {
      const now = new Date().getTime();
      const diff = target - now;

      if (diff <= 0) {
        d.textContent = '00';
        h.textContent = '00';
        m.textContent = '00';
        s.textContent = '00';
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const secs = Math.floor((diff % (1000 * 60)) / 1000);

      d.textContent = String(days).padStart(2, '0');
      h.textContent = String(hours).padStart(2, '0');
      m.textContent = String(mins).padStart(2, '0');
      s.textContent = String(secs).padStart(2, '0');
    }

    update();
    const interval = setInterval(update, 1000);

    return () => {
      clearInterval(interval);
    };
  }

  // Subliminal ambient flow canvas
  function initTelemetryFlowCanvas() {
    const canvas = document.getElementById('telemetry-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = 0;
    let height = 0;
    let dpr = 1;
    let animationId = 0;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx!.scale(dpr, dpr);
    }

    window.addEventListener('resize', resize);
    resize();

    const baseGlyphs = ["0", "1", "+", "-", "•", ".", "x", "y", "_", "$", "€", "¥", "₿", "%", "&", "{", "}", "[", "]"];
    const cells: string[] = [];
    
    for (let col = 0; col < 100; col++) {
      for (let row = 0; row < 50; row++) {
        cells.push(baseGlyphs[(col * 7 + row * 13) % baseGlyphs.length]);
      }
    }

    const cycleDuration = 9000;

    function draw(time: number) {
      ctx!.clearRect(0, 0, width, height);

      const spacingX = 22;
      const spacingY = 22;

      ctx!.font = '9px ui-monospace, SFMono-Regular, SF Mono, Menlo, Monaco, Consolas, monospace';
      ctx!.textAlign = 'center';
      ctx!.textBaseline = 'middle';

      const phase = (time / cycleDuration) * Math.PI * 2;

      let cellIdx = 0;
      for (let gridX = spacingX / 2; gridX < width; gridX += spacingX) {
        for (let gridY = spacingY / 2; gridY < height; gridY += spacingY) {
          const char = cells[cellIdx % cells.length];
          cellIdx++;

          const wave = Math.sin(phase + (gridX * 0.003) + (gridY * 0.005));
          const opacity = 0.02 + (wave * 0.5 + 0.5) * 0.12;

          ctx!.fillStyle = `rgba(245, 245, 247, ${opacity})`;
          ctx!.fillText(char, gridX, gridY);
        }
      }

      animationId = requestAnimationFrame(draw);
    }

    animationId = requestAnimationFrame(draw);

    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', resize);
    };
  }

  // Card mouseover radial gradient tracking
  function initCardShine() {
    const cards = document.querySelectorAll('.material-card');
    cards.forEach(c => {
      const card = c as HTMLElement;
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
      });
    });
  }

  // Page load initializer
  function initAllWorldClassInteractions() {
    initScrambleHeaders();

    initScrollBehavior();
    initScrollCompass();
    initCardShine();
    initStatsRollup();
    const cleanupWorldCup = initWorldCupCountdown();
    const cleanupStory = initStoryRouteCanvas();
    const cleanupCanvas = initTelemetryFlowCanvas();
    const cleanupCaia = initCaiaFrontierCanvas();
    
    const container = document.querySelector('.showroom-container');
    if (container) container.classList.add('loaded');
    
    document.addEventListener('astro:before-swap', () => {
      if (cleanupWorldCup) cleanupWorldCup();
      if (cleanupStory) cleanupStory();
      if (cleanupCanvas) cleanupCanvas();
      if (cleanupCaia) cleanupCaia();
    }, { once: true });
  }

  // Make sure it runs safely on View Transitions
  document.addEventListener('astro:page-load', initAllWorldClassInteractions);
</script>
