---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import StrategyMapChapter from '@/components/StrategyMapChapter.astro';
import {
  strategyMapChapters,
  strategyMapDestinations,
  strategyMapSignals
} from '@/data/strategy-map';

const firstChapter = strategyMapChapters[0];
const routeSegments = [
  'M153 367 C165 355 182 340 198 335',
  'M198 335 C280 300 390 215 504 184',
  'M504 184 C564 176 632 160 693 146',
  'M693 146 C720 165 748 218 756 302'
];
const ghostRoute = 'M120 390 C180 320 260 286 330 250 C420 202 496 168 566 166 C654 162 718 166 790 312';
const contourPaths = [
  'M102 258 C132 222 182 198 232 208 C274 216 304 246 338 236 C392 218 416 176 470 178 C512 180 540 198 558 222',
  'M480 232 C534 210 604 212 654 232 C690 248 730 240 764 220 C792 204 826 206 848 228',
  'M702 272 C728 282 748 302 756 330 C744 348 714 354 690 342 C678 316 684 286 702 272'
];
---

<BaseLayout description="From global foundations to financial intelligence — the personal site of C M Nafi.">
  <div
    class="strategy-map-page"
    data-strategy-map
    data-active-chapter={firstChapter.id}
    style={`--portrait-scale:${firstChapter.portraitScale}; --deployment-progress:0;`}
  >
    <section class="page-section page-section-hero strategy-hero">
      <div class="strategy-hero__copy">
        <p class="eyebrow">C M Nafi</p>
        <p class="strategy-hero__identity">Global foundations. Financial intelligence. Work in motion.</p>
        <h1>From Global Foundations to Financial Intelligence</h1>
        <p class="strategy-hero__body">
          A story defined by bold, independent transitions — across continents, disciplines, and institutions.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href="#deployment-map">Follow the route</a>
          <a class="button button-secondary" href="/brewing">Open Brewing</a>
        </div>

        <div class="strategy-hero__cue" aria-hidden="true">
          <span class="strategy-hero__cue-line"></span>
          <span>Scroll to explore</span>
        </div>
      </div>

      <div class="strategy-hero__visual panel" aria-hidden="true">
        <div class="strategy-hero__visual-glow strategy-hero__visual-glow--warm"></div>
        <div class="strategy-hero__visual-glow strategy-hero__visual-glow--cool"></div>
        <div class="strategy-hero__grid"></div>

        <svg class="strategy-hero__map" viewBox="0 0 900 540" preserveAspectRatio="xMidYMid meet">
          <g class="strategy-hero__continents">
            {contourPaths.map((path) => (
              <path d={path}></path>
            ))}
          </g>
          <path class="strategy-hero__ghost-route" d={ghostRoute}></path>
          {routeSegments.map((path, index) => (
            <path class={`strategy-hero__route strategy-hero__route--${index + 1}`} d={path}></path>
          ))}
        </svg>

        {strategyMapChapters.map((chapter) => (
          <span class={`strategy-hero__node strategy-hero__node--${chapter.id}`} style={`left:${chapter.mapX}; top:${chapter.mapY};`}>
            <span></span>
          </span>
        ))}

        <div class="strategy-hero__label strategy-hero__label--coverage">Coverage</div>
        <div class="strategy-hero__label strategy-hero__label--signal">Signal strengthening</div>
        <div class="strategy-hero__label strategy-hero__label--deployment">Current deployment</div>

        <div class="strategy-hero__signal-card">
          <span>The journey</span>
          <strong>From global foundations to financial intelligence.</strong>
        </div>
      </div>
    </section>

    <section id="deployment-map" class="page-section strategy-journey">
      <SectionHeading
        eyebrow="Deployment Map"
        title="A story shaped by bold, independent transitions."
        description="The route now moves through the places, institutions, and disciplines that shaped the work: one active waypoint at a time, with the present becoming clearer as the story progresses."
      />

      <div class="strategy-journey__grid">
        <aside class="strategy-control panel">
          <div class="strategy-control__header">
            <div>
              <p class="eyebrow">Current waypoint</p>
              <h2 data-active-place>{firstChapter.place}</h2>
              <p class="strategy-control__signal" data-active-signal>{firstChapter.signal}</p>
            </div>
            <span class="strategy-control__step" data-active-step>{firstChapter.step}</span>
          </div>

          <div class="strategy-control__surface">
            <div class="strategy-control__surface-grid"></div>

            <svg class="strategy-control__map" viewBox="0 0 900 540" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
              <g class="strategy-control__continents">
                {contourPaths.map((path) => (
                  <path d={path}></path>
                ))}
              </g>
              <path class="strategy-control__ghost-route" d={ghostRoute}></path>
              {routeSegments.map((path) => (
                <path class="strategy-control__route-segment" data-route-segment d={path}></path>
              ))}
            </svg>

            {strategyMapChapters.map((chapter) => (
              <button
                type="button"
                class="strategy-control__node"
                data-map-node
                data-map-target={chapter.id}
                style={`left:${chapter.mapX}; top:${chapter.mapY};`}
                aria-label={`Jump to ${chapter.place}`}
              >
                <span class="strategy-control__node-dot"></span>
                <span class="strategy-control__node-label">{chapter.place.split(',')[0]}</span>
              </button>
            ))}

            <div class="strategy-control__micro strategy-control__micro--a">Coverage</div>
            <div class="strategy-control__micro strategy-control__micro--b">Signal strengthening</div>
            <div class="strategy-control__micro strategy-control__micro--c">Current base</div>

            <div class="strategy-control__portrait-shell">
              <div class="strategy-control__portrait-glow"></div>
              <div class="strategy-control__portrait-ring strategy-control__portrait-ring--outer"></div>
              <div class="strategy-control__portrait-ring strategy-control__portrait-ring--inner"></div>
              <img src="/profile.jpg" alt="Portrait of C M Nafi" />
              <div class="strategy-control__portrait-meta">
                <span data-active-label>{firstChapter.label}</span>
                <strong data-active-theme>{firstChapter.theme}</strong>
                <small data-active-capability>{firstChapter.capability}</small>
                <small class="strategy-control__atlas" data-active-atlas>{firstChapter.atlasLabel}</small>
              </div>
            </div>
          </div>

          <div class="strategy-control__footer" aria-hidden="true">
            <span>Origin</span>
            <span>Discipline layer</span>
            <span>Expansion node</span>
            <span>Compounding stage</span>
            <span>Active deployment</span>
          </div>
        </aside>

        <div class="strategy-journey__chapters">
          {strategyMapChapters.map((chapter) => (
            <StrategyMapChapter chapter={chapter} />
          ))}
        </div>
      </div>
    </section>

    <section class="page-section strategy-now">
      <SectionHeading
        eyebrow="Current Deployment"
        title="From Research to Financial Intelligence."
        description="I believe that data is only as valuable as the narrative it helps uncover. The present chapter brings together research, product thinking, writing, and public work into one clearer direction."
      />

      <div class="two-up strategy-now__grid">
        <article class="panel strategy-now__card">
          <p class="eyebrow">Current</p>
          <h2>Bridging the gap between complex regulatory data and actionable intelligence.</h2>
          <p>
            The current work is focused on building due diligence and RFP automation platforms that make complex financial information more usable for real operators, while continuing to write, reflect, and build in public.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/brewing">See what's brewing</a>
            <a class="button button-secondary" href="/connect">Let's connect</a>
          </div>
        </article>

        <article class="panel strategy-now__card strategy-now__card--signals">
          <p class="eyebrow">Beyond the Data</p>
          <div class="strategy-signal-list">
            {strategyMapSignals.map((signal) => (
              <article class="strategy-signal-item">
                <h3>{signal.title}</h3>
                <p>{signal.description}</p>
              </article>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="page-section strategy-destinations">
      <SectionHeading
        eyebrow="Operating Areas"
        title="The rest of the site carries the same story into different forms."
        description="Writing, projects, adventures, work in progress, and outward connection all extend the same path in different directions."
      />

      <div class="strategy-destination-grid">
        {strategyMapDestinations.map((destination) => (
          <a class="panel strategy-destination-card" href={destination.href}>
            <span class="strategy-destination-card__mode">{destination.mode}</span>
            <h3>{destination.title}</h3>
            <p>{destination.description}</p>
            <span class="strategy-destination-card__arrow">Go deeper -></span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script>
    const root = document.querySelector('[data-strategy-map]');

    if (root) {
      const chapters = Array.from(root.querySelectorAll('[data-strategy-chapter]'));
      const mapNodes = Array.from(root.querySelectorAll('[data-map-node]'));
      const routeSegments = Array.from(root.querySelectorAll('[data-route-segment]'));
      const activePlace = root.querySelector('[data-active-place]');
      const activeSignal = root.querySelector('[data-active-signal]');
      const activeStep = root.querySelector('[data-active-step]');
      const activeLabel = root.querySelector('[data-active-label]');
      const activeTheme = root.querySelector('[data-active-theme]');
      const activeCapability = root.querySelector('[data-active-capability]');
      const activeAtlas = root.querySelector('[data-active-atlas]');

      const setActive = (index) => {
        const chapter = chapters[index];
        if (!chapter) return;

        root.dataset.activeChapter = chapter.dataset.chapterId ?? '';
        root.style.setProperty('--portrait-scale', chapter.dataset.scale ?? '1');
        root.style.setProperty('--deployment-progress', String(index / Math.max(chapters.length - 1, 1)));

        if (activePlace) activePlace.textContent = chapter.dataset.place ?? '';
        if (activeSignal) activeSignal.textContent = chapter.dataset.signal ?? '';
        if (activeStep) activeStep.textContent = chapter.dataset.step ?? '';
        if (activeLabel) activeLabel.textContent = chapter.dataset.label ?? '';
        if (activeTheme) activeTheme.textContent = chapter.dataset.theme ?? '';
        if (activeCapability) activeCapability.textContent = chapter.dataset.capability ?? '';
        if (activeAtlas) activeAtlas.textContent = chapter.dataset.atlas ?? '';

        chapters.forEach((item, itemIndex) => {
          item.classList.toggle('is-active', itemIndex === index);
          item.classList.toggle('is-complete', itemIndex < index);
        });

        mapNodes.forEach((node, nodeIndex) => {
          node.classList.toggle('is-active', nodeIndex === index);
          node.classList.toggle('is-complete', nodeIndex < index);
        });

        routeSegments.forEach((segment, segmentIndex) => {
          segment.classList.toggle('is-active', segmentIndex < index);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio || a.boundingClientRect.top - b.boundingClientRect.top)[0];

          if (!visible) return;
          setActive(chapters.indexOf(visible.target));
        },
        {
          threshold: [0.25, 0.45, 0.7],
          rootMargin: '-12% 0px -28% 0px'
        }
      );

      chapters.forEach((chapter) => observer.observe(chapter));
      setActive(0);

      mapNodes.forEach((node) => {
        node.addEventListener('click', () => {
          const target = node.getAttribute('data-map-target');
          const chapter = root.querySelector(`[data-chapter-id="${target}"]`);
          chapter?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });
    }
  </script>
</BaseLayout>

<style>
  .strategy-map-page {
    --strategy-accent: #d39a59;
    --strategy-cool: #7e869d;
    position: relative;
    padding-bottom: 4rem;
  }

  .strategy-map-page::before,
  .strategy-map-page::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .strategy-map-page::before {
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--strategy-accent) 18%, transparent), transparent 28%),
      radial-gradient(circle at 82% 16%, color-mix(in srgb, var(--strategy-cool) 18%, transparent), transparent 24%),
      radial-gradient(circle at 52% 82%, color-mix(in srgb, var(--strategy-accent) 12%, transparent), transparent 30%);
  }

  .strategy-map-page::after {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 100% 7rem, 7rem 100%;
    opacity: 0.22;
    mask-image: linear-gradient(180deg, transparent, black 12%, black 88%, transparent);
  }

  .strategy-map-page > * {
    position: relative;
    z-index: 1;
  }

  .strategy-map-page[data-active-chapter='dinajpur'] {
    --strategy-accent: #ca9258;
    --strategy-cool: #86796e;
  }

  .strategy-map-page[data-active-chapter='rangpur'] {
    --strategy-accent: #ce9b63;
    --strategy-cool: #888599;
  }

  .strategy-map-page[data-active-chapter='changshu'] {
    --strategy-accent: #d9aa72;
    --strategy-cool: #7e97aa;
  }

  .strategy-map-page[data-active-chapter='decorah'] {
    --strategy-accent: #dfb584;
    --strategy-cool: #90a7bb;
  }

  .strategy-map-page[data-active-chapter='tampa'] {
    --strategy-accent: #e6be8f;
    --strategy-cool: #9cb3c7;
  }

  .strategy-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
    gap: clamp(1.4rem, 4vw, 3rem);
    min-height: calc(100vh - 7.5rem);
    align-items: center;
  }

  .strategy-hero__copy {
    display: grid;
    gap: 1.35rem;
  }

  .strategy-hero__identity {
    margin: -0.65rem 0 0;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.5;
    color: rgba(243, 237, 225, 0.82);
  }

  .strategy-hero h1 {
    margin: 0;
    max-width: 10ch;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(3.7rem, 7.1vw, 6.9rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
  }

  .strategy-hero__body {
    max-width: 43rem;
    margin: 0;
    color: rgba(243, 237, 225, 0.74);
    font-size: 1.05rem;
    line-height: 1.84;
  }

  .strategy-hero__cue {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    color: rgba(243, 237, 225, 0.62);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .strategy-hero__cue-line {
    width: 4.2rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.16), var(--strategy-accent));
  }

  .strategy-hero__visual {
    position: relative;
    min-height: 34rem;
    padding: 1.4rem;
    overflow: hidden;
    isolation: isolate;
  }

  .strategy-hero__visual::after {
    content: "";
    position: absolute;
    top: 18%;
    left: -18%;
    width: 36%;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0));
    transform: rotate(9deg);
    opacity: 0.55;
    animation: strategySweep 9s linear infinite;
  }

  .strategy-hero__visual-glow,
  .strategy-hero__grid,
  .strategy-hero__map,
  .strategy-hero__signal-card,
  .strategy-hero__label,
  .strategy-hero__node {
    position: absolute;
  }

  .strategy-hero__visual-glow {
    inset: auto;
    border-radius: 999px;
    filter: blur(40px);
    opacity: 0.55;
    animation: strategyFloat 15s ease-in-out infinite alternate;
  }

  .strategy-hero__visual-glow--warm {
    top: 10%;
    left: 10%;
    width: 18rem;
    height: 18rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--strategy-accent) 24%, transparent), transparent 70%);
  }

  .strategy-hero__visual-glow--cool {
    right: 6%;
    top: 18%;
    width: 16rem;
    height: 16rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--strategy-cool) 24%, transparent), transparent 70%);
    animation-duration: 18s;
  }

  .strategy-hero__grid {
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 100% 4.5rem, 5rem 100%;
    opacity: 0.24;
    mask-image: radial-gradient(circle at 54% 42%, black 30%, transparent 88%);
  }

  .strategy-hero__map {
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .strategy-hero__continents path,
  .strategy-control__continents path {
    fill: none;
    stroke: rgba(255, 255, 255, 0.1);
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .strategy-hero__ghost-route,
  .strategy-control__ghost-route {
    fill: none;
    stroke: rgba(255, 255, 255, 0.12);
    stroke-width: 1.1;
    stroke-dasharray: 5 7;
    stroke-linecap: round;
  }

  .strategy-hero__route {
    fill: none;
    stroke: var(--strategy-accent);
    stroke-width: 1.75;
    stroke-linecap: round;
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--strategy-accent) 28%, transparent));
    opacity: 0.92;
  }

  .strategy-hero__node {
    transform: translate(-50%, -50%);
  }

  .strategy-hero__node span {
    display: block;
    width: 0.82rem;
    height: 0.82rem;
    border-radius: 999px;
    background: rgba(243, 237, 225, 0.26);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--strategy-accent) 18%, transparent);
    animation: strategyNodePulse 5.5s ease-in-out infinite;
  }

  .strategy-hero__node--rangpur span { animation-delay: -0.8s; }
  .strategy-hero__node--changshu span { animation-delay: -1.6s; }
  .strategy-hero__node--decorah span { animation-delay: -2.4s; }
  .strategy-hero__node--tampa span { animation-delay: -3.2s; }

  .strategy-hero__label {
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(9, 10, 14, 0.52);
    color: rgba(243, 237, 225, 0.68);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    backdrop-filter: blur(16px);
  }

  .strategy-hero__label--coverage { left: 8%; top: 12%; }
  .strategy-hero__label--signal { right: 12%; top: 14%; }
  .strategy-hero__label--deployment { right: 10%; bottom: 18%; }

  .strategy-hero__signal-card {
    left: 8%;
    right: 8%;
    bottom: 8%;
    display: grid;
    gap: 0.55rem;
    padding: 1rem 1.1rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(8, 10, 15, 0.74), rgba(8, 10, 15, 0.38));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .strategy-hero__signal-card span,
  .strategy-control__portrait-meta span,
  .strategy-destination-card__mode {
    color: rgba(243, 237, 225, 0.56);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .strategy-hero__signal-card strong {
    font-size: 0.98rem;
    line-height: 1.7;
    color: rgba(243, 237, 225, 0.88);
  }

  .strategy-journey {
    display: grid;
    gap: 1.4rem;
    margin-top: 2.2rem;
  }

  .strategy-journey__grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.94fr) minmax(0, 1.06fr);
    gap: 1.2rem;
    align-items: start;
  }

  .strategy-control {
    position: sticky;
    top: 6rem;
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    overflow: hidden;
  }

  .strategy-control__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
  }

  .strategy-control__header h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
  }

  .strategy-control__signal {
    margin: 0.45rem 0 0;
    color: rgba(243, 237, 225, 0.66);
    line-height: 1.7;
  }

  .strategy-control__step {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--strategy-accent);
    letter-spacing: -0.04em;
  }

  .strategy-control__surface {
    position: relative;
    min-height: 36rem;
    border-radius: 28px;
    overflow: hidden;
    background:
      radial-gradient(circle at 20% 24%, color-mix(in srgb, var(--strategy-accent) 12%, transparent), transparent 26%),
      radial-gradient(circle at 76% 22%, color-mix(in srgb, var(--strategy-cool) 14%, transparent), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(11, 10, 14, 0.2) 32%, rgba(11, 10, 14, 0.54));
  }

  .strategy-control__surface-grid,
  .strategy-control__map,
  .strategy-control__portrait-shell,
  .strategy-control__micro,
  .strategy-control__node {
    position: absolute;
  }

  .strategy-control__surface-grid {
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 100% 4rem, 4rem 100%;
    opacity: 0.4;
    mask-image: radial-gradient(circle at 50% 46%, black 36%, transparent 92%);
  }

  .strategy-control__map { inset: 0; width: 100%; height: 100%; }

  .strategy-control__route-segment {
    fill: none;
    stroke: var(--strategy-accent);
    stroke-width: 2.1;
    stroke-linecap: round;
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    transition: stroke-dashoffset 420ms cubic-bezier(0.22, 1, 0.36, 1), stroke 260ms ease;
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--strategy-accent) 28%, transparent));
  }

  .strategy-control__route-segment.is-active { stroke-dashoffset: 0; }

  .strategy-control__node {
    transform: translate(-50%, -50%);
    display: grid;
    gap: 0.38rem;
    justify-items: center;
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--text);
    cursor: pointer;
    transition: transform 180ms ease;
  }

  .strategy-control__node-dot {
    width: 0.92rem;
    height: 0.92rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.16);
    transition: transform 220ms ease, background 220ms ease, box-shadow 220ms ease;
  }

  .strategy-control__node-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
