---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import SiteTreeHeader from '@/components/SiteTreeHeader.astro';
---

<BaseLayout title="Connect" description="How to reach me, what I am interested in, and the kinds of conversations I actually want to have.">
  <SiteTreeHeader
    branch="connect"
    currentHref="/connect"
    title="Connect"
    description="The clearest way into a conversation with me, without the vague networking language."
  />

  <section class="page-section">
    <SectionHeading
      eyebrow="Connect"
      title="Connect"
      description="If you are reaching out, these are the topics and kinds of people I am most naturally excited to talk with right now."
    />
    <div class="now-grid">
      <section class="panel now-panel">
        <h3>Current interests</h3>
        <ul>
          <li>Books that keep changing shape after I finish them.</li>
          <li>Cricket stories with enough detail to feel like I am back in the match.</li>
          <li>The experience of growing up in Bangladesh, studying in China, and living in the United States.</li>
        </ul>
      </section>
      <section class="panel now-panel">
        <h3>Open to talk about</h3>
        <ul>
          <li>How books and sport end up shaping the rest of a life.</li>
          <li>What it means to carry home across countries and still make something personal.</li>
          <li>How to build a personal website that sounds like a person instead of a polished internet profile.</li>
        </ul>
      </section>
      <section class="panel now-panel">
        <h3>Working on</h3>
        <ul>
          <li>Keeping this site honest enough that it still feels like me when I reread it later.</li>
          <li>Adding more cricket writing and keeping the book shelf useful.</li>
          <li>Finding a steadier rhythm for publishing things I actually mean.</li>
        </ul>
      </section>
      <section class="panel now-panel">
        <h3>Good fit intros</h3>
        <ul>
          <li>Readers, writers, and cricket people who care about detail.</li>
          <li>Anyone building a life across places and trying to make sense of what still feels like home.</li>
          <li>People who like honest websites more than polished personal branding.</li>
        </ul>
      </section>
    </div>
    <section class="panel contact-panel">
      <h3>Contact</h3>
      <p>If any of that overlaps with what you are building, reading, or thinking about, I would be glad to hear from you.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="mailto:nafi@cmnafi.com">Email nafi@cmnafi.com</a>
        <a class="button button-secondary" href="https://github.com/cmnafi" target="_blank" rel="noreferrer">GitHub</a>
        <a class="button button-ghost" href="https://www.linkedin.com/in/cm-nafi/" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </section>
  </section>
</BaseLayout>
