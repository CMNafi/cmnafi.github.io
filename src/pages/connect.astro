---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Parc Fermé">
  <nav class="paddock-override-nav">
    <a href="/" class="return-wall">← PIT WALL</a>
    <div class="nav-title">PARC FERMÉ</div>
  </nav>

  <main class="connect-viewport">
    <div class="comms-panel">
      <h1>Secure Comms</h1>
      <p>I read all messages and try to respond if there is a clear strategic overlap or an interesting technical problem being solved.</p>
      
      <div class="comms-grid">
        <a href="mailto:nafi@cmnafi.com" class="comms-link">
          <span class="c-label">INBOX</span>
          <span class="c-val">nafi@cmnafi.com</span>
        </a>
        <a href="https://x.com/naficm01" target="_blank" rel="noopener" class="comms-link">
          <span class="c-label">TWITTER / X</span>
          <span class="c-val">@naficm01</span>
        </a>
        <a href="https://www.linkedin.com/in/cm-nafi/" target="_blank" rel="noopener" class="comms-link">
          <span class="c-label">LINKEDIN</span>
          <span class="c-val">/in/cm-nafi</span>
        </a>
        <a href="https://github.com/CMNafi" target="_blank" rel="noopener" class="comms-link">
          <span class="c-label">GITHUB</span>
          <span class="c-val">CMNafi</span>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .paddock-override-nav { display: flex; justify-content: space-between; padding: 2rem; font-family: var(--font-mono); }
  .return-wall { color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
  .nav-title { color: var(--pitlane-white); font-size: 11px; letter-spacing: 0.15em; }
  
  .connect-viewport {
    min-height: 80vh;
    background: var(--paddock-black);
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }
  
  .comms-panel {
    background: var(--carbon);
    border: 1px solid var(--graphite);
    padding: 4rem;
    border-radius: var(--radius-card);
    border-top: 3px solid var(--telemetry-green);
    max-width: 600px;
    width: 100%;
  }

  .comms-panel h1 {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--pitlane-white);
    margin: 0 0 1rem;
  }
  .comms-panel p {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .comms-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .comms-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: var(--paddock-black);
    border: 1px solid var(--graphite);
    border-radius: var(--radius-chip);
    text-decoration: none;
    transition: 0.2s;
  }
  .comms-link:hover {
    border-color: var(--pitlane-white);
    transform: translateX(5px);
  }

  .c-label {
    font-family: var(--font-mono);
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }
  .c-val {
    font-family: var(--font-mono);
    color: var(--pitlane-white);
    font-weight: 700;
  }

  @media (max-width: 600px) {
    .comms-panel { padding: 2rem; }
    .comms-link { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
