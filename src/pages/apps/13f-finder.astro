---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="13F Finder"
  description="Search institutional investment managers and explore their 13F holdings, quarter-over-quarter changes, and portfolio composition."
>
  <div class="finder">
    <section class="page-section finder__hero">
      <p class="eyebrow">SEC EDGAR</p>
      <h1>13F Finder</h1>
      <p class="finder__lead">
        Search any institutional investment manager by name. View their latest 13F holdings and
        compare quarter-over-quarter changes — powered by the SEC EDGAR public API.
      </p>
    </section>

    <section class="page-section finder__search-section">
      <div class="panel finder__search-panel">
        <div class="finder__input-row">
          <input
            type="text"
            id="manager-search"
            class="finder__input"
            placeholder="Search manager name (e.g. Berkshire Hathaway, Bridgewater, Citadel)..."
            autocomplete="off"
          />
          <button id="search-btn" class="finder__btn" type="button">Search</button>
        </div>
        <div id="search-results" class="finder__results" style="display:none;"></div>
        <div id="search-status" class="finder__status"></div>
      </div>
    </section>

    <section id="manager-detail" class="page-section finder__detail" style="display:none;">
      <div class="panel finder__detail-header">
        <div class="finder__manager-info">
          <p class="eyebrow" id="manager-cik"></p>
          <h2 id="manager-name"></h2>
          <div class="finder__manager-meta" id="manager-meta"></div>
        </div>
        <div class="finder__filing-selector">
          <label for="filing-select-current">Compare quarters:</label>
          <div class="finder__selects-row">
            <select id="filing-select-current" class="finder__select">
              <option value="">Latest quarter</option>
            </select>
            <span class="finder__vs">vs</span>
            <select id="filing-select-previous" class="finder__select">
              <option value="">Previous quarter</option>
            </select>
            <button id="compare-btn" class="finder__btn finder__btn--sm" type="button">Compare</button>
          </div>
        </div>
      </div>

      <div id="holdings-status" class="finder__status"></div>

      <div id="portfolio-summary" class="finder__summary-grid" style="display:none;">
        <div class="panel finder__stat-card">
          <p class="eyebrow">Total Value</p>
          <p class="finder__stat-value" id="stat-total-value">--</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">Positions</p>
          <p class="finder__stat-value" id="stat-positions">--</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">Top Holding</p>
          <p class="finder__stat-value finder__stat-value--sm" id="stat-top-holding">--</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">New Positions</p>
          <p class="finder__stat-value" id="stat-new-positions">--</p>
        </div>
      </div>

      <div id="holdings-table-wrap" class="panel finder__table-wrap" style="display:none;">
        <div class="finder__table-header">
          <p class="eyebrow" id="table-period-label">Holdings</p>
          <div class="finder__table-controls">
            <input
              type="text"
              id="holdings-filter"
              class="finder__filter-input"
              placeholder="Filter by name or CUSIP..."
            />
            <select id="holdings-sort" class="finder__select finder__select--sm">
              <option value="value-desc">Value (High to Low)</option>
              <option value="value-asc">Value (Low to High)</option>
              <option value="name-asc">Name (A-Z)</option>
              <option value="shares-desc">Shares (High to Low)</option>
              <option value="change-desc">Change % (High to Low)</option>
              <option value="change-asc">Change % (Low to High)</option>
            </select>
          </div>
        </div>
        <div class="finder__table-scroll">
          <table class="finder__table" id="holdings-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Issuer</th>
                <th>Class</th>
                <th>CUSIP</th>
                <th class="num">Value ($)</th>
                <th class="num">Shares</th>
                <th class="num">% Portfolio</th>
                <th class="num">Share Chg</th>
                <th class="num">Chg %</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="holdings-body"></tbody>
          </table>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    // ---- API Layer ----
    // data.sec.gov supports CORS (Access-Control-Allow-Origin: *).
    // efts.sec.gov and www.sec.gov do NOT support CORS.
    // For non-CORS endpoints, we use corsproxy.io which works from browsers.

    const PROXY = 'https://corsproxy.io/?url=';

    async function fetchDirect(url) {
      const r = await fetch(url);
      if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
      return r;
    }

    async function fetchProxied(url) {
      const r = await fetch(PROXY + encodeURIComponent(url));
      if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
      return r;
    }

    // ---- Formatters ----
    function fmtVal(v) {
      if (v >= 1e12) return '$' + (v/1e12).toFixed(2) + 'T';
      if (v >= 1e9) return '$' + (v/1e9).toFixed(2) + 'B';
      if (v >= 1e6) return '$' + (v/1e6).toFixed(1) + 'M';
      if (v >= 1e3) return '$' + (v/1e3).toFixed(0) + 'K';
      return '$' + v.toLocaleString();
    }

    function fmtShares(s) {
      if (s >= 1e9) return (s/1e9).toFixed(2) + 'B';
      if (s >= 1e6) return (s/1e6).toFixed(2) + 'M';
      if (s >= 1e3) return (s/1e3).toFixed(1) + 'K';
      return s.toLocaleString();
    }

    function padCik(c) { return String(c).replace(/^0+/,'').padStart(10,'0'); }

    function setStatus(id, msg, err) {
      const el = document.getElementById(id);
      el.innerHTML = msg;
      el.className = 'finder__status' + (err ? ' finder__status--error' : '');
    }

    // ---- Search ----
    const searchInput = document.getElementById('manager-search');
    const searchBtn = document.getElementById('search-btn');
    const searchResults = document.getElementById('search-results');

    searchBtn.addEventListener('click', doSearch);
    searchInput.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });

    async function doSearch() {
      const q = searchInput.value.trim();
      if (!q) return;

      setStatus('search-status', '<span class="finder__loading">Searching SEC EDGAR...</span>');
      searchResults.style.display = 'none';

      try {
        const url = `https://efts.sec.gov/LATEST/search-index?q=${encodeURIComponent('"'+q+'"')}&forms=13F-HR&dateRange=custom&startdt=2020-01-01&enddt=2027-12-31`;
        const resp = await fetchProxied(url);
        const data = await resp.json();
        const hits = data.hits?.hits || [];

        const managers = new Map();
        for (const h of hits) {
          const s = h._source || {};
          const ciks = s.ciks || [];
          const names = s.display_names || [];
          const loc = (s.biz_locations || [])[0] || '';
          for (let i = 0; i < ciks.length; i++) {
            const cik = ciks[i];
            if (!managers.has(cik)) {
              const raw = names[i] || names[0] || 'Unknown';
              managers.set(cik, {
                cik,
                name: raw.replace(/\s*\(CIK\s+\d+\)\s*$/, ''),
                location: loc,
                lastFiling: s.file_date
              });
            }
          }
        }

        if (!managers.size) {
          setStatus('search-status', 'No 13F filers found. Try a different name.', true);
          return;
        }

        setStatus('search-status', `Found ${managers.size} manager(s).`);
        searchResults.innerHTML = '';
        searchResults.style.display = 'block';

        for (const [cik, m] of managers) {
          const btn = document.createElement('button');
          btn.className = 'finder__result-card';
          btn.innerHTML = `<strong>${m.name}</strong><span class="finder__result-meta">CIK: ${cik}${m.location ? ' · '+m.location : ''}${m.lastFiling ? ' · Last: '+m.lastFiling : ''}</span>`;
          btn.addEventListener('click', () => loadManager(cik, m.name));
          searchResults.appendChild(btn);
        }
      } catch (e) {
        setStatus('search-status', 'Search error: ' + e.message + '. Try again in a moment.', true);
      }
    }

    // ---- Load Manager ----
    let currentFilings = [];
    let currentCik = '';

    async function loadManager(cik, name) {
      currentCik = cik;
      const detail = document.getElementById('manager-detail');
      detail.style.display = 'block';
      detail.scrollIntoView({ behavior: 'smooth', block: 'start' });

      document.getElementById('manager-name').textContent = name;
      document.getElementById('manager-cik').textContent = 'CIK ' + cik;
      document.getElementById('portfolio-summary').style.display = 'none';
      document.getElementById('holdings-table-wrap').style.display = 'none';

      setStatus('holdings-status', '<span class="finder__loading">Loading filing history...</span>');

      try {
        // data.sec.gov has CORS * — direct fetch
        const resp = await fetchDirect(`https://data.sec.gov/submissions/CIK${padCik(cik)}.json`);
        const data = await resp.json();

        // Manager meta
        const meta = document.getElementById('manager-meta');
        const parts = [];
        if (data.stateOfIncorporationDescription) parts.push('Inc: ' + data.stateOfIncorporationDescription);
        if (data.sicDescription) parts.push(data.sicDescription);
        if (data.tickers?.length) parts.push('Tickers: ' + data.tickers.join(', '));
        const biz = data.addresses?.business;
        if (biz?.city) parts.push(biz.city + ', ' + biz.stateOrCountry);
        meta.innerHTML = parts.map(p => `<span class="finder__meta-tag">${p}</span>`).join('');

        // Extract 13F-HR filings
        const r = data.filings?.recent;
        if (!r) throw new Error('No filing data');

        const filings = [];
        for (let i = 0; i < r.form.length; i++) {
          if (r.form[i] === '13F-HR') {
            filings.push({
              accession: r.accessionNumber[i],
              date: r.filingDate[i],
              primaryDoc: r.primaryDocument[i],
              reportDate: r.reportDate?.[i] || r.filingDate[i]
            });
          }
        }

        if (!filings.length) {
          setStatus('holdings-status', 'No 13F-HR filings found for this manager.', true);
          return;
        }

        currentFilings = filings;

        const curSel = document.getElementById('filing-select-current');
        const prevSel = document.getElementById('filing-select-previous');
        curSel.innerHTML = '';
        prevSel.innerHTML = '<option value="">None (no comparison)</option>';

        filings.forEach((f, i) => {
          const label = f.reportDate + ' (filed ' + f.date + ')';
          curSel.appendChild(new Option(label, i));
          prevSel.appendChild(new Option(label, i));
        });

        if (filings.length > 1) prevSel.value = '1';

        setStatus('holdings-status', `Found ${filings.length} 13F filings. Loading holdings...`);
        await loadHoldings();
      } catch (e) {
        setStatus('holdings-status', 'Error: ' + e.message, true);
      }
    }

    // ---- Load Holdings ----
    document.getElementById('compare-btn').addEventListener('click', loadHoldings);

    async function loadHoldings() {
      const ci = parseInt(document.getElementById('filing-select-current').value);
      const pi = document.getElementById('filing-select-previous').value;
      if (isNaN(ci) || !currentFilings[ci]) return;

      setStatus('holdings-status', '<span class="finder__loading">Fetching 13F holdings...</span>');
      document.getElementById('portfolio-summary').style.display = 'none';
      document.getElementById('holdings-table-wrap').style.display = 'none';

      try {
        const cur = await fetchInfoTable(currentFilings[ci]);
        let prev = null;
        if (pi && pi !== '' && currentFilings[parseInt(pi)]) {
          prev = await fetchInfoTable(currentFilings[parseInt(pi)]);
        }
        displayHoldings(cur, prev, currentFilings[ci]);
        setStatus('holdings-status', '');
      } catch (e) {
        setStatus('holdings-status', 'Error loading holdings: ' + e.message, true);
      }
    }

    async function fetchInfoTable(filing) {
      const cikNum = currentCik.replace(/^0+/, '');
      const accNoDash = filing.accession.replace(/-/g, '');

      // www.sec.gov needs proxy for CORS
      const idxUrl = `https://www.sec.gov/Archives/edgar/data/${cikNum}/${accNoDash}/index.json`;
      const idxResp = await fetchProxied(idxUrl);
      const idx = await idxResp.json();

      const items = idx.directory?.item || [];
      const xmlFile = items.find(i =>
        i.name.endsWith('.xml') &&
        !i.name.includes('primary_doc') &&
        !i.name.includes('index') &&
        !i.name.startsWith('R')
      );

      if (!xmlFile) throw new Error('Information table XML not found in filing');

      const xmlUrl = `https://www.sec.gov/Archives/edgar/data/${cikNum}/${accNoDash}/${xmlFile.name}`;
      const xmlResp = await fetchProxied(xmlUrl);
      const xmlText = await xmlResp.text();

      return parseInfoTable(xmlText);
    }

    function parseInfoTable(xml) {
      const doc = new DOMParser().parseFromString(xml, 'text/xml');
      const ns = 'http://www.sec.gov/edgar/document/thirteenf/informationtable';
      let entries = doc.getElementsByTagNameNS(ns, 'infoTable');
      if (!entries.length) entries = doc.getElementsByTagName('infoTable');

      const map = new Map();
      for (const e of entries) {
        const g = tag => {
          let el = e.getElementsByTagNameNS(ns, tag)[0];
          if (!el) el = e.getElementsByTagName(tag)[0];
          return el?.textContent?.trim() || '';
        };
        const cusip = g('cusip');
        const issuer = g('nameOfIssuer');
        const titleClass = g('titleOfClass');
        const value = parseInt(g('value')) || 0;
        const shares = parseInt(g('sshPrnamt')) || 0;
        const shareType = g('sshPrnamtType');
        const key = cusip || issuer;

        if (map.has(key)) {
          const x = map.get(key);
          x.value += value;
          x.shares += shares;
        } else {
          map.set(key, { cusip, issuer, titleClass, value, shares, shareType });
        }
      }
      return Array.from(map.values());
    }

    // ---- Display ----
    let allRows = [];

    function displayHoldings(cur, prev, filing) {
      const totalVal = cur.reduce((s, h) => s + h.value, 0);
      const prevMap = new Map();
      if (prev) for (const h of prev) prevMap.set(h.cusip || h.issuer, h);

      const rows = cur.map(h => {
        const key = h.cusip || h.issuer;
        const p = prevMap.get(key);
        const pct = totalVal > 0 ? h.value / totalVal * 100 : 0;
        let chg = 0, chgPct = 0, status = '';

        if (prev) {
          if (p) {
            chg = h.shares - p.shares;
            chgPct = p.shares > 0 ? (h.shares - p.shares) / p.shares * 100 : 0;
            status = chg > 0 ? 'increased' : chg < 0 ? 'decreased' : 'unchanged';
          } else {
            status = 'new'; chg = h.shares; chgPct = 100;
          }
        }
        return { ...h, pct, chg, chgPct, status };
      });

      // Add sold positions
      if (prev) {
        const curKeys = new Set(cur.map(h => h.cusip || h.issuer));
        for (const h of prev) {
          const k = h.cusip || h.issuer;
          if (!curKeys.has(k)) {
            rows.push({ ...h, value:0, shares:0, pct:0, chg:-h.shares, chgPct:-100, status:'sold' });
          }
        }
      }

      allRows = rows;

      document.getElementById('stat-total-value').textContent = fmtVal(totalVal);
      document.getElementById('stat-positions').textContent = cur.length.toString();
      const top = cur.reduce((m, h) => h.value > m.value ? h : m, cur[0]);
      document.getElementById('stat-top-holding').textContent = top ? top.issuer : '--';
      document.getElementById('stat-new-positions').textContent = prev ? rows.filter(r => r.status === 'new').length.toString() : '--';
      document.getElementById('table-period-label').textContent = 'Holdings for ' + filing.reportDate;
      document.getElementById('portfolio-summary').style.display = 'grid';
      document.getElementById('holdings-table-wrap').style.display = 'block';
      renderTable();
    }

    document.getElementById('holdings-filter').addEventListener('input', renderTable);
    document.getElementById('holdings-sort').addEventListener('change', renderTable);

    function renderTable() {
      const f = document.getElementById('holdings-filter').value.toLowerCase();
      const s = document.getElementById('holdings-sort').value;
      const tbody = document.getElementById('holdings-body');

      let rows = allRows.filter(r => !f || r.issuer.toLowerCase().includes(f) || r.cusip.toLowerCase().includes(f));

      rows.sort((a, b) => {
        switch(s) {
          case 'value-asc': return a.value - b.value;
          case 'name-asc': return a.issuer.localeCompare(b.issuer);
          case 'shares-desc': return b.shares - a.shares;
          case 'change-desc': return b.chgPct - a.chgPct;
          case 'change-asc': return a.chgPct - b.chgPct;
          default: return b.value - a.value;
        }
      });

      tbody.innerHTML = '';
      for (let i = 0; i < rows.length; i++) {
        const r = rows[i];
        const tr = document.createElement('tr');
        if (r.status) tr.classList.add('finder__row--' + r.status);

        const sign = r.chg > 0 ? '+' : '';
        const cpStr = r.chgPct !== 0 ? (r.chgPct > 0 ? '+' : '') + r.chgPct.toFixed(1) + '%' : '--';
        let badge = '';
        if (r.status === 'new') badge = '<span class="finder__badge finder__badge--new">NEW</span>';
        else if (r.status === 'sold') badge = '<span class="finder__badge finder__badge--sold">SOLD</span>';
        else if (r.status === 'increased') badge = '<span class="finder__badge finder__badge--up">UP</span>';
        else if (r.status === 'decreased') badge = '<span class="finder__badge finder__badge--down">DOWN</span>';
        else if (r.status === 'unchanged') badge = '<span class="finder__badge finder__badge--flat">FLAT</span>';

        tr.innerHTML = `
          <td>${i+1}</td>
          <td class="finder__issuer">${r.issuer}</td>
          <td>${r.titleClass}</td>
          <td class="finder__cusip">${r.cusip}</td>
          <td class="num">${fmtVal(r.value)}</td>
          <td class="num">${fmtShares(r.shares)}</td>
          <td class="num">${r.pct.toFixed(2)}%</td>
          <td class="num ${r.chg>0?'finder__up':r.chg<0?'finder__down':''}">${r.status ? sign+fmtShares(Math.abs(r.chg)) : '--'}</td>
          <td class="num ${r.chgPct>0?'finder__up':r.chgPct<0?'finder__down':''}">${r.status ? cpStr : '--'}</td>
          <td>${badge}</td>`;
        tbody.appendChild(tr);
      }
    }
  </script>
</BaseLayout>

<style>
  .finder {
    position: relative;
    padding-bottom: 4rem;
  }

  .finder::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 18% 12%, rgba(74, 237, 196, 0.08), transparent 24%),
      radial-gradient(circle at 80% 20%, rgba(74, 237, 196, 0.05), transparent 18%),
      linear-gradient(180deg, rgba(10, 18, 32, 0.98), rgba(6, 10, 20, 0.99));
  }

  .finder > * { position: relative; z-index: 1; }

  .finder__hero {
    padding-top: clamp(2rem, 6vw, 4rem);
    max-width: 42rem;
  }

  .finder__hero h1 {
    margin: 0 0 0.7rem;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .finder__lead {
    margin: 0;
    color: rgba(224, 247, 239, 0.78);
    line-height: 1.78;
    max-width: 36rem;
  }

  /* Search */
  .finder__search-panel {
    display: grid;
    gap: 0.8rem;
    padding: clamp(1rem, 2.5vw, 1.4rem);
    background: linear-gradient(180deg, rgba(12, 22, 40, 0.92), rgba(6, 10, 20, 0.97));
    border-color: rgba(74, 237, 196, 0.18);
  }

  .finder__input-row { display: flex; gap: 0.6rem; }

  .finder__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(74, 237, 196, 0.2);
    background: rgba(6, 10, 20, 0.8);
    color: #e0f7ef;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 180ms ease;
  }

  .finder__input:focus { border-color: rgba(74, 237, 196, 0.5); }
  .finder__input::placeholder { color: rgba(224, 247, 239, 0.38); }

  .finder__btn {
    padding: 0.75rem 1.4rem;
    border-radius: 16px;
    border: 1px solid rgba(74, 237, 196, 0.3);
    background: linear-gradient(180deg, rgba(74, 237, 196, 0.18), rgba(74, 237, 196, 0.08));
    color: #4aedc4;
    font-size: 0.9rem;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background 180ms ease, transform 180ms ease;
    white-space: nowrap;
  }

  .finder__btn:hover {
    background: linear-gradient(180deg, rgba(74, 237, 196, 0.28), rgba(74, 237, 196, 0.14));
    transform: translateY(-1px);
  }

  .finder__btn--sm { padding: 0.55rem 1rem; font-size: 0.82rem; }

  .finder__results {
    display: grid;
    gap: 0.4rem;
    max-height: 24rem;
    overflow-y: auto;
    padding-right: 0.3rem;
  }

  .finder__result-card {
    display: grid;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(74, 237, 196, 0.12);
    background: rgba(6, 10, 20, 0.6);
    color: #e0f7ef;
    text-align: left;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
    font-family: inherit;
  }

  .finder__result-card:hover {
    border-color: rgba(74, 237, 196, 0.3);
    background: rgba(12, 22, 40, 0.8);
  }

  .finder__result-card strong {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 1.05rem;
  }

  .finder__result-meta {
    color: rgba(74, 237, 196, 0.65);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
  }

  .finder__status { font-size: 0.88rem; color: rgba(224, 247, 239, 0.7); }
  .finder__status--error { color: #ff6b6b; }

  .finder__loading { display: inline-flex; align-items: center; gap: 0.4rem; }

  .finder__loading::before {
    content: "";
    width: 0.9rem;
    height: 0.9rem;
    border: 2px solid rgba(74, 237, 196, 0.25);
    border-top-color: #4aedc4;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Detail */
  .finder__detail { display: grid; gap: 1rem; }

  .finder__detail-header {
    display: grid;
    gap: 1.2rem;
    padding: clamp(1rem, 2.5vw, 1.4rem);
    background: linear-gradient(180deg, rgba(12, 22, 40, 0.92), rgba(6, 10, 20, 0.97));
    border-color: rgba(74, 237, 196, 0.18);
  }

  .finder__manager-info h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.02;
