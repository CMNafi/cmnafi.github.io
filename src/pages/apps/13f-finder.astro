---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="13F Finder"
  description="Search institutional investment managers and explore their 13F holdings, quarter-over-quarter changes, and portfolio composition."
>
  <div class="finder">
    <section class="page-section finder__hero">
      <p class="eyebrow">SEC EDGAR</p>
      <h1>13F Finder</h1>
      <p class="finder__lead">
        Search any institutional investment manager by name. View their latest 13F holdings and
        compare quarter-over-quarter changes — all powered by the SEC EDGAR public API.
      </p>
    </section>

    <section class="page-section finder__search-section">
      <div class="panel finder__search-panel">
        <div class="finder__input-row">
          <input
            type="text"
            id="manager-search"
            class="finder__input"
            placeholder="Search manager name (e.g. Berkshire Hathaway, Bridgewater, Citadel)..."
            autocomplete="off"
          />
          <button id="search-btn" class="finder__btn" type="button">Search</button>
        </div>
        <div id="search-results" class="finder__results" style="display:none;"></div>
        <div id="search-status" class="finder__status"></div>
      </div>
    </section>

    <section id="manager-detail" class="page-section finder__detail" style="display:none;">
      <div class="panel finder__detail-header">
        <div class="finder__manager-info">
          <p class="eyebrow" id="manager-cik"></p>
          <h2 id="manager-name"></h2>
          <div class="finder__manager-meta" id="manager-meta"></div>
        </div>
        <div class="finder__filing-selector">
          <label for="filing-select">Compare quarters:</label>
          <div class="finder__selects-row">
            <select id="filing-select-current" class="finder__select">
              <option value="">Latest quarter</option>
            </select>
            <span class="finder__vs">vs</span>
            <select id="filing-select-previous" class="finder__select">
              <option value="">Previous quarter</option>
            </select>
            <button id="compare-btn" class="finder__btn finder__btn--sm" type="button">Compare</button>
          </div>
        </div>
      </div>

      <div id="holdings-status" class="finder__status"></div>

      <div id="portfolio-summary" class="finder__summary-grid" style="display:none;">
        <div class="panel finder__stat-card">
          <p class="eyebrow">Total Value</p>
          <p class="finder__stat-value" id="stat-total-value">—</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">Positions</p>
          <p class="finder__stat-value" id="stat-positions">—</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">Top Holding</p>
          <p class="finder__stat-value finder__stat-value--sm" id="stat-top-holding">—</p>
        </div>
        <div class="panel finder__stat-card">
          <p class="eyebrow">New Positions</p>
          <p class="finder__stat-value" id="stat-new-positions">—</p>
        </div>
      </div>

      <div id="holdings-table-wrap" class="panel finder__table-wrap" style="display:none;">
        <div class="finder__table-header">
          <p class="eyebrow" id="table-period-label">Holdings</p>
          <div class="finder__table-controls">
            <input
              type="text"
              id="holdings-filter"
              class="finder__filter-input"
              placeholder="Filter by name or CUSIP..."
            />
            <select id="holdings-sort" class="finder__select finder__select--sm">
              <option value="value-desc">Value (High to Low)</option>
              <option value="value-asc">Value (Low to High)</option>
              <option value="name-asc">Name (A-Z)</option>
              <option value="shares-desc">Shares (High to Low)</option>
              <option value="change-desc">Change % (High to Low)</option>
              <option value="change-asc">Change % (Low to High)</option>
            </select>
          </div>
        </div>
        <div class="finder__table-scroll">
          <table class="finder__table" id="holdings-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Issuer</th>
                <th>Class</th>
                <th>CUSIP</th>
                <th class="num">Value ($)</th>
                <th class="num">Shares</th>
                <th class="num">% of Portfolio</th>
                <th class="num">Share Change</th>
                <th class="num">Change %</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="holdings-body"></tbody>
          </table>
        </div>
      </div>
    </section>
  </div>

  <script>
    const SEC_UA = 'cmnafi.com admin@cmnafi.com';
    const CORS_PROXY = '';

    function secFetch(url) {
      return fetch(url, {
        headers: { 'User-Agent': SEC_UA, 'Accept': 'application/json, application/xml, text/xml, */*' }
      });
    }

    function formatValue(val) {
      if (val >= 1e12) return `$${(val / 1e12).toFixed(2)}T`;
      if (val >= 1e9) return `$${(val / 1e9).toFixed(2)}B`;
      if (val >= 1e6) return `$${(val / 1e6).toFixed(1)}M`;
      if (val >= 1e3) return `$${(val / 1e3).toFixed(0)}K`;
      return `$${val.toLocaleString()}`;
    }

    function formatShares(s) {
      if (s >= 1e9) return `${(s / 1e9).toFixed(2)}B`;
      if (s >= 1e6) return `${(s / 1e6).toFixed(2)}M`;
      if (s >= 1e3) return `${(s / 1e3).toFixed(1)}K`;
      return s.toLocaleString();
    }

    function padCik(cik) {
      return String(cik).replace(/^0+/, '').padStart(10, '0');
    }

    function setStatus(id, msg, isError = false) {
      const el = document.getElementById(id);
      el.innerHTML = msg;
      el.className = `finder__status ${isError ? 'finder__status--error' : ''}`;
    }

    // --- Search ---
    const searchInput = document.getElementById('manager-search');
    const searchBtn = document.getElementById('search-btn');
    const searchResults = document.getElementById('search-results');

    searchBtn.addEventListener('click', doSearch);
    searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });

    async function doSearch() {
      const query = searchInput.value.trim();
      if (!query) return;

      setStatus('search-status', '<span class="finder__loading">Searching SEC EDGAR...</span>');
      searchResults.style.display = 'none';

      try {
        const encoded = encodeURIComponent(`"${query}"`);
        const resp = await secFetch(
          `https://efts.sec.gov/LATEST/search-index?q=${encoded}&forms=13F-HR&dateRange=custom&startdt=2020-01-01&enddt=2027-12-31`
        );

        if (!resp.ok) throw new Error(`EDGAR search failed: ${resp.status}`);
        const data = await resp.json();
        const hits = data.hits?.hits || [];

        // Deduplicate by CIK
        const managers = new Map();
        for (const hit of hits) {
          const src = hit._source || {};
          const ciks = src.ciks || [];
          const names = src.display_names || [];
          const loc = (src.biz_locations || [])[0] || '';
          for (let i = 0; i < ciks.length; i++) {
            const cik = ciks[i];
            if (!managers.has(cik)) {
              const nameRaw = names[i] || names[0] || 'Unknown';
              const name = nameRaw.replace(/\s*\(CIK\s+\d+\)\s*$/, '');
              managers.set(cik, { cik, name, location: loc, lastFiling: src.file_date });
            }
          }
        }

        if (managers.size === 0) {
          setStatus('search-status', 'No 13F filers found matching that name.', true);
          return;
        }

        setStatus('search-status', `Found ${managers.size} manager(s).`);
        searchResults.innerHTML = '';
        searchResults.style.display = 'block';

        for (const [cik, mgr] of managers) {
          const card = document.createElement('button');
          card.className = 'finder__result-card';
          card.innerHTML = `
            <strong>${mgr.name}</strong>
            <span class="finder__result-meta">CIK: ${cik} ${mgr.location ? `· ${mgr.location}` : ''} ${mgr.lastFiling ? `· Last filing: ${mgr.lastFiling}` : ''}</span>
          `;
          card.addEventListener('click', () => loadManager(cik, mgr.name));
          searchResults.appendChild(card);
        }
      } catch (err) {
        setStatus('search-status', `Search error: ${err.message}`, true);
      }
    }

    // --- Load Manager ---
    let currentFilings = [];
    let currentCik = '';

    async function loadManager(cik, name) {
      currentCik = cik;
      const detail = document.getElementById('manager-detail');
      detail.style.display = 'block';
      detail.scrollIntoView({ behavior: 'smooth', block: 'start' });

      document.getElementById('manager-name').textContent = name;
      document.getElementById('manager-cik').textContent = `CIK ${cik}`;
      document.getElementById('portfolio-summary').style.display = 'none';
      document.getElementById('holdings-table-wrap').style.display = 'none';

      setStatus('holdings-status', '<span class="finder__loading">Loading filing history...</span>');

      try {
        const paddedCik = padCik(cik);
        const resp = await secFetch(`https://data.sec.gov/submissions/CIK${paddedCik}.json`);
        if (!resp.ok) throw new Error(`Failed to load submissions: ${resp.status}`);
        const data = await resp.json();

        // Show manager meta
        const meta = document.getElementById('manager-meta');
        const metaParts = [];
        if (data.stateOfIncorporation) metaParts.push(`Inc: ${data.stateOfIncorporationDescription || data.stateOfIncorporation}`);
        if (data.sicDescription) metaParts.push(data.sicDescription);
        if (data.tickers?.length) metaParts.push(`Tickers: ${data.tickers.join(', ')}`);
        if (data.addresses?.business?.city) {
          const addr = data.addresses.business;
          metaParts.push(`${addr.city}, ${addr.stateOrCountry}`);
        }
        meta.innerHTML = metaParts.map(p => `<span class="finder__meta-tag">${p}</span>`).join('');

        // Extract 13F-HR filings
        const recent = data.filings?.recent;
        if (!recent) throw new Error('No filing data found');

        const filings13f = [];
        for (let i = 0; i < recent.form.length; i++) {
          if (recent.form[i] === '13F-HR') {
            filings13f.push({
              accession: recent.accessionNumber[i],
              date: recent.filingDate[i],
              primaryDoc: recent.primaryDocument[i],
              reportDate: recent.reportDate?.[i] || recent.filingDate[i]
            });
          }
        }

        if (filings13f.length === 0) {
          setStatus('holdings-status', 'No 13F-HR filings found for this manager.', true);
          return;
        }

        currentFilings = filings13f;

        // Populate dropdowns
        const currentSelect = document.getElementById('filing-select-current');
        const previousSelect = document.getElementById('filing-select-previous');
        currentSelect.innerHTML = '';
        previousSelect.innerHTML = '<option value="">None (no comparison)</option>';

        filings13f.forEach((f, i) => {
          const label = `${f.reportDate} (filed ${f.date})`;
          const opt1 = new Option(label, i.toString());
          const opt2 = new Option(label, i.toString());
          currentSelect.appendChild(opt1);
          previousSelect.appendChild(opt2);
        });

        if (filings13f.length > 1) {
          previousSelect.value = '1';
        }

        setStatus('holdings-status', `Found ${filings13f.length} 13F-HR filings. Loading latest holdings...`);

        // Auto-load latest + comparison
        await loadHoldings();
      } catch (err) {
        setStatus('holdings-status', `Error: ${err.message}`, true);
      }
    }

    // --- Load Holdings ---
    document.getElementById('compare-btn').addEventListener('click', loadHoldings);

    async function loadHoldings() {
      const currentIdx = parseInt(document.getElementById('filing-select-current').value);
      const previousIdx = document.getElementById('filing-select-previous').value;

      if (isNaN(currentIdx) || !currentFilings[currentIdx]) return;

      setStatus('holdings-status', '<span class="finder__loading">Fetching 13F holdings XML...</span>');
      document.getElementById('portfolio-summary').style.display = 'none';
      document.getElementById('holdings-table-wrap').style.display = 'none';

      try {
        const currentHoldings = await fetchInfoTable(currentFilings[currentIdx]);

        let previousHoldings = null;
        if (previousIdx && previousIdx !== '' && currentFilings[parseInt(previousIdx)]) {
          previousHoldings = await fetchInfoTable(currentFilings[parseInt(previousIdx)]);
        }

        displayHoldings(currentHoldings, previousHoldings, currentFilings[currentIdx]);
        setStatus('holdings-status', '');
      } catch (err) {
        setStatus('holdings-status', `Error loading holdings: ${err.message}`, true);
      }
    }

    async function fetchInfoTable(filing) {
      const cikNum = currentCik.replace(/^0+/, '');
      const accessionNoDash = filing.accession.replace(/-/g, '');

      // Get filing index to find the infotable XML
      const indexResp = await secFetch(
        `https://www.sec.gov/Archives/edgar/data/${cikNum}/${accessionNoDash}/index.json`
      );
      if (!indexResp.ok) throw new Error(`Failed to load filing index: ${indexResp.status}`);
      const indexData = await indexResp.json();

      const items = indexData.directory?.item || [];
      // Find the infotable XML (not primary_doc.xml, not index files)
      const xmlFile = items.find(item =>
        item.name.endsWith('.xml') &&
        !item.name.includes('primary_doc') &&
        !item.name.includes('index') &&
        !item.name.includes('R')
      );

      if (!xmlFile) throw new Error('Could not find information table XML');

      const xmlResp = await secFetch(
        `https://www.sec.gov/Archives/edgar/data/${cikNum}/${accessionNoDash}/${xmlFile.name}`
      );
      if (!xmlResp.ok) throw new Error(`Failed to load infotable XML: ${xmlResp.status}`);
      const xmlText = await xmlResp.text();

      return parseInfoTable(xmlText);
    }

    function parseInfoTable(xmlText) {
      const parser = new DOMParser();
      const doc = parser.parseFromString(xmlText, 'text/xml');

      const ns = 'http://www.sec.gov/edgar/document/thirteenf/informationtable';
      let entries = doc.getElementsByTagNameNS(ns, 'infoTable');
      if (entries.length === 0) {
        entries = doc.getElementsByTagName('infoTable');
      }

      const holdings = new Map();

      for (const entry of entries) {
        const get = (tag) => {
          let el = entry.getElementsByTagNameNS(ns, tag)[0];
          if (!el) el = entry.getElementsByTagName(tag)[0];
          return el?.textContent?.trim() || '';
        };

        const cusip = get('cusip');
        const issuer = get('nameOfIssuer');
        const titleClass = get('titleOfClass');
        const value = parseInt(get('value')) || 0;
        const shares = parseInt(get('sshPrnamt')) || 0;
        const shareType = get('sshPrnamtType');

        const key = cusip || issuer;
        if (holdings.has(key)) {
          const existing = holdings.get(key);
          existing.value += value;
          existing.shares += shares;
        } else {
          holdings.set(key, { cusip, issuer, titleClass, value, shares, shareType });
        }
      }

      return Array.from(holdings.values());
    }

    // --- Display ---
    let allDisplayRows = [];

    function displayHoldings(current, previous, filing) {
      const totalValue = current.reduce((s, h) => s + h.value, 0);

      // Build previous lookup
      const prevMap = new Map();
      if (previous) {
        for (const h of previous) {
          const key = h.cusip || h.issuer;
          prevMap.set(key, h);
        }
      }

      // Build display rows
      const rows = current.map(h => {
        const key = h.cusip || h.issuer;
        const prev = prevMap.get(key);
        const pctOfPortfolio = totalValue > 0 ? (h.value / totalValue * 100) : 0;
        let shareChange = 0;
        let changePct = 0;
        let status = '';

        if (previous) {
          if (prev) {
            shareChange = h.shares - prev.shares;
            changePct = prev.shares > 0 ? ((h.shares - prev.shares) / prev.shares * 100) : 0;
            if (shareChange > 0) status = 'increased';
            else if (shareChange < 0) status = 'decreased';
            else status = 'unchanged';
          } else {
            status = 'new';
            shareChange = h.shares;
            changePct = 100;
          }
        }

        return { ...h, pctOfPortfolio, shareChange, changePct, status };
      });

      // Add sold positions
      if (previous) {
        const currentKeys = new Set(current.map(h => h.cusip || h.issuer));
        for (const h of previous) {
          const key = h.cusip || h.issuer;
          if (!currentKeys.has(key)) {
            rows.push({
              ...h,
              value: 0,
              shares: 0,
              pctOfPortfolio: 0,
              shareChange: -h.shares,
              changePct: -100,
              status: 'sold'
            });
          }
        }
      }

      allDisplayRows = rows;

      // Stats
      document.getElementById('stat-total-value').textContent = formatValue(totalValue);
      document.getElementById('stat-positions').textContent = current.length.toString();
      const topHolding = current.reduce((max, h) => h.value > max.value ? h : max, current[0]);
      document.getElementById('stat-top-holding').textContent = topHolding ? topHolding.issuer : '—';
      const newCount = rows.filter(r => r.status === 'new').length;
      document.getElementById('stat-new-positions').textContent = previous ? newCount.toString() : '—';

      document.getElementById('table-period-label').textContent =
        `Holdings for ${filing.reportDate}`;

      document.getElementById('portfolio-summary').style.display = 'grid';
      document.getElementById('holdings-table-wrap').style.display = 'block';

      renderTable();
    }

    // --- Filter & Sort ---
    document.getElementById('holdings-filter').addEventListener('input', renderTable);
    document.getElementById('holdings-sort').addEventListener('change', renderTable);

    function renderTable() {
      const filter = document.getElementById('holdings-filter').value.toLowerCase();
      const sort = document.getElementById('holdings-sort').value;
      const tbody = document.getElementById('holdings-body');

      let rows = allDisplayRows.filter(r =>
        !filter ||
        r.issuer.toLowerCase().includes(filter) ||
        r.cusip.toLowerCase().includes(filter)
      );

      // Sort
      rows.sort((a, b) => {
        switch (sort) {
          case 'value-desc': return b.value - a.value;
          case 'value-asc': return a.value - b.value;
          case 'name-asc': return a.issuer.localeCompare(b.issuer);
          case 'shares-desc': return b.shares - a.shares;
          case 'change-desc': return b.changePct - a.changePct;
          case 'change-asc': return a.changePct - b.changePct;
          default: return b.value - a.value;
        }
      });

      tbody.innerHTML = '';
      rows.forEach((r, i) => {
        const tr = document.createElement('tr');
        if (r.status) tr.classList.add(`finder__row--${r.status}`);

        const changeSign = r.shareChange > 0 ? '+' : '';
        const changePctStr = r.changePct !== 0 ? `${r.changePct > 0 ? '+' : ''}${r.changePct.toFixed(1)}%` : '—';

        let statusBadge = '';
        if (r.status === 'new') statusBadge = '<span class="finder__badge finder__badge--new">NEW</span>';
        else if (r.status === 'sold') statusBadge = '<span class="finder__badge finder__badge--sold">SOLD</span>';
        else if (r.status === 'increased') statusBadge = '<span class="finder__badge finder__badge--up">UP</span>';
        else if (r.status === 'decreased') statusBadge = '<span class="finder__badge finder__badge--down">DOWN</span>';
        else if (r.status === 'unchanged') statusBadge = '<span class="finder__badge finder__badge--flat">FLAT</span>';

        tr.innerHTML = `
          <td>${i + 1}</td>
          <td class="finder__issuer">${r.issuer}</td>
          <td>${r.titleClass}</td>
          <td class="finder__cusip">${r.cusip}</td>
          <td class="num">${formatValue(r.value)}</td>
          <td class="num">${formatShares(r.shares)}</td>
          <td class="num">${r.pctOfPortfolio.toFixed(2)}%</td>
          <td class="num ${r.shareChange > 0 ? 'finder__up' : r.shareChange < 0 ? 'finder__down' : ''}">${r.status ? `${changeSign}${formatShares(Math.abs(r.shareChange))}` : '—'}</td>
          <td class="num ${r.changePct > 0 ? 'finder__up' : r.changePct < 0 ? 'finder__down' : ''}">${r.status ? changePctStr : '—'}</td>
          <td>${statusBadge}</td>
        `;
        tbody.appendChild(tr);
      });
    }
  </script>
</BaseLayout>

<style>
  .finder {
    position: relative;
    padding-bottom: 4rem;
  }

  .finder::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 18% 12%, rgba(74, 237, 196, 0.08), transparent 24%),
      radial-gradient(circle at 80% 20%, rgba(74, 237, 196, 0.05), transparent 18%),
      linear-gradient(180deg, rgba(10, 18, 32, 0.98), rgba(6, 10, 20, 0.99));
  }

  .finder > * {
    position: relative;
    z-index: 1;
  }

  .finder__hero {
    padding-top: clamp(2rem, 6vw, 4rem);
    max-width: 42rem;
  }

  .finder__hero h1 {
    margin: 0 0 0.7rem;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .finder__lead {
    margin: 0;
    color: rgba(224, 247, 239, 0.78);
    line-height: 1.78;
    max-width: 36rem;
  }

  /* Search */
  .finder__search-panel {
    display: grid;
    gap: 0.8rem;
    padding: clamp(1rem, 2.5vw, 1.4rem);
    background:
      linear-gradient(180deg, rgba(12, 22, 40, 0.92), rgba(6, 10, 20, 0.97));
    border-color: rgba(74, 237, 196, 0.18);
  }

  .finder__input-row {
    display: flex;
    gap: 0.6rem;
  }

  .finder__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(74, 237, 196, 0.2);
    background: rgba(6, 10, 20, 0.8);
    color: #e0f7ef;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color 180ms ease;
  }

  .finder__input:focus {
    border-color: rgba(74, 237, 196, 0.5);
  }

  .finder__input::placeholder {
    color: rgba(224, 247, 239, 0.38);
  }

  .finder__btn {
    padding: 0.75rem 1.4rem;
    border-radius: 16px;
    border: 1px solid rgba(74, 237, 196, 0.3);
    background: linear-gradient(180deg, rgba(74, 237, 196, 0.18), rgba(74, 237, 196, 0.08));
    color: #4aedc4;
    font-size: 0.9rem;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background 180ms ease, transform 180ms ease;
    white-space: nowrap;
  }

  .finder__btn:hover {
    background: linear-gradient(180deg, rgba(74, 237, 196, 0.28), rgba(74, 237, 196, 0.14));
    transform: translateY(-1px);
  }

  .finder__btn--sm {
    padding: 0.55rem 1rem;
    font-size: 0.82rem;
  }

  .finder__results {
    display: grid;
    gap: 0.4rem;
    max-height: 24rem;
    overflow-y: auto;
    padding-right: 0.3rem;
  }

  .finder__result-card {
    display: grid;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(74, 237, 196, 0.12);
    background: rgba(6, 10, 20, 0.6);
    color: #e0f7ef;
    text-align: left;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease;
    font-family: inherit;
  }

  .finder__result-card:hover {
    border-color: rgba(74, 237, 196, 0.3);
    background: rgba(12, 22, 40, 0.8);
  }

  .finder__result-card strong {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: 1.05rem;
  }

  .finder__result-meta {
    color: rgba(74, 237, 196, 0.65);
    font-size: 0.76rem;
    letter-spacing: 0.05em;
  }

  .finder__status {
    font-size: 0.88rem;
