---
import { homepageConfig } from '@/config/homepage';
import { siteConfig } from '@/config/site';

type HeroConfig = typeof homepageConfig.hero;

const { hero } = Astro.props as {
  hero: HeroConfig;
};

const quickLinks = siteConfig.nav.filter((item) => item.href !== '/' && item.href !== '/connect');
---

<section class="hero landing-hero panel">
  <a class="hero-avatar" href="https://www.linkedin.com/in/cm-nafi/" target="_blank" rel="noopener noreferrer" aria-label="C M Nafi on LinkedIn">
    <img src="/profile.jpg" alt="C M Nafi" />
  </a>
  <p class="eyebrow">{hero.eyebrow}</p>
  <h1>{hero.title}</h1>
  <p class="landing-hero__descriptor">{hero.descriptor}</p>
  <p class="hero-description">{hero.intro}</p>

  <div class="hero-actions">
    {hero.ctas.map((cta) => (
      <a class={`button button-${cta.variant}`} href={cta.href}>{cta.label}</a>
    ))}
  </div>

  <div class="landing-hero__links">
    {quickLinks.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </div>

  <div class="landing-hero__steam" aria-hidden="true">
    <span></span>
    <span></span>
  </div>
</section>
