---
import { homepageConfig } from '@/config/homepage';
const { hero, processChapters } = Astro.props as {
  hero: typeof homepageConfig.hero;
  processChapters: typeof homepageConfig.processChapters;
};
---

<section class="hero hero-shell panel">
  <div class="hero-atmosphere" aria-hidden="true">
    <span class="hero-haze hero-haze-amber"></span>
    <span class="hero-haze hero-haze-blue"></span>
    <span class="hero-grid"></span>
    <span class="hero-vignette"></span>
  </div>

  <div class="hero-copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1>
      {hero.title}
      <span>{hero.highlight}</span>
    </h1>
    <p class="hero-description">{hero.description}</p>
    <p class="hero-manifesto">{hero.manifesto}</p>

    <div class="hero-actions">
      {hero.ctas.map((cta) => (
        <a class={`button button-${cta.variant}`} href={cta.href}>{cta.label}</a>
      ))}
    </div>

    <div class="hero-stats hero-stats-premium">
      {hero.stats.map((stat) => (
        <article class="hero-stat panel">
          <span>{stat.label}</span>
          <strong>{stat.value}</strong>
        </article>
      ))}
    </div>
  </div>

  <div class="hero-visual" aria-hidden="true">
    <div class="hero-visual-shell">
      <div class="scene-orbit scene-orbit-outer"></div>
      <div class="scene-orbit scene-orbit-inner"></div>
      <div class="scene-ring-glow"></div>

      <div class="scene-stage scene-stage-intake">
        <span class="scene-label">Signals arrive</span>
        <div class="bean-cluster">
          <span class="bean bean-1"></span>
          <span class="bean bean-2"></span>
          <span class="bean bean-3"></span>
          <span class="bean bean-4"></span>
          <span class="bean bean-5"></span>
        </div>
      </div>

      <div class="scene-stage scene-stage-grind">
        <span class="scene-label">Thoughts refined</span>
        <div class="grinder-ring grinder-ring-outer"></div>
        <div class="grinder-ring grinder-ring-inner"></div>
        <div class="grind-dust grind-dust-a"></div>
        <div class="grind-dust grind-dust-b"></div>
      </div>

      <div class="scene-stage scene-stage-brew">
        <span class="scene-label">Work extracting</span>
        <div class="brew-column">
          <span class="brew-flow brew-flow-a"></span>
          <span class="brew-flow brew-flow-b"></span>
          <span class="steam-line steam-line-a"></span>
          <span class="steam-line steam-line-b"></span>
          <span class="steam-line steam-line-c"></span>
        </div>
      </div>

      <div class="scene-stage scene-stage-serve">
        <span class="scene-label">Public release</span>
        <div class="cup-saucer"></div>
        <div class="cup-body"></div>
        <div class="cup-handle"></div>
        <div class="cup-glow"></div>
      </div>

      <div class="scene-stream scene-stream-main"></div>
      <div class="scene-stream scene-stream-accent"></div>

      <div class="hero-destination-links">
        <a class="hero-destination hero-destination-blog" href="/blog">
          <span>Journal</span>
          <strong>Blog</strong>
        </a>
        <a class="hero-destination hero-destination-projects" href="/projects">
          <span>Build log</span>
          <strong>Projects</strong>
        </a>
        <a class="hero-destination hero-destination-adventures" href="/adventures">
          <span>Field notes</span>
          <strong>Adventures</strong>
        </a>
      </div>

      <div class="hero-scene-caption panel">
        <p>Every section follows the same ritual: gather, refine, brew, and serve.</p>
      </div>
    </div>
  </div>

  <div class="hero-rail">
    {processChapters.map((chapter, index) => (
      <article class="hero-rail-card panel">
        <span class="hero-rail-index">0{index + 1}</span>
        <div>
          <p>{chapter.phase}</p>
          <h2>{chapter.title}</h2>
          <small>{chapter.cue}</small>
        </div>
      </article>
    ))}
  </div>
</section>
