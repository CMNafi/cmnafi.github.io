---
import { homepageConfig } from '@/config/homepage';

type HeroStage = {
  label: string;
  cue: string;
};

type HeroConfig = typeof homepageConfig.hero & {
  animationStages?: readonly HeroStage[];
};

const { hero, processChapters } = Astro.props as {
  hero: HeroConfig;
  processChapters: typeof homepageConfig.processChapters;
};

const animationStages =
  hero.animationStages ??
  ([
    { label: 'Bean Intake', cue: '0-20% cycle' },
    { label: 'Grind', cue: '20-45% cycle' },
    { label: 'Brew', cue: '45-75% cycle' },
    { label: 'Serve', cue: '75-100% cycle' }
  ] as const);

const chapterRail = processChapters.slice(0, 4);
---

<section class="hero coffee-hero panel">
  <div class="coffee-hero__copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1>
      {hero.title}
      <span>{hero.highlight}</span>
    </h1>
    <p class="hero-description">{hero.description}</p>
    <p class="hero-manifesto">{hero.manifesto}</p>

    <div class="hero-actions">
      {hero.ctas.map((cta) => (
        <a class={`button button-${cta.variant}`} href={cta.href}>{cta.label}</a>
      ))}
    </div>

    <div class="hero-stats coffee-hero__stats">
      {hero.stats.map((stat) => (
        <article class="hero-stat panel">
          <span>{stat.label}</span>
          <strong>{stat.value}</strong>
        </article>
      ))}
    </div>

    <div class="coffee-hero__phase-list">
      {animationStages.map((stage, index) => (
        <article class="coffee-phase-card">
          <span>{`0${index + 1}`}</span>
          <strong>{stage.label}</strong>
          <small>{stage.cue}</small>
        </article>
      ))}
    </div>
  </div>

  <div class="coffee-hero__scene" aria-hidden="true">
    <div class="brew-apparatus">
      <div class="brew-apparatus__backdrop"></div>

      <div class="brew-orbit brew-orbit--outer"></div>
      <div class="brew-orbit brew-orbit--inner"></div>

      <section class="brew-stage brew-stage--intake">
        <span class="brew-stage__label">Bean intake</span>
        <div class="bean-cluster">
          <span class="bean bean-1"></span>
          <span class="bean bean-2"></span>
          <span class="bean bean-3"></span>
          <span class="bean bean-4"></span>
        </div>
        <span class="stage-glow stage-glow--intake"></span>
      </section>

      <section class="brew-stage brew-stage--grind">
        <span class="brew-stage__label">Grind</span>
        <div class="grinder-ring grinder-ring--outer"></div>
        <div class="grinder-ring grinder-ring--inner"></div>
        <span class="grind-dust grind-dust--a"></span>
        <span class="grind-dust grind-dust--b"></span>
      </section>

      <section class="brew-stage brew-stage--extract">
        <span class="brew-stage__label">Brew</span>
        <div class="brew-column">
          <span class="brew-liquid brew-liquid--main"></span>
          <span class="brew-liquid brew-liquid--alt"></span>
        </div>
        <span class="pour-stream"></span>
      </section>

      <section class="brew-stage brew-stage--serve">
        <span class="brew-stage__label">Serve</span>
        <div class="cup-saucer"></div>
        <div class="cup-body"></div>
        <div class="cup-handle"></div>
        <span class="cup-glow"></span>
        <span class="steam steam-a"></span>
        <span class="steam steam-b"></span>
        <span class="steam steam-c"></span>
      </section>

      <div class="brew-route"></div>

      <div class="coffee-hero__destinations">
        <a class="hero-destination" href="/blog">
          <span>Journal</span>
          <strong>Blog</strong>
        </a>
        <a class="hero-destination" href="/projects">
          <span>Build log</span>
          <strong>Projects</strong>
        </a>
        <a class="hero-destination" href="/adventures">
          <span>Field notes</span>
          <strong>Adventures</strong>
        </a>
      </div>
    </div>
  </div>

  <div class="hero-rail coffee-hero__rail">
    {chapterRail.map((chapter, index) => (
      <article class="hero-rail-card panel">
        <span class="hero-rail-index">0{index + 1}</span>
        <div>
          <p>{chapter.phase}</p>
          <h2>{chapter.title}</h2>
          <small>{chapter.cue}</small>
        </div>
      </article>
    ))}
  </div>
</section>
