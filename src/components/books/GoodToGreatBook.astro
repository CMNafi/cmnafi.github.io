---
// src/components/books/GoodToGreatBook.astro
---
<div class="book-scene">
  <div class="book-3d">
    <!-- Shadow -->
    <div class="book-shadow"></div>
    
    <!-- Spine -->
    <div class="book-spine">
      <div class="spine-top">
        <span class="spine-author">JIM COLLINS</span>
      </div>
      <div class="spine-title-wrap">
        <span class="spine-word">GOOD</span>
        <span class="spine-to">TO</span>
        <span class="spine-word">GREAT</span>
      </div>
      <div class="spine-bottom">
        <div class="spine-logo"></div>
      </div>
    </div>
    
    <!-- Front Cover -->
    <div class="book-front">
      <!-- White rising jagged line SVG background -->
      <svg class="cover-chart" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M 0 85 L 10 80 L 15 82 L 25 65 L 30 68 L 40 50 L 50 55 L 60 30 L 70 35 L 80 15 L 90 20 L 100 5" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="0.75" vector-effect="non-scaling-stroke"/>
      </svg>
      
      <div class="front-content">
        <div class="bestseller-stripe">NATIONAL BESTSELLER</div>
        <div class="subtitle">Why Some Companies<br/>Make the Leap...<br/>and Others Don't</div>
        
        <div class="title-group">
          <div class="title-good">GOOD TO</div>
          <div class="title-great">GREAT</div>
        </div>
        
        <div class="author-group">
          <div class="author-name">JIM COLLINS</div>
          <div class="author-sub">Coauthor of the bestselling<br/><em>BUILT TO LAST</em></div>
        </div>
      </div>
      
      <div class="front-cover-thickness"></div>
      <div class="front-cover-inner"></div>
    </div>
    
    <!-- Pages (Top and side) -->
    <div class="book-pages-top"></div>
    <div class="book-pages-right"></div>
    
    <!-- Back Cover (Inside) -->
    <div class="book-back-inner"></div>
  </div>
</div>

<style>
.book-scene {
  width: 100%;
  height: 100%;
  perspective: 1200px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  /* Disable pointer events on the scene to avoid blocking parent clicks, but enable on the book */
  pointer-events: none;
}

.book-3d {
  position: relative;
  width: 210px;
  height: 320px;
  transform-style: preserve-3d;
  /* Match the 3D isometric angle from the user's image */
  transform: rotateX(12deg) rotateY(-22deg) rotateZ(0deg);
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  pointer-events: auto;
  cursor: pointer;
}

.book-scene:hover .book-3d, .book-3d:hover {
  transform: rotateX(6deg) rotateY(-14deg) scale(1.03);
}

.book-shadow {
  position: absolute;
  bottom: -15px;
  left: 20px;
  width: 200px;
  height: 25px;
  background: rgba(0,0,0,0.6);
  filter: blur(12px);
  transform: translateZ(-20px) rotateX(90deg);
  transition: opacity 0.6s, transform 0.6s;
}

.book-3d:hover .book-shadow {
  transform: translateZ(-30px) rotateX(90deg) scale(1.05);
  opacity: 0.8;
}

/* Base Red Cover Color */
:root {
  --book-red: #ea3824;
  --book-dark-red: #c22112;
  --book-shadow-red: #911204;
}

/* FRONT COVER */
.book-front {
  position: absolute;
  width: 100%;
  height: 100%;
  background-color: var(--book-red);
  transform: translateZ(20px) rotateY(-8deg); /* Slightly open by default */
  transform-origin: left;
  transform-style: preserve-3d;
  border-radius: 2px 5px 5px 2px;
  box-shadow: inset 4px 0 10px rgba(0,0,0,0.1), inset -1px 0 2px rgba(255,255,255,0.4);
  /* overflow needs to be visible for thickness to show, but chart needs clipping */
  transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.book-3d:hover .book-front {
  transform: translateZ(20px) rotateY(-26deg);
}

.front-cover-inner {
  position: absolute; inset: 0; background: #fff; transform: translateZ(-1px);
  border-radius: 2px 5px 5px 2px;
}

.front-cover-thickness {
  position: absolute;
  top: 0; bottom: 0; right: 0;
  width: 3px;
  background: var(--book-dark-red);
  transform: rotateY(90deg) translateZ(1.5px);
  transform-origin: right;
  border-radius: 2px;
}

/* SPINE */
.book-spine {
  position: absolute;
  width: 40px;
  height: 100%;
  background: linear-gradient(to right, 
    var(--book-dark-red) 0%, 
    var(--book-red) 20%, 
    var(--book-red) 70%, 
    var(--book-shadow-red) 100%
  );
  transform: rotateY(-90deg) translateZ(20px);
  transform-origin: left;
  border-radius: 4px 0 0 4px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
  box-shadow: inset 2px 0 4px rgba(255,255,255,0.25);
  overflow: hidden;
}

/* PAGES TOP & RIGHT */
.book-pages-top {
  position: absolute;
  width: 206px;
  height: 38px; /* Thickness of book */
  background: #f4f4f4;
  top: 0;
  left: 2px;
  transform: rotateX(90deg) translateZ(19px);
  transform-origin: top;
  background-image: repeating-linear-gradient(to bottom, #d4d4d4, #d4d4d4 1px, #f9f9f9 1px, #f9f9f9 3px);
  border-radius: 0 4px 0 0;
  box-shadow: inset 0 0 10px rgba(0,0,0,0.1);
}

.book-pages-right {
  position: absolute;
  width: 38px;
  height: 316px;
  background: #efefef;
  right: 0;
  top: 2px;
  transform: rotateY(90deg) translateZ(19px);
  transform-origin: right;
  background-image: repeating-linear-gradient(to right, #cccccc, #cccccc 1px, #f9f9f9 1px, #f9f9f9 3px);
  border-radius: 0 3px 3px 0;
  box-shadow: inset 0 0 10px rgba(0,0,0,0.1);
}

/* BACK INNER (structural base) */
.book-back-inner {
  position: absolute;
  width: 210px;
  height: 320px;
  background: #2a2a2a;
  transform: translateZ(-20px);
  border-radius: 2px 5px 5px 2px;
  box-shadow: 10px 15px 35px rgba(0,0,0,0.9);
}

/* --- TYPOGRAPHY AND COVER LAYOUT --- */
.cover-chart {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 1;
  border-radius: 2px 5px 5px 2px;
  overflow: hidden;
}

.front-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  padding: 24px 12px;
  font-family: 'Inter', Helvetica, Arial, sans-serif;
  text-align: center;
  border-radius: 2px 5px 5px 2px;
  overflow: hidden;
  /* Add tiny vignette to cover */
  background: radial-gradient(circle at 50% 30%, transparent 60%, rgba(0,0,0,0.15) 120%);
}

.bestseller-stripe {
  font-size: 8px;
  font-weight: 500;
  color: #fff;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin-top: 5px;
  opacity: 0.95;
  border-bottom: 0.5px solid rgba(255,255,255,0.3);
  padding-bottom: 2px;
}

.subtitle {
  font-size: 11px;
  color: #111;
  font-weight: 600;
  line-height: 1.3;
  margin-top: 24px;
  margin-bottom: 28px;
  letter-spacing: -0.2px;
  text-shadow: 0 1px 2px rgba(255,255,255,0.4);
}

.title-good {
  font-size: 32px;
  font-weight: 900;
  color: #111;
  letter-spacing: 1.5px;
  line-height: 1;
  margin-bottom: -1px;
}

.title-great {
  font-size: 58px;
  font-weight: 900;
  color: #fff;
  letter-spacing: 3px;
  line-height: 0.85;
  transform: scaleY(1.3);
  text-shadow: 1px 2px 4px rgba(0,0,0,0.3);
  margin-top: 5px;
}

.author-group {
  margin-top: auto;
  margin-bottom: 10px;
}

.author-name {
  font-size: 18px;
  font-weight: 900;
  color: #111;
  letter-spacing: 3px;
}

.author-sub {
  font-size: 9px;
  font-weight: 600;
  color: #111;
  line-height: 1.3;
  margin-top: 4px;
}

/* SPINE TYPOGRAPHY */
.spine-top { padding-top: 10px; }

.spine-author {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
  font-family: 'Inter', sans-serif;
  font-size: 8px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1.5px;
  opacity: 0.9;
}

.spine-title-wrap {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
  font-family: 'Inter', sans-serif;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  flex: 1;
  justify-content: center;
}

.spine-word {
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  letter-spacing: 2px;
}

.spine-to {
  color: #111;
  font-size: 20px;
  font-weight: 900;
  letter-spacing: 1px;
}

.spine-bottom { padding-bottom: 10px; }

.spine-logo {
  width: 14px;
  height: 20px;
  background: rgba(255,255,255,0.85);
  border-radius: 1px;
  position: relative;
}
.spine-logo::after {
  content: "";
  position: absolute;
  top: 4px; left: 3px; right: 3px; height: 3px;
  background: var(--book-dark-red);
}
</style>
