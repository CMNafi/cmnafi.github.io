---
import DirectoryCard from './DirectoryCard.astro';

interface Item {
  title: string;
  slug: string;
  description: string;
  category: string;
  status: string;
  icon: string;
  count?: number;
}

const { tabs, items } = Astro.props as { tabs: string[]; items: Item[] };
---

<section class="directory-board">
  <div class="directory-tabs" role="tablist" aria-label="Homepage directory filters">
    {tabs.map((tab, index) => (
      <button
        class="directory-tab"
        role="tab"
        aria-selected={index === 0 ? 'true' : 'false'}
        data-filter={tab}
      >
        {tab}
      </button>
    ))}
  </div>
  <div class="directory-grid" data-directory-grid>
    {items.map((item) => <DirectoryCard item={item} />)}
  </div>
</section>

<script>
  const setupDirectoryTabs = () => {
    const tabs = Array.from(document.querySelectorAll('.directory-tab'));
    const cards = Array.from(document.querySelectorAll('.directory-card'));

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const filter = tab.dataset.filter;
        tabs.forEach((candidate) => candidate.setAttribute('aria-selected', String(candidate === tab)));
        cards.forEach((card) => {
          const category = card.getAttribute('data-category');
          const show = filter === 'All' || category === filter;
          card.toggleAttribute('hidden', !show);
        });
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDirectoryTabs, { once: true });
  } else {
    setupDirectoryTabs();
  }
</script>
