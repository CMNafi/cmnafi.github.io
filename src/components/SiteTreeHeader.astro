---
import { getSiteBranch, type SiteBranchId } from '@/data/site-tree';

interface Props {
  branch: SiteBranchId;
  currentHref: string;
  title?: string;
  description?: string;
  eyebrow?: string;
}

const { branch, currentHref, title, description, eyebrow } = Astro.props;
const branchData = getSiteBranch(branch);

if (!branchData) {
  throw new Error(`Unknown site branch: ${branch}`);
}

const currentNode = branchData.nodes.find((node) => node.href === currentHref) ?? {
  label: branchData.label,
  href: branchData.href,
  description: branchData.description
};

const primaryNodes = branchData.nodes.filter((node) => node.kind !== 'secondary');
const secondaryNodes = branchData.nodes.filter((node) => node.kind === 'secondary');
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: branchData.label, href: branchData.href }
];

if (currentNode.href !== branchData.href) {
  breadcrumbs.push({ label: currentNode.label, href: currentNode.href });
}
---

<section class="page-section site-tree-header">
  <div class="site-tree-header__intro">
    <nav class="site-tree-header__breadcrumbs" aria-label="Breadcrumb">
      {breadcrumbs.map((crumb, index) => (
        <>
          <a href={crumb.href} aria-current={index === breadcrumbs.length - 1 ? 'page' : undefined}>{crumb.label}</a>
          {index < breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
        </>
      ))}
    </nav>

    <p class="eyebrow">{eyebrow ?? branchData.eyebrow}</p>
    {title && <h1>{title}</h1>}
    <p>{description ?? currentNode.description}</p>
  </div>

  <aside class="panel site-tree-header__panel">
    <p class="eyebrow">Site tree</p>
    <div class="site-tree-header__root">
      <span class="site-tree-header__connector" aria-hidden="true"></span>
      <a class:list={['site-tree-header__root-link', currentHref === branchData.href && 'is-active']} href={branchData.href}>
        <strong>{branchData.label}</strong>
        <small>{branchData.description}</small>
      </a>
    </div>

    <div class="site-tree-header__children">
      {primaryNodes.map((node) => (
        <a class:list={['site-tree-header__child', node.href === currentHref && 'is-active']} href={node.href}>
          <span class="site-tree-header__child-line" aria-hidden="true"></span>
          <span>
            <strong>{node.label}</strong>
            <small>{node.description}</small>
          </span>
        </a>
      ))}
    </div>

    {secondaryNodes.length > 0 && (
      <div class="site-tree-header__secondary">
        <p>Secondary pages in this branch</p>
        <div class="site-tree-header__secondary-links">
          {secondaryNodes.map((node) => (
            <a class:list={[node.href === currentHref && 'is-active']} href={node.href}>{node.label}</a>
          ))}
        </div>
      </div>
    )}
  </aside>
</section>

<style>
  .site-tree-header {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.95fr);
    gap: 1rem;
    padding-top: clamp(1.2rem, 4vw, 2.2rem);
    align-items: start;
  }

  .site-tree-header__intro {
    display: grid;
    gap: 0.7rem;
    max-width: 44rem;
  }

  .site-tree-header__intro h1 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .site-tree-header__intro p:last-child {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .site-tree-header__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: rgba(243, 237, 225, 0.5);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .site-tree-header__breadcrumbs a {
    color: inherit;
  }

  .site-tree-header__panel {
    display: grid;
    gap: 0.9rem;
    padding: 1rem 1.05rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .site-tree-header__root,
  .site-tree-header__child {
    position: relative;
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    gap: 0.8rem;
    text-decoration: none;
  }

  .site-tree-header__root-link,
  .site-tree-header__child > span {
    display: grid;
    gap: 0.22rem;
    padding: 0.75rem 0.85rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .site-tree-header__root-link strong,
  .site-tree-header__child strong {
    color: var(--text);
    font-size: 0.98rem;
  }

  .site-tree-header__root-link small,
  .site-tree-header__child small {
    color: rgba(243, 237, 225, 0.58);
    line-height: 1.55;
  }

  .site-tree-header__connector,
  .site-tree-header__child-line {
    position: relative;
    display: block;
  }

  .site-tree-header__connector::before,
  .site-tree-header__child-line::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(243, 237, 225, 0.12);
    transform: translateX(-50%);
  }

  .site-tree-header__connector::after,
  .site-tree-header__child-line::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 1rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: rgba(226, 186, 116, 0.82);
    box-shadow: 0 0 0 5px rgba(226, 186, 116, 0.12);
    transform: translate(-50%, -50%);
  }

  .site-tree-header__children {
    display: grid;
    gap: 0.75rem;
  }

  .site-tree-header__root-link:hover,
  .site-tree-header__root-link.is-active,
  .site-tree-header__child:hover > span,
  .site-tree-header__child.is-active > span {
    border-color: rgba(226, 186, 116, 0.22);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  .site-tree-header__secondary {
    display: grid;
    gap: 0.7rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .site-tree-header__secondary p {
    margin: 0;
    color: rgba(243, 237, 225, 0.52);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .site-tree-header__secondary-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .site-tree-header__secondary-links a {
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(243, 237, 225, 0.74);
    background: rgba(255, 255, 255, 0.02);
  }

  .site-tree-header__secondary-links a.is-active {
    color: var(--text);
    border-color: rgba(226, 186, 116, 0.22);
  }

  @media (max-width: 920px) {
    .site-tree-header {
      grid-template-columns: 1fr;
    }
  }
</style>
