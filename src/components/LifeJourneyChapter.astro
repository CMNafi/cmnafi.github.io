---
import type { LifeJourneyChapter } from '@/data/life-journey';

interface Props {
  chapter: LifeJourneyChapter;
  index: number;
  isLast?: boolean;
}

const { chapter } = Astro.props;
---

<article
  class="life-chapter"
  data-journey-chapter
  data-chapter-id={chapter.id}
  data-step={chapter.step}
  data-place={`${chapter.location}, ${chapter.region}`}
  data-theme={chapter.theme}
  data-era={chapter.era}
  data-scale={String(chapter.scale)}
>
  <div class="life-chapter__content panel">
    <div class="life-chapter__stage">
      <span class="life-chapter__index">{chapter.step}</span>
      <div>
        <p class="eyebrow">{chapter.era}</p>
        <p class="life-chapter__location">{chapter.location}, {chapter.region}</p>
      </div>
      <span class="life-chapter__theme">{chapter.theme}</span>
    </div>

    <h2>{chapter.title}</h2>
    <p class="life-chapter__narrative">{chapter.narrative}</p>

    <div class="life-chapter__meta">
      <span>{chapter.note}</span>
      <span>{chapter.atlasLabel}</span>
    </div>
  </div>
</article>
