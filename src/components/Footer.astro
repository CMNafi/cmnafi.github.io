---
import { siteConfig } from '@/config/site';
const year = new Date().getFullYear();
const lastUpdated = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
}).format(new Date());
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a class="footer-title" href="/">C M Nafi</a>
      <span class="footer-copy">A personal home for my story, my books, and the cricket memories worth keeping.</span>
    </div>
    
    <div class="footer-actions">
      <nav class="footer-nav" aria-label="Footer navigation">
        {siteConfig.footerLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
      <div class="footer-links">
        <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        {siteConfig.socialLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </div>
    
    <div class="footer-meta">
      <span>&copy; {year}</span>
      <span>Updated {lastUpdated}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    height: 54px;
    border-top: 1px solid rgba(255,255,255,0.05);
    background: #05070B;
    padding: 0 2rem;
    position: relative;
    z-index: 50;
    display: flex;
    align-items: center;
  }
  
  .footer-inner {
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: nowrap;
    white-space: nowrap;
    overflow: hidden;
  }

  .footer-brand { display: flex; align-items: center; gap: 1rem; flex-shrink: 1; overflow: hidden; }
  .footer-title { font-family: 'Sora', sans-serif; font-weight: 700; color: #F3F3F1; text-decoration: none; font-size: 0.9rem; }
  .footer-copy { font-family: 'Manrope', sans-serif; color: #8B919A; font-size: 0.8rem; text-overflow: ellipsis; overflow: hidden; }
  
  .footer-actions { display: flex; align-items: center; gap: 1.5rem; border-left: 1px solid rgba(255,255,255,0.1); border-right: 1px solid rgba(255,255,255,0.1); padding: 0 1.5rem; flex-shrink: 0; }
  .footer-nav, .footer-links { display: flex; gap: 1rem; align-items: center; }
  .footer-nav a, .footer-links a { font-family: 'DM Sans', sans-serif; color: #b8ad9a; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: 0.2s; }
  .footer-nav a:hover, .footer-links a:hover { color: #0EA5B7; }

  .footer-meta { display: flex; gap: 1rem; align-items: center; font-family: 'DM Sans', sans-serif; color: #8B919A; font-size: 0.75rem; flex-shrink: 0; }

  @media (max-width: 1100px) {
    .site-footer { height: auto; min-height: 54px; overflow-x: auto; padding: 0 1rem; }
    .footer-copy { display: none; }
    .footer-actions { border: none; padding: 0; }
  }
</style>
