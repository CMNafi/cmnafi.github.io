---
import { interestSections } from '@/data/interests';
---

<section class="page-section interest-hub">
  <div class="interest-hub__intro">
    <p class="eyebrow">Interests</p>
    <h1>Choose a world.</h1>
    <p>Six entry points. Nothing extra in the way.</p>
  </div>

  <div class="interest-hub__grid">
    {interestSections.map((section) => (
      <a
        class={`panel interest-hub__card interest-hub__card--${section.id}`}
        href={section.href}
        style={`--world-accent:${section.palette.accent}; --world-border:${section.palette.border}; --world-glow:${section.palette.glow}; --world-surface:${section.palette.surface}; --world-text:${section.palette.text};`}
      >
        <div class="interest-hub__visual" aria-hidden="true">
          {section.id === 'cricket' && (
            <div class="interest-hub__mini-ground">
              <span class="interest-hub__oval"></span>
              <span class="interest-hub__circle"></span>
              <span class="interest-hub__pitch"></span>
            </div>
          )}
          {section.id === 'books' && (
            <div class="interest-hub__spines">
              <span></span><span></span><span></span><span></span>
            </div>
          )}
          {section.id === 'writing' && (
            <div class="interest-hub__papers">
              <span></span><span></span><span></span>
            </div>
          )}
          {section.id === 'movies' && (
            <div class="interest-hub__ticket">
              <span></span>
            </div>
          )}
          {section.id === 'finance' && (
            <div class="interest-hub__candles">
              <span class="interest-hub__candle interest-hub__candle--up" style="--h:62%"></span>
              <span class="interest-hub__candle interest-hub__candle--down" style="--h:45%"></span>
              <span class="interest-hub__candle interest-hub__candle--up" style="--h:78%"></span>
              <span class="interest-hub__candle interest-hub__candle--down" style="--h:38%"></span>
              <span class="interest-hub__candle interest-hub__candle--up" style="--h:55%"></span>
            </div>
          )}
          {section.id === 'tech' && (
            <div class="interest-hub__pcb">
              <span class="interest-hub__trace interest-hub__trace--h"></span>
              <span class="interest-hub__trace interest-hub__trace--v"></span>
              <span class="interest-hub__node" style="--nx:22%;--ny:28%"></span>
              <span class="interest-hub__node" style="--nx:50%;--ny:50%"></span>
              <span class="interest-hub__node" style="--nx:78%;--ny:28%"></span>
              <span class="interest-hub__node" style="--nx:35%;--ny:72%"></span>
              <span class="interest-hub__node" style="--nx:65%;--ny:72%"></span>
            </div>
          )}
        </div>

        <div class="interest-hub__copy">
          <p>{section.title}</p>
          <h2>{section.cardTitle}</h2>
          <p>{section.description}</p>
          <span class="interest-hub__cta">Enter {section.title}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .interest-hub {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }

  .interest-hub__intro {
    max-width: 26rem;
    margin-bottom: 1.35rem;
  }

  .interest-hub__intro h1 {
    margin: 0 0 0.7rem;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2.8rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .interest-hub__intro p:last-child {
    margin: 0;
    color: rgba(243, 237, 225, 0.72);
    line-height: 1.7;
    max-width: 20rem;
  }

  .interest-hub__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .interest-hub__card {
    display: grid;
    gap: 1.1rem;
    min-height: 21rem;
    padding: 1.4rem;
    color: var(--world-text);
    border-color: var(--world-border);
    background: var(--world-surface);
    overflow: hidden;
    position: relative;
    isolation: isolate;
    transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
  }

  .interest-hub__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, var(--world-glow), transparent 36%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    opacity: 0.9;
    z-index: -1;
  }

  .interest-hub__card:hover,
  .interest-hub__card:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
    outline: none;
  }

  .interest-hub__visual {
    min-height: 7.75rem;
    display: grid;
    place-items: center;
  }

  .interest-hub__copy {
    display: grid;
    gap: 0.7rem;
    align-content: end;
  }

  .interest-hub__copy > p:first-child,
  .interest-hub__cta {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.64);
  }

  .interest-hub__copy h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .interest-hub__copy p:last-of-type {
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
  }

  .interest-hub__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--world-accent);
  }

  .interest-hub__cta::after {
    content: "\2192";
    font-size: 0.9em;
  }

  .interest-hub__mini-ground {
    position: relative;
    width: min(17rem, 100%);
    aspect-ratio: 1.35;
  }

  .interest-hub__oval,
  .interest-hub__circle,
  .interest-hub__pitch {
    position: absolute;
    inset: 0;
    margin: auto;
  }

  .interest-hub__oval {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid rgba(237, 244, 216, 0.2);
    background: radial-gradient(circle at 50% 48%, rgba(182, 215, 143, 0.1), transparent 58%);
  }

  .interest-hub__circle {
    width: 64%;
    height: 64%;
    border-radius: 50%;
    border: 1px solid rgba(237, 244, 216, 0.2);
  }

  .interest-hub__pitch {
    width: 16%;
    height: 74%;
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(154, 111, 66, 0.92), rgba(101, 68, 35, 0.94));
    box-shadow:
      0 -4.4rem 0 -4rem rgba(237, 244, 216, 0.32),
      0 4.4rem 0 -4rem rgba(237, 244, 216, 0.32);
  }

  .interest-hub__spines {
    display: flex;
    align-items: end;
    gap: 0.35rem;
    height: 8rem;
  }

  .interest-hub__spines span {
    display: block;
    height: 100%;
    border-radius: 10px 10px 3px 3px;
    box-shadow: inset -1px 0 0 rgba(0, 0, 0, 0.22);
  }

  .interest-hub__spines span:nth-child(1) { width: 2.2rem; background: #6e4224; height: 86%; }
  .interest-hub__spines span:nth-child(2) { width: 1.55rem; background: #a36334; height: 100%; }
  .interest-hub__spines span:nth-child(3) { width: 2.7rem; background: #c78a46; height: 92%; }
  .interest-hub__spines span:nth-child(4) { width: 1.8rem; background: #7f5a35; height: 80%; }

  .interest-hub__papers {
    position: relative;
    width: 12rem;
    height: 8.5rem;
  }

  .interest-hub__papers span {
    position: absolute;
    inset: 0;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(239, 230, 247, 0.92), rgba(221, 209, 238, 0.9));
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .interest-hub__papers span:nth-child(1) { transform: rotate(-7deg) translateX(-0.5rem); opacity: 0.7; }
  .interest-hub__papers span:nth-child(2) { transform: rotate(5deg) translateX(0.4rem); opacity: 0.78; }
  .interest-hub__papers span:nth-child(3) { transform: translateY(0.1rem); }

  .interest-hub__ticket {
    position: relative;
    width: min(16rem, 100%);
    height: 7.4rem;
    border-radius: 22px;
    border: 1px solid rgba(255, 210, 195, 0.2);
    background: linear-gradient(90deg, rgba(255, 140, 105, 0.18), rgba(255, 140, 105, 0.08));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  .interest-hub__ticket::before,
  .interest-hub__ticket::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    background: rgba(7, 7, 9, 0.98);
    transform: translateY(-50%);
  }

  .interest-hub__ticket::before { left: -0.7rem; }
  .interest-hub__ticket::after { right: -0.7rem; }

  .interest-hub__ticket span {
    position: absolute;
    inset: 0.95rem 1rem;
    border: 1px dashed rgba(255, 210, 195, 0.22);
    border-radius: 14px;
  }

  /* Finance: candlestick chart */
  .interest-hub__candles {
    display: flex;
    align-items: end;
    justify-content: center;
    gap: 0.6rem;
    height: 7.5rem;
    padding-bottom: 0.5rem;
  }

  .interest-hub__candle {
    display: block;
    width: 0.7rem;
    height: var(--h);
    border-radius: 3px;
    position: relative;
  }

  .interest-hub__candle::before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    top: -0.5rem;
    bottom: -0.5rem;
  }

  .interest-hub__candle--up {
    background: rgba(74, 237, 196, 0.7);
  }

  .interest-hub__candle--up::before {
    background: rgba(74, 237, 196, 0.4);
  }

  .interest-hub__candle--down {
    background: rgba(255, 99, 99, 0.6);
  }

  .interest-hub__candle--down::before {
    background: rgba(255, 99, 99, 0.35);
  }

  /* Tech: circuit board */
  .interest-hub__pcb {
    position: relative;
    width: min(15rem, 100%);
    aspect-ratio: 1.4;
    border-radius: 14px;
    background: rgba(8, 12, 8, 0.6);
    border: 1px solid rgba(57, 255, 20, 0.12);
    overflow: hidden;
  }

  .interest-hub__trace {
    position: absolute;
    background: rgba(57, 255, 20, 0.18);
  }

  .interest-hub__trace--h {
    width: 80%;
    height: 1px;
    top: 50%;
    left: 10%;
  }

  .interest-hub__trace--v {
    width: 1px;
    height: 70%;
    top: 15%;
    left: 50%;
  }

  .interest-hub__node {
    position: absolute;
    left: var(--nx);
    top: var(--ny);
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: rgba(57, 255, 20, 0.5);
    box-shadow: 0 0 8px rgba(57, 255, 20, 0.3);
    transform: translate(-50%, -50%);
  }

  @media (max-width: 1100px) {
    .interest-hub__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .interest-hub__grid {
      grid-template-columns: 1fr;
    }

    .interest-hub__card {
      min-height: 18rem;
    }
  }

  @media (max-width: 640px) {
    .interest-hub {
      padding-top: 2rem;
    }

    .interest-hub__card {
      padding: 1rem;
      min-height: 16.75rem;
    }

    .interest-hub__intro h1 {
      font-size: clamp(2.4rem, 12vw, 3.8rem);
    }
  }
</style>
