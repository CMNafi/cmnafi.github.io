---
import { publicInterestSections } from '@/data/interests';
---

<section class="page-section interest-index">
  <div class="index-header">
    <h1 class="paddock-headline">Interests</h1>
    <p class="paddock-editorial">
      The two shelves that feel most like home. Books and cricket are the parts of the site that feel the most lived in, so this page stays with those two exclusively.
    </p>
  </div>

  <div class="index-list">
    {publicInterestSections.map((section) => (
      <a href={section.href} class="index-row" style={`--world-accent:${section.palette.accent};`}>
        <div class="row-indicator"></div>
        <div class="row-core">
          <div class="row-meta">
            <span class="row-category">{section.title}</span>
            <h2 class="row-title">{section.cardTitle}</h2>
          </div>
          <p class="row-desc">{section.description}</p>
        </div>
        <div class="row-action">
          <span>Enter {section.title}</span> &rarr;
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .interest-index {
    padding-top: clamp(4rem, 8vw, 6rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
    max-width: 1000px;
    margin: 0 auto;
  }

  .index-header {
    margin-bottom: 3rem;
    border-bottom: 2px solid var(--accent-red, #E10600);
    padding-bottom: 2rem;
  }

  .paddock-headline {
    margin: 0 0 1rem;
    font-family: 'Sora', 'Fraunces', serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--text-white, #F3F3F1);
  }

  .paddock-editorial {
    margin: 0;
    max-width: 600px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-silver, #8B919A);
  }

  /* LIST LAYOUT */
  .index-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .index-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem 1rem;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: transparent;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  /* Hover Glint Background */
  .index-row::before {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);
    transform: translateX(-100%); transition: transform 0.6s ease;
    z-index: 0; pointer-events: none;
  }

  .index-row:hover::before { transform: translateX(100%); }

  .index-row:hover {
    background: rgba(255,255,255,0.01);
  }

  .index-row:hover .row-indicator {
    background: var(--world-accent);
    box-shadow: 0 0 15px var(--world-accent);
  }

  .index-row:hover .row-action {
    color: var(--text-white, #F3F3F1);
    transform: translateX(8px);
  }

  /* INDICATOR */
  .row-indicator {
    flex-shrink: 0;
    width: 14px; height: 14px; border-radius: 50%;
    background: rgba(255,255,255,0.1);
    transition: all 0.3s ease;
    z-index: 1;
  }

  /* CORE CONTENT */
  .row-core {
    flex-grow: 1; display: flex; flex-direction: column; gap: 0.6rem;
    z-index: 1;
  }

  .row-meta {
    display: flex; flex-direction: column; gap: 0.25rem;
  }

  .row-category {
    font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.15em; color: var(--world-accent);
  }

  .row-title {
    margin: 0; font-family: 'Sora', 'Fraunces', serif; font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700; color: var(--text-white, #F3F3F1); line-height: 1.1; letter-spacing: -0.02em;
  }

  .row-desc {
    margin: 0; max-width: 600px; font-family: 'Manrope', sans-serif;
    font-size: 1rem; color: var(--text-silver, #8B919A); line-height: 1.6;
  }

  /* ACTION */
  .row-action {
    flex-shrink: 0; font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.2);
    transition: all 0.3s ease; z-index: 1; display: flex; align-items: center; gap: 0.5rem;
  }

  @media(max-width: 768px) {
    .index-row { flex-direction: column; align-items: flex-start; gap: 1.5rem; padding: 2rem 1rem; }
    .row-action { width: 100%; border-top: 1px dashed rgba(255,255,255,0.1); padding-top: 1rem; justify-content: space-between; }
  }
</style>
