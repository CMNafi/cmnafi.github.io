---
interface Props {
  variant: 'p1' | 'p2' | 'p3' | 'sector1' | 'sector2' | 'sector3' | 'sector4' | 'sector2b';
  label?: string;
}
const { variant, label } = Astro.props;
const displayLabel = label || variant.toUpperCase();

const bgMap: Record<string, string> = {
  p1: 'var(--violet-flag)',
  p2: 'var(--telemetry-green)',
  p3: 'var(--warning-amber)',
  sector1: 'var(--surface-raised)',
  sector2: 'var(--surface-raised)',
  sector3: 'var(--surface-raised)',
  sector4: 'var(--surface-raised)',
  sector2b: 'var(--surface-raised)'
};

const bgColor = bgMap[variant] || 'var(--surface-raised)';
---

<div class="sector-badge" style={`background-color: ${bgColor}`}>
  {displayLabel}
</div>

<style>
  .sector-badge {
    font-family: var(--font-mono);
    color: var(--pitlane-white);
    padding: 2px 6px;
    border: 1px solid var(--surface-line);
    border-radius: var(--radius-chip);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
  }
</style>
