---
interface Resource {
  title: string;
  url: string;
  type: 'Video' | 'Article' | 'Tool' | 'PDF';
  description?: string;
}

interface Props {
  resources: Resource[];
}
const { resources } = Astro.props;
---
<div class="caia-free-resources" style="margin-top: 4rem; padding: 2rem; background: var(--caia-card); border-left: 4px solid var(--caia-highlight); border-radius: 4px;">
  <h3 style="margin-top: 0; display: flex; align-items: center; gap: 0.5rem;">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--caia-highlight)"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
    Recommended Free Resources
  </h3>
  <p style="font-size: 0.9em; opacity: 0.8; margin-bottom: 1.5rem;">Supplemental materials to deepen your understanding of this topic.</p>
  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem;">
    {resources.map(res => (
      <li style="border-bottom: 1px dashed var(--caia-border); padding-bottom: 1rem;">
        <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.25rem;">
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7em; padding: 2px 6px; background: var(--caia-bg); border: 1px solid var(--caia-border); border-radius: 2px; color: var(--caia-ink);">{res.type}</span>
          <a href={res.url} target="_blank" rel="noopener noreferrer" style="font-weight: 600; text-decoration: none; color: var(--caia-accent);">{res.title} ↗</a>
        </div>
        {res.description && <div style="font-size: 0.85em; opacity: 0.8; margin-top: 0.25rem;">{res.description}</div>}
      </li>
    ))}
  </ul>
</div>
