---
import StatusBadge from './StatusBadge.astro';

interface Props {
  item: {
    title: string;
    slug: string;
    description: string;
    category: string;
    status: string;
    icon: string;
    count?: number;
  };
}

const { item } = Astro.props;
const isLive = item.status === 'live';
---

<a class="directory-card panel" href={item.slug} data-category={item.category}>
  <div class="directory-card__top">
    <span class="directory-icon">{item.icon}</span>
    <StatusBadge status={item.status} />
  </div>
  <div>
    <h3>{item.title}</h3>
    <p>{item.description}</p>
  </div>
  <div class="directory-card__meta">
    <span>{item.count ? `${item.count} items` : isLive ? 'Open section' : 'Planned space'}</span>
    <span aria-hidden="true">↗</span>
  </div>
</a>
