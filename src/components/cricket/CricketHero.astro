---
import CareerStatCard from './CareerStatCard.astro';
import SourceBadge from './SourceBadge.astro';
import VerifiedBadge from './VerifiedBadge.astro';
import type { PlayerProfile, SourceStatus } from '@/types/cricket';

interface Props {
  player: PlayerProfile;
  stats: { label: string; value: string; detail: string }[];
  statusLabel?: string;
  sourceStatus?: SourceStatus;
}

const { player, stats, statusLabel = 'Selective archive refresh', sourceStatus = 'manually added' } = Astro.props;
---

<section class="cricket-hero panel">
  <div class="cricket-hero__copy">
    <p class="eyebrow">Adventures / Cricket</p>
    <div class="cricket-hero__heading-row">
      <div>
        <h1>{player.name}</h1>
        <p class="cricket-hero__subtitle">{player.role} / {player.battingStyle} / {player.bowlingStyle}</p>
      </div>
      <SourceBadge status={sourceStatus} />
    </div>
    <p class="cricket-hero__intro">{player.intro}</p>

    <div class="cricket-hero__meta">
      <article class="panel cricket-meta-card">
        <span>Current team</span>
        <strong>{player.currentTeam}</strong>
      </article>
      <article class="panel cricket-meta-card">
        <span>Player ID</span>
        <strong>{player.playerId}</strong>
      </article>
      <article class="panel cricket-meta-card">
        <span>Archive mode</span>
        <strong>{statusLabel}</strong>
      </article>
    </div>

    <div class="hero-actions">
      <a class="button button-primary" href="/adventures/cricket/matches">Browse matches</a>
      <a class="button button-secondary" href="/adventures/cricket/highlights">Read standout matches</a>
      <a class="button button-ghost" href={player.profileUrl} target="_blank" rel="noreferrer">Open public profile</a>
    </div>

    <VerifiedBadge label="Headline totals refreshed for player ID 4593171" />
  </div>

  <div class="cricket-hero__stats">
    {stats.map((stat) => <CareerStatCard {...stat} />)}
  </div>
</section>
