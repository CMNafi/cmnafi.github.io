---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'journey'>;
  step: string;
  index: number;
  Content: any;
}

const { entry, step, index, Content } = Astro.props;
const anchorHref = `/story#${entry.slug}`;
const professionalTheme = entry.data.theme;
const personalTheme = entry.data.personalTheme ?? entry.data.theme;
const professionalSummary = entry.data.professionalSummary ?? entry.data.summary;
const personalSummary = entry.data.personalSummary ?? entry.data.summary;
const professionalHighlights = entry.data.professionalHighlights.length > 0 ? entry.data.professionalHighlights : entry.data.highlights;
const personalHighlights = entry.data.personalHighlights.length > 0 ? entry.data.personalHighlights : entry.data.highlights;
const professionalPullQuote = entry.data.professionalPullQuote ?? entry.data.pullQuote;
const personalPullQuote = entry.data.personalPullQuote ?? entry.data.pullQuote;
const layoutKind = entry.data.featured ? 'feature' : index % 2 === 1 ? 'reverse' : 'standard';
---

<article
  id={entry.slug}
  class:list={['panel', 'journey-chapter', `journey-chapter--${layoutKind}`, entry.data.featured && 'journey-chapter--featured']}
  data-journey-stop
  data-stop-id={entry.slug}
  data-stop-step={step}
  data-stop-place={entry.data.place}
  data-stop-organization={entry.data.organization}
  data-stop-professional-summary={professionalSummary}
  data-stop-personal-summary={personalSummary}
  data-stop-map-x={entry.data.mapX}
  data-stop-map-y={entry.data.mapY}
  data-stop-period={entry.data.period}
  data-stop-professional-theme={professionalTheme}
  data-stop-personal-theme={personalTheme}
  data-stop-atlas={entry.data.atlasLabel}
  data-stop-featured={String(entry.data.featured)}
  data-stop-link={anchorHref}
  tabindex="-1"
>
  <div class="journey-chapter__glow" aria-hidden="true"></div>

  <header class="journey-chapter__header">
    <div class="journey-chapter__step-wrap">
      <span class="journey-chapter__step">{step}</span>
      <span class="journey-chapter__period">{entry.data.period}</span>
    </div>

    <div class="journey-chapter__intro">
      <div class="journey-chapter__mode-eyebrows">
        <p class="journey-chapter__eyebrow mode-professional">{professionalTheme}</p>
        <p class="journey-chapter__eyebrow mode-personal">{personalTheme}</p>
      </div>

      <div class="journey-chapter__headline">
        <div>
          <p class="journey-chapter__organization">{entry.data.organization}</p>
          <h2>{entry.data.place}</h2>
        </div>
        <a class="journey-chapter__anchor" href={anchorHref}>{entry.data.deepLinkLabel}</a>
      </div>

      <p class="journey-chapter__summary mode-professional">{professionalSummary}</p>
      <p class="journey-chapter__summary mode-personal">{personalSummary}</p>

      <div class="journey-chapter__meta">
        <span>{entry.data.region}</span>
        <span>{entry.data.atlasLabel}</span>
        <span>{entry.data.period}</span>
      </div>
    </div>
  </header>

  <div class="journey-chapter__showcase">
    <div class="journey-chapter__visual" aria-hidden="true">
      <div class="journey-chapter__visual-grid"></div>
      <div class="journey-chapter__visual-orbit journey-chapter__visual-orbit--one"></div>
      <div class="journey-chapter__visual-orbit journey-chapter__visual-orbit--two"></div>
      <div class="journey-chapter__visual-pulse"></div>
    </div>

    <div class="journey-chapter__insight">
      {(entry.data.statLabel || entry.data.statValue) && (
        <div class="journey-chapter__stat">
          {entry.data.statLabel && <p>{entry.data.statLabel}</p>}
          {entry.data.statValue && <strong>{entry.data.statValue}</strong>}
        </div>
      )}

      <div class="journey-chapter__signal-group mode-professional">
        <p class="journey-chapter__signal-label">Professional view</p>
        <div class="journey-chapter__signal-list">
          {professionalHighlights.map((highlight) => <span>{highlight}</span>)}
        </div>
      </div>

      <div class="journey-chapter__signal-group mode-personal">
        <p class="journey-chapter__signal-label">Personal view</p>
        <div class="journey-chapter__signal-list">
          {personalHighlights.map((highlight) => <span>{highlight}</span>)}
        </div>
      </div>
    </div>
  </div>

  <div class="journey-chapter__body-wrap">
    <div class="journey-chapter__body prose">
      <Content />
    </div>

    <aside class="journey-chapter__aside">
      {professionalPullQuote && (
        <blockquote class="journey-chapter__quote mode-professional">
          <p>{professionalPullQuote}</p>
        </blockquote>
      )}

      {personalPullQuote && (
        <blockquote class="journey-chapter__quote mode-personal">
          <p>{personalPullQuote}</p>
        </blockquote>
      )}

      <a class="journey-chapter__deep-link" href={anchorHref}>Permalink to this chapter</a>
    </aside>
  </div>
</article>

<style>
  .journey-chapter {
    position: relative;
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.2rem, 3vw, 2rem);
    overflow: hidden;
    opacity: 0;
    transform: translateY(34px);
    transition:
      opacity 420ms ease,
      transform 520ms cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 220ms ease,
      box-shadow 220ms ease,
      background 220ms ease;
    scroll-margin-top: 10rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.048), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top right, rgba(211, 154, 89, 0.08), transparent 32%);
  }

  .journey-chapter.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .journey-chapter.is-active {
    border-color: rgba(211, 154, 89, 0.26);
    box-shadow:
      0 28px 64px rgba(0, 0, 0, 0.26),
      0 0 0 1px rgba(211, 154, 89, 0.08);
  }

  .journey-chapter--featured {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.022)),
      radial-gradient(circle at top right, rgba(211, 154, 89, 0.18), transparent 34%),
      radial-gradient(circle at bottom left, rgba(126, 134, 157, 0.12), transparent 30%);
  }

  .journey-chapter__glow {
    position: absolute;
    inset: auto auto -4rem -4rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(211, 154, 89, 0.2), transparent 72%);
    filter: blur(28px);
    opacity: 0;
    transition: opacity 260ms ease;
    pointer-events: none;
  }

  .journey-chapter.is-active .journey-chapter__glow,
  .journey-chapter--featured .journey-chapter__glow {
    opacity: 1;
  }

  .journey-chapter__header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.1rem;
    align-items: start;
  }

  .journey-chapter__step-wrap {
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }

  .journey-chapter__step,
  .journey-chapter__period,
  .journey-chapter__meta span,
  .journey-chapter__anchor,
  .journey-chapter__stat p,
  .journey-chapter__signal-label,
  .journey-chapter__deep-link {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    font-family: 'Manrope', sans-serif;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .journey-chapter__step {
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    color: var(--accent);
    background: rgba(211, 154, 89, 0.12);
    border: 1px solid rgba(211, 154, 89, 0.28);
    font-weight: 700;
  }

  .journey-chapter__period,
  .journey-chapter__meta span,
  .journey-chapter__anchor,
  .journey-chapter__stat p,
  .journey-chapter__signal-label,
  .journey-chapter__deep-link {
    padding: 0.34rem 0.72rem;
    color: rgba(243, 237, 225, 0.7);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(243, 237, 225, 0.08);
  }

  .journey-chapter__intro {
    display: grid;
    gap: 0.8rem;
  }

  .journey-chapter__mode-eyebrows {
    min-height: 1rem;
  }

  .journey-chapter__eyebrow,
  .journey-chapter__organization {
    margin: 0;
    color: var(--accent);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .journey-chapter__headline {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: start;
  }

  .journey-chapter__headline h2 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(2.15rem, 5vw, 3.4rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
  }

  .journey-chapter--featured .journey-chapter__headline h2 {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
  }

  .journey-chapter__summary {
    margin: 0;
    max-width: 52rem;
    color: rgba(243, 237, 225, 0.78);
    font-size: 1.03rem;
    line-height: 1.75;
  }

  .journey-chapter__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .journey-chapter__showcase {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.9fr);
    gap: 1rem;
    align-items: stretch;
  }

  .journey-chapter--reverse .journey-chapter__showcase {
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.2fr);
  }

  .journey-chapter--reverse .journey-chapter__visual {
    order: 2;
  }

  .journey-chapter--reverse .journey-chapter__insight {
    order: 1;
  }

  .journey-chapter__visual,
  .journey-chapter__insight {
    position: relative;
    min-height: 18rem;
    border-radius: 28px;
    border: 1px solid rgba(243, 237, 225, 0.08);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }

  .journey-chapter__visual {
    background:
      radial-gradient(circle at 20% 20%, rgba(211, 154, 89, 0.14), transparent 28%),
      radial-gradient(circle at 76% 35%, rgba(126, 134, 157, 0.14), transparent 24%),
      linear-gradient(140deg, rgba(255, 255, 255, 0.04), rgba(8, 10, 15, 0.34));
  }

  .journey-chapter__visual-grid,
  .journey-chapter__visual-orbit,
  .journey-chapter__visual-pulse {
    position: absolute;
  }

  .journey-chapter__visual-grid {
    inset: 0;
    background-image:
      linear-gradient(rgba(243, 237, 225, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(243, 237, 225, 0.04) 1px, transparent 1px);
    background-size: 2.8rem 2.8rem;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent 96%);
  }

  .journey-chapter__visual-orbit {
    border-radius: 999px;
    border: 1px solid rgba(243, 237, 225, 0.12);
  }

  .journey-chapter__visual-orbit--one {
    inset: 18% 10% auto auto;
    width: 12rem;
    height: 12rem;
  }

  .journey-chapter__visual-orbit--two {
    inset: auto auto 12% 8%;
    width: 10rem;
    height: 10rem;
  }

  .journey-chapter__visual-pulse {
    inset: 50% auto auto 50%;
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(243, 237, 225, 0.18), rgba(211, 154, 89, 0.12), transparent 74%);
    filter: blur(6px);
  }

  .journey-chapter__insight {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      radial-gradient(circle at top right, rgba(211, 154, 89, 0.1), transparent 32%);
  }

  .journey-chapter__stat {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border-radius: 22px;
    border: 1px solid rgba(243, 237, 225, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .journey-chapter__stat strong {
    font-family: 'Fraunces', 'Times New Roman', serif;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--text);
  }

  .journey-chapter__signal-group {
    display: grid;
    gap: 0.7rem;
  }

  .journey-chapter__signal-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .journey-chapter__signal-list span {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(243, 237, 225, 0.08);
    color: rgba(243, 237, 225, 0.78);
    font-size: 0.88rem;
  }

  .journey-chapter__body-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.7fr);
    gap: 1.2rem;
    align-items: start;
  }

  .journey-chapter__body {
    max-width: none;
  }

  .journey-chapter__aside {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 10rem;
  }

  .journey-chapter__quote {
    margin: 0;
    padding: 1.1rem 1.15rem;
    border-radius: 24px;
    border-left: 3px solid rgba(211, 154, 89, 0.8);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(243, 237, 225, 0.8);
  }

  .journey-chapter__quote p {
    margin: 0;
    line-height: 1.75;
  }

  .journey-chapter__deep-link {
    justify-content: center;
    padding-block: 0.8rem;
    text-decoration: none;
    transition: border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .journey-chapter__deep-link:hover,
  .journey-chapter__deep-link:focus-visible,
  .journey-chapter__anchor:hover,
  .journey-chapter__anchor:focus-visible {
    color: var(--text);
    border-color: rgba(211, 154, 89, 0.24);
    transform: translateY(-1px);
    outline: none;
  }

  .journey-story[data-mode='professional'] .mode-personal,
  .journey-story[data-mode='personal'] .mode-professional {
    display: none !important;
  }

  @media (max-width: 960px) {
    .journey-chapter__showcase,
    .journey-chapter__body-wrap {
      grid-template-columns: 1fr;
    }

    .journey-chapter--reverse .journey-chapter__visual,
    .journey-chapter--reverse .journey-chapter__insight {
      order: initial;
    }

    .journey-chapter__aside {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .journey-chapter {
      padding: 1rem;
      border-radius: 24px;
    }

    .journey-chapter__header {
      grid-template-columns: 1fr;
    }

    .journey-chapter__headline {
      flex-direction: column;
    }

    .journey-chapter__visual,
    .journey-chapter__insight {
      min-height: 14rem;
    }
  }
</style>
