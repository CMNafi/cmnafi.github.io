---
import { formatDate } from '@/utils/format';

interface TimelinePost {
  slug: string;
  data: {
    title: string;
    description: string;
    publishedAt: Date;
    category: string;
    readingTime: string;
    tags: string[];
  };
}

interface Props {
  id: string;
  title: string;
  description: string;
  posts: TimelinePost[];
}

const { id, title, description, posts } = Astro.props;
---

<section class="panel interest-section" id={id}>
  <div class="interest-section__intro">
    <p class="eyebrow">Timeline</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <div class="interest-section__timeline">
    {posts.map((post) => (
      <a class="interest-section__entry" href={`/blog/${post.slug}`}>
        <div class="interest-section__date">
          <span>{formatDate(post.data.publishedAt)}</span>
        </div>
        <div class="interest-section__line" aria-hidden="true"></div>
        <article class="interest-section__card">
          <p class="interest-section__meta">
            <span>{post.data.category}</span>
            <span>{post.data.readingTime}</span>
          </p>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="interest-section__tags">
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      </a>
    ))}
  </div>
</section>

<style>
  .interest-section {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.25rem, 3vw, 1.8rem);
    border-radius: 28px;
  }

  .interest-section__intro {
    max-width: 38rem;
  }

  .interest-section__intro h2,
  .interest-section__card h3 {
    margin: 0;
    font-family: 'Fraunces', 'Times New Roman', serif;
    letter-spacing: -0.05em;
  }

  .interest-section__intro h2 {
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.04;
    margin-bottom: 0.6rem;
  }

  .interest-section__intro p,
  .interest-section__card p {
    margin: 0;
    color: rgba(243, 237, 225, 0.72);
    line-height: 1.8;
  }

  .interest-section__timeline {
    display: grid;
    gap: 1rem;
  }

  .interest-section__entry {
    display: grid;
    grid-template-columns: auto 1.2rem minmax(0, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .interest-section__date {
    min-width: 10rem;
    padding-top: 0.55rem;
  }

  .interest-section__date span,
  .interest-section__meta span,
  .interest-section__tags span {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    font-family: 'Manrope', sans-serif;
  }

  .interest-section__date span {
    padding: 0.34rem 0.7rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(211, 154, 89, 0.12);
    border: 1px solid rgba(211, 154, 89, 0.24);
  }

  .interest-section__line {
    position: relative;
  }

  .interest-section__line::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(211, 154, 89, 0.5), rgba(243, 237, 225, 0.08));
  }

  .interest-section__line::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 1rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    box-shadow: 0 0 0 10px rgba(211, 154, 89, 0.08);
  }

  .interest-section__card {
    display: grid;
    gap: 0.7rem;
    padding: 1.15rem;
    border-radius: 24px;
    border: 1px solid rgba(243, 237, 225, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02));
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .interest-section__entry:hover .interest-section__card,
  .interest-section__entry:focus-visible .interest-section__card {
    transform: translateY(-2px);
    border-color: rgba(211, 154, 89, 0.22);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.025)),
      radial-gradient(circle at top left, rgba(211, 154, 89, 0.06), transparent 68%);
  }

  .interest-section__meta,
  .interest-section__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .interest-section__meta span,
  .interest-section__tags span {
    padding: 0.28rem 0.65rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(243, 237, 225, 0.62);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(243, 237, 225, 0.08);
  }

  .interest-section__card h3 {
    font-size: clamp(1.35rem, 2.3vw, 1.75rem);
    line-height: 1.08;
    color: rgba(243, 237, 225, 0.95);
  }

  @media (max-width: 720px) {
    .interest-section__entry {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .interest-section__date {
      min-width: 0;
      padding-top: 0;
    }

    .interest-section__line {
      display: none;
    }
  }
 </style>
