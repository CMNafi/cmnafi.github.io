---
import '../styles/global.css';
import { siteConfig } from '@/config/site';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonical,
  image = '/og-default.svg',
  type = 'website'
} = Astro.props;

const pageTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.title}`;
const canonicalUrl = canonical ? new URL(canonical, siteConfig.siteUrl).toString() : Astro.url.toString();
const imageUrl = new URL(image, siteConfig.siteUrl).toString();
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="theme-color" content="#120f0d" />
    <slot name="head" />
  </head>
  <body>
    <div class="page-shell">
      <div class="ambient ambient--one"></div>
      <div class="ambient ambient--two"></div>
      <div class="grain"></div>
      <header class="site-header">
        <a class="site-mark" href="/">
          <span>C M Nafi</span>
          <small>Work in motion</small>
        </a>
        <nav aria-label="Primary navigation">
          <ul class="nav-list">
            {siteConfig.nav.map((item) => (
              <li>
                <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
