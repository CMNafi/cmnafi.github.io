---
import '../styles/global.css';
import { siteConfig } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: any;
}

const { title, description, frontmatter } = Astro.props;
const pageTitle = title || frontmatter?.title || 'World Cup 2026 Corner';
const pageDescription = description || frontmatter?.description || 'The smart fan’s home for World Cup 2026.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="wc-theme">
    <div class="wc-container">
      <header class="wc-header">
        <div class="wc-logo">
          <a href="/world-cup-2026">WORLD CUP CORNER</a>
        </div>
        <nav class="wc-nav-desktop">
          <a href="/world-cup-2026/matches">Matches</a>
          <a href="/world-cup-2026/teams">Teams</a>
          <a href="/world-cup-2026/groups">Groups</a>
          <a href="/world-cup-2026/knockouts">Bracket</a>
          <a href="/">← cmnafi.com</a>
        </nav>
      </header>

      <main class="wc-main">
        <slot />
      </main>

      <nav class="wc-nav-mobile">
        <a href="/world-cup-2026/teams">Teams</a>
        <a href="/world-cup-2026/groups">Groups</a>
        <a href="/world-cup-2026/matches">Matches</a>
        <a href="/world-cup-2026/knockouts">Bracket</a>
      </nav>
      
      <footer class="wc-footer">
        <p>Built for the smart fan. Not affiliated with FIFA.</p>
      </footer>
    </div>

    <!-- Stub Analytics as requested -->
    <script>
      console.log('High-level tracking initialized');
    </script>
  </body>
</html>

<style is:global>
  :root {
    --wc-bg: #0A0E14;
    --wc-surface: #161B22;
    --wc-ink: #EDE7D9;
    --wc-accent: #3DA15B;
    --wc-highlight: #E8A33D;
    --wc-muted: #6E7681;
    --wc-border: rgba(237, 231, 217, 0.1);
  }

  body.wc-theme {
    margin: 0;
    padding: 0;
    background-color: var(--wc-bg);
    color: var(--wc-ink);
    font-family: 'IBM Plex Sans', sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body.wc-theme h1, body.wc-theme h2, body.wc-theme h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 600;
    margin-top: 0;
    line-height: 1.2;
  }

  .wc-container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .wc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--wc-border);
    position: sticky;
    top: 0;
    background: rgba(10, 14, 20, 0.95);
    backdrop-filter: blur(8px);
    z-index: 100;
  }

  .wc-logo a {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--wc-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .wc-nav-desktop {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .wc-nav-desktop a {
    color: var(--wc-ink);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s, color 0.2s;
  }

  .wc-nav-desktop a:hover {
    opacity: 1;
    color: var(--wc-accent);
  }

  .live-pulse {
    color: var(--wc-highlight) !important;
    position: relative;
    font-weight: 600 !important;
  }

  .live-pulse::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background-color: var(--wc-highlight);
    border-radius: 50%;
    margin-right: 6px;
    box-shadow: 0 0 8px var(--wc-highlight);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.5; }
  }

  .wc-main {
    flex-grow: 1;
    padding: 2rem;
  }

  .wc-nav-mobile {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--wc-surface);
    border-top: 1px solid var(--wc-border);
    padding: 1rem;
    justify-content: space-around;
    z-index: 100;
  }

  .wc-nav-mobile a {
    color: var(--wc-ink);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .wc-footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--wc-border);
    font-size: 0.85rem;
    color: var(--wc-muted);
  }

  @media (max-width: 768px) {
    .wc-nav-desktop {
      display: none;
    }
    .wc-nav-mobile {
      display: flex;
    }
    .wc-main {
      padding-bottom: 5rem; /* space for bottom nav */
    }
    .wc-header {
      padding: 1rem;
    }
    .wc-main {
      padding: 1rem;
    }
  }

  /* Utility classes */
  .wc-card {
    background: var(--wc-surface);
    border: 1px solid var(--wc-border);
    border-radius: 6px;
    padding: 1.5rem;
  }
  
  .wc-mono {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
