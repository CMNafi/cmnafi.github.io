---
// src/layouts/CapitalLensPost.astro
// Used by all Capital Lens finance deep dives
import type { CollectionEntry } from 'astro:content';

interface Props {
  frontmatter: CollectionEntry<'blog'>['data'];
  accentColor?: string;
  paperColor?: string;
}

const {
  frontmatter,
  accentColor = '#c0392b',   // default Capital Lens red
  paperColor  = '#f5f0e8',   // default Capital Lens cream
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{frontmatter.title} — C M Nafi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Capital Lens Design System: all shared CSS -->
<style define:vars={{ accentColor, paperColor }}>

  /* ── ROOT TOKENS ── */
  :root {
    --ink: #0d0d0d;
    --paper: var(--paperColor);
    --accent: var(--accentColor);
    --gold: #b8860b;
    --muted: #6b6560;
    --rule: #d4cfc5;
    --card-bg: #fffdf8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.75;
    overflow-x: hidden;
  }

  /* ── MASTHEAD ── */
  .cl-masthead {
    background: var(--ink);
    color: var(--paper);
    padding: 14px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .cl-masthead .pub {
    font-size: 15px;
    font-family: 'Playfair Display', serif;
    letter-spacing: 0.04em;
    font-weight: 700;
  }
  .cl-masthead .date { color: #aaa; }
  .cl-masthead a {
    color: inherit;
    text-decoration: none;
  }
  .cl-masthead a:hover { text-decoration: underline; }

  /* ── HERO ── */
  .cl-hero {
    max-width: 860px;
    margin: 72px auto 0;
    padding: 0 32px;
  }
  .cl-hero .cl-category {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cl-hero .cl-category::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 2px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .cl-h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 6vw, 56px); /* mobile typography adjusted */
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .cl-h1 em { font-style: italic; color: var(--accent); }

  .cl-deck {
    font-size: 18px;
    font-weight: 400;
    color: #3a3530;
    line-height: 1.6;
    border-left: 3px solid var(--gold);
    padding-left: 20px;
    margin-bottom: 32px;
  }

  .cl-meta {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
    display: flex;
    gap: 24px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }

  /* ── LAYOUT ── */
  .cl-content-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 32px 80px;
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 48px;
    align-items: start;
  }

  .cl-body-col { padding-top: 40px; }

  /* ── TYPOGRAPHY ── */
  .cl-body-col p {
    margin-bottom: 22px;
    font-size: 16.5px;
    max-width: 70ch;
  }

  .cl-body-col h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    margin: 44px 0 14px;
    line-height: 1.2;
  }
  .cl-body-col h2::after {
    content: '';
    display: block;
    width: 36px;
    height: 3px;
    background: var(--accent);
    margin-top: 8px;
  }

  /* ── PULL QUOTE ── */
  .cl-pull-quote {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule);
    padding: 20px 0;
    margin: 36px 0;
  }
  .cl-pull-quote p {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-style: italic;
    line-height: 1.4;
    font-weight: 700;
    margin: 0;
    color: var(--ink);
    max-width: none;
  }
  .cl-pull-quote cite {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 10px;
  }

  /* ── SIDEBAR ── */
  .cl-sidebar { padding-top: 40px; }

  .cl-sidebar-card {
    background: var(--card-bg);
    border: 1px solid var(--rule);
    padding: 24px;
    margin-bottom: 24px;
  }
  .cl-sidebar-card h3 {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 10px;
  }

  .cl-deal-stat {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dotted var(--rule);
    font-size: 13.5px;
  }
  .cl-deal-stat:last-child { border-bottom: none; }
  .cl-deal-stat .label { color: var(--muted); font-size: 12px; }
  .cl-deal-stat .val {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    text-align: right;
    max-width: 55%;
  }

  .cl-consortium-item {
    display: flex;
    flex-direction: column;
    padding: 10px 0;
    border-bottom: 1px dotted var(--rule);
    font-size: 13px;
  }
  .cl-consortium-item:last-child { border-bottom: none; }
  .cl-consortium-item strong { font-weight: 500; font-size: 13.5px; }
  .cl-consortium-item span { color: var(--muted); font-size: 12px; margin-top: 2px; line-height: 1.5; }

  /* ── HIGHLIGHT BOX ── */
  .cl-highlight-box {
    background: var(--ink);
    color: var(--paper);
    padding: 28px;
    margin: 36px 0;
  }
  .cl-highlight-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 14px;
    color: #f0c060;
  }
  .cl-highlight-box p {
    font-size: 14.5px;
    color: #ccc;
    line-height: 1.65;
    margin-bottom: 10px;
    max-width: none;
  }
  .cl-highlight-box p:last-child { margin-bottom: 0; }

  /* ── TABLES ── */
  .cl-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 24px 0;
  }
  .cl-table {
    width: 100%;
    min-width: 480px;
    border-collapse: collapse;
    font-size: 14px;
  }
  .cl-table th {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: 8px 12px;
    background: #ece8df;
    border-bottom: 2px solid var(--rule);
    white-space: nowrap;
  }
  .cl-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    font-size: 13.5px;
  }
  .cl-table tr:last-child td { border-bottom: none; }
  .cl-table tr:hover td { background: #f8f5ee; }

  /* ── COMPARE GRID ── */
  .cl-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin: 28px 0;
    border: 1px solid var(--rule);
  }
  .cl-compare-col { padding: 24px; }
  .cl-compare-col:first-child { border-right: 1px solid var(--rule); }
  .cl-compare-col h4 {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .cl-compare-col ul { list-style: none; }
  .cl-compare-col ul li {
    font-size: 13.5px;
    padding: 6px 0;
    border-bottom: 1px dotted var(--rule);
  }
  .cl-compare-col ul li:last-child { border-bottom: none; }

  /* ── ANALYST DEEP DIVE ── */
  .cl-deep-dive {
    background: #0d0d0d;
    color: #f5f0e8;
    padding: 56px 0 64px;
  }
  .cl-deep-dive-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .cl-section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 10px;
  }
  .cl-deep-dive h2 {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    font-weight: 900;
    margin-bottom: 6px;
    color: #f5f0e8;
  }
  .cl-deep-dive h2::after { display: none; }
  .cl-deep-dive-sub {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: #666;
    margin-bottom: 48px;
    letter-spacing: 0.06em;
  }
  .cl-section-divider {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid #333;
    padding-bottom: 10px;
    margin-bottom: 24px;
  }

  /* Metric grid */
  .cl-metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: #222;
    border: 1px solid #222;
    margin-bottom: 24px;
  }
  .cl-metric-cell {
    background: #0d0d0d;
    padding: 20px;
  }
  .cl-metric-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: #666;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .cl-metric-value {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    color: #f5f0e8;
    line-height: 1;
  }
  .cl-metric-value.positive { color: #b8ff6e; }
  .cl-metric-value.warning  { color: #f0c060; }
  .cl-metric-value.alert    { color: #ff9b6b; }
  .cl-metric-note {
    font-size: 12px;
    color: #888;
    margin-top: 4px;
  }

  /* Dark table */
  .cl-dark-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 24px; }
  .cl-dark-table {
    width: 100%;
    min-width: 480px;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .cl-dark-table thead tr { border-bottom: 1px solid #333; }
  .cl-dark-table th {
    text-align: left;
    padding: 8px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666;
    font-weight: 400;
    white-space: nowrap;
  }
  .cl-dark-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #1e1e1e;
    color: #ccc;
    vertical-align: top;
  }
  .cl-dark-table tr:nth-child(odd) td { background: #111; }
  .cl-dark-table tr:last-child td { border-bottom: none; }
  .cl-dark-table .highlight { color: #f5f0e8; font-weight: 500; }
  .cl-dark-table .positive { color: #6bff9e; }
  .cl-dark-table .negative { color: #ff6b6b; }
  .cl-dark-table .neutral  { color: #c8a94a; }

  /* Risk register */
  .cl-risk-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .cl-risk-box { border: 1px solid #2a2a2a; padding: 20px; }
  .cl-risk-box .risk-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .cl-risk-box .risk-label.warn  { color: #f0c060; }
  .cl-risk-box .risk-label.bull  { color: #4af; }
  .cl-risk-box p {
    font-size: 13px;
    color: #aaa;
    line-height: 1.65;
    margin: 0;
  }

  /* ── FOOTER RULE ── */
  .cl-end-rule {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 32px 40px;
  }
  .cl-end-rule hr { border: none; border-top: 1px solid var(--rule); margin-bottom: 16px; }
  .cl-end-rule p {
    font-family: 'DM Mono', monospace;
    font-size: 10.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  /* ── TAGS ── */
  .cl-tag {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    font-family: 'DM Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 2px;
  }
  .cl-tag-accent { background: var(--accent); }

  /* ══════════════════════════════════════════
     MOBILE RESPONSIVE
     ══════════════════════════════════════════ */

  @media (max-width: 768px) {
    /* Masthead: compact, single-line on mobile */
    .cl-masthead {
      padding: 12px 20px;
      flex-wrap: wrap;
      gap: 4px;
    }
    .cl-masthead .date { display: none; } /* hide date on small screens */

    /* Hero */
    .cl-hero {
      padding: 0 20px;
      margin-top: 40px;
    }
    .cl-deck {
      font-size: 16px;
    }

    /* 2-column → single column layout */
    .cl-content-wrap {
      grid-template-columns: 1fr;
      padding: 0 20px 60px;
      gap: 32px;
    }

    /* Sidebar moves below body on mobile */
    .cl-sidebar {
      padding-top: 0;
      order: 2; /* ensure sidebar is after body */
    }
    .cl-body-col {
      order: 1;
      padding-top: 24px;
    }

    /* Body text */
    .cl-body-col p { font-size: 15.5px; max-width: 100%; }
    .cl-body-col h2 { font-size: 22px; margin: 32px 0 12px; }

    /* Pull quotes */
    .cl-pull-quote p { font-size: 18px; }

    /* Tables scroll horizontally */
    .cl-table-wrap, .cl-dark-table-wrap { overflow-x: auto; }

    /* Compare grid: stack vertically */
    .cl-compare-grid { grid-template-columns: 1fr; }
    .cl-compare-col:first-child { border-right: none; border-bottom: 1px solid var(--rule); }

    /* Risk register: single column */
    .cl-risk-grid { grid-template-columns: 1fr; }

    /* Metric grid: 2 columns max */
    .cl-metric-grid { grid-template-columns: repeat(2, 1fr); }
    .cl-metric-value { font-size: 22px; }

    /* Deep dive section padding */
    .cl-deep-dive-inner { padding: 0 20px; }
    .cl-deep-dive { padding: 40px 0 48px; }
    .cl-deep-dive h2 { font-size: 24px; }

    /* Sidebar cards */
    .cl-sidebar-card { padding: 18px; }
    .cl-deal-stat .val { font-size: 12px; }

    /* End rule */
    .cl-end-rule { padding: 0 20px 32px; }

    /* Highlight box */
    .cl-highlight-box { padding: 20px; }
  }

  @media (max-width: 400px) {
    .cl-metric-grid { grid-template-columns: 1fr; }
    .cl-h1 { font-size: 26px; }
  }
</style>

<!-- Site navigation (keep in sync with your existing nav) -->
<nav style="background:#0d0d0d; padding: 10px 32px;">
  <a href="/" style="color:#f5f0e8; font-family:'Playfair Display',serif; font-weight:700; font-size:15px; text-decoration:none; letter-spacing:0.04em;">C M Nafi</a>
  <span style="color:#555; font-family:'DM Mono',monospace; font-size:10px; margin-left:24px; letter-spacing:0.1em; text-transform:uppercase;">
    <a href="/blog" style="color:#aaa; text-decoration:none;">← All Posts</a>
  </span>
</nav>

<!-- Capital Lens Masthead -->
<div class="cl-masthead">
  <a href="/" class="pub">Capital Lens</a>
  <span class="date">{frontmatter.publishedAt ? new Date(frontmatter.publishedAt).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) : ''} &nbsp;·&nbsp; {frontmatter.category}</span>
  <span>Finance &amp; Investing</span>
</div>

<!-- The MDX content renders here — it should include .cl-hero, .cl-content-wrap etc -->
<slot />

</body>
</html>
